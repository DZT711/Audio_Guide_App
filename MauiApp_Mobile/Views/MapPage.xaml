<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiApp_Mobile.Views.MapPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:MauiApp_Mobile.Views.Controls"
    x:Name="ThisPage"
    BackgroundColor="{DynamicResource LightBg}">

    <Grid>
        <Grid x:Name="MapContainer">
            <WebView x:Name="MapWebView"
                     Opacity="0" />

            <Grid x:Name="MapLoadingOverlay"
                  BackgroundColor="{DynamicResource LightBg}"
                  Padding="16,18,16,24"
                  RowDefinitions="Auto,Auto,Auto,*"
                  RowSpacing="14"
                  ZIndex="10">
                <Border x:Name="MapHeaderSkeleton"
                        HeightRequest="72"
                        Style="{StaticResource SkeletonBoneStyle}" />

                <Border x:Name="MapCanvasSkeleton"
                        Grid.Row="1"
                        HeightRequest="228"
                        Style="{StaticResource SkeletonBoneStyle}" />

                <Grid Grid.Row="2"
                      ColumnDefinitions="*,*"
                      ColumnSpacing="12">
                    <Border x:Name="MapInfoSkeleton"
                            HeightRequest="84"
                            Style="{StaticResource SkeletonBoneStyle}" />

                    <Border x:Name="MapActionSkeleton"
                            Grid.Column="1"
                            HeightRequest="84"
                            Style="{StaticResource SkeletonBoneStyle}" />
                </Grid>

                <Grid Grid.Row="3">
                    <VerticalStackLayout x:Name="MapSkeletonRows"
                                         Spacing="12">
                        <Border x:Name="MapRowSkeleton1"
                                HeightRequest="52"
                                Style="{StaticResource SkeletonBoneStyle}" />
                        <Border x:Name="MapRowSkeleton2"
                                HeightRequest="52"
                                Style="{StaticResource SkeletonBoneStyle}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout x:Name="MapRetryPanel"
                                         IsVisible="False"
                                         HorizontalOptions="Center"
                                         VerticalOptions="Center"
                                         Spacing="16"
                                         Padding="24">
                        <Label Text="🗺️"
                               FontSize="30"
                               HorizontalOptions="Center" />
                        <Label x:Name="MapRetryMessageLabel"
                               Text="Bản đồ chưa tải được."
                               FontSize="15"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"
                               TextColor="{DynamicResource BodyText}" />
                        <Label x:Name="MapRetrySubLabel"
                               Text="Hãy kiểm tra kết nối mạng rồi thử lại."
                               FontSize="13"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"
                               TextColor="{DynamicResource MutedText}" />
                        <Border BackgroundColor="{DynamicResource PrimaryGreen}"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 18"
                                Padding="28,14"
                                HorizontalOptions="Center">
                            <Label Text="🔄  Tải lại bản đồ"
                                   FontAttributes="Bold"
                                   FontSize="14"
                                   TextColor="White" />
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnRetryMapTapped" />
                            </Border.GestureRecognizers>
                        </Border>
                    </VerticalStackLayout>
                </Grid>
            </Grid>

            <VerticalStackLayout Padding="{OnPlatform Android='16,18,16,0', iOS='16,54,16,0', Default='16,18,16,0'}"
                                 Spacing="10"
                                 VerticalOptions="Start"
                                 ZIndex="18">
                <Label x:Name="TitleLabel"
                       IsVisible="False"
                       Text="Bản đồ" />

                <Grid ColumnDefinitions="*,Auto,Auto"
                      ColumnSpacing="10">
                    <Frame Style="{StaticResource TopHeaderSearchFrameStyle}">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <Label Text="🔍"
                                   Style="{StaticResource TopHeaderSearchIconStyle}">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnSearchIconTapped" />
                                </Label.GestureRecognizers>
                            </Label>

                            <Entry x:Name="SearchEntry"
                                   Grid.Column="1"
                                   BackgroundColor="Transparent"
                                   ClearButtonVisibility="WhileEditing"
                                   Completed="OnSearchCompleted"
                                   Placeholder="Tìm kiếm địa điểm..."
                                   PlaceholderColor="{DynamicResource MutedText}"
                                   ReturnType="Search"
                                   TextChanged="OnSearchTextChanged"
                                   TextColor="{DynamicResource BodyText}" />
                        </Grid>
                    </Frame>

                    <Border x:Name="ConnectionStatusChip"
                            Grid.Column="1"
                            BackgroundColor="#E8F7EE"
                            Padding="10,6"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 14"
                            VerticalOptions="Center">
                        <HorizontalStackLayout Spacing="6">
                            <Label x:Name="ConnectionStatusDot"
                                   FontSize="12"
                                   Text="●"
                                   VerticalOptions="Center" />
                            <Label x:Name="ConnectionStatusLabel"
                                   FontAttributes="Bold"
                                   FontSize="12"
                                   Text="Online"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>

                    <Border Grid.Column="2"
                            BackgroundColor="{DynamicResource MapButtonBg}"
                            Padding="0"
                            Stroke="{DynamicResource MapButtonRing}"
                            StrokeShape="RoundRectangle 24"
                            StrokeThickness="1.2"
                            VerticalOptions="Center"
                            WidthRequest="48"
                            HeightRequest="48">
                        <Label Text="{Binding SearchToggleGlyph}"
                               FontAttributes="Bold"
                               FontSize="16"
                               HorizontalOptions="Center"
                               TextColor="White"
                               VerticalOptions="Center" />
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnToggleSearchChromeTapped" />
                        </Border.GestureRecognizers>
                    </Border>
                </Grid>

                <VerticalStackLayout x:Name="SearchChromePanel"
                                     Spacing="10">
                    <ScrollView Orientation="Horizontal"
                                HorizontalOptions="Fill"
                                HorizontalScrollBarVisibility="Never">
                        <HorizontalStackLayout Spacing="10">
                        <Border BackgroundColor="{DynamicResource MapButtonBg}"
                                Padding="0"
                                Stroke="{DynamicResource MapButtonRing}"
                                StrokeShape="RoundRectangle 24"
                                StrokeThickness="1.2"
                                VerticalOptions="Center"
                                WidthRequest="48"
                                HeightRequest="48">
                            <Label Text="🔎"
                                   FontSize="18"
                                   HorizontalOptions="Center"
                                   TextColor="{DynamicResource PrimaryGreen}"
                                   VerticalOptions="Center" />
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnSearchIconTapped" />
                            </Border.GestureRecognizers>
                        </Border>

                        <Border BackgroundColor="{DynamicResource MapButtonBg}"
                                Padding="0"
                                Stroke="{DynamicResource MapButtonRing}"
                                StrokeShape="RoundRectangle 24"
                                StrokeThickness="1.2"
                                VerticalOptions="Center"
                                WidthRequest="48"
                                HeightRequest="48">
                            <Label Text="↻"
                                   FontAttributes="Bold"
                                   FontSize="18"
                                   HorizontalOptions="Center"
                                   TextColor="{DynamicResource PrimaryGreen}"
                                   VerticalOptions="Center" />
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnRefreshButtonTapped" />
                            </Border.GestureRecognizers>
                        </Border>

                        <Border x:Name="DeveloperModeButton"
                                BackgroundColor="{DynamicResource MapButtonBg}"
                                IsVisible="False"
                                Padding="0"
                                Stroke="{DynamicResource MapButtonRing}"
                                StrokeShape="RoundRectangle 24"
                                StrokeThickness="1.2"
                                VerticalOptions="Center"
                                WidthRequest="48"
                                HeightRequest="48">
                            <Grid>
                                <Label x:Name="DeveloperModeLabel"
                                       FontAttributes="Bold"
                                       FontSize="16"
                                       HorizontalOptions="Center"
                                       Text="&lt;&gt;"
                                       TextColor="{DynamicResource BodyText}"
                                       VerticalOptions="Center" />
                            </Grid>

                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnDeveloperModeTapped" />
                            </Border.GestureRecognizers>
                        </Border>

                        <Border x:Name="TourButton"
                                BackgroundColor="{DynamicResource MapButtonBg}"
                                Padding="0"
                                Stroke="{DynamicResource MapButtonRing}"
                                StrokeShape="RoundRectangle 24"
                                StrokeThickness="1.2"
                                VerticalOptions="Center"
                                WidthRequest="48"
                                HeightRequest="48">
                            <Grid>
                                <Label FontSize="18"
                                       HorizontalOptions="Center"
                                       Text="🗺"
                                       TextColor="{DynamicResource PrimaryGreen}"
                                       VerticalOptions="Center" />
                            </Grid>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnTourButtonTapped" />
                            </Border.GestureRecognizers>
                        </Border>

                        <Border x:Name="CurrentLocationButton"
                                BackgroundColor="{DynamicResource MapButtonBg}"
                                Padding="0"
                                Stroke="{DynamicResource MapButtonRing}"
                                StrokeShape="RoundRectangle 24"
                                StrokeThickness="1.2"
                                VerticalOptions="Center"
                                WidthRequest="48"
                                HeightRequest="48">
                            <Grid>
                                <Label x:Name="CurrentLocationIcon"
                                       FontSize="20"
                                       HorizontalOptions="Center"
                                       Text="🧭"
                                       TextColor="{DynamicResource PrimaryGreen}"
                                       VerticalOptions="Center" />

                                <ActivityIndicator x:Name="CurrentLocationSpinner"
                                                   Color="{DynamicResource PrimaryGreen}"
                                                   HorizontalOptions="Center"
                                                   IsRunning="False"
                                                   IsVisible="False"
                                                   VerticalOptions="Center"
                                                   WidthRequest="22"
                                                   HeightRequest="22" />
                            </Grid>

                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnCurrentLocationTapped" />
                            </Border.GestureRecognizers>
                        </Border>
                        </HorizontalStackLayout>
                    </ScrollView>

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="10">
                        <Border x:Name="PoiSearchModeChip"
                                BackgroundColor="{DynamicResource InputBg}"
                                Padding="12,9"
                                Stroke="{DynamicResource BorderColor}"
                                StrokeShape="RoundRectangle 16"
                                StrokeThickness="1">
                            <HorizontalStackLayout HorizontalOptions="Center"
                                                   Spacing="8">
                                <Label Text="📍"
                                       FontSize="14"
                                       VerticalOptions="Center" />
                                <Label x:Name="PoiSearchModeLabel"
                                       FontAttributes="Bold"
                                       FontSize="13"
                                       Text="Tên POI"
                                       TextColor="{DynamicResource BodyText}"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>

                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnPoiSearchModeTapped" />
                            </Border.GestureRecognizers>
                        </Border>

                        <Border x:Name="AddressSearchModeChip"
                                Grid.Column="1"
                                BackgroundColor="{DynamicResource InputBg}"
                                Padding="12,9"
                                Stroke="{DynamicResource BorderColor}"
                                StrokeShape="RoundRectangle 16"
                                StrokeThickness="1">
                            <HorizontalStackLayout HorizontalOptions="Center"
                                                   Spacing="8">
                                <Label Text="🗺"
                                       FontSize="14"
                                       VerticalOptions="Center" />
                                <Label x:Name="AddressSearchModeLabel"
                                       FontAttributes="Bold"
                                       FontSize="13"
                                       Text="Địa chỉ"
                                       TextColor="{DynamicResource BodyText}"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>

                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnAddressSearchModeTapped" />
                            </Border.GestureRecognizers>
                        </Border>
                    </Grid>
                </VerticalStackLayout>

                <Border x:Name="SearchStatusChip"
                        BackgroundColor="{DynamicResource PopupBg}"
                        IsVisible="False"
                        Padding="10,8"
                        Stroke="{DynamicResource BorderColor}"
                        StrokeShape="RoundRectangle 14"
                        StrokeThickness="1">
                    <Label x:Name="SearchStatusLabel"
                           FontSize="12"
                           IsVisible="False"
                           Text=""
                           TextColor="{DynamicResource BodyText}" />
                </Border>

                <Border x:Name="SearchResultsPanel"
                        BackgroundColor="{DynamicResource PopupBg}"
                        HorizontalOptions="Fill"
                        IsVisible="False"
                        MaximumHeightRequest="252"
                        Padding="12"
                        Stroke="{DynamicResource BorderColor}"
                        StrokeShape="RoundRectangle 18"
                        StrokeThickness="1"
                        ZIndex="19">
                <Grid RowDefinitions="Auto,*"
                      RowSpacing="8">
                    <Label x:Name="SearchResultsTitleLabel"
                           FontAttributes="Bold"
                           FontSize="14"
                           Text="Kết quả tìm kiếm"
                           TextColor="{DynamicResource TitleText}" />

                    <CollectionView x:Name="SearchResultsView"
                                    Grid.Row="1"
                                    ItemsLayout="VerticalList"
                                    SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border BackgroundColor="{DynamicResource CardBg}"
                                        Margin="0,0,0,8"
                                        Padding="12"
                                        Stroke="{DynamicResource DividerColor}"
                                        StrokeShape="RoundRectangle 14"
                                        StrokeThickness="1">
                                    <Grid ColumnDefinitions="Auto,*,Auto"
                                          ColumnSpacing="10">
                                        <Border BackgroundColor="{Binding AccentBackground}"
                                                HeightRequest="34"
                                                Padding="10,0"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 17"
                                                VerticalOptions="Start">
                                            <Label Text="{Binding BadgeText}"
                                                   FontAttributes="Bold"
                                                   FontSize="12"
                                                   TextColor="{Binding AccentForeground}"
                                                   VerticalTextAlignment="Center" />
                                        </Border>

                                        <VerticalStackLayout Grid.Column="1"
                                                             Spacing="3">
                                            <Label Text="{Binding Title}"
                                                   FontAttributes="Bold"
                                                   FontSize="14"
                                                   LineBreakMode="TailTruncation"
                                                   TextColor="{DynamicResource BodyText}" />
                                            <Label Text="{Binding Subtitle}"
                                                   FontSize="12"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="2"
                                                   TextColor="{DynamicResource MutedText}" />
                                        </VerticalStackLayout>

                                        <Label Grid.Column="2"
                                               FontSize="16"
                                               Text="›"
                                               TextColor="{DynamicResource MutedText}"
                                               VerticalOptions="Center" />
                                    </Grid>

                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnSearchResultTapped" />
                                    </Border.GestureRecognizers>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
                </Border>

                <Border x:Name="MapTipChip"
                        BackgroundColor="{DynamicResource PopupBg}"
                        HorizontalOptions="Start"
                        Margin="0,0,86,0"
                        Padding="12,10"
                        Stroke="{DynamicResource BorderColor}"
                        StrokeShape="RoundRectangle 16"
                        StrokeThickness="1"
                        ZIndex="20">
                    <HorizontalStackLayout Spacing="8">
                        <Label FontSize="15"
                               Text="🛰"
                               VerticalOptions="Center" />
                        <Label x:Name="MapTipLabel"
                               FontSize="12"
                               LineBreakMode="WordWrap"
                               Text="Chạm la bàn để lấy vị trí hiện tại"
                               TextColor="{DynamicResource BodyText}"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>
            </VerticalStackLayout>

            <Border IsVisible="{Binding IsTourPanelVisible}"
                    BackgroundColor="{DynamicResource PopupBg}"
                    Margin="16,120,16,92"
                    Padding="14"
                    Stroke="{DynamicResource BorderColor}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 22"
                    VerticalOptions="End"
                    ZIndex="22">
                <Grid RowDefinitions="Auto,Auto,*"
                      RowSpacing="12">
                    <Grid ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="8">
                        <Label Text="🧭"
                               FontSize="16"
                               VerticalOptions="Center" />
                        <VerticalStackLayout Grid.Column="1"
                                             Spacing="2">
                            <Label Text="{Binding TourPanelHeaderTitle}"
                                   FontAttributes="Bold"
                                   FontSize="16"
                                   TextColor="{DynamicResource BodyText}" />
                            <Label Text="{Binding TourPanelHeaderSubtitle}"
                                   FontSize="12"
                                   TextColor="{DynamicResource MutedText}" />
                        </VerticalStackLayout>
                        <Label Grid.Column="2"
                               Text="✕"
                               FontSize="16"
                               TextColor="{DynamicResource MutedText}"
                               VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnCloseTourPanelTapped" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>

                        <Grid Grid.Row="1"
                              IsVisible="{Binding IsTourDetailVisible}"
                              ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="8">
                        <Label Text="‹"
                               FontSize="18"
                               TextColor="{DynamicResource BodyText}"
                               VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnTourBackTapped" />
                            </Label.GestureRecognizers>
                        </Label>
                        <VerticalStackLayout Grid.Column="1"
                                             Spacing="2">
                            <Label Text="{Binding SelectedTourSummaryText}"
                                   FontSize="12"
                                   TextColor="{DynamicResource BodyText}" />
                            <Label Text="{Binding SelectedTourRoadHintText}"
                                   FontSize="11"
                                   TextColor="{DynamicResource MutedText}" />
                            <Label Text="{Binding SelectedTourStopsText}"
                                   FontSize="11"
                                   LineBreakMode="WordWrap"
                                   MaxLines="2"
                                   TextColor="{DynamicResource MutedText}" />
                        </VerticalStackLayout>
                    </Grid>

                    <Grid Grid.Row="2">
                        <ScrollView IsVisible="{Binding IsTourListVisible}">
                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding AvailableTours}"
                                                 Spacing="10">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="12"
                                                BackgroundColor="{DynamicResource CardBg}"
                                                Stroke="{DynamicResource DividerColor}"
                                                StrokeThickness="1"
                                                StrokeShape="RoundRectangle 16">
                                            <VerticalStackLayout Spacing="10">
                                                <Grid ColumnDefinitions="64,*,Auto"
                                                      ColumnSpacing="10">
                                                <Border WidthRequest="64"
                                                        HeightRequest="64"
                                                        BackgroundColor="{DynamicResource SurfaceAlt}"
                                                        StrokeThickness="0"
                                                        StrokeShape="RoundRectangle 16"
                                                        Padding="0">
                                                    <Image Source="{Binding CoverImageUrl}"
                                                           Aspect="AspectFill" />
                                                </Border>

                                                <VerticalStackLayout Grid.Column="1"
                                                                     Spacing="5">
                                                    <Label Text="{Binding Name}"
                                                           FontAttributes="Bold"
                                                           FontSize="14"
                                                           TextColor="{DynamicResource BodyText}" />
                                                    <Label Text="{Binding Description}"
                                                           FontSize="12"
                                                           LineBreakMode="TailTruncation"
                                                           MaxLines="2"
                                                           TextColor="{DynamicResource MutedText}" />
                                                    <Label Text="{Binding JourneyText}"
                                                           FontSize="11"
                                                           LineBreakMode="TailTruncation"
                                                           MaxLines="1"
                                                           TextColor="{DynamicResource MutedText}" />
                                                </VerticalStackLayout>
                                                <Label Grid.Column="2"
                                                       Text="›"
                                                       FontSize="18"
                                                       TextColor="{DynamicResource MutedText}"
                                                       VerticalOptions="Center" />
                                                </Grid>

                                                <HorizontalStackLayout Spacing="8">
                                                    <Border Padding="8,4"
                                                            BackgroundColor="{DynamicResource SurfaceAlt}"
                                                            StrokeThickness="0"
                                                            StrokeShape="RoundRectangle 10">
                                                        <Label Text="{Binding StopCount, StringFormat='📍 {0} điểm'}"
                                                               FontSize="11"
                                                               TextColor="{DynamicResource BodyText}" />
                                                    </Border>
                                                    <Border Padding="8,4"
                                                            BackgroundColor="{DynamicResource SurfaceAlt}"
                                                            StrokeThickness="0"
                                                            StrokeShape="RoundRectangle 10">
                                                        <Label Text="{Binding DurationText}"
                                                               FontSize="11"
                                                               TextColor="{DynamicResource BodyText}" />
                                                    </Border>
                                                    <Border Padding="8,4"
                                                            BackgroundColor="{DynamicResource SurfaceAlt}"
                                                            StrokeThickness="0"
                                                            StrokeShape="RoundRectangle 10">
                                                        <Label Text="{Binding DistanceText}"
                                                               FontSize="11"
                                                               TextColor="{DynamicResource PrimaryGreen}" />
                                                    </Border>
                                                </HorizontalStackLayout>

                                                <Label Text="{Binding StopsPreviewText}"
                                                       FontSize="11"
                                                       MaxLines="2"
                                                       LineBreakMode="TailTruncation"
                                                       TextColor="{DynamicResource MutedText}" />
                                            </VerticalStackLayout>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnTourItemTapped" />
                                            </Border.GestureRecognizers>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>
                        </ScrollView>

                        <VerticalStackLayout IsVisible="{Binding IsTourDetailVisible}"
                                             Spacing="10">
                            <Border BackgroundColor="{DynamicResource CardBg}"
                                    Stroke="{DynamicResource DividerColor}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 16"
                                    Padding="12">
                                <VerticalStackLayout Spacing="12">
                                    <Grid ColumnDefinitions="72,*"
                                          ColumnSpacing="12">
                                    <Border WidthRequest="72"
                                            HeightRequest="72"
                                            BackgroundColor="{DynamicResource SurfaceAlt}"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 18"
                                            Padding="0">
                                        <Image Source="{Binding SelectedTour.CoverImageUrl}"
                                               Aspect="AspectFill" />
                                    </Border>

                                    <VerticalStackLayout Grid.Column="1"
                                                         Spacing="4">
                                        <Label Text="{Binding SelectedTour.Name}"
                                               FontAttributes="Bold"
                                               FontSize="15"
                                               TextColor="{DynamicResource BodyText}" />
                                        <Label Text="{Binding SelectedTourJourneyText}"
                                               FontSize="12"
                                               MaxLines="2"
                                               LineBreakMode="TailTruncation"
                                               TextColor="{DynamicResource MutedText}" />
                                        <Label Text="{Binding SelectedTourTimingText}"
                                               FontSize="12"
                                               TextColor="{DynamicResource PrimaryGreen}" />
                                        <Label Text="{Binding SelectedTourRoadHintText}"
                                               FontSize="12"
                                               MaxLines="2"
                                               LineBreakMode="TailTruncation"
                                               TextColor="{DynamicResource MutedText}" />
                                    </VerticalStackLayout>
                                    </Grid>

                                    <HorizontalStackLayout Spacing="8">
                                        <Border Padding="8,4"
                                                BackgroundColor="{DynamicResource SurfaceAlt}"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 10">
                                            <Label Text="{Binding SelectedTour.StopCount, StringFormat='📍 {0} điểm'}"
                                                   FontSize="11"
                                                   TextColor="{DynamicResource BodyText}" />
                                        </Border>
                                        <Border Padding="8,4"
                                                BackgroundColor="{DynamicResource SurfaceAlt}"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 10">
                                            <Label Text="{Binding SelectedTour.DurationText}"
                                                   FontSize="11"
                                                   TextColor="{DynamicResource BodyText}" />
                                        </Border>
                                        <Border Padding="8,4"
                                                BackgroundColor="{DynamicResource SurfaceAlt}"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 10">
                                            <Label Text="{Binding SelectedTour.DistanceText}"
                                                   FontSize="11"
                                                   TextColor="{DynamicResource PrimaryGreen}" />
                                        </Border>
                                    </HorizontalStackLayout>

                                    <Label Text="{Binding ActiveTourProgressText}"
                                           FontSize="12"
                                           TextColor="{DynamicResource PrimaryGreen}" />
                                    <Label Text="{Binding NextTourStopText}"
                                           FontSize="12"
                                           MaxLines="2"
                                           LineBreakMode="TailTruncation"
                                           TextColor="{DynamicResource MutedText}" />
                                    <Label Text="Các điểm sẽ đi qua"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           TextColor="{DynamicResource BodyText}" />

                                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding SelectedTour.Stops}"
                                                         Spacing="8">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate>
                                                <Grid ColumnDefinitions="Auto,*"
                                                      ColumnSpacing="10">
                                                    <Border WidthRequest="24"
                                                            HeightRequest="24"
                                                            BackgroundColor="{DynamicResource SoftGreen}"
                                                            StrokeThickness="0"
                                                            StrokeShape="RoundRectangle 12"
                                                            VerticalOptions="Start">
                                                        <Label Text="{Binding SequenceBadgeText}"
                                                               FontSize="11"
                                                               FontAttributes="Bold"
                                                               HorizontalTextAlignment="Center"
                                                               VerticalTextAlignment="Center"
                                                               TextColor="{DynamicResource PrimaryGreen}" />
                                                    </Border>

                                                    <VerticalStackLayout Grid.Column="1"
                                                                         Spacing="1">
                                                        <Label Text="{Binding Name}"
                                                               FontSize="12"
                                                               FontAttributes="Bold"
                                                               TextColor="{DynamicResource BodyText}" />
                                                        <Label Text="{Binding Address}"
                                                               FontSize="11"
                                                               MaxLines="1"
                                                               LineBreakMode="TailTruncation"
                                                               TextColor="{DynamicResource MutedText}" />
                                                    </VerticalStackLayout>
                                                </Grid>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                            </Border>

                            <Grid ColumnDefinitions="*,Auto,Auto"
                                  ColumnSpacing="8">
                                <Button Text="Nghe điểm này"
                                        Clicked="OnTourListenTapped"
                                        BackgroundColor="{DynamicResource PrimaryGreen}"
                                        TextColor="White"
                                        CornerRadius="14" />
                                <Button Grid.Column="1"
                                        Text="Chi tiết"
                                        Clicked="OnTourDetailTapped"
                                        BackgroundColor="{DynamicResource SurfaceAlt}"
                                        TextColor="{DynamicResource BodyText}"
                                        CornerRadius="14" />
                                <Button Grid.Column="2"
                                        Text="Tiếp"
                                        Clicked="OnTourNextTapped"
                                        IsEnabled="{Binding HasNextTourStop}"
                                        BackgroundColor="{DynamicResource SurfaceAlt}"
                                        TextColor="{DynamicResource BodyText}"
                                        CornerRadius="14" />
                            </Grid>
                        </VerticalStackLayout>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <controls:MiniPlayerView UseTransparentChrome="True"
                                 VerticalOptions="End"
