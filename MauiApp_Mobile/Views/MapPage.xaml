<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiApp_Mobile.Views.MapPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="{StaticResource LightBg}">

    <Grid RowDefinitions="180,*">
        <Grid BackgroundColor="{StaticResource PrimaryGreen}" Padding="20,50,20,20">
            <VerticalStackLayout Spacing="18">
                <Label x:Name="TitleLabel"
                       Text="Bản đồ"
                       Style="{StaticResource PageTitleStyle}" />

                <Frame
                    BackgroundColor="White"
                    BorderColor="Transparent"
                    CornerRadius="18"
                    HasShadow="False"
                    Padding="16,10">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <Label Text="🔍"
                               FontSize="22"
                               TextColor="{StaticResource MutedText}"
                               VerticalOptions="Center" />

                        <Entry x:Name="SearchEntry"
                               Grid.Column="1"
                               Placeholder="Tìm kiếm địa điểm..."
                               PlaceholderColor="{StaticResource MutedText}"
                               BackgroundColor="Transparent"
                               TextColor="{StaticResource BodyText}" />
                    </Grid>
                </Frame>
            </VerticalStackLayout>
        </Grid>

        <!-- Fake map -->
        <Grid Grid.Row="1" BackgroundColor="#ECECEC">
            <Label Text="Khu vực bản đồ (demo)"
                   TextColor="#999"
                   FontSize="18"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />
        </Grid>
    </Grid>
</ContentPage>