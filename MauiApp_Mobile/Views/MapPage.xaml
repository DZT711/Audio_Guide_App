<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiApp_Mobile.Views.MapPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="{StaticResource LightBg}">

    <Grid RowDefinitions="Auto,*">
        <Grid Style="{StaticResource TopHeaderGridStyle}"
              MinimumHeightRequest="128">
            <VerticalStackLayout Spacing="8" VerticalOptions="Center">
                <Label x:Name="TitleLabel"
                       Text="Bản đồ"
                       Style="{StaticResource TopHeaderTitleStyle}" />

                <Frame Style="{StaticResource TopHeaderSearchFrameStyle}">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <Label Text="🔍"
                               Style="{StaticResource TopHeaderSearchIconStyle}">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnSearchIconTapped" />
                            </Label.GestureRecognizers>
                        </Label>

                        <Entry x:Name="SearchEntry"
                               Grid.Column="1"
                               Placeholder="Tìm kiếm địa điểm..."
                               PlaceholderColor="{StaticResource MutedText}"
                               BackgroundColor="Transparent"
                               TextColor="{StaticResource BodyText}"
                               ClearButtonVisibility="WhileEditing"
                               ReturnType="Search"
                               Completed="OnSearchCompleted"
                               TextChanged="OnSearchTextChanged" />
                    </Grid>
                </Frame>

                <Label x:Name="SearchStatusLabel"
                       Text=""
                       FontSize="12"
                       TextColor="#E8F7EE"
                       IsVisible="False" />
            </VerticalStackLayout>
        </Grid>

        <Grid Grid.Row="1" x:Name="MapContainer">
            <WebView x:Name="MapWebView" />
            
            <!-- Button định vị cũ (giữ nếu cần) -->
            <Frame
                WidthRequest="54"
                HeightRequest="54"
                CornerRadius="27"
                BackgroundColor="White"
                HasShadow="True"
                Padding="0"
                HorizontalOptions="End"
                VerticalOptions="Start"
                Margin="0,16,16,0">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnCurrentLocationTapped" />
                </Frame.GestureRecognizers>
                <Label Text="🧭"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       FontSize="22"
                       TextColor="{StaticResource PrimaryGreen}" />
            </Frame>
        </Grid>
    </Grid>
</ContentPage>
