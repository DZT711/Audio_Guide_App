<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiApp_Mobile.Views.HistoryPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="ThisPage"
    BackgroundColor="{StaticResource LightBg}">

    <Grid RowDefinitions="Auto,*">
        <Grid Style="{StaticResource TopHeaderGridStyle}">
            <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                <VerticalStackLayout Spacing="3" VerticalOptions="Center">
                    <Label x:Name="TitleLabel"
                           Text="Lịch sử"
                           Style="{StaticResource TopHeaderTitleStyle}" />
                    <Label x:Name="SubtitleLabel"
                           Text="Các địa điểm đã nghe thuyết minh"
                           Style="{StaticResource TopHeaderSubtitleStyle}" />
                </VerticalStackLayout>

                <Frame Grid.Column="1"
                       Style="{StaticResource TopHeaderActionFrameStyle}">
                    <Label Text="🗑" HorizontalOptions="Center" VerticalOptions="Center" FontSize="18" />
                </Frame>
            </Grid>
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16,12,16,24" Spacing="12">
                <HorizontalStackLayout Spacing="20">
                    <Label x:Name="CountLabel"
                           Text="⏱ 0 địa điểm"
                           FontSize="15"
                           TextColor="{StaticResource BodyText}" />
                </HorizontalStackLayout>

                <CollectionView x:Name="HistoryCollectionView"
                                ItemsSource="{Binding HistoryItems}"
                                SelectionMode="None">
                     <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical"
                                           ItemSpacing="14" />
                    </CollectionView.ItemsLayout>
                     <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Style="{StaticResource CardFrameStyle}" Margin="0">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnHistoryItemTapped" />
                                </Frame.GestureRecognizers>
                                <Grid ColumnDefinitions="90,*,Auto" ColumnSpacing="14">
                                    <Image Source="{Binding Image}" WidthRequest="90" HeightRequest="90" Aspect="AspectFill" />
                                    
                                    <VerticalStackLayout Grid.Column="1" Spacing="4">
                                        <Label Text="{Binding Name}" FontSize="17" FontAttributes="Bold" TextColor="{StaticResource BodyText}" />
                                        <Label Text="{Binding Address}" FontSize="13" TextColor="{StaticResource MutedText}" />
                                        <HorizontalStackLayout Spacing="10">
                                            <Frame Padding="10,4" CornerRadius="10" HasShadow="False" BackgroundColor="#FFE3E3" BorderColor="Transparent">
                                                <Label Text="Lịch sử" FontSize="12" TextColor="#E53935" />
                                            </Frame>
                                            <Label Text="⭐ 10/10" FontSize="13" TextColor="{StaticResource MutedText}" VerticalOptions="Center" />
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>
                                    
                                    <VerticalStackLayout Grid.Column="2" Spacing="10" HorizontalOptions="End">
                                        <!-- Play/Speaker Button -->
                                        <Frame WidthRequest="44" HeightRequest="44" CornerRadius="22" Padding="0" BackgroundColor="{StaticResource PrimaryGreen}" HasShadow="False">
                                            <Label Text="{Binding PlayIcon}" HorizontalOptions="Center" VerticalOptions="Center" TextColor="White" FontSize="18"/>
                                        </Frame>
                                        
                                        <!-- Delete Button -->
                                        <Frame WidthRequest="34" HeightRequest="34" CornerRadius="17" Padding="0" BackgroundColor="#F3F4F6" HasShadow="False">
                                            <Label Text="🗑" HorizontalOptions="Center" VerticalOptions="Center" FontSize="14" />
                                            <Frame.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnDeleteTapped" />
                                            </Frame.GestureRecognizers>
                                        </Frame>
                                    </VerticalStackLayout>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Empty State -->
                <Label x:Name="EmptyLabel"
                       Text="Chưa có lịch sử nào"
                       HorizontalOptions="Center"
                       TextColor="Gray" /> 
            </VerticalStackLayout>
        </ScrollView>

        <Grid Grid.RowSpan="2"
              IsVisible="{Binding Source={x:Reference ThisPage}, Path=IsHistoryDetailVisible}"
              BackgroundColor="#66000000"
              RowDefinitions="*,Auto"
              ZIndex="90">

            <Grid Grid.Row="0">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHistoryDetailBackdropTapped" />
                </Grid.GestureRecognizers>
            </Grid>

            <Border x:Name="HistoryDetailSheet"
                    Grid.Row="1"
                    BackgroundColor="White"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 24,24,0,0"
                    Padding="0,0,0,10"
                    TranslationY="520">

                <Grid RowDefinitions="Auto,190,*">
                    <Grid Grid.Row="0"
                          Padding="0,10,0,8"
                          HorizontalOptions="Fill">
                        <Grid.GestureRecognizers>
                            <PanGestureRecognizer PanUpdated="OnHistoryDetailPanUpdated" />
                            <TapGestureRecognizer Tapped="OnHistoryDetailHandleTapped" />
                        </Grid.GestureRecognizers>
                        <Border WidthRequest="52"
                                HeightRequest="6"
                                BackgroundColor="#D0D5DD"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 3"
                                HorizontalOptions="Center" />
                    </Grid>

                    <Grid Grid.Row="1">
                        <Grid.GestureRecognizers>
                            <PanGestureRecognizer PanUpdated="OnHistoryDetailPanUpdated" />
                        </Grid.GestureRecognizers>

                        <Image Source="{Binding Source={x:Reference ThisPage}, Path=SelectedHistoryItem.Image}"
                               Aspect="AspectFill" />

                        <Grid Padding="14"
                              RowDefinitions="Auto,*,Auto"
                              BackgroundColor="#33000000">
                            <Border BackgroundColor="#FDECEC"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 12"
                                    Padding="10,4"
                                    HorizontalOptions="Start">
                                <Label Text="{Binding Source={x:Reference ThisPage}, Path=SelectedHistoryItem.Category}"
                                       FontSize="12"
                                       TextColor="#E53935" />
                            </Border>

                            <Button Grid.Row="0"
                                    Text="✕"
                                    Clicked="OnCloseHistoryDetail"
                                    WidthRequest="38"
                                    HeightRequest="38"
                                    CornerRadius="19"
                                    BackgroundColor="#88000000"
                                    TextColor="White"
                                    HorizontalOptions="End"
                                    VerticalOptions="Start" />

                            <VerticalStackLayout Grid.Row="2" Spacing="4">
                                <Label Text="{Binding Source={x:Reference ThisPage}, Path=SelectedHistoryItem.Name}"
                                       FontSize="32"
                                       FontAttributes="Bold"
                                       TextColor="White" />
                                <HorizontalStackLayout Spacing="8">
                                    <Label Text="★★★★★" FontSize="12" TextColor="#FACC15" />
                                    <Label Text="{Binding Source={x:Reference ThisPage}, Path=HistoryDetailPriorityText}" FontSize="12" TextColor="White" />
                                    <Border BackgroundColor="#16A34A"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 10"
                                            Padding="8,2">
                                        <Label Text="GPS" FontSize="11" TextColor="White" />
                                    </Border>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Grid>
                    </Grid>

                    <ScrollView Grid.Row="2">
                        <VerticalStackLayout Padding="14,12" Spacing="12">
                            <Label Text="{Binding Source={x:Reference ThisPage}, Path=SelectedHistoryItem.AudioDescription}"
                                   FontSize="15"
                                   TextColor="#344054" />

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                <Border BackgroundColor="#ECFDF3"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 12"
                                        Padding="10">
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="Bán kính kích hoạt" FontSize="12" TextColor="#64748B" />
                                        <Label Text="{Binding Source={x:Reference ThisPage}, Path=SelectedHistoryItem.RadiusText}" FontSize="20" FontAttributes="Bold" TextColor="#0F172A" />
                                    </VerticalStackLayout>
                                </Border>

                                <Border Grid.Column="1"
                                        BackgroundColor="#EFF6FF"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 12"
                                        Padding="10">
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="Tọa độ GPS" FontSize="12" TextColor="#64748B" />
                                        <Label Text="{Binding Source={x:Reference ThisPage}, Path=SelectedHistoryItem.GpsText}" FontSize="20" FontAttributes="Bold" TextColor="#0F172A" />
                                    </VerticalStackLayout>
                                </Border>
                            </Grid>

                            <Border BackgroundColor="#F8FAFC"
                                    Stroke="#E5E7EB"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 14"
                                    Padding="12">
                                <VerticalStackLayout Spacing="6">
                                    <Label Text="{Binding Source={x:Reference ThisPage}, Path=SelectedHistoryItem.Address, StringFormat='📍 {0}'}" FontSize="14" TextColor="#334155" />
                                    <Label Text="{Binding Source={x:Reference ThisPage}, Path=SelectedHistoryItem.Phone, StringFormat='📞 {0}'}" FontSize="14" TextColor="#16A34A" />
                                    <Label Text="{Binding Source={x:Reference ThisPage}, Path=SelectedHistoryItem.Email, StringFormat='✉ {0}'}" FontSize="14" TextColor="#16A34A" />
                                    <Label Text="{Binding Source={x:Reference ThisPage}, Path=SelectedHistoryItem.Website, StringFormat='🌐 {0}'}" FontSize="14" TextColor="#16A34A" />
                                    <Label Text="{Binding Source={x:Reference ThisPage}, Path=SelectedHistoryItem.EstablishedYear, StringFormat='📅 Thành lập năm {0}'}" FontSize="14" TextColor="#334155" />
                                </VerticalStackLayout>
                            </Border>
                        </VerticalStackLayout>
                    </ScrollView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
