<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiApp_Mobile.Views.HistoryPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="ThisPage"
    BackgroundColor="{DynamicResource LightBg}">

    <Grid RowDefinitions="Auto,*">
        <Grid Style="{StaticResource TopHeaderGridStyle}">
            <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                <VerticalStackLayout Spacing="3" VerticalOptions="Center">
                    <Label x:Name="TitleLabel"
                           Text="Lịch sử"
                           Style="{StaticResource TopHeaderTitleStyle}" />
                    <Label x:Name="SubtitleLabel"
                           Text="Các địa điểm đã nghe thuyết minh"
                           Style="{StaticResource TopHeaderSubtitleStyle}" />
                </VerticalStackLayout>

                <Frame Grid.Column="1"
                       Style="{StaticResource TopHeaderActionFrameStyle}">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnClearHistoryTapped" />
                    </Frame.GestureRecognizers>
                    <Label Text="🗑"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           FontSize="18" />
                </Frame>
            </Grid>
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16,12,16,24" Spacing="14">
                <HorizontalStackLayout Spacing="10">
                    <Border BackgroundColor="{DynamicResource CardBg}"
                            Stroke="{DynamicResource BorderColor}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 16"
                            Padding="12,8">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="🕘"
                                   FontSize="14"
                                   VerticalTextAlignment="Center" />
                            <Label x:Name="CountLabel"
                                   Text="0 địa điểm"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="{DynamicResource BodyText}" />
                        </HorizontalStackLayout>
                    </Border>

                    <Border BackgroundColor="{DynamicResource CardBg}"
                            Stroke="{DynamicResource BorderColor}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 16"
                            Padding="12,8">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="🕒"
                                   FontSize="14"
                                   VerticalTextAlignment="Center" />
                            <Label x:Name="DurationLabel"
                                   Text="00:00 tổng"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="{DynamicResource BodyText}" />
                        </HorizontalStackLayout>
                    </Border>
                </HorizontalStackLayout>

                <CollectionView x:Name="HistoryCollectionView"
                                ItemsSource="{Binding HistoryItems}"
                                SelectionMode="None">
                     <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical"
                                           ItemSpacing="14" />
                    </CollectionView.ItemsLayout>
                     <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="{DynamicResource CardBg}"
                                    Stroke="{DynamicResource BorderColor}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 22"
                                    Padding="12">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnHistoryItemTapped" />
                                </Border.GestureRecognizers>
                                <Grid ColumnDefinitions="74,*,Auto"
                                      ColumnSpacing="12">
                                    <Grid WidthRequest="74"
                                          HeightRequest="74">
                                        <Border StrokeThickness="0"
                                                StrokeShape="RoundRectangle 18"
                                                BackgroundColor="{DynamicResource SurfaceAlt}">
                                            <Image Source="{Binding Image, Converter={StaticResource PlaceImageSourceConverter}}"
                                                   Aspect="AspectFill" />
                                        </Border>

                                        <Border BackgroundColor="#1F2937"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 10"
                                                Padding="6,2"
                                                HorizontalOptions="Start"
                                                VerticalOptions="End"
                                                Margin="6,0,0,6">
                                            <Label Text="{Binding AudioCountText}"
                                                   FontSize="10"
                                                   TextColor="White"
                                                   HorizontalTextAlignment="Center"
                                                   VerticalTextAlignment="Center" />
                                        </Border>
                                    </Grid>

                                    <VerticalStackLayout Grid.Column="1"
                                                         Spacing="5"
                                                         VerticalOptions="Center">
                                        <Label Text="{Binding Name}"
                                               FontSize="18"
                                               FontAttributes="Bold"
                                               TextColor="{DynamicResource BodyText}"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="2" />
                                        <Label Text="{Binding Address, StringFormat='📍 {0}'}"
                                               FontSize="13"
                                               TextColor="{DynamicResource MutedText}"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="1" />
                                        <HorizontalStackLayout Spacing="8">
                                            <Border Padding="10,4"
                                                    BackgroundColor="{Binding CategoryColor}"
                                                    StrokeThickness="0"
                                                    StrokeShape="RoundRectangle 10">
                                                <Label Text="{Binding Category}"
                                                       FontSize="12"
                                                       TextColor="{Binding CategoryTextColor}" />
                                            </Border>
                                            <Label Text="{Binding HistoryRelativeTimeText}"
                                                   FontSize="12"
                                                   TextColor="{DynamicResource MutedText}"
                                                   VerticalOptions="Center" />
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Grid.Column="2"
                                                         Spacing="10"
                                                         HorizontalOptions="End"
                                                         VerticalOptions="Center">
                                        <Border WidthRequest="46"
                                                HeightRequest="46"
                                                BackgroundColor="{DynamicResource PrimaryGreen}"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 23">
                                            <Label Text="{Binding PlayIcon}"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"
                                                   TextColor="White"
                                                   FontSize="18" />
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnPlayTapped" />
                                            </Border.GestureRecognizers>
                                        </Border>

                                        <Border WidthRequest="36"
                                                HeightRequest="36"
                                                BackgroundColor="#F3F4F6"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 18">
                                            <Label Text="🗑"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"
                                                   FontSize="14" />
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnDeleteTapped" />
                                            </Border.GestureRecognizers>
                                        </Border>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Empty State -->
                <Label x:Name="EmptyLabel"
                       Text="Chưa có lịch sử nào"
                       HorizontalOptions="Center"
                       TextColor="Gray" /> 
            </VerticalStackLayout>
        </ScrollView>

        <Grid Grid.RowSpan="2"
              IsVisible="{Binding Source={x:Reference ThisPage}, Path=IsHistoryDetailVisible}"
              BackgroundColor="{DynamicResource OverlayColor}"
              Padding="16"
              RowDefinitions="*,Auto"
              ZIndex="90">

            <Grid Grid.Row="0">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHistoryDetailBackdropTapped" />
                </Grid.GestureRecognizers>
            </Grid>

            <Border x:Name="HistoryDetailSheet"
                    Grid.Row="1"
                    VerticalOptions="End"
                    BackgroundColor="{DynamicResource BottomSheetBg}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 26"
                    Padding="0"
                    TranslationY="520">

                <Grid RowDefinitions="Auto,220,Auto,*">
                    <Grid Grid.Row="0"
                          Padding="0,10,0,8"
                          HorizontalOptions="Fill">
                        <Grid.GestureRecognizers>
                            <PanGestureRecognizer PanUpdated="OnHistoryDetailPanUpdated" />
                            <TapGestureRecognizer Tapped="OnHistoryDetailHandleTapped" />
                        </Grid.GestureRecognizers>
                        <Border WidthRequest="52"
                                HeightRequest="6"
                                BackgroundColor="{DynamicResource SheetHandleColor}"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 3"
                                HorizontalOptions="Center" />
                    </Grid>

                    <Grid Grid.Row="1"
                          Padding="14,0,14,0">
                        <Border BackgroundColor="#10243C"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 24">
                            <Image Source="{Binding Source={x:Reference ThisPage}, Path=SelectedHistoryItem.Image, Converter={StaticResource PlaceImageSourceConverter}}"
                                   Aspect="{OnPlatform Default=AspectFill, WinUI=AspectFit}" />
                        </Border>

                        <Button Text="✕"
                                Clicked="OnCloseHistoryDetail"
                                WidthRequest="38"
                                HeightRequest="38"
                                CornerRadius="19"
                                BackgroundColor="#88000000"
                                TextColor="White"
                                HorizontalOptions="End"
                                Margin="0,14,14,0"
                                VerticalOptions="Start" />
                    </Grid>

                    <VerticalStackLayout Grid.Row="2"
                                         Padding="16,14,16,0"
                                         Spacing="10">
                        <Border BackgroundColor="{Binding Source={x:Reference ThisPage}, Path=SelectedHistoryItem.CategoryColor}"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 12"
                                Padding="10,4"
                                HorizontalOptions="Start">
                            <Label Text="{Binding Source={x:Reference ThisPage}, Path=SelectedHistoryItem.Category}"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="{Binding Source={x:Reference ThisPage}, Path=SelectedHistoryItem.CategoryTextColor}" />
                        </Border>

                        <Label Text="{Binding Source={x:Reference ThisPage}, Path=SelectedHistoryItem.Name}"
                               FontSize="28"
                               FontAttributes="Bold"
                               TextColor="{DynamicResource TitleText}" />

                        <Label Text="{Binding Source={x:Reference ThisPage}, Path=SelectedHistoryItem.Description}"
                               FontSize="14"
                               TextColor="{DynamicResource MutedText}"
                               MaxLines="3"
                               LineBreakMode="TailTruncation" />
                    </VerticalStackLayout>

                    <ScrollView Grid.Row="3">
                        <VerticalStackLayout Padding="16,14,16,18" Spacing="12">
                            <Grid ColumnDefinitions="*,*"
                                  ColumnSpacing="12">
                                <Border BackgroundColor="#ECFDF3"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 14"
                                        Padding="12">
                                    <VerticalStackLayout Spacing="3">
                                        <Label Text="Audio offline"
                                               FontSize="12"
                                               TextColor="{DynamicResource MutedText}" />
                                        <Label Text="{Binding Source={x:Reference ThisPage}, Path=SelectedHistoryItem.AudioCountText}"
                                               FontSize="20"
                                               FontAttributes="Bold"
                                               TextColor="{DynamicResource TitleText}" />
                                        <Label Text="{Binding Source={x:Reference ThisPage}, Path=SelectedHistoryLanguagesText}"
                                               FontSize="12"
                                               TextColor="{DynamicResource SuccessText}" />
                                    </VerticalStackLayout>
                                </Border>

                                <Border Grid.Column="1"
                                        BackgroundColor="#EFF6FF"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 14"
                                        Padding="12">
                                    <VerticalStackLayout Spacing="3">
                                        <Label Text="Dung lượng ước tính"
                                               FontSize="12"
                                               TextColor="{DynamicResource MutedText}" />
                                        <Label Text="2.4 MB"
                                               FontSize="20"
                                               FontAttributes="Bold"
                                               TextColor="{DynamicResource TitleText}" />
                                        <Label Text="02:05"
                                               FontSize="12"
                                               TextColor="{DynamicResource InfoText}" />
                                    </VerticalStackLayout>
                                </Border>
                            </Grid>

                            <Border BackgroundColor="{DynamicResource SurfaceAlt}"
                                    Stroke="{DynamicResource BorderColor}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 16"
                                    Padding="14">
                                <VerticalStackLayout Spacing="8">
                                    <Label Text="Thông tin POI"
                                           FontSize="18"
                                           FontAttributes="Bold"
                                           TextColor="{DynamicResource BodyText}" />
                                    <Label Text="{Binding Source={x:Reference ThisPage}, Path=SelectedHistoryItem.Address, StringFormat='📍 {0}'}"
                                           FontSize="14"
                                           TextColor="{DynamicResource BodyText}" />
                                    <Label Text="{Binding Source={x:Reference ThisPage}, Path=SelectedHistoryItem.GpsText, StringFormat='🛰 {0}'}"
                                           FontSize="14"
                                           TextColor="{DynamicResource BodyText}" />
                                    <Label Text="Đã lưu trong lịch sử nghe"
                                           FontSize="14"
                                           TextColor="{DynamicResource SuccessText}" />
                                </VerticalStackLayout>
                            </Border>

                            <Border BackgroundColor="{DynamicResource CardBg}"
                                    Stroke="{DynamicResource BorderColor}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 16"
                                    Padding="14">
                                <Grid ColumnDefinitions="Auto,*,Auto"
                                      ColumnSpacing="12">
                                    <Border WidthRequest="44"
                                            HeightRequest="44"
                                            BackgroundColor="#E8F7EE"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 22"
                                            VerticalOptions="Center">
                                        <Label Text="🗺"
                                               FontSize="18"
                                               HorizontalTextAlignment="Center"
                                               VerticalTextAlignment="Center" />
                                    </Border>

                                    <VerticalStackLayout Grid.Column="1"
                                                         Spacing="2"
                                                         VerticalOptions="Center">
                                        <Label Text="Xem trên bản đồ"
                                               FontSize="16"
                                               FontAttributes="Bold"
                                               TextColor="{DynamicResource BodyText}" />
                                        <Label Text="Mở vị trí POI này trên bản đồ để xem nhanh đường đi"
                                               FontSize="13"
                                               TextColor="{DynamicResource MutedText}" />
                                    </VerticalStackLayout>

                                    <Label Grid.Column="2"
                                           Text="›"
                                           FontSize="22"
                                           TextColor="{DynamicResource MutedText}"
                                           VerticalOptions="Center" />
                                </Grid>

                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnViewHistoryPlaceOnMapTapped" />
                                </Border.GestureRecognizers>
                            </Border>

                            <Border BackgroundColor="{DynamicResource CardBg}"
                                    Stroke="{DynamicResource BorderColor}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 16"
                                    Padding="14">
                                <VerticalStackLayout Spacing="8">
                                    <Grid ColumnDefinitions="*,Auto"
                                          ColumnSpacing="10">
                                        <VerticalStackLayout Spacing="2">
                                            <Label Text="Danh sách audio"
                                                   FontSize="18"
                                                   FontAttributes="Bold"
                                                   TextColor="{DynamicResource BodyText}" />
                                            <Label Text="{Binding Source={x:Reference ThisPage}, Path=SelectedHistoryLanguagesText}"
                                                   FontSize="14"
                                                   TextColor="{DynamicResource MutedText}" />
                                        </VerticalStackLayout>

                                        <Border Grid.Column="1"
                                                BackgroundColor="{DynamicResource SurfaceAlt}"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 18"
                                                WidthRequest="36"
                                                HeightRequest="36"
                                                VerticalOptions="Center">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnToggleHistoryAudioListTapped" />
                                            </Border.GestureRecognizers>
                                            <Image Source="{Binding Source={x:Reference ThisPage}, Path=HistoryAudioListExpandIcon}"
                                                   WidthRequest="14"
                                                   HeightRequest="10"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center" />
                                        </Border>
                                    </Grid>

                                    <VerticalStackLayout IsVisible="{Binding Source={x:Reference ThisPage}, Path=IsHistoryAudioListExpanded}"
                                                         BindableLayout.ItemsSource="{Binding Source={x:Reference ThisPage}, Path=SelectedHistoryAudioTracks}"
                                                         Spacing="10">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate>
                                                <Grid ColumnDefinitions="Auto,*,Auto"
                                                      ColumnSpacing="10">
                                                    <Border BackgroundColor="{DynamicResource SurfaceAlt}"
                                                            Stroke="{DynamicResource BorderColor}"
                                                            StrokeThickness="1"
                                                            StrokeShape="RoundRectangle 10"
                                                            Padding="8,4"
                                                            VerticalOptions="Center">
                                                        <Label Text="{Binding LanguageCode}"
                                                               FontSize="11"
                                                               FontAttributes="Bold"
                                                               TextColor="{DynamicResource BodyText}"
                                                               VerticalTextAlignment="Center" />
                                                    </Border>

                                                    <VerticalStackLayout Grid.Column="1"
                                                                         Spacing="2"
                                                                         VerticalOptions="Center">
                                                        <Label Text="{Binding Title}"
                                                               FontSize="13"
                                                               FontAttributes="Bold"
                                                               TextColor="{DynamicResource BodyText}"
                                                               LineBreakMode="TailTruncation" />
                                                        <Label Text="{Binding MetaText}"
                                                               FontSize="12"
                                                               TextColor="{DynamicResource MutedText}" />
                                                    </VerticalStackLayout>

                                                    <Border Grid.Column="2"
                                                            BackgroundColor="{DynamicResource PrimaryGreen}"
                                                            StrokeThickness="0"
                                                            StrokeShape="RoundRectangle 18"
                                                            WidthRequest="36"
                                                            HeightRequest="36"
                                                            VerticalOptions="Center">
                                                        <Border.GestureRecognizers>
                                                            <TapGestureRecognizer Tapped="OnHistoryAudioTrackPlayTapped" />
                                                        </Border.GestureRecognizers>
                                                        <Label Text="{Binding PlayIcon}"
                                                               TextColor="White"
                                                               FontSize="14"
                                                               HorizontalTextAlignment="Center"
                                                               VerticalTextAlignment="Center" />
                                                    </Border>
                                                </Grid>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                            </Border>
                        </VerticalStackLayout>
                    </ScrollView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
