<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiApp_Mobile.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="{DynamicResource LightBg}">

    <Grid RowDefinitions="Auto,*">
        <Grid Style="{StaticResource TopHeaderGridStyle}">
            <Label x:Name="TitleLabel"
                   Text="Cài đặt"
                   Style="{StaticResource TopHeaderTitleStyle}"
                   HorizontalOptions="Start" />
        </Grid>

        <Grid Grid.Row="1">
            <ScrollView>
                <VerticalStackLayout Padding="16,18,16,28" Spacing="18">

                    <HorizontalStackLayout Spacing="8">
                        <Label Text="🔊" FontSize="18" />
                        <Label x:Name="AudioLabel"
                               Text="Âm thanh"
                               Style="{StaticResource SectionTitleStyle}" />
                    </HorizontalStackLayout>

                    <Border x:Name="AudioCard"
                            Style="{StaticResource CardBorderStyle}">
                        <VerticalStackLayout Spacing="18">

                            <!-- Dòng ngôn ngữ -->
                            <Grid ColumnDefinitions="*,Auto">
                                <Label x:Name="LanguageRowLabel"
                                       Text="Ngôn ngữ"
                                       FontSize="16"
                                       TextColor="{DynamicResource BodyText}" />

                                <Label x:Name="LanguageValueLabel"
                                       Grid.Column="1"
                                       Text="Tiếng Việt ›"
                                       FontSize="16"
                                       TextColor="{DynamicResource PrimaryGreen}"
                                       FontAttributes="Bold"
                                       VerticalOptions="Center" />

                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnToggleLanguagePopupTapped" />
                                </Grid.GestureRecognizers>
                            </Grid>

                            <Grid ColumnDefinitions="*,Auto,Auto"
                                  ColumnSpacing="8">
                                <Label x:Name="VoiceRowLabel"
                                       Text="Giọng đọc"
                                       FontSize="16"
                                       TextColor="{DynamicResource BodyText}" />
                                <Label x:Name="VoiceValueLabel"
                                       Grid.Column="1"
                                       Text="Giọng nữ miền Nam"
                                       FontSize="16"
                                       TextColor="{DynamicResource PrimaryGreen}"
                                       FontAttributes="Bold" />
                                <Image Grid.Column="2"
                                       Source="triangle_down_filled.svg"
                                       WidthRequest="14"
                                       HeightRequest="10"
                                       VerticalOptions="Center"
                                       HorizontalOptions="Center" />
                            </Grid>

                            <Label x:Name="ReadingSpeedLabel"
                                   Text="Tốc độ đọc"
                                   FontSize="16"
                                   TextColor="{DynamicResource BodyText}" />

                            <Grid ColumnDefinitions="*,Auto">
                                <Slider Minimum="0.5"
                                        Maximum="2"
                                        Value="1.0"
                                        MinimumTrackColor="{DynamicResource PrimaryGreen}"
                                        MaximumTrackColor="{DynamicResource BorderColor}"
                                        ThumbColor="{DynamicResource PrimaryGreen}"
                                        x:Name="ReadingSpeedSlider"
                                        ValueChanged="OnReadingSpeedChanged" />
                                <Label x:Name="ReadingSpeedValueLabel"
                                       Grid.Column="1"
                                       Text="1.0x"
                                       Margin="10,0,0,0"
                                       VerticalOptions="Center"
                                       FontSize="16"
                                       FontAttributes="Bold" />
                            </Grid>

                            <Label x:Name="VolumeLabel"
                                   Text="Âm lượng"
                                   FontSize="16"
                                   TextColor="{DynamicResource BodyText}" />

                            <Grid ColumnDefinitions="*,Auto">
                                <Slider Minimum="0"
                                        Maximum="100"
                                        Value="100"
                                        MinimumTrackColor="{DynamicResource PrimaryGreen}"
                                        MaximumTrackColor="{DynamicResource BorderColor}"
                                        ThumbColor="{DynamicResource PrimaryGreen}"
                                        x:Name="VolumeSlider"
                                        ValueChanged="OnVolumeChanged" />
                                <Label x:Name="VolumeValueLabel"
                                       Grid.Column="1"
                                       Text="100%"
                                       Margin="10,0,0,0"
                                       VerticalOptions="Center"
                                       FontSize="16"
                                       FontAttributes="Bold" />
                            </Grid>

                            <Button x:Name="TestVoiceButton"
                                    Text="🎙 Test giọng đọc"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Clicked="OnTestVoiceClicked" />
                        </VerticalStackLayout>
                    </Border>

                    <HorizontalStackLayout Spacing="8">
                        <Label Text="🎨" FontSize="18" />
                        <Label x:Name="AppearanceLabel"
                               Text="Giao diện"
                               Style="{StaticResource SectionTitleStyle}" />
                    </HorizontalStackLayout>

                    <Border x:Name="AppearanceCard"
                            Style="{StaticResource CardBorderStyle}">
                        <VerticalStackLayout Spacing="14">
                            <Label x:Name="ThemeHintLabel"
                                   Text="Chọn theme phù hợp với hành trình của bạn. Áp dụng ngay lập tức trên toàn app."
                                   FontSize="14"
                                   TextColor="{DynamicResource MutedText}" />

                            <ScrollView Orientation="Horizontal">
                                <HorizontalStackLayout Spacing="12">
                                    <Border x:Name="ThemeEcoCard"
                                            BackgroundColor="{DynamicResource CardBg}"
                                            Padding="12"
                                            Stroke="{DynamicResource BorderColor}"
                                            StrokeShape="RoundRectangle 20"
                                            StrokeThickness="1"
                                            WidthRequest="208">
                                        <Grid RowDefinitions="Auto,Auto,Auto"
                                              RowSpacing="10">
                                            <Grid HeightRequest="74">
                                                <Border BackgroundColor="#109245"
                                                        StrokeThickness="0"
                                                        StrokeShape="RoundRectangle 16" />
                                                <BoxView Color="#A7F3C5"
                                                         CornerRadius="18"
                                                         HeightRequest="36"
                                                         HorizontalOptions="End"
                                                         Margin="0,10,12,0"
                                                         VerticalOptions="Start"
                                                         WidthRequest="36" />
                                                <Border BackgroundColor="White"
                                                        HeightRequest="18"
                                                        HorizontalOptions="Start"
                                                        Margin="14,44,0,0"
                                                        StrokeThickness="0"
                                                        StrokeShape="RoundRectangle 9"
                                                        VerticalOptions="Start"
                                                        WidthRequest="86" />
                                                <Border x:Name="ThemeEcoBadge"
                                                        BackgroundColor="{DynamicResource PrimaryGreen}"
                                                        HorizontalOptions="End"
                                                        IsVisible="False"
                                                        Padding="7,4"
                                                        StrokeThickness="0"
                                                        StrokeShape="RoundRectangle 12"
                                                        VerticalOptions="Start">
                                                    <Label Text="✓"
                                                           FontSize="11"
                                                           FontAttributes="Bold"
                                                           TextColor="{DynamicResource OnAccentText}" />
                                                </Border>
                                            </Grid>

                                            <Label x:Name="ThemeEcoTitleLabel"
                                                   Grid.Row="1"
                                                   Text="Eco Light"
                                                   FontSize="16"
                                                   FontAttributes="Bold"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="1"
                                                   TextColor="{DynamicResource TitleText}" />

                                            <Label x:Name="ThemeEcoSubtitleLabel"
                                                   Grid.Row="2"
                                                   Text="Tươi, sáng và gần gũi cho bản đồ khám phá ban ngày."
                                                   FontSize="13"
                                                   LineBreakMode="WordWrap"
                                                   MaxLines="3"
                                                   TextColor="{DynamicResource MutedText}" />

                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnThemeEcoTapped" />
                                            </Border.GestureRecognizers>
                                        </Grid>
                                    </Border>

                                    <Border x:Name="ThemeMidnightCard"
                                            BackgroundColor="{DynamicResource CardBg}"
                                            Padding="12"
                                            Stroke="{DynamicResource BorderColor}"
                                            StrokeShape="RoundRectangle 20"
                                            StrokeThickness="1"
                                            WidthRequest="208">
                                        <Grid RowDefinitions="Auto,Auto,Auto"
                                              RowSpacing="10">
                                            <Grid HeightRequest="74">
                                                <Border BackgroundColor="#08141D"
                                                        StrokeThickness="0"
                                                        StrokeShape="RoundRectangle 16" />
                                                <BoxView Color="#58D18E"
                                                         CornerRadius="18"
                                                         HeightRequest="36"
                                                         HorizontalOptions="End"
                                                         Margin="0,10,12,0"
                                                         VerticalOptions="Start"
                                                         WidthRequest="36" />
                                                <Border BackgroundColor="#173242"
                                                        HeightRequest="18"
                                                        HorizontalOptions="Start"
                                                        Margin="14,44,0,0"
                                                        StrokeThickness="0"
                                                        StrokeShape="RoundRectangle 9"
                                                        VerticalOptions="Start"
                                                        WidthRequest="86" />
                                                <Border x:Name="ThemeMidnightBadge"
                                                        BackgroundColor="{DynamicResource PrimaryGreen}"
                                                        HorizontalOptions="End"
                                                        IsVisible="False"
                                                        Padding="7,4"
                                                        StrokeThickness="0"
                                                        StrokeShape="RoundRectangle 12"
                                                        VerticalOptions="Start">
                                                    <Label Text="✓"
                                                           FontSize="11"
                                                           FontAttributes="Bold"
                                                           TextColor="{DynamicResource OnAccentText}" />
                                                </Border>
                                            </Grid>

                                            <Label x:Name="ThemeMidnightTitleLabel"
                                                   Grid.Row="1"
                                                   Text="Midnight"
                                                   FontSize="16"
                                                   FontAttributes="Bold"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="1"
                                                   TextColor="{DynamicResource TitleText}" />

                                            <Label x:Name="ThemeMidnightSubtitleLabel"
                                                   Grid.Row="2"
                                                   Text="Độ tương phản dịu mắt hơn khi đi buổi tối hoặc ngoài trời tối."
                                                   FontSize="13"
                                                   LineBreakMode="WordWrap"
                                                   MaxLines="3"
                                                   TextColor="{DynamicResource MutedText}" />

                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnThemeMidnightTapped" />
                                            </Border.GestureRecognizers>
                                        </Grid>
                                    </Border>

                                    <Border x:Name="ThemeHeritageCard"
                                            BackgroundColor="{DynamicResource CardBg}"
                                            Padding="12"
                                            Stroke="{DynamicResource BorderColor}"
                                            StrokeShape="RoundRectangle 20"
                                            StrokeThickness="1"
                                            WidthRequest="208">
                                        <Grid RowDefinitions="Auto,Auto,Auto"
                                              RowSpacing="10">
                                            <Grid HeightRequest="74">
                                                <Border BackgroundColor="#8E4A26"
                                                        StrokeThickness="0"
                                                        StrokeShape="RoundRectangle 16" />
                                                <BoxView Color="#F4C9A7"
                                                         CornerRadius="18"
                                                         HeightRequest="36"
                                                         HorizontalOptions="End"
                                                         Margin="0,10,12,0"
                                                         VerticalOptions="Start"
                                                         WidthRequest="36" />
                                                <Border BackgroundColor="#FFF6EA"
                                                        HeightRequest="18"
                                                        HorizontalOptions="Start"
                                                        Margin="14,44,0,0"
                                                        StrokeThickness="0"
                                                        StrokeShape="RoundRectangle 9"
                                                        VerticalOptions="Start"
                                                        WidthRequest="86" />
                                                <Border x:Name="ThemeHeritageBadge"
                                                        BackgroundColor="{DynamicResource PrimaryGreen}"
                                                        HorizontalOptions="End"
                                                        IsVisible="False"
                                                        Padding="7,4"
                                                        StrokeThickness="0"
                                                        StrokeShape="RoundRectangle 12"
                                                        VerticalOptions="Start">
                                                    <Label Text="✓"
                                                           FontSize="11"
                                                           FontAttributes="Bold"
                                                           TextColor="{DynamicResource OnAccentText}" />
                                                </Border>
                                            </Grid>

                                            <Label x:Name="ThemeHeritageTitleLabel"
                                                   Grid.Row="1"
                                                   Text="Heritage"
                                                   FontSize="16"
                                                   FontAttributes="Bold"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="1"
                                                   TextColor="{DynamicResource TitleText}" />

                                            <Label x:Name="ThemeHeritageSubtitleLabel"
                                                   Grid.Row="2"
                                                   Text="Tông ấm gợi cảm giác di sản và du lịch văn hóa."
                                                   FontSize="13"
                                                   LineBreakMode="WordWrap"
                                                   MaxLines="3"
                                                   TextColor="{DynamicResource MutedText}" />

                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnThemeHeritageTapped" />
                                            </Border.GestureRecognizers>
                                        </Grid>
                                    </Border>
                                </HorizontalStackLayout>
                            </ScrollView>
                        </VerticalStackLayout>
                    </Border>

                    <HorizontalStackLayout Spacing="8">
                        <Label Text="🛰" FontSize="18" />
                        <Label x:Name="GpsLabel"
                               Text="GPS và Vị trí"
                               Style="{StaticResource SectionTitleStyle}" />
                    </HorizontalStackLayout>

                    <Border x:Name="GpsCard"
                            Style="{StaticResource CardBorderStyle}">
                        <VerticalStackLayout Spacing="18">

                            <Grid ColumnDefinitions="*,Auto">
                                <Label x:Name="GpsAccuracyLabel"
                                       Text="Độ chính xác GPS"
                                       FontSize="16"
                                       TextColor="{DynamicResource BodyText}" />
                                <Picker x:Name="GpsAccuracyPicker"
                                        Grid.Column="1"
                                        Title="Accuracy"
                                        WidthRequest="160"
                                        HorizontalOptions="End"
                                        SelectedIndexChanged="OnGpsAccuracyChanged"
                                        TextColor="{DynamicResource PrimaryGreen}"
                                        TitleColor="{DynamicResource MutedText}" />
                            </Grid>

                            <Label x:Name="TriggerRadiusLabel"
                                   Text="Bán kính kích hoạt"
                                   FontSize="16"
                                   TextColor="{DynamicResource BodyText}" />

                            <Grid ColumnDefinitions="*,Auto">
                                <Slider Minimum="10"
                                        Maximum="100"
                                        Value="50"
                                        MinimumTrackColor="{DynamicResource PrimaryGreen}"
                                        MaximumTrackColor="{DynamicResource BorderColor}"
                                        ThumbColor="{DynamicResource PrimaryGreen}"
                                        x:Name="TriggerRadiusSlider"
                                        ValueChanged="OnTriggerRadiusChanged" />
                                <Label x:Name="TriggerRadiusValueLabel"
                                       Grid.Column="1"
                                       Text="50m"
                                       Margin="10,0,0,0"
                                       VerticalOptions="Center"
                                       FontSize="16"
                                       FontAttributes="Bold" />
                            </Grid>

                            <Label x:Name="AlertRadiusLabel"
                                   Text="Bán kính cảnh báo"
                                   FontSize="16"
                                   TextColor="{DynamicResource BodyText}" />

                            <Grid ColumnDefinitions="*,Auto">
                                <Slider Minimum="20"
                                        Maximum="200"
                                        Value="100"
                                        MinimumTrackColor="{DynamicResource PrimaryGreen}"
                                        MaximumTrackColor="{DynamicResource BorderColor}"
                                        ThumbColor="{DynamicResource PrimaryGreen}"
                                        x:Name="AlertRadiusSlider"
                                        ValueChanged="OnAlertRadiusChanged" />
                                <Label x:Name="AlertRadiusValueLabel"
                                       Grid.Column="1"
                                       Text="100m"
                                       Margin="10,0,0,0"
                                       VerticalOptions="Center"
                                       FontSize="16"
                                       FontAttributes="Bold" />
                            </Grid>

                            <Label x:Name="WaitTimeLabel"
                                   Text="Thời gian chờ"
                                   FontSize="16"
                                   TextColor="{DynamicResource BodyText}" />

                              <Grid ColumnDefinitions="*,Auto">
                                  <Slider Minimum="60"
                                          Maximum="600"
                                          Value="300"
                                        MinimumTrackColor="{DynamicResource PrimaryGreen}"
                                        MaximumTrackColor="{DynamicResource BorderColor}"
                                        ThumbColor="{DynamicResource PrimaryGreen}"
                                        x:Name="WaitTimeSlider"
                                        ValueChanged="OnWaitTimeChanged" />
                                <Label x:Name="WaitTimeValueLabel"
                                       Grid.Column="1"
                                       Text="300s"
                                       Margin="10,0,0,0"
                                       VerticalOptions="Center"
                                         FontSize="16"
                                         FontAttributes="Bold" />
                              </Grid>

                              <Grid ColumnDefinitions="*,Auto"
                                    ColumnSpacing="12">
                                  <Label x:Name="ShowPoiRadiusLabel"
                                         Text="Hiện bán kính POI trên bản đồ"
                                         FontSize="16"
                                         TextColor="{DynamicResource BodyText}" />
                                  <Switch x:Name="ShowPoiRadiusSwitch"
                                          Grid.Column="1"
                                          IsToggled="True"
                                          OnColor="{DynamicResource PrimaryGreen}" />
                              </Grid>

                              <Label x:Name="AutoFocusIdleLabel"
                                     Text="Tự focus POI sau khi không chạm bản đồ"
                                     FontSize="16"
                                     TextColor="{DynamicResource BodyText}" />

                              <Grid ColumnDefinitions="*,Auto"
                                    ColumnSpacing="12">
                                  <Entry x:Name="AutoFocusIdleEntry"
                                         Keyboard="Numeric"
                                         Placeholder="60"
                                         TextColor="{DynamicResource BodyText}"
                                         PlaceholderColor="{DynamicResource MutedText}"
                                         BackgroundColor="{DynamicResource CardBg}" />
                                  <Label x:Name="AutoFocusIdleHintLabel"
                                         Grid.Column="1"
                                         Text="s, -1 để tắt"
                                         VerticalOptions="Center"
                                         TextColor="{DynamicResource MutedText}" />
                              </Grid>
                          </VerticalStackLayout>
                    </Border>

                    <HorizontalStackLayout Spacing="8">
                        <Label Text="⤴" FontSize="18" />
                        <Label x:Name="BehaviorLabel"
                               Text="Hành vi"
                               Style="{StaticResource SectionTitleStyle}" />
                    </HorizontalStackLayout>

                    <Border x:Name="BehaviorCard"
                            Style="{StaticResource CardBorderStyle}">
                        <VerticalStackLayout Spacing="18">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label x:Name="AutoPlayLabel"
                                       Text="Tự động phát khi vào vùng"
                                       FontSize="16"
                                       TextColor="{DynamicResource BodyText}" />
                                <Switch x:Name="AutoPlaySwitch"
                                        Grid.Column="1"
                                        IsToggled="True"
                                        OnColor="{DynamicResource PrimaryGreen}" />
                            </Grid>

                            <Grid ColumnDefinitions="*,Auto">
                                <Label x:Name="NotifyNearLabel"
                                       Text="Thông báo khi đến gần"
                                       FontSize="16"
                                       TextColor="{DynamicResource BodyText}" />
                                <Switch x:Name="NotifyNearSwitch"
                                        Grid.Column="1"
                                        IsToggled="True"
                                        OnColor="{DynamicResource PrimaryGreen}" />
                            </Grid>

                            <Grid ColumnDefinitions="*,Auto">
                                <Label x:Name="BackgroundTrackingLabel"
                                       Text="Theo dõi ở nền"
                                       FontSize="16"
                                       TextColor="{DynamicResource BodyText}" />
                                <Switch x:Name="BackgroundTrackingSwitch"
                                         Grid.Column="1"
                                         IsToggled="True"
                                         Toggled="OnBackgroundTrackingToggled"
                                         OnColor="{DynamicResource PrimaryGreen}" />
                            </Grid>

                            <Grid ColumnDefinitions="*,Auto">
                                <Label x:Name="BatterySaverLabel"
                                       Text="Chế độ tiết kiệm pin"
                                       FontSize="16"
                                       TextColor="{DynamicResource BodyText}" />
                                <Switch x:Name="BatterySaverSwitch"
                                        Grid.Column="1"
                                        IsToggled="False"
                                        OnColor="{DynamicResource PrimaryGreen}"
                                        Toggled="OnBatterySaverToggled" />
                            </Grid>

                            <Grid ColumnDefinitions="*,Auto">
                                <Label x:Name="ApiModeLabel"
                                       Text="Offline mode"
                                       FontSize="16"
                                       TextColor="{DynamicResource BodyText}" />
                                <Switch x:Name="ApiModeSwitch"
                                        Grid.Column="1"
                                        IsToggled="True"
                                        OnColor="{DynamicResource PrimaryGreen}"
                                        Toggled="OnApiModeToggled" />
                            </Grid>

                            <Grid ColumnDefinitions="*,Auto">
                                <Label x:Name="DeveloperModeLabel"
                                       Text="Hiện nút dev trên bản đồ"
                                       FontSize="16"
                                       TextColor="{DynamicResource BodyText}" />
                                <Switch x:Name="DeveloperModeSwitch"
                                        Grid.Column="1"
                                        IsToggled="False"
                                        OnColor="{DynamicResource PrimaryGreen}" />
                            </Grid>

                            <Grid ColumnDefinitions="*,Auto">
                                <Label x:Name="MiniPlayerLabel"
                                       Text="Hiện thanh phát mini"
                                       FontSize="16"
                                       TextColor="{DynamicResource BodyText}" />
                                <Switch x:Name="MiniPlayerSwitch"
                                        Grid.Column="1"
                                        IsToggled="True"
                                        OnColor="{DynamicResource PrimaryGreen}" />
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <Button x:Name="SaveSettingsButton"
                            Text="Lưu cài đặt"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Clicked="OnSaveSettingsClicked" />

                </VerticalStackLayout>
            </ScrollView>

            <!-- Popup chọn ngôn ngữ -->
            <Border x:Name="LanguagePopup"
                    IsVisible="False"
                    Stroke="{DynamicResource BorderColor}"
                    StrokeThickness="1"
                    BackgroundColor="{DynamicResource PopupBg}"
                    StrokeShape="RoundRectangle 18"
                    HorizontalOptions="End"
                    VerticalOptions="Start"
                    Margin="0,70,16,0"
                    WidthRequest="250"
                    MaximumHeightRequest="420"
                    ZIndex="10">

                <ScrollView>
                    <VerticalStackLayout Spacing="0">
                        <Label x:Name="LanguagePopupTitleLabel"
                               Text="CHỌN NGÔN NGỮ"
                               Padding="18,16,18,12"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="{DynamicResource MutedText}" />

                        <Grid x:Name="LangViItem"
                              Padding="0"
                              ColumnDefinitions="4,Auto,*"
                              ColumnSpacing="12"
                              MinimumHeightRequest="54"
                              BackgroundColor="Transparent">
                            <BoxView x:Name="LangViIndicator"
                                     Grid.Column="0"
                                     Color="{DynamicResource PrimaryGreen}"
                                     IsVisible="False" />
                            <Label Grid.Column="1"
                                   Text="VN"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   Margin="16,0,0,0"
                                   VerticalOptions="Center" />
                            <Label x:Name="LangViLabel"
                                   Grid.Column="2"
                                   Text="Tiếng Việt"
                                   FontSize="16"
                                   VerticalOptions="Center"
                                   TextColor="{DynamicResource BodyText}" />
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnLanguageViTapped" />
                            </Grid.GestureRecognizers>
                        </Grid>

                        <BoxView HeightRequest="1" Color="{DynamicResource DividerColor}" />

                        <Grid x:Name="LangEnItem"
                              Padding="0"
                              ColumnDefinitions="4,Auto,*"
                              ColumnSpacing="12"
                              MinimumHeightRequest="54"
                              BackgroundColor="Transparent">
                            <BoxView x:Name="LangEnIndicator"
                                     Grid.Column="0"
                                     Color="{DynamicResource PrimaryGreen}"
                                     IsVisible="False" />
                            <Label Grid.Column="1"
                                   Text="GB"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   Margin="16,0,0,0"
                                   VerticalOptions="Center" />
                            <Label x:Name="LangEnLabel"
                                   Grid.Column="2"
                                   Text="English"
                                   FontSize="16"
                                   VerticalOptions="Center"
                                   TextColor="{DynamicResource BodyText}" />
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnLanguageEnTapped" />
                            </Grid.GestureRecognizers>
                        </Grid>

                        <BoxView HeightRequest="1" Color="{DynamicResource DividerColor}" />

                        <Grid x:Name="LangCnItem"
                              Padding="0"
                              ColumnDefinitions="4,Auto,*"
                              ColumnSpacing="12"
                              MinimumHeightRequest="54"
                              BackgroundColor="Transparent">
                            <BoxView x:Name="LangCnIndicator"
                                     Grid.Column="0"
                                     Color="{DynamicResource PrimaryGreen}"
                                     IsVisible="False" />
                            <Label Grid.Column="1"
                                   Text="CN"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   Margin="16,0,0,0"
                                   VerticalOptions="Center" />
                            <Label x:Name="LangCnLabel"
                                   Grid.Column="2"
                                   Text="中文"
                                   FontSize="16"
                                   VerticalOptions="Center"
                                   TextColor="{DynamicResource BodyText}" />
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnLanguageCnTapped" />
                            </Grid.GestureRecognizers>
                        </Grid>

                        <BoxView HeightRequest="1" Color="{DynamicResource DividerColor}" />

                        <Grid x:Name="LangJpItem"
                              Padding="0"
                              ColumnDefinitions="4,Auto,*"
                              ColumnSpacing="12"
                              MinimumHeightRequest="54"
                              BackgroundColor="Transparent">
                            <BoxView x:Name="LangJpIndicator"
                                     Grid.Column="0"
                                     Color="{DynamicResource PrimaryGreen}"
                                     IsVisible="False" />
                            <Label Grid.Column="1"
                                   Text="JP"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   Margin="16,0,0,0"
                                   VerticalOptions="Center" />
                            <Label x:Name="LangJpLabel"
                                   Grid.Column="2"
                                   Text="日本語"
                                   FontSize="16"
                                   VerticalOptions="Center"
                                   TextColor="{DynamicResource BodyText}" />
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnLanguageJpTapped" />
                            </Grid.GestureRecognizers>
                        </Grid>

                        <BoxView HeightRequest="1" Color="{DynamicResource DividerColor}" />

                        <Grid x:Name="LangKrItem"
                              Padding="0"
                              ColumnDefinitions="4,Auto,*"
                              ColumnSpacing="12"
                              MinimumHeightRequest="54"
                              BackgroundColor="Transparent">
                            <BoxView x:Name="LangKrIndicator"
                                     Grid.Column="0"
                                     Color="{DynamicResource PrimaryGreen}"
                                     IsVisible="False" />
                            <Label Grid.Column="1"
                                   Text="KR"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   Margin="16,0,0,0"
                                   VerticalOptions="Center" />
                            <Label x:Name="LangKrLabel"
                                   Grid.Column="2"
                                   Text="한국어"
                                   FontSize="16"
                                   VerticalOptions="Center"
                                   TextColor="{DynamicResource BodyText}" />
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnLanguageKrTapped" />
                            </Grid.GestureRecognizers>
                        </Grid>

                        <BoxView HeightRequest="1" Color="{DynamicResource DividerColor}" />

                        <Grid x:Name="LangFrItem"
                              Padding="0"
                              ColumnDefinitions="4,Auto,*"
                              ColumnSpacing="12"
                              MinimumHeightRequest="54"
                              BackgroundColor="Transparent">
                            <BoxView x:Name="LangFrIndicator"
                                     Grid.Column="0"
                                     Color="{DynamicResource PrimaryGreen}"
                                     IsVisible="False" />
                            <Label Grid.Column="1"
                                   Text="FR"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   Margin="16,0,0,0"
                                   VerticalOptions="Center" />
                            <Label x:Name="LangFrLabel"
                                   Grid.Column="2"
                                   Text="Français"
                                   FontSize="16"
                                   VerticalOptions="Center"
                                   TextColor="{DynamicResource BodyText}" />
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnLanguageFrTapped" />
                            </Grid.GestureRecognizers>
                        </Grid>
                    </VerticalStackLayout>
                </ScrollView>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
