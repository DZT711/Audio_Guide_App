<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiApp_Mobile.Views.OfflinePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:MauiApp_Mobile.Views"
    x:Name="ThisPage"
    BackgroundColor="{DynamicResource LightBg}"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="0">

        <!-- Header -->
        <Grid Grid.Row="0"
              Style="{StaticResource TopHeaderGridStyle}">

            <Grid ColumnDefinitions="*,Auto"
                  VerticalOptions="Center">

                <VerticalStackLayout Spacing="3" VerticalOptions="Center">
                    <Label Text="Offline"
                           Style="{StaticResource TopHeaderTitleStyle}" />

                    <Label Text="Quản lý audio pack nghe offline"
                           Style="{StaticResource TopHeaderSubtitleStyle}" />
                </VerticalStackLayout>

                <Button Grid.Column="1"
                        Text="↓ Tải tất cả"
                        Clicked="OnDownloadAllClicked"
                        Style="{StaticResource TopHeaderActionButtonStyle}" />
            </Grid>
        </Grid>

        <!-- Stats -->
        <Grid Grid.Row="1"
              Padding="16,14,16,12">
            <VerticalStackLayout Spacing="12">
                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="12">
                    <Border x:Name="OfflineSummaryCard1"
                            BackgroundColor="{DynamicResource CardBg}"
                            Padding="14"
                            Stroke="{DynamicResource BorderColor}"
                            StrokeShape="RoundRectangle 18"
                            StrokeThickness="1">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Sẵn sàng offline"
                                   FontSize="12"
                                   TextColor="{DynamicResource MutedText}" />
                            <Label Text="{Binding DownloadedCountText}"
                                   FontAttributes="Bold"
                                   FontSize="22"
                                   TextColor="{DynamicResource TitleText}" />
                            <Label Text="Các pack đã tải"
                                   FontSize="12"
                                   TextColor="{DynamicResource SuccessText}" />
                        </VerticalStackLayout>
                    </Border>

                    <Border x:Name="OfflineSummaryCard2"
                            Grid.Column="1"
                            BackgroundColor="{DynamicResource CardBg}"
                            Padding="14"
                            Stroke="{DynamicResource BorderColor}"
                            StrokeShape="RoundRectangle 18"
                            StrokeThickness="1">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Dung lượng"
                                   FontSize="12"
                                   TextColor="{DynamicResource MutedText}" />
                            <Label Text="{Binding DownloadedSizeText}"
                                   FontAttributes="Bold"
                                   FontSize="22"
                                   TextColor="{DynamicResource TitleText}" />
                            <Label Text="Đã lưu trong thiết bị"
                                   FontSize="12"
                                   TextColor="{DynamicResource InfoText}" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <Border x:Name="OfflineProgressCard"
                        BackgroundColor="{DynamicResource CardBg}"
                        Padding="14"
                        Stroke="{DynamicResource BorderColor}"
                        StrokeShape="RoundRectangle 18"
                        StrokeThickness="1">
                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="10">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Thư viện nghe không cần mạng"
                                       FontAttributes="Bold"
                                       FontSize="15"
                                       TextColor="{DynamicResource BodyText}" />
                                <Label Text="{Binding DownloadProgressText}"
                                       FontSize="12"
                                       TextColor="{DynamicResource MutedText}" />
                            </VerticalStackLayout>

                            <Label Grid.Column="1"
                                   Text="🗑 Xóa hết"
                                   FontSize="14"
                                   TextColor="{DynamicResource DangerText}"
                                   VerticalTextAlignment="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnClearAllTapped" />
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>

                        <ProgressBar Progress="{Binding DownloadProgress}"
                                     ProgressColor="{DynamicResource PrimaryGreen}"
                                     BackgroundColor="{DynamicResource DividerColor}"
                                     HeightRequest="10" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </Grid>

        <!-- Filter -->
        <HorizontalStackLayout Grid.Row="2"
                               BackgroundColor="{DynamicResource CardBg}"
                               Padding="16,0,16,12"
                               Spacing="10">

            <Border StrokeThickness="0"
                    BackgroundColor="{Binding AllTabBg}"
                    StrokeShape="RoundRectangle 16"
                    Padding="14,6">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnAllTapped" />
                </Border.GestureRecognizers>
                <Label Text="Tất cả"
                       TextColor="{Binding AllTabTextColor}"
                       FontAttributes="Bold"
                       FontSize="14" />
            </Border>

            <Border StrokeThickness="0"
                    BackgroundColor="{Binding DownloadedTabBg}"
                    StrokeShape="RoundRectangle 16"
                    Padding="14,6">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnDownloadedTapped" />
                </Border.GestureRecognizers>
                <Label Text="Đã tải"
                       TextColor="{Binding DownloadedTabTextColor}"
                       FontAttributes="Bold"
                       FontSize="14" />
            </Border>

            <Border StrokeThickness="0"
                    BackgroundColor="{Binding NotDownloadedTabBg}"
                    StrokeShape="RoundRectangle 16"
                    Padding="14,6">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnNotDownloadedTapped" />
                </Border.GestureRecognizers>
                <Label Text="Chưa tải"
                       TextColor="{Binding NotDownloadedTabTextColor}"
                       FontAttributes="Bold"
                       FontSize="14" />
            </Border>
        </HorizontalStackLayout>

        <!-- List -->
        <Grid Grid.Row="3">
            <CollectionView x:Name="OfflineCollectionView"
                            IsVisible="{Binding HasItems}"
                            ItemsSource="{Binding FilteredItems}"
                            Margin="0,0,0,0"
                            Opacity="0"
                            ItemSizingStrategy="MeasureFirstItem"
                            SelectionMode="None">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical"
                                   ItemSpacing="14" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="local:OfflinePackItem">
                    <Border Margin="10,0"
                            Padding="12"
                            BackgroundColor="{DynamicResource CardBg}"
                            Stroke="{Binding CardStrokeColor}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 18">

                        <Grid RowDefinitions="Auto,Auto"
                              RowSpacing="10">

                            <Grid Grid.Row="0"
                                  ColumnDefinitions="Auto,*,Auto"
                                  ColumnSpacing="12">

                                <!-- Image -->
                                <Grid WidthRequest="56"
                                      HeightRequest="56"
                                    VerticalOptions="Center">
                                    <Frame Padding="0"
                                           HasShadow="False"
                                           CornerRadius="14"
                                           IsClippedToBounds="True"
                                           WidthRequest="56"
                                           HeightRequest="56"
                                           BackgroundColor="{DynamicResource SurfaceAlt}">
                                        <Image Source="{Binding Image}"
                                               Aspect="AspectFill" />
                                    </Frame>

                                    <Border IsVisible="{Binding IsDownloaded}"
                                            BackgroundColor="{DynamicResource CardBg}"
                                            Stroke="{DynamicResource PrimaryGreen}"
                                            StrokeThickness="1"
                                            StrokeShape="RoundRectangle 10"
                                            WidthRequest="20"
                                            HeightRequest="20"
                                            HorizontalOptions="End"
                                            VerticalOptions="End"
                                            TranslationX="4"
                                            TranslationY="4">
                                        <Label Text="✓"
                                               TextColor="{DynamicResource PrimaryGreen}"
                                               FontSize="12"
                                               HorizontalTextAlignment="Center"
                                               VerticalTextAlignment="Center" />
                                    </Border>
                                </Grid>

                                <!-- Content -->
                                <VerticalStackLayout Grid.Column="1"
                                                     Spacing="5"
                                                     VerticalOptions="Center">

                                    <Border BackgroundColor="{Binding CategoryBg}"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 10"
                                            Padding="8,2"
                                            HorizontalOptions="Start">
                                        <Label Text="{Binding Category}"
                                               FontSize="12"
                                               TextColor="{Binding CategoryTextColor}" />
                                    </Border>

                                    <Label Text="{Binding Title}"
                                           FontSize="17"
                                           FontAttributes="Bold"
                                           TextColor="{DynamicResource TitleText}"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="1" />

                                    <HorizontalStackLayout Spacing="10">
                                        <Label Text="{Binding AudioCountText}"
                                               FontSize="13"
                                               TextColor="{DynamicResource MutedText}" />
                                        <Label Text="{Binding Duration}"
                                               FontSize="13"
                                               TextColor="{DynamicResource MutedText}" />
                                        <Label Text="{Binding Size}"
                                               FontSize="13"
                                               TextColor="{DynamicResource MutedText}" />
                                    </HorizontalStackLayout>

                                    <Label Text="{Binding DownloadedDateText}"
                                           FontSize="13"
                                           TextColor="{DynamicResource SuccessText}"
                                           IsVisible="{Binding IsDownloaded}" />
                                </VerticalStackLayout>

                                <!-- Actions -->
                                <VerticalStackLayout Grid.Column="2"
                                                     Spacing="8"
                                                     HorizontalOptions="Center"
                                                     VerticalOptions="Center">

                                    <!-- Chưa tải -->
                                    <Border IsVisible="{Binding IsNotDownloaded}"
                                            BackgroundColor="{DynamicResource PrimaryGreen}"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 22"
                                            WidthRequest="44"
                                            HeightRequest="44">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.DownloadCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                        <Label Text="↓"
                                               TextColor="White"
                                               FontSize="20"
                                               HorizontalTextAlignment="Center"
                                               VerticalTextAlignment="Center" />
                                    </Border>

                                    <!-- Đã tải: Xóa -->
                                    <Border IsVisible="{Binding IsDownloaded}"
                                            BackgroundColor="{DynamicResource SoftRed}"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 14"
                                            WidthRequest="44"
                                            HeightRequest="44">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.DeleteCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                        <Label Text="&#xE74D;"
                                               FontFamily="Segoe MDL2 Assets"
                                               TextColor="{DynamicResource DangerText}"
                                               FontSize="18"
                                               HorizontalTextAlignment="Center"
                                               VerticalTextAlignment="Center" />
                                    </Border>

                                    <!-- Expand/Collapse -->
                                    <Border BackgroundColor="{DynamicResource SurfaceAlt}"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 18"
                                            WidthRequest="36"
                                            HeightRequest="36">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.ToggleExpandCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                        <Label Text="{Binding ExpandIcon}"
                                               TextColor="{DynamicResource MutedText}"
                                               FontSize="14"
                                               HorizontalTextAlignment="Center"
                                               VerticalTextAlignment="Center" />
                                    </Border>
                                </VerticalStackLayout>
                            </Grid>

                            <!-- Expanded language list -->
                            <Border Grid.Row="1"
                                    IsVisible="{Binding IsExpanded}"
                                    BackgroundColor="{DynamicResource SurfaceAlt}"
                                    Stroke="{DynamicResource BorderColor}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 14"
                                    Padding="10">
                                <VerticalStackLayout BindableLayout.ItemsSource="{Binding LocalizedTitles}"
                                                     Spacing="8">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="local:LocalizedTitleItem">
                                            <Grid ColumnDefinitions="Auto,*"
                                                  ColumnSpacing="8">
                                                <Label Text="{Binding LanguageCode}"
                                                       FontSize="11"
                                                       TextColor="{DynamicResource BodyText}"
                                                       BackgroundColor="{DynamicResource CardBg}"
                                                       Padding="6,2"
                                                       VerticalTextAlignment="Center" />
                                                <Label Grid.Column="1"
                                                       Text="{Binding LocalizedName}"
                                                       FontSize="13"
                                                       TextColor="{DynamicResource BodyText}"
                                                       LineBreakMode="TailTruncation" />
                                            </Grid>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            </CollectionView>

            <VerticalStackLayout IsVisible="{Binding ShowEmptyState}"
                                 Padding="24,36,24,0"
                                 Spacing="8">
                <Label Text="📦"
                       FontSize="32"
                       HorizontalOptions="Center" />
                <Label Text="Không có pack phù hợp"
                       FontAttributes="Bold"
                       FontSize="18"
                       HorizontalTextAlignment="Center"
                       TextColor="{DynamicResource BodyText}" />
                <Label Text="Thử đổi bộ lọc hoặc tải thêm audio để nghe offline."
                       FontSize="14"
                       HorizontalTextAlignment="Center"
                       TextColor="{DynamicResource MutedText}" />
            </VerticalStackLayout>

            <Grid x:Name="OfflineLoadingOverlay"
                  BackgroundColor="{DynamicResource LightBg}"
                  IsVisible="True"
                  Padding="10,0,10,0"
                  RowDefinitions="Auto,Auto,Auto"
                  RowSpacing="14"
                  ZIndex="10">
                <Border x:Name="OfflineSkeletonCard1"
                        HeightRequest="118"
                        Style="{StaticResource SkeletonBoneStyle}" />
                <Border x:Name="OfflineSkeletonCard2"
                        Grid.Row="1"
                        HeightRequest="118"
                        Style="{StaticResource SkeletonBoneStyle}" />
                <Border x:Name="OfflineSkeletonCard3"
                        Grid.Row="2"
                        HeightRequest="118"
                        Style="{StaticResource SkeletonBoneStyle}" />
            </Grid>
        </Grid>

        <!-- Delete Confirm Modal -->
        <Grid Grid.RowSpan="4"
              IsVisible="{Binding IsDeleteConfirmVisible}"
              BackgroundColor="{DynamicResource OverlayColor}"
              Padding="16"
              ZIndex="99">

            <Border VerticalOptions="End"
                    BackgroundColor="{DynamicResource BottomSheetBg}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 24"
                    Padding="16,18,16,16">

                <VerticalStackLayout Spacing="16">
                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="12">
                        <Border WidthRequest="42"
                                HeightRequest="42"
                                BackgroundColor="{DynamicResource SoftRed}"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 21"
                                VerticalOptions="Start">
                            <Label Text="&#xE74D;"
                                   FontFamily="Segoe MDL2 Assets"
                                   TextColor="#FF4D4F"
                                   FontSize="18"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center" />
                        </Border>

                        <VerticalStackLayout Grid.Column="1"
                                             Spacing="2">
                            <Label Text="{Binding DeleteConfirmTitle}"
                                   FontAttributes="Bold"
                                FontSize="18"
                                   TextColor="{DynamicResource TitleText}" />
                            <Label Text="{Binding DeleteConfirmDescription}"
                                FontSize="14"
                                   TextColor="{DynamicResource MutedText}" />
                        </VerticalStackLayout>
                    </Grid>

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="12">
                        <Button Grid.Column="0"
                                Text="Hủy"
                                Clicked="OnCancelDeleteClicked"
                                BackgroundColor="{DynamicResource SurfaceAlt}"
                                TextColor="{DynamicResource BodyText}"
                                FontSize="18"
                                FontAttributes="Bold"
                                CornerRadius="14"
                                HeightRequest="52" />
                        <Button Grid.Column="1"
                                Text="Xóa"
                                Clicked="OnConfirmDeleteClicked"
                                BackgroundColor="#FF2D3D"
                                TextColor="White"
                                FontSize="18"
                                FontAttributes="Bold"
                                CornerRadius="14"
                                HeightRequest="52" />
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
