<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiApp_Mobile.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="{StaticResource LightBg}">

    <Grid RowDefinitions="180,*">
        <Grid BackgroundColor="{StaticResource PrimaryGreen}" Padding="20,50,20,20">
            <VerticalStackLayout Spacing="18">
                <Label Text="Địa điểm" Style="{StaticResource PageTitleStyle}" />

                <Frame
                    BackgroundColor="White"
                    BorderColor="Transparent"
                    CornerRadius="18"
                    HasShadow="False"
                    Padding="16,10">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <Label Text="🔍" FontSize="22" TextColor="{StaticResource MutedText}" VerticalOptions="Center" />
                        <Entry
                            Grid.Column="1"
                            Placeholder="Tìm kiếm điểm..."
                            PlaceholderColor="{StaticResource MutedText}"
                            BackgroundColor="Transparent"
                            TextColor="{StaticResource BodyText}" />
                    </Grid>
                </Frame>
            </VerticalStackLayout>
        </Grid>

        <Grid Grid.Row="1" Padding="0">
            <ScrollView>
                <VerticalStackLayout Padding="16,14,16,24" Spacing="0">
                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,14">
                        <Label Text="16 điểm tham quan" FontSize="15" TextColor="{StaticResource BodyText}" />
                        <HorizontalStackLayout Grid.Column="1" Spacing="6">
                            <Label Text="⚙" FontSize="16" TextColor="{StaticResource MutedText}" />
                            <Label Text="Lọc" FontSize="15" TextColor="{StaticResource BodyText}" />
                        </HorizontalStackLayout>
                    </Grid>

                    <!-- Card 1 -->
                    <Frame Style="{StaticResource CardFrameStyle}">
                        <Grid ColumnDefinitions="88,*,Auto" ColumnSpacing="14">
                            <Image Source="dotnet_bot.png" WidthRequest="88" HeightRequest="88" Aspect="AspectFill" />
                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label Text="Dinh Độc Lập" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource BodyText}" />
                                <Label Text="Dinh Thống Nhất – biểu tượng lịch sử Việt Nam" FontSize="13" TextColor="#667085" />
                                <HorizontalStackLayout Spacing="8" Margin="0,6,0,0">
                                    <Frame Padding="10,4" CornerRadius="10" HasShadow="False" BackgroundColor="{StaticResource SoftRed}" BorderColor="Transparent">
                                        <Label Text="Lịch sử" FontSize="12" TextColor="#E53935" />
                                    </Frame>
                                    <Label Text="⭐ 10/10" FontSize="13" TextColor="#667085" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                            <Frame
                                Grid.Column="2"
                                WidthRequest="44"
                                HeightRequest="44"
                                CornerRadius="22"
                                Padding="0"
                                BackgroundColor="{StaticResource PrimaryGreen}"
                                HorizontalOptions="End"
                                VerticalOptions="Center">
                                <Label Text="▶" HorizontalOptions="Center" VerticalOptions="Center" TextColor="White" FontSize="18" />
                            </Frame>
                        </Grid>
                    </Frame>

                    <!-- Card 2 -->
                    <Frame Style="{StaticResource CardFrameStyle}">
                        <Grid ColumnDefinitions="88,*,Auto" ColumnSpacing="14">
                            <Image Source="dotnet_bot.png" WidthRequest="88" HeightRequest="88" Aspect="AspectFill" />
                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label Text="Đại Nội Huế" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource BodyText}" />
                                <Label Text="Hoàng thành Huế – Di sản văn hóa Thế giới UNESCO" FontSize="13" TextColor="#667085" />
                                <HorizontalStackLayout Spacing="8" Margin="0,6,0,0">
                                    <Frame Padding="10,4" CornerRadius="10" HasShadow="False" BackgroundColor="{StaticResource SoftPurple}" BorderColor="Transparent">
                                        <Label Text="Di sản" FontSize="12" TextColor="#7C3AED" />
                                    </Frame>
                                    <Label Text="⭐ 10/10" FontSize="13" TextColor="#667085" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                            <Frame
                                Grid.Column="2"
                                WidthRequest="44"
                                HeightRequest="44"
                                CornerRadius="22"
                                Padding="0"
                                BackgroundColor="{StaticResource PrimaryGreen}"
                                HorizontalOptions="End"
                                VerticalOptions="Center">
                                <Label Text="▶" HorizontalOptions="Center" VerticalOptions="Center" TextColor="White" FontSize="18" />
                            </Frame>
                        </Grid>
                    </Frame>

                    <!-- Card 3 -->
                    <Frame Style="{StaticResource CardFrameStyle}">
                        <Grid ColumnDefinitions="88,*,Auto" ColumnSpacing="14">
                            <Image Source="dotnet_bot.png" WidthRequest="88" HeightRequest="88" Aspect="AspectFill" />
                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label Text="Bảo tàng Chứng tích Chiến..." FontSize="18" FontAttributes="Bold" TextColor="{StaticResource BodyText}" />
                                <Label Text="Bảo tàng về chiến tranh Việt Nam, thu hút hàng triệu du khách" FontSize="13" TextColor="#667085" />
                                <HorizontalStackLayout Spacing="8" Margin="0,6,0,0">
                                    <Frame Padding="10,4" CornerRadius="10" HasShadow="False" BackgroundColor="{StaticResource SoftRed}" BorderColor="Transparent">
                                        <Label Text="Lịch sử" FontSize="12" TextColor="#E53935" />
                                    </Frame>
                                    <Label Text="⭐ 9/10" FontSize="13" TextColor="#667085" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                            <Frame
                                Grid.Column="2"
                                WidthRequest="44"
                                HeightRequest="44"
                                CornerRadius="22"
                                Padding="0"
                                BackgroundColor="{StaticResource PrimaryGreen}"
                                HorizontalOptions="End"
                                VerticalOptions="Center">
                                <Label Text="▶" HorizontalOptions="Center" VerticalOptions="Center" TextColor="White" FontSize="18" />
                            </Frame>
                        </Grid>
                    </Frame>

                    <!-- Card 4 -->
                    <Frame Style="{StaticResource CardFrameStyle}">
                        <Grid ColumnDefinitions="88,*,Auto" ColumnSpacing="14">
                            <Image Source="dotnet_bot.png" WidthRequest="88" HeightRequest="88" Aspect="AspectFill" />
                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label Text="Chùa Thiên Mụ" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource BodyText}" />
                                <Label Text="Ngôi chùa nổi tiếng bên sông Hương, biểu tượng của Huế" FontSize="13" TextColor="#667085" />
                                <HorizontalStackLayout Spacing="8" Margin="0,6,0,0">
                                    <Frame Padding="10,4" CornerRadius="10" HasShadow="False" BackgroundColor="{StaticResource SoftOrange}" BorderColor="Transparent">
                                        <Label Text="Tâm linh" FontSize="12" TextColor="#D97706" />
                                    </Frame>
                                    <Label Text="⭐ 9/10" FontSize="13" TextColor="#667085" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                            <Frame
                                Grid.Column="2"
                                WidthRequest="44"
                                HeightRequest="44"
                                CornerRadius="22"
                                Padding="0"
                                BackgroundColor="{StaticResource PrimaryGreen}"
                                HorizontalOptions="End"
                                VerticalOptions="Center">
                                <Label Text="▶" HorizontalOptions="Center" VerticalOptions="Center" TextColor="White" FontSize="18" />
                            </Frame>
                        </Grid>
                    </Frame>
                </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </Grid>
</ContentPage>