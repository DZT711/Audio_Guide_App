<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiApp_Mobile.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:MauiApp_Mobile"
    xmlns:models="clr-namespace:MauiApp_Mobile.Models"
    x:DataType="local:MainPage"
    Shell.NavBarIsVisible="False"
    Padding="0"
    BackgroundColor="{DynamicResource LightBg}">

    <Grid RowDefinitions="Auto,*" RowSpacing="0">

        <Grid Style="{StaticResource TopHeaderGridStyle}"
              MinimumHeightRequest="122">
            <VerticalStackLayout Spacing="8" VerticalOptions="Center">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="12">
                    <Label x:Name="TitleLabel"
                           Text="Địa điểm"
                           Style="{StaticResource TopHeaderTitleStyle}" />

                    <Border x:Name="ConnectionStatusChip"
                            Grid.Column="1"
                            BackgroundColor="#E8F7EE"
                            Padding="10,6"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 14"
                            VerticalOptions="Center">
                        <HorizontalStackLayout Spacing="6">
                            <Label x:Name="ConnectionStatusDot"
                                   FontSize="12"
                                   Text="●"
                                   VerticalOptions="Center" />
                            <Label x:Name="ConnectionStatusLabel"
                                   FontAttributes="Bold"
                                   FontSize="12"
                                   Text="Online"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>
                </Grid>

                <Frame Style="{StaticResource TopHeaderSearchFrameStyle}">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <Label Text="🔍"
                               Style="{StaticResource TopHeaderSearchIconStyle}" />

                        <Entry x:Name="SearchEntry"
                               Grid.Column="1"
                               Placeholder="Tìm kiếm điểm..."
                               PlaceholderColor="{DynamicResource MutedText}"
                               BackgroundColor="Transparent"
                               TextColor="{DynamicResource BodyText}"
                               ClearButtonVisibility="WhileEditing"
                               Text="{Binding ViewModel.SearchText, Mode=TwoWay}" />
                    </Grid>
                </Frame>
            </VerticalStackLayout>
        </Grid>

        <Grid Grid.Row="1" Padding="16,8,16,12" RowDefinitions="Auto,Auto,*" RowSpacing="8">

            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="12"
                  Margin="0,0,0,6">
                <Border Padding="14,10"
                        BackgroundColor="{DynamicResource CardBg}"
                        Stroke="{DynamicResource BorderColor}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 16">
                    <VerticalStackLayout Spacing="2">
                        <Label x:Name="CountLabel"
                               Text="{Binding ViewModel.CountText}"
                               FontSize="17"
                               FontAttributes="Bold"
                               TextColor="{DynamicResource BodyText}" />
                        <Label x:Name="CountHintLabel"
                               Text="Danh sách đang hiển thị"
                               FontSize="12"
                               TextColor="{DynamicResource MutedText}" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="1"
                        Padding="14,10"
                        BackgroundColor="{DynamicResource CardBg}"
                        Stroke="{DynamicResource BorderColor}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 16">
                    <HorizontalStackLayout Spacing="8"
                                           VerticalOptions="Center">
                        <Label Text="⚙"
                               FontSize="16"
                               TextColor="{DynamicResource MutedText}"
                               VerticalOptions="Center" />
                        <Label x:Name="FilterLabel"
                               Text="{Binding ViewModel.FilterHeaderText}"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="{Binding ViewModel.FilterHeaderColor}"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnToggleFilterPopup" />
                    </Border.GestureRecognizers>
                </Border>
            </Grid>

            <VerticalStackLayout x:Name="EmptyStateLayout"
                                 Grid.Row="1"
                                 IsVisible="{Binding ViewModel.ShowEmptyState}"
                                 Spacing="8"
                                 Padding="0,8,0,8">
                <Label Text="🔎"
                       FontSize="34"
                       HorizontalOptions="Center" />
                <Label x:Name="EmptyTitleLabel"
                       Text="Không tìm thấy địa điểm"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="{DynamicResource BodyText}"
                       HorizontalTextAlignment="Center" />
                <Label x:Name="EmptySubtitleLabel"
                       Text="Thử nhập từ khóa khác"
                       FontSize="14"
                       TextColor="{DynamicResource MutedText}"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <Grid x:Name="PlacesLoadingOverlay"
                  Grid.RowSpan="3"
                  IsVisible="True"
                  Padding="0,4,0,0"
                  RowDefinitions="Auto,Auto,*"
                  RowSpacing="12"
                  ZIndex="8">
                <Border x:Name="PlacesCountSkeleton"
                        HeightRequest="18"
                        HorizontalOptions="Start"
                        Style="{StaticResource SkeletonBoneStyle}"
                        WidthRequest="110" />

                <VerticalStackLayout Grid.Row="1"
                                     Spacing="14">
                    <Border x:Name="PlacesCardSkeleton1"
                            HeightRequest="122"
                            Style="{StaticResource SkeletonBoneStyle}" />
                    <Border x:Name="PlacesCardSkeleton2"
                            HeightRequest="122"
                            Style="{StaticResource SkeletonBoneStyle}" />
                    <Border x:Name="PlacesCardSkeleton3"
                            HeightRequest="122"
                            Style="{StaticResource SkeletonBoneStyle}" />
                </VerticalStackLayout>
            </Grid>

            <RefreshView x:Name="PlacesRefreshView"
                         Grid.Row="2"
                         IsRefreshing="{Binding IsRefreshing, Mode=TwoWay}"
                         RefreshColor="{DynamicResource PrimaryGreen}"
                         Command="{Binding RefreshPlacesCommand}">
                <Grid RowDefinitions="Auto,*"
                      RowSpacing="0">
                    <Border x:Name="PullToRefreshHeader"
                            HeightRequest="0"
                            IsVisible="False"
                            BackgroundColor="#E8F7EE"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 14"
                            HorizontalOptions="Center"
                            Margin="0,0,0,8"
                            Padding="12,6">
                        <Label x:Name="PullToRefreshLabel"
                               Text="Kéo xuống để cập nhật"
                               FontSize="12"
                               TextColor="{DynamicResource PrimaryGreen}"
                               HorizontalTextAlignment="Center" />
                    </Border>

                    <CollectionView x:Name="PlacesCollectionView"
                                    Grid.Row="1"
                                    ItemsSource="{Binding ViewModel.Places}"
                                    IsVisible="False"
                                    Opacity="0"
                                    SelectionMode="None"
                                    VerticalOptions="FillAndExpand"
                                    ItemsLayout="VerticalList">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:PlaceItem">
                            <Frame Style="{StaticResource CardFrameStyle}">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type local:MainPage}}, Path=ViewModel.OpenPlaceCommand}"
                                                          CommandParameter="{Binding .}" />
                                </Frame.GestureRecognizers>
                                <Grid ColumnDefinitions="88,*,Auto" ColumnSpacing="14">
                                    <Image Source="{Binding Image, Converter={StaticResource PlaceImageSourceConverter}}"
                                           WidthRequest="88"
                                           HeightRequest="88"
                                           Aspect="AspectFill" />

                                    <VerticalStackLayout Grid.Column="1" Spacing="4">
                                        <Label Text="{Binding Name}"
                                               FontSize="18"
                                               FontAttributes="Bold"
                                               TextColor="{DynamicResource BodyText}" />

                                        <Label Text="{Binding Description}"
                                               FontSize="13"
                                               TextColor="#667085" />

                                        <HorizontalStackLayout Spacing="8" Margin="0,6,0,0">
                                            <Frame Padding="10,4"
                                                   CornerRadius="10"
                                                   HasShadow="False"
                                                   BackgroundColor="{Binding CategoryColor}"
                                                   BorderColor="Transparent">
                                                <Label Text="{Binding Category}"
                                                       FontSize="12"
                                                       TextColor="{Binding CategoryTextColor}" />
                                            </Frame>

                                            <Label Text="{Binding Rating, StringFormat='⭐ {0}'}"
                                                   FontSize="13"
                                                   TextColor="#667085"
                                                   VerticalOptions="Center" />
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>

                                    <Frame Grid.Column="2"
                                           WidthRequest="44"
                                           HeightRequest="44"
                                           CornerRadius="22"
                                           Padding="0"
                                           BackgroundColor="{DynamicResource PrimaryGreen}"
                                           HorizontalOptions="End"
                                           VerticalOptions="Center">
                                        <Grid>
                                            <ActivityIndicator IsVisible="{Binding IsAudioLoading}"
                                                               IsRunning="{Binding IsAudioLoading}"
                                                               Color="White"
                                                               WidthRequest="18"
                                                               HeightRequest="18"
                                                               HorizontalOptions="Center"
                                                               VerticalOptions="Center" />
                                            <Label Text="{Binding PlayIcon}"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"
                                                   TextColor="White"
                                                   FontSize="18">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label"
                                                                 Binding="{Binding IsAudioLoading}"
                                                                 Value="True">
                                                        <Setter Property="Opacity"
                                                                Value="0" />
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>
                                        </Grid>
                                        <Frame.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type local:MainPage}}, Path=ViewModel.PlayPlaceCommand}"
                                                                  CommandParameter="{Binding .}" />
                                        </Frame.GestureRecognizers>
                                    </Frame>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </RefreshView>

            <Border x:Name="FilterPopup"
                    Grid.RowSpan="3"
                    IsVisible="False"
                    Stroke="{DynamicResource BorderColor}"
                    StrokeThickness="1"
                    BackgroundColor="{DynamicResource PopupBg}"
                    StrokeShape="RoundRectangle 18"
                    HorizontalOptions="End"
                    VerticalOptions="Start"
                    Margin="0,38,0,0"
                    WidthRequest="270"
                    MaximumHeightRequest="520"
                    ZIndex="10">

                <ScrollView>
                    <VerticalStackLayout Spacing="0">
                        <HorizontalStackLayout Margin="18,16,18,10">
                            <Border Stroke="{DynamicResource BorderColor}"
                                    StrokeThickness="2"
                                    BackgroundColor="{DynamicResource CardBg}"
                                    StrokeShape="RoundRectangle 10"
                                    Padding="12,6">
                                <Label x:Name="FilterPopupTitleLabel"
                                       Text="DANH MỤC"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="{DynamicResource BodyText}" />
                            </Border>
                        </HorizontalStackLayout>

                        <VerticalStackLayout x:Name="FilterOptionsLayout"
                                             Spacing="0"
                                             BindableLayout.ItemsSource="{Binding CategoryFilters}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="models:CategoryFilterOption">
                                    <Grid Padding="0"
                                          ColumnDefinitions="4,Auto,*"
                                          ColumnSpacing="12"
                                          BackgroundColor="Transparent"
                                          MinimumHeightRequest="56">
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnCategoryFilterTapped" />
                                        </Grid.GestureRecognizers>

                                        <BoxView Grid.Column="0"
                                                 Color="{DynamicResource PrimaryGreen}"
                                                 IsVisible="{Binding IsSelected}" />

                                        <Label Grid.Column="1"
                                               Text="{Binding Icon}"
                                               FontSize="18"
                                               VerticalOptions="Center"
                                               HorizontalTextAlignment="Center"
                                               Margin="16,0,0,0" />

                                        <Label Grid.Column="2"
                                               Text="{Binding DisplayName}"
                                               FontSize="16"
                                               VerticalOptions="Center"
                                               TextColor="{DynamicResource BodyText}">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label"
                                                             Binding="{Binding IsSelected}"
                                                             Value="True">
                                                    <Setter Property="TextColor"
                                                            Value="{DynamicResource PrimaryGreen}" />
                                                    <Setter Property="FontAttributes"
                                                            Value="Bold" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>

                                        <Grid.Triggers>
                                            <DataTrigger TargetType="Grid"
                                                         Binding="{Binding IsSelected}"
                                                         Value="True">
                                                <Setter Property="BackgroundColor"
                                                        Value="{DynamicResource SoftGreen}" />
                                            </DataTrigger>
                                        </Grid.Triggers>
                                    </Grid>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1"
                                 Margin="18,10"
                                 Color="{DynamicResource DividerColor}" />

                        <HorizontalStackLayout Margin="18,0,18,10">
                            <Border Stroke="{DynamicResource BorderColor}"
                                    StrokeThickness="2"
                                    BackgroundColor="{DynamicResource CardBg}"
                                    StrokeShape="RoundRectangle 10"
                                    Padding="12,6">
                                <Label x:Name="VoiceFilterPopupTitleLabel"
                                       Text="GIỌNG ĐỌC"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="{DynamicResource BodyText}" />
                            </Border>
                        </HorizontalStackLayout>

                        <VerticalStackLayout x:Name="VoiceFilterOptionsLayout"
                                             Spacing="0"
                                             BindableLayout.ItemsSource="{Binding VoiceFilters}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="models:CategoryFilterOption">
                                    <Grid Padding="0"
                                          ColumnDefinitions="4,Auto,*"
                                          ColumnSpacing="12"
                                          BackgroundColor="Transparent"
                                          MinimumHeightRequest="56">
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnVoiceFilterTapped" />
                                        </Grid.GestureRecognizers>

                                        <BoxView Grid.Column="0"
                                                 Color="{DynamicResource PrimaryGreen}"
                                                 IsVisible="{Binding IsSelected}" />

                                        <Label Grid.Column="1"
                                               Text="{Binding Icon}"
                                               FontSize="18"
                                               VerticalOptions="Center"
                                               HorizontalTextAlignment="Center"
                                               Margin="16,0,0,0" />

                                        <Label Grid.Column="2"
                                               Text="{Binding DisplayName}"
                                               FontSize="16"
                                               VerticalOptions="Center"
                                               TextColor="{DynamicResource BodyText}">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label"
                                                             Binding="{Binding IsSelected}"
                                                             Value="True">
                                                    <Setter Property="TextColor"
                                                            Value="{DynamicResource PrimaryGreen}" />
                                                    <Setter Property="FontAttributes"
                                                            Value="Bold" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>

                                        <Grid.Triggers>
                                            <DataTrigger TargetType="Grid"
                                                         Binding="{Binding IsSelected}"
                                                         Value="True">
                                                <Setter Property="BackgroundColor"
                                                        Value="{DynamicResource SoftGreen}" />
                                            </DataTrigger>
                                        </Grid.Triggers>
                                    </Grid>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1"
                                 Margin="18,10"
                                 Color="{DynamicResource DividerColor}" />

                        <HorizontalStackLayout Margin="18,0,18,10">
                            <Border Stroke="{DynamicResource BorderColor}"
                                    StrokeThickness="2"
                                    BackgroundColor="{DynamicResource CardBg}"
                                    StrokeShape="RoundRectangle 10"
                                    Padding="12,6">
                                <Label x:Name="LanguageFilterPopupTitleLabel"
                                       Text="NGÔN NGỮ"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="{DynamicResource BodyText}" />
                            </Border>
                        </HorizontalStackLayout>

                        <VerticalStackLayout x:Name="LanguageFilterOptionsLayout"
                                             Spacing="0"
                                             BindableLayout.ItemsSource="{Binding LanguageFilters}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="models:CategoryFilterOption">
                                    <Grid Padding="0"
                                          ColumnDefinitions="4,Auto,*"
                                          ColumnSpacing="12"
                                          BackgroundColor="Transparent"
                                          MinimumHeightRequest="56">
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnLanguageFilterTapped" />
                                        </Grid.GestureRecognizers>

                                        <BoxView Grid.Column="0"
                                                 Color="{DynamicResource PrimaryGreen}"
                                                 IsVisible="{Binding IsSelected}" />

                                        <Label Grid.Column="1"
                                               Text="{Binding Icon}"
                                               FontSize="18"
                                               VerticalOptions="Center"
                                               HorizontalTextAlignment="Center"
                                               Margin="16,0,0,0" />

                                        <Label Grid.Column="2"
                                               Text="{Binding DisplayName}"
                                               FontSize="16"
                                               VerticalOptions="Center"
                                               TextColor="{DynamicResource BodyText}">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label"
                                                             Binding="{Binding IsSelected}"
                                                             Value="True">
                                                    <Setter Property="TextColor"
                                                            Value="{DynamicResource PrimaryGreen}" />
                                                    <Setter Property="FontAttributes"
                                                            Value="Bold" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>

                                        <Grid.Triggers>
                                            <DataTrigger TargetType="Grid"
                                                         Binding="{Binding IsSelected}"
                                                         Value="True">
                                                <Setter Property="BackgroundColor"
                                                        Value="{DynamicResource SoftGreen}" />
                                            </DataTrigger>
                                        </Grid.Triggers>
                                    </Grid>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </ScrollView>
            </Border>
        </Grid>

        <Grid Grid.RowSpan="2"
              IsVisible="{Binding IsPlaceDetailVisible}"
              BackgroundColor="{DynamicResource OverlayColor}"
              RowDefinitions="*,Auto"
              ZIndex="90">

            <Grid Grid.Row="0">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnPlaceDetailBackdropTapped" />
                </Grid.GestureRecognizers>
            </Grid>

            <Border x:Name="PlaceDetailSheet"
                    Grid.Row="1"
                    BackgroundColor="{DynamicResource BottomSheetBg}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 24,24,0,0"
                    Padding="0,0,0,10"
                    TranslationY="520">

                <Grid RowDefinitions="Auto,214,*">
                    <Grid Grid.Row="0"
                          Padding="0,10,0,8"
                          HorizontalOptions="Fill">
                        <Grid.GestureRecognizers>
                            <PanGestureRecognizer PanUpdated="OnPlaceDetailPanUpdated" />
                                                        <TapGestureRecognizer Tapped="OnPlaceDetailHandleTapped" />
                        </Grid.GestureRecognizers>
                        <Border WidthRequest="52"
                                HeightRequest="6"
                                BackgroundColor="{DynamicResource SheetHandleColor}"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 3"
                                HorizontalOptions="Center" />
                    </Grid>

                    <Grid Grid.Row="1"
                          Padding="12,0,12,10">
                        <Border BackgroundColor="#11283F"
                                Stroke="#12000000"
                                StrokeShape="RoundRectangle 28"
                                StrokeThickness="0">
                            <CarouselView x:Name="PlaceDetailCarousel"
                                          HorizontalOptions="Fill"
                                          IndicatorView="PlaceDetailIndicator"
                                          ItemsSource="{Binding SelectedPlaceGallery}"
                                          Loop="True"
                                          PeekAreaInsets="0"
                                          PositionChanged="OnPlaceDetailCarouselPositionChanged"
                                          VerticalOptions="Fill">
                                <CarouselView.ItemsLayout>
                                    <LinearItemsLayout ItemSpacing="0"
                                                       Orientation="Horizontal"
                                                       SnapPointsAlignment="Center"
                                                       SnapPointsType="MandatorySingle" />
                                </CarouselView.ItemsLayout>
                                <CarouselView.ItemTemplate>
                                    <DataTemplate x:DataType="models:PlaceGallerySlide">
                                        <Grid HorizontalOptions="Fill"
                                              VerticalOptions="Fill"
                                              WidthRequest="{Binding Source={x:Reference PlaceDetailCarousel}, Path=Width}">
                                            <Border BackgroundColor="#0F172A"
                                                    StrokeThickness="0" />

                                            <Image Source="{Binding Image, Converter={StaticResource PlaceImageSourceConverter}}"
                                                   Aspect="{OnPlatform Default=AspectFill, WinUI=AspectFit}"
                                                   Margin="18,14,18,14"
                                                   Opacity="1" />

                                            <Border StrokeThickness="0">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0"
                                                                         EndPoint="0,1">
                                                        <GradientStop Color="#22000000" Offset="0.0" />
                                                        <GradientStop Color="#40000000" Offset="0.45" />
                                                        <GradientStop Color="#C0102030" Offset="1.0" />
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>

                                            <Grid Padding="18"
                                                  RowDefinitions="Auto,*,Auto">
                                                <Grid ColumnDefinitions="*">
                                                    <HorizontalStackLayout Spacing="8">
                                                        <Border BackgroundColor="{Binding BadgeBackground}"
                                                                Padding="10,4"
                                                                StrokeThickness="0"
                                                                StrokeShape="RoundRectangle 12"
                                                                VerticalOptions="Start">
                                                            <Label Text="{Binding BadgeText}"
                                                                   FontAttributes="Bold"
                                                                   FontSize="11"
                                                                   TextColor="{Binding BadgeForeground}" />
                                                        </Border>

                                                        <Label Text="{Binding Eyebrow}"
                                                               FontAttributes="Bold"
                                                               FontSize="11"
                                                               TextColor="#F5FFFA"
                                                               VerticalOptions="Center" />
                                                    </HorizontalStackLayout>
                                                </Grid>

                                                <Grid Grid.Row="1">
                                                    <Border WidthRequest="120"
                                                            HeightRequest="120"
                                                            BackgroundColor="#16FFFFFF"
                                                            HorizontalOptions="End"
                                                            StrokeThickness="0"
                                                            StrokeShape="RoundRectangle 60"
                                                            TranslationX="32"
                                                            TranslationY="-8" />
                                                </Grid>

                                                <VerticalStackLayout Grid.Row="2"
                                                                     Spacing="6">
                                                    <Label Text="{Binding Title}"
                                                           FontSize="26"
                                                           FontAttributes="Bold"
                                                           LineBreakMode="TailTruncation"
                                                           MaxLines="2"
                                                           TextColor="White" />
                                                    <Label Text="{Binding Subtitle}"
                                                           FontSize="13"
                                                           LineBreakMode="TailTruncation"
                                                           MaxLines="3"
                                                           TextColor="#F8FAFC" />
                                                    <Label Text="{Binding FooterText}"
                                                           FontSize="12"
                                                           LineBreakMode="TailTruncation"
                                                           MaxLines="1"
                                                           TextColor="#FDE68A" />
                                                </VerticalStackLayout>
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </CarouselView.ItemTemplate>
                            </CarouselView>
                        </Border>

                        <Button Text="✕"
                                Clicked="OnClosePlaceDetail"
                                WidthRequest="38"
                                HeightRequest="38"
                                CornerRadius="19"
                                BackgroundColor="#88000000"
                                TextColor="White"
                                HorizontalOptions="End"
                                Margin="0,16,18,0"
                                VerticalOptions="Start" />

                        <IndicatorView x:Name="PlaceDetailIndicator"
                                       HorizontalOptions="Center"
                                       IndicatorColor="#6FFFFFFF"
                                       Margin="0,0,0,20"
                                       SelectedIndicatorColor="White"
                                       VerticalOptions="End" />
                    </Grid>

                    <ScrollView Grid.Row="2">
                        <VerticalStackLayout Padding="14,12" Spacing="12">
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                <Border BackgroundColor="#ECFDF3"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 12"
                                        Padding="10">
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="Bán kính kích hoạt" FontSize="12" TextColor="#64748B" />
                                        <Label Text="{Binding SelectedPlace.RadiusText}" FontSize="20" FontAttributes="Bold" TextColor="#0F172A" />
                                    </VerticalStackLayout>
                                </Border>

                                <Border Grid.Column="1"
                                        BackgroundColor="#EFF6FF"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 12"
                                        Padding="10">
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="Tọa độ GPS" FontSize="12" TextColor="#64748B" />
                                        <Label Text="{Binding SelectedPlace.GpsText}" FontSize="20" FontAttributes="Bold" TextColor="#0F172A" />
                                    </VerticalStackLayout>
                                </Border>
                            </Grid>

                            <Label Text="🔊 Audio mô tả"
                                   FontSize="22"
                                   FontAttributes="Bold"
                                   TextColor="#0F172A" />

                            <Label Text="{Binding SelectedPlace.AudioDescription}"
                                   FontSize="15"
                                   TextColor="#344054" />

                            <Border BackgroundColor="#F8FAFC"
                                    Stroke="#E5E7EB"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 14"
                                    Padding="12">
                                <VerticalStackLayout Spacing="6">
                                    <Label Text="{Binding SelectedPlace.Address, StringFormat='📍 {0}'}" FontSize="14" TextColor="#334155" />
                                    <Label Text="{Binding SelectedPlace.Phone, StringFormat='📞 {0}'}" FontSize="14" TextColor="#16A34A" />
                                    <Label Text="{Binding SelectedPlace.Email, StringFormat='✉ {0}'}" FontSize="14" TextColor="#16A34A" />
                                    <Label Text="{Binding SelectedPlace.Website, StringFormat='🌐 {0}'}" FontSize="14" TextColor="#16A34A" />
                                    <Label Text="{Binding SelectedPlace.EstablishedYear, StringFormat='📅 Thành lập năm {0}'}" FontSize="14" TextColor="#334155" />
                                </VerticalStackLayout>
                            </Border>

                            <Border BackgroundColor="{DynamicResource CardBg}"
                                    Stroke="{DynamicResource BorderColor}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 16"
                                    Padding="14">
                                <Grid ColumnDefinitions="Auto,*,Auto"
                                      ColumnSpacing="12">
                                    <Border WidthRequest="44"
                                            HeightRequest="44"
                                            BackgroundColor="#E8F7EE"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 22"
                                            VerticalOptions="Center">
                                        <Label Text="🗺"
                                               FontSize="18"
                                               HorizontalTextAlignment="Center"
                                               VerticalTextAlignment="Center" />
                                    </Border>

                                    <VerticalStackLayout Grid.Column="1"
                                                         Spacing="2"
                                                         VerticalOptions="Center">
                                        <Label Text="Xem trên bản đồ"
                                               FontSize="16"
                                               FontAttributes="Bold"
                                               TextColor="{DynamicResource BodyText}" />
                                        <Label Text="Mở vị trí POI trên bản đồ để xem chính xác điểm đến"
                                               FontSize="13"
                                               TextColor="{DynamicResource MutedText}" />
                                    </VerticalStackLayout>

                                    <Label Grid.Column="2"
                                           Text="›"
                                           FontSize="22"
                                           TextColor="{DynamicResource MutedText}"
                                           VerticalOptions="Center" />
                                </Grid>

                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnViewPlaceOnMapTapped" />
                                </Border.GestureRecognizers>
                            </Border>

                            <Label Text="Thông tin đồng bộ"
                                   FontSize="19"
                                   FontAttributes="Bold"
                                   TextColor="#0F172A" />

                            <VerticalStackLayout Spacing="8">
                                <Border BackgroundColor="White"
                                        Stroke="#E5E7EB"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 14"
                                        Padding="12">
                                    <VerticalStackLayout Spacing="6">
                                        <Label Text="{Binding SelectedPlace.OwnerName, StringFormat='👤 {0}'}" FontSize="14" TextColor="#334155" />
                                        <Label Text="{Binding SelectedPlace.StatusText, StringFormat='📌 {0}'}" FontSize="14" TextColor="#334155" />
                                        <Label Text="{Binding SelectedPlace.GpsTriggerText, StringFormat='🛰 {0}'}" FontSize="14" TextColor="#334155" />
                                        <Label Text="{Binding SelectedPlace.AudioCountText, StringFormat='🔊 {0}'}" FontSize="14" TextColor="#334155" />
                                    </VerticalStackLayout>
                                </Border>

                                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                    <Border BackgroundColor="#FFF7ED"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 12"
                                            Padding="10">
                                        <VerticalStackLayout Spacing="2">
                                            <Label Text="Standby Radius" FontSize="12" TextColor="#9A3412" />
                                            <Label Text="{Binding SelectedPlace.StandbyRadiusText}" FontSize="18" FontAttributes="Bold" TextColor="#7C2D12" />
                                        </VerticalStackLayout>
                                    </Border>

                                    <Border Grid.Column="1"
                                            BackgroundColor="#F5F3FF"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 12"
                                            Padding="10">
                                        <VerticalStackLayout Spacing="2">
                                            <Label Text="Cooldown" FontSize="12" TextColor="#6D28D9" />
                                            <Label Text="{Binding SelectedPlace.DebounceText}" FontSize="18" FontAttributes="Bold" TextColor="#5B21B6" />
                                        </VerticalStackLayout>
                                    </Border>
                                </Grid>
                            </VerticalStackLayout>

                            <Border BackgroundColor="{DynamicResource CardBg}"
                                    Stroke="{DynamicResource BorderColor}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 16"
                                    Padding="14">
                                <VerticalStackLayout Spacing="12">
                                    <Grid ColumnDefinitions="*,Auto"
                                          ColumnSpacing="10">
                                        <VerticalStackLayout Spacing="2">
                                            <Label Text="Danh sách audio"
                                                   FontSize="19"
                                                   FontAttributes="Bold"
                                                   TextColor="#0F172A" />
                                            <Label Text="{Binding AudioTrackSummaryText}"
                                                   FontSize="13"
                                                   TextColor="{DynamicResource MutedText}" />
                                        </VerticalStackLayout>

                                        <Border Grid.Column="1"
                                                BackgroundColor="{DynamicResource SurfaceAlt}"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 18"
                                                WidthRequest="36"
                                                HeightRequest="36"
                                                VerticalOptions="Center">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnToggleAudioListTapped" />
                                            </Border.GestureRecognizers>
                                            <Image Source="{Binding AudioListExpandIcon}"
                                                   WidthRequest="14"
                                                   HeightRequest="10"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center" />
                                        </Border>
                                    </Grid>

                                    <VerticalStackLayout IsVisible="{Binding IsAudioListExpanded}"
                                                         BindableLayout.ItemsSource="{Binding SelectedPlaceAudioTracks}"
                                                         Spacing="10">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate x:DataType="local:PlaceDetailAudioTrack">
                                                <Grid ColumnDefinitions="Auto,*,Auto,Auto"
                                                      ColumnSpacing="10">
                                                    <Border BackgroundColor="{DynamicResource SurfaceAlt}"
                                                            Stroke="{DynamicResource BorderColor}"
                                                            StrokeThickness="1"
                                                            StrokeShape="RoundRectangle 10"
                                                            Padding="8,4"
                                                            VerticalOptions="Center">
                                                        <Label Text="{Binding LanguageCode}"
                                                               FontSize="11"
                                                               FontAttributes="Bold"
                                                               TextColor="{DynamicResource BodyText}"
                                                               VerticalTextAlignment="Center" />
                                                    </Border>

                                                    <VerticalStackLayout Grid.Column="1"
                                                                         Spacing="5"
                                                                         VerticalOptions="Center">
                                                        <Label Text="{Binding Title}"
                                                               FontSize="14"
                                                               FontAttributes="Bold"
                                                               TextColor="{DynamicResource BodyText}"
                                                               LineBreakMode="TailTruncation" />
                                                        <Label Text="{Binding MetaText}"
                                                               FontSize="12"
                                                               TextColor="{DynamicResource MutedText}" />

                                                        <Border IsVisible="{Binding IsDownloadStatusVisible}"
                                                                BackgroundColor="{Binding DownloadStatusBackgroundColor}"
                                                                StrokeThickness="0"
                                                                StrokeShape="RoundRectangle 10"
                                                                Padding="8,4"
                                                                HorizontalOptions="Start">
                                                            <HorizontalStackLayout Spacing="6">
                                                                <Label Text="{Binding DownloadStatusIcon}"
                                                                       FontSize="12"
                                                                       FontAttributes="Bold"
                                                                       TextColor="{Binding DownloadStatusTextColor}"
                                                                       VerticalTextAlignment="Center" />
                                                                <Label Text="{Binding DownloadStatusText}"
                                                                       FontSize="11"
                                                                       FontAttributes="Bold"
                                                                       TextColor="{Binding DownloadStatusTextColor}"
                                                                       VerticalTextAlignment="Center" />
                                                            </HorizontalStackLayout>
                                                        </Border>

                                                        <Label Text="{Binding DownloadDetailText}"
                                                               FontSize="11"
                                                               TextColor="{Binding DownloadStatusTextColor}"
                                                               IsVisible="{Binding HasDownloadDetail}"
                                                               LineBreakMode="WordWrap" />

                                                        <ProgressBar Progress="{Binding DownloadProgress}"
                                                                     IsVisible="{Binding IsDownloadProgressVisible}"
                                                                     HeightRequest="6"
                                                                     BackgroundColor="{DynamicResource DividerColor}"
                                                                     ProgressColor="{DynamicResource PrimaryGreen}" />
                                                    </VerticalStackLayout>

                                                    <Border Grid.Column="2"
                                                            BackgroundColor="{Binding DownloadButtonBackgroundColor}"
                                                            Stroke="{Binding DownloadButtonStrokeColor}"
                                                            StrokeThickness="1"
                                                            StrokeShape="RoundRectangle 18"
                                                            InputTransparent="{Binding IsDownloadDisabled}"
                                                            Opacity="{Binding DownloadButtonOpacity}"
                                                            WidthRequest="36"
                                                            HeightRequest="36"
                                                            VerticalOptions="Center">
                                                        <Border.GestureRecognizers>
                                                            <TapGestureRecognizer Tapped="OnAudioTrackDownloadTapped" />
                                                        </Border.GestureRecognizers>
                                                        <Label Text="{Binding DownloadButtonGlyph}"
                                                               FontAttributes="Bold"
                                                               FontSize="14"
                                                               HorizontalOptions="Center"
                                                               VerticalOptions="Center" />
                                                    </Border>

                                                    <Border Grid.Column="3"
                                                            BackgroundColor="{DynamicResource PrimaryGreen}"
                                                            StrokeThickness="0"
                                                            StrokeShape="RoundRectangle 18"
                                                            WidthRequest="36"
                                                            HeightRequest="36"
                                                            VerticalOptions="Center">
                                                        <Border.GestureRecognizers>
                                                            <TapGestureRecognizer Tapped="OnAudioTrackPlayTapped" />
                                                        </Border.GestureRecognizers>
                                                        <Grid>
                                                            <ActivityIndicator IsVisible="{Binding IsLoading}"
                                                                               IsRunning="{Binding IsLoading}"
                                                                               Color="White"
                                                                               WidthRequest="16"
                                                                               HeightRequest="16"
                                                                               HorizontalOptions="Center"
                                                                               VerticalOptions="Center" />
                                                            <Label Text="{Binding PlayIcon}"
                                                                   TextColor="White"
                                                                   FontSize="14"
                                                                   HorizontalTextAlignment="Center"
                                                                   VerticalTextAlignment="Center">
                                                                <Label.Triggers>
                                                                    <DataTrigger TargetType="Label"
                                                                                 Binding="{Binding IsLoading}"
                                                                                 Value="True">
                                                                        <Setter Property="Opacity"
                                                                                Value="0" />
                                                                    </DataTrigger>
                                                                </Label.Triggers>
                                                            </Label>
                                                        </Grid>
                                                    </Border>
                                                </Grid>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                            </Border>
                        </VerticalStackLayout>
                    </ScrollView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
