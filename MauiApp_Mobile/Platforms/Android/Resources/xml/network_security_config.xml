<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
  <base-config cleartextTrafficPermitted="true" />

  <!-- Android network security config does not support CIDR/IP ranges.
       Allow the concrete debug hosts used by the app and local development. -->
  <domain-config cleartextTrafficPermitted="true">
    <domain includeSubdomains="false">10.0.2.2</domain>
    <domain includeSubdomains="false">127.0.0.1</domain>
    <domain includeSubdomains="false">localhost</domain>
    <!-- AUTO_LOCAL_IPV4_START -->
    <domain includeSubdomains="false">10.45.61.250</domain>
    <!-- AUTO_LOCAL_IPV4_END -->
  </domain-config>
</network-security-config>





