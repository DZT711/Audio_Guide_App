<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
  <base-config cleartextTrafficPermitted="true" />

  <!-- Android network security config does not support CIDR/IP ranges.
       Allow the concrete debug hosts used by the app and local development. -->
  <domain-config cleartextTrafficPermitted="true">
    <domain includeSubdomains="false">192.168.208.250</domain>
    <!-- <domain includeSubdomains="false">10.0.2.2</domain> -->
    <domain includeSubdomains="false">127.0.0.1</domain>
    <domain includeSubdomains="false">localhost</domain>
    <domain includeSubdomains="false">192.168.1.3</domain>
    <!-- <domain includeSubdomains="false">10.20.126.28</domain>
    <domain includeSubdomains="false">172.20.10.10</domain> -->
  </domain-config>
</network-security-config>
