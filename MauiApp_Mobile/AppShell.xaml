<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="MauiApp_Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:MauiApp_Mobile"
    xmlns:views="clr-namespace:MauiApp_Mobile.Views"
    FlyoutBehavior="Disabled"
    Shell.NavBarIsVisible="False"
    Shell.TabBarBackgroundColor="White"
    Shell.TabBarTitleColor="#98A2B3"
    Shell.TabBarUnselectedColor="#98A2B3"
    Shell.TabBarForegroundColor="#18A94B">

    <ShellContent
        Title="Ngôn ngữ"
        Route="language"
        ContentTemplate="{DataTemplate views:LanguagePage}" />

    <TabBar Route="mainTabs">
        <ShellContent
            Title="Địa điểm"
            Route="places"
            Icon="dotnet_bot.png"
            ContentTemplate="{DataTemplate local:MainPage}" />

        <ShellContent
            Title="Bản đồ"
            Route="map"
            Icon="dotnet_bot.png"
            ContentTemplate="{DataTemplate views:MapPage}" />

        <ShellContent
            Title="Lịch sử"
            Route="history"
            Icon="dotnet_bot.png"
            ContentTemplate="{DataTemplate views:HistoryPage}" />

        <ShellContent
            Title="Cài đặt"
            Route="settings"
            Icon="dotnet_bot.png"
            ContentTemplate="{DataTemplate views:SettingsPage}" />
    </TabBar>
</Shell>