<?xml version="1.0" encoding="utf-8" ?>
<Application
    x:Class="MauiApp_Mobile.App"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="PrimaryGreen">#18A94B</Color>
            <Color x:Key="PrimaryGreenDark">#148F40</Color>
            <Color x:Key="LightBg">#F3F4F6</Color>
            <Color x:Key="CardBg">#FFFFFF</Color>
            <Color x:Key="MutedText">#8A94A6</Color>
            <Color x:Key="BodyText">#1E3250</Color>
            <Color x:Key="BorderColor">#E5E7EB</Color>
            <Color x:Key="SoftGreen">#E8F7EE</Color>
            <Color x:Key="SoftPurple">#F2E8FF</Color>
            <Color x:Key="SoftOrange">#FFE8D8</Color>
            <Color x:Key="SoftRed">#FFE3E3</Color>

            <Style x:Key="PageTitleStyle" TargetType="Label">
                <Setter Property="FontSize" Value="26" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="White" />
            </Style>

            <Style x:Key="SectionTitleStyle" TargetType="Label">
                <Setter Property="FontSize" Value="18" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{StaticResource BodyText}" />
            </Style>

            <Style x:Key="BodyStyle" TargetType="Label">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="TextColor" Value="{StaticResource BodyText}" />
            </Style>

            <Style x:Key="MutedStyle" TargetType="Label">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="TextColor" Value="{StaticResource MutedText}" />
            </Style>

            <Style x:Key="CardFrameStyle" TargetType="Frame">
                <Setter Property="BackgroundColor" Value="{StaticResource CardBg}" />
                <Setter Property="BorderColor" Value="{StaticResource BorderColor}" />
                <Setter Property="CornerRadius" Value="22" />
                <Setter Property="Padding" Value="16" />
                <Setter Property="HasShadow" Value="True" />
                <Setter Property="Margin" Value="0,0,0,14" />
            </Style>

            <Style x:Key="PrimaryButtonStyle" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource PrimaryGreen}" />
                <Setter Property="TextColor" Value="White" />
                <Setter Property="CornerRadius" Value="18" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="FontSize" Value="18" />
                <Setter Property="HeightRequest" Value="64" />
            </Style>

            <Style x:Key="TopHeaderGridStyle" TargetType="Grid">
                <Setter Property="BackgroundColor" Value="{StaticResource PrimaryGreen}" />
                <Setter Property="Padding" Value="18,12,18,10" />
                <Setter Property="MinimumHeightRequest" Value="118" />
            </Style>

            <Style x:Key="TopHeaderTitleStyle"
                   TargetType="Label"
                   BasedOn="{StaticResource PageTitleStyle}">
                <Setter Property="FontSize" Value="22" />
                <Setter Property="VerticalOptions" Value="Center" />
            </Style>

            <Style x:Key="TopHeaderSubtitleStyle" TargetType="Label">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="TextColor" Value="#DDF7E7" />
            </Style>

            <Style x:Key="TopHeaderSearchFrameStyle" TargetType="Frame">
                <Setter Property="BackgroundColor" Value="White" />
                <Setter Property="BorderColor" Value="Transparent" />
                <Setter Property="CornerRadius" Value="16" />
                <Setter Property="HasShadow" Value="False" />
                <Setter Property="Padding" Value="14,8" />
            </Style>

            <Style x:Key="TopHeaderSearchIconStyle" TargetType="Label">
                <Setter Property="FontSize" Value="20" />
                <Setter Property="TextColor" Value="{StaticResource MutedText}" />
                <Setter Property="VerticalOptions" Value="Center" />
            </Style>

            <Style x:Key="TopHeaderActionFrameStyle" TargetType="Frame">
                <Setter Property="WidthRequest" Value="42" />
                <Setter Property="HeightRequest" Value="42" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="HasShadow" Value="False" />
                <Setter Property="BackgroundColor" Value="#45C26F" />
                <Setter Property="VerticalOptions" Value="Center" />
            </Style>

            <Style x:Key="TopHeaderActionButtonStyle" TargetType="Button">
                <Setter Property="BackgroundColor" Value="#46C768" />
                <Setter Property="TextColor" Value="White" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="CornerRadius" Value="16" />
                <Setter Property="Padding" Value="12,6" />
                <Setter Property="HeightRequest" Value="34" />
                <Setter Property="VerticalOptions" Value="Center" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
