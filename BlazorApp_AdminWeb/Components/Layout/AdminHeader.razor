<header class="p-3 mb-3 border-bottom bg-white">
    <div class="container-fluid">
        <div class="d-flex align-items-center justify-content-between">
            
            <div class="d-flex align-items-center text-dark text-decoration-none">
                 <nav aria-label="breadcrumb">
                  <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="#">Admin</a></li>
                    <li class="breadcrumb-item active" aria-current="page">@PageTitle</li>
                  </ol>
                </nav>
            </div>

            <div class="d-flex align-items-center" style="gap: 12px;">
                <span class="fw-bold text-dark d-none d-md-block">Phố ẩm thực Vĩnh Khánh</span>
                <button type="button" class="btn btn-outline-secondary btn-sm">Đăng xuất</button>
                <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-bold" 
                     style="width: 36px; height: 36px; background-color: #3B82F6;">
                    A
                </div>
            </div>
        </div>
    </div>
</header>

@code {
    [Parameter]
    public string PageTitle { get; set; } = "Dashboard";
}