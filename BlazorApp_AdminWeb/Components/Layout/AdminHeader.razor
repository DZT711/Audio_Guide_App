@implements IDisposable
@inject NavigationManager Navigation
@inject AdminAuthService AuthService
@inject NotificationService Notifications

<header class="admin-header">
    <div class="admin-header__leading">
        <button class="btn admin-header__menu d-lg-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#admin-sidebar-drawer" aria-controls="admin-sidebar-drawer">
            <i class="bi bi-list"></i>
        </button>

        <div>
            <span class="admin-header__eyebrow">Smart Tourism Admin</span>
            <h1>@GetPageTitle()</h1>
        </div>
    </div>

    <div class="admin-header__actions">
        <span class="admin-header__context d-none d-md-inline-flex">
            <i class="bi bi-lightning-charge-fill"></i>
            Static admin session
        </span>

        <button type="button" class="btn btn-outline-secondary admin-header__logout" @onclick="LogoutAsync">
            <i class="bi bi-box-arrow-right me-2"></i>
            Logout
        </button>

        <div class="admin-header__avatar">A</div>
    </div>
</header>

@code {
    protected override void OnInitialized()
    {
        Navigation.LocationChanged += HandleLocationChanged;
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
        => InvokeAsync(StateHasChanged);

    private async Task LogoutAsync()
    {
        await AuthService.LogoutAsync();
        Notifications.Info("You have been signed out.", "Logout");
        Navigation.NavigateTo("/");
    }

    private string GetPageTitle()
    {
        var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri).Split('?', '#')[0].Trim('/').ToLowerInvariant();

        return relativePath switch
        {
            "" => "Login",
            "dashboard" => "Dashboard",
            "poi" => "Location Management",
            "categories" => "Category Management",
            "audio" => "Audio & Voice Management",
            "users" => "User Management",
            "moderation" => "Moderation Queue",
            _ => "Admin"
        };
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= HandleLocationChanged;
    }
}
