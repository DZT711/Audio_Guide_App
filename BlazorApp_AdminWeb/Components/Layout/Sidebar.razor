@inject AdminSessionState SessionState
@using Project_SharedClassLibrary.Security

<nav class="@GetSidebarClass()">
    <a href="/dashboard" class="sidebar-brand" aria-label="Dashboard home">
        <span class="sidebar-brand__icon">
            <i class="bi bi-compass-fill"></i>
        </span>
        <span class="sidebar-brand__copy">
            <strong>Smart Tourism</strong>
            <small>Admin Console</small>
        </span>
    </a>

    <div class="sidebar-group">
        <span class="sidebar-group__label">Overview</span>
        @if (SessionState.HasPermission(AdminPermissions.DashboardView))
        {
            <NavLink class="sidebar-link" href="/dashboard" Match="NavLinkMatch.All" title="Dashboard" aria-label="Dashboard" @attributes="GetDismissAttributes()">
                <i class="bi bi-grid-1x2-fill"></i>
                <span class="sidebar-link__text">Dashboard</span>
            </NavLink>
        }
        @if (SessionState.HasPermission(AdminPermissions.AnalyticsView))
        {
            <NavLink class="sidebar-link" href="/statistics" title="Statistics" aria-label="Statistics" @attributes="GetDismissAttributes()">
                <i class="bi bi-graph-up-arrow"></i>
                <span class="sidebar-link__text">Statistics</span>
            </NavLink>
        }
        @if (SessionState.HasPermission(AdminPermissions.UsageHistoryView))
        {
            <NavLink class="sidebar-link" href="/usage" title="Usage History" aria-label="Usage History" @attributes="GetDismissAttributes()">
                <i class="bi bi-clock-history"></i>
                <span class="sidebar-link__text">Usage History</span>
            </NavLink>
        }
        @if (SessionState.HasPermission(AdminPermissions.InboxView))
        {
            <NavLink class="sidebar-link" href="/inbox" title="Inbox" aria-label="Inbox" @attributes="GetDismissAttributes()">
                <i class="bi bi-inbox-fill"></i>
                <span class="sidebar-link__text">Inbox</span>
            </NavLink>
        }
    </div>

    <div class="sidebar-group">
        <span class="sidebar-group__label">Management</span>
        @if (SessionState.HasPermission(AdminPermissions.LocationRead))
        {
            <NavLink class="sidebar-link" href="/poi" title="Locations" aria-label="Locations" @attributes="GetDismissAttributes()">
                <i class="bi bi-geo-alt-fill"></i>
                <span class="sidebar-link__text">Locations</span>
            </NavLink>
        }
        @if (SessionState.HasPermission(AdminPermissions.TourRead))
        {
            <NavLink class="sidebar-link" href="/tours" title="Tour Management" aria-label="Tour Management" @attributes="GetDismissAttributes()">
                <i class="bi bi-signpost-split-fill"></i>
                <span class="sidebar-link__text">Tour Management</span>
            </NavLink>
        }
        @if (SessionState.HasPermission(AdminPermissions.CategoryRead))
        {
            <NavLink class="sidebar-link" href="/categories" title="Categories" aria-label="Categories" @attributes="GetDismissAttributes()">
                <i class="bi bi-diagram-3-fill"></i>
                <span class="sidebar-link__text">Categories</span>
            </NavLink>
        }
        @if (SessionState.HasPermission(AdminPermissions.LanguageRead))
        {
            <NavLink class="sidebar-link" href="/languages" title="Languages" aria-label="Languages" @attributes="GetDismissAttributes()">
                <i class="bi bi-translate"></i>
                <span class="sidebar-link__text">Languages</span>
            </NavLink>
        }
        @if (SessionState.HasPermission(AdminPermissions.AudioRead))
        {
            <NavLink class="sidebar-link" href="/audio" title="Audio & Voice" aria-label="Audio & Voice" @attributes="GetDismissAttributes()">
                <i class="bi bi-mic-fill"></i>
                <span class="sidebar-link__text">Audio &amp; Voice</span>
            </NavLink>
        }
    </div>

    @if (CanViewAdminSection)
    {
        <div class="sidebar-group">
            <span class="sidebar-group__label">Admin Section</span>
            @if (SessionState.HasPermission(AdminPermissions.UserRead))
            {
                <NavLink class="sidebar-link" href="/users" title="Users" aria-label="Users" @attributes="GetDismissAttributes()">
                    <i class="bi bi-people-fill"></i>
                    <span class="sidebar-link__text">Users</span>
                </NavLink>
            }
            @if (SessionState.HasPermission(AdminPermissions.ModerationView))
            {
                <NavLink class="sidebar-link" href="/moderation" title="Moderation" aria-label="Moderation" @attributes="GetDismissAttributes()">
                    <i class="bi bi-shield-check"></i>
                    <span class="sidebar-link__text">Moderation</span>
                </NavLink>
            }
        </div>
    }

    <div class="sidebar-profile">
        <div class="sidebar-profile__avatar">@GetAvatarInitial()</div>
        <div class="sidebar-profile__copy">
            <strong>@SessionState.DisplayName</strong>
            <small>@GetProfileMeta()</small>
        </div>
    </div>
</nav>

@code {
    [Parameter]
    public bool DismissOnNavigate { get; set; }

    [Parameter]
    public bool Collapsed { get; set; }

    private string GetSidebarClass() => Collapsed
        ? "sidebar-nav sidebar-nav--collapsed"
        : "sidebar-nav";

    private IReadOnlyDictionary<string, object>? GetDismissAttributes()
        => DismissOnNavigate
            ? new Dictionary<string, object> { ["data-bs-dismiss"] = "offcanvas" }
            : null;

    private string GetAvatarInitial()
    {
        var value = SessionState.DisplayName;
        return string.IsNullOrWhiteSpace(value) ? "A" : value[..1].ToUpperInvariant();
    }

    private string GetProfileMeta() =>
        string.IsNullOrWhiteSpace(SessionState.Role)
            ? "Admin session"
            : $"{SessionState.Role} · {SessionState.StatusLabel}";

    private bool CanViewAdminSection =>
        SessionState.HasPermission(AdminPermissions.UserRead)
        || SessionState.HasPermission(AdminPermissions.ModerationView);
}
