<nav class="sidebar-nav">
    <a href="/dashboard" class="sidebar-brand">
        <span class="sidebar-brand__icon">
            <i class="bi bi-compass-fill"></i>
        </span>
        <span>
            <strong>Smart Tourism</strong>
            <small>Admin Console</small>
        </span>
    </a>

    <div class="sidebar-group">
        <span class="sidebar-group__label">Overview</span>
        <NavLink class="sidebar-link" href="/dashboard" Match="NavLinkMatch.All" @attributes="GetDismissAttributes()">
            <i class="bi bi-grid-1x2-fill"></i>
            <span>Dashboard</span>
        </NavLink>
    </div>

    <div class="sidebar-group">
        <span class="sidebar-group__label">Management</span>
        <NavLink class="sidebar-link" href="/poi" @attributes="GetDismissAttributes()">
            <i class="bi bi-geo-alt-fill"></i>
            <span>Locations</span>
        </NavLink>
        <NavLink class="sidebar-link" href="/categories" @attributes="GetDismissAttributes()">
            <i class="bi bi-diagram-3-fill"></i>
            <span>Categories</span>
        </NavLink>
        <NavLink class="sidebar-link" href="/audio" @attributes="GetDismissAttributes()">
            <i class="bi bi-mic-fill"></i>
            <span>Audio &amp; Voice</span>
        </NavLink>
        <NavLink class="sidebar-link" href="/users" @attributes="GetDismissAttributes()">
            <i class="bi bi-people-fill"></i>
            <span>Users</span>
        </NavLink>
        <NavLink class="sidebar-link" href="/moderation" @attributes="GetDismissAttributes()">
            <i class="bi bi-shield-check"></i>
            <span>Moderation</span>
        </NavLink>
    </div>

    <div class="sidebar-profile">
        <div class="sidebar-profile__avatar">A</div>
        <div>
            <strong>admin</strong>
            <small>Static administrator</small>
        </div>
    </div>
</nav>

@code {
    [Parameter]
    public bool DismissOnNavigate { get; set; }

    private IReadOnlyDictionary<string, object>? GetDismissAttributes()
        => DismissOnNavigate
            ? new Dictionary<string, object> { ["data-bs-dismiss"] = "offcanvas" }
            : null;
}
