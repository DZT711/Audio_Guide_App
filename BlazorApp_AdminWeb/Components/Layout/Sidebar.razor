@implements IAsyncDisposable
@inject AdminSessionState SessionState
@inject AdminUiLanguageService Language
@inject InboxState InboxState
@inject ModerationState ModerationState
@using Project_SharedClassLibrary.Security

<nav class="@GetSidebarClass()">
    <a href="/dashboard" class="sidebar-brand" aria-label="Dashboard home">
        <span class="sidebar-brand__icon">
            <i class="bi bi-compass-fill"></i>
        </span>
        <span class="sidebar-brand__copy">
            <strong>Smart Tourism</strong>
            <small>@Language.T("header.brand", "Admin Console")</small>
        </span>
    </a>

    <div class="sidebar-group">
        <span class="sidebar-group__label">@Language.T("sidebar.overview", "Overview")</span>
        @if (SessionState.HasPermission(AdminPermissions.DashboardView))
        {
            <NavLink class="sidebar-link" href="/dashboard" Match="NavLinkMatch.All" title="@(Language.T("sidebar.dashboard", "Dashboard"))" aria-label="@(Language.T("sidebar.dashboard", "Dashboard"))" @attributes="GetDismissAttributes()">
                <i class="bi bi-grid-1x2-fill"></i>
                <span class="sidebar-link__text">@Language.T("sidebar.dashboard", "Dashboard")</span>
            </NavLink>
        }
        @if (SessionState.HasPermission(AdminPermissions.AnalyticsView))
        {
            <NavLink class="sidebar-link" href="/statistics" title="@(Language.T("sidebar.statistics", "Statistics"))" aria-label="@(Language.T("sidebar.statistics", "Statistics"))" @attributes="GetDismissAttributes()">
                <i class="bi bi-graph-up-arrow"></i>
                <span class="sidebar-link__text">@Language.T("sidebar.statistics", "Statistics")</span>
            </NavLink>
        }
        @if (SessionState.HasPermission(AdminPermissions.UsageHistoryView))
        {
            <NavLink class="sidebar-link" href="/usage" title="@(Language.T("sidebar.usage", "Usage History"))" aria-label="@(Language.T("sidebar.usage", "Usage History"))" @attributes="GetDismissAttributes()">
                <i class="bi bi-clock-history"></i>
                <span class="sidebar-link__text">@Language.T("sidebar.usage", "Usage History")</span>
            </NavLink>
        }
        @if (SessionState.HasPermission(AdminPermissions.InboxView))
        {
            <NavLink class="sidebar-link" href="/inbox" title="@(Language.T("sidebar.inbox", "Inbox"))" aria-label="@(Language.T("sidebar.inbox", "Inbox"))" @attributes="GetDismissAttributes()">
                <i class="bi bi-inbox-fill"></i>
                <span class="sidebar-link__text">@Language.T("sidebar.inbox", "Inbox")</span>
                @if (InboxState.UnreadCount > 0)
                {
                    <span class="sidebar-link__badge">@GetInboxBadgeLabel()</span>
                }
            </NavLink>
        }
    </div>

    <div class="sidebar-group">
        <span class="sidebar-group__label">@Language.T("sidebar.management", "Management")</span>
        @if (SessionState.HasPermission(AdminPermissions.LocationRead))
        {
            <NavLink class="sidebar-link" href="/poi" title="@(Language.T("sidebar.locations", "Locations"))" aria-label="@(Language.T("sidebar.locations", "Locations"))" @attributes="GetDismissAttributes()">
                <i class="bi bi-geo-alt-fill"></i>
                <span class="sidebar-link__text">@Language.T("sidebar.locations", "Locations")</span>
            </NavLink>
        }
        @if (SessionState.HasPermission(AdminPermissions.TourRead))
        {
            <NavLink class="sidebar-link" href="/tours" title="@(Language.T("sidebar.tours", "Tour Management"))" aria-label="@(Language.T("sidebar.tours", "Tour Management"))" @attributes="GetDismissAttributes()">
                <i class="bi bi-signpost-split-fill"></i>
                <span class="sidebar-link__text">@Language.T("sidebar.tours", "Tour Management")</span>
            </NavLink>
        }
        @if (SessionState.HasPermission(AdminPermissions.CategoryRead))
        {
            <NavLink class="sidebar-link" href="/categories" title="@(Language.T("sidebar.categories", "Categories"))" aria-label="@(Language.T("sidebar.categories", "Categories"))" @attributes="GetDismissAttributes()">
                <i class="bi bi-diagram-3-fill"></i>
                <span class="sidebar-link__text">@Language.T("sidebar.categories", "Categories")</span>
            </NavLink>
        }
        @if (SessionState.HasPermission(AdminPermissions.LanguageRead))
        {
            <NavLink class="sidebar-link" href="/languages" title="@(Language.T("sidebar.languages", "Languages"))" aria-label="@(Language.T("sidebar.languages", "Languages"))" @attributes="GetDismissAttributes()">
                <i class="bi bi-translate"></i>
                <span class="sidebar-link__text">@Language.T("sidebar.languages", "Languages")</span>
            </NavLink>
        }
        @if (SessionState.HasPermission(AdminPermissions.AudioRead))
        {
            <NavLink class="sidebar-link" href="/audio" title="@(Language.T("sidebar.audio", "Audio & Voice"))" aria-label="@(Language.T("sidebar.audio", "Audio & Voice"))" @attributes="GetDismissAttributes()">
                <i class="bi bi-mic-fill"></i>
                <span class="sidebar-link__text">@Language.T("sidebar.audio", "Audio & Voice")</span>
            </NavLink>
        }
    </div>

    @if (CanViewAdminSection)
    {
        <div class="sidebar-group">
            <span class="sidebar-group__label">@Language.T("sidebar.admin", "Admin Section")</span>
            @if (SessionState.HasPermission(AdminPermissions.UserRead))
            {
                <NavLink class="sidebar-link" href="/users" title="@(Language.T("sidebar.users", "Users"))" aria-label="@(Language.T("sidebar.users", "Users"))" @attributes="GetDismissAttributes()">
                    <i class="bi bi-people-fill"></i>
                    <span class="sidebar-link__text">@Language.T("sidebar.users", "Users")</span>
                </NavLink>
            }
            @if (SessionState.HasPermission(AdminPermissions.ModerationView))
            {
                <NavLink class="sidebar-link" href="/moderation" title="@(Language.T("sidebar.moderation", "Moderation"))" aria-label="@(Language.T("sidebar.moderation", "Moderation"))" @attributes="GetDismissAttributes()">
                    <i class="bi bi-shield-check"></i>
                    <span class="sidebar-link__text">@Language.T("sidebar.moderation", "Moderation")</span>
                    @if (ModerationState.PendingCount > 0)
                    {
                        <span class="sidebar-link__badge">@GetModerationBadgeLabel()</span>
                    }
                </NavLink>
            }
            @if (SessionState.HasPermission(AdminPermissions.ActivityLogView))
            {
                <NavLink class="sidebar-link" href="/history" title="@(Language.T("sidebar.activity", "Activity History"))" aria-label="@(Language.T("sidebar.activity", "Activity History"))" @attributes="GetDismissAttributes()">
                    <i class="bi bi-clock-history"></i>
                    <span class="sidebar-link__text">@Language.T("sidebar.activity", "Activity History")</span>
                </NavLink>
            }
        </div>
    }

    <div class="sidebar-profile">
        <div class="sidebar-profile__avatar">@GetAvatarInitial()</div>
        <div class="sidebar-profile__copy">
            <strong>@SessionState.DisplayName</strong>
            <small>@GetProfileMeta()</small>
        </div>
    </div>
</nav>

@code {
    private CancellationTokenSource? _sidebarPollingCancellationSource;
    private Task? _sidebarPollingTask;

    [Parameter]
    public bool DismissOnNavigate { get; set; }

    [Parameter]
    public bool Collapsed { get; set; }

    protected override async Task OnInitializedAsync()
    {
        SessionState.Changed += HandleSessionChanged;
        InboxState.Changed += HandleInboxStateChanged;
        ModerationState.Changed += HandleModerationStateChanged;
        Language.Changed += HandleLanguageChanged;

        if (SessionState.HasPermission(AdminPermissions.InboxView)
            || SessionState.HasPermission(AdminPermissions.ModerationView))
        {
            await RefreshSidebarCountsAsync();
            StartSidebarPolling();
        }
    }

    private string GetSidebarClass() => Collapsed
        ? "sidebar-nav sidebar-nav--collapsed"
        : "sidebar-nav";

    private IReadOnlyDictionary<string, object>? GetDismissAttributes()
        => DismissOnNavigate
            ? new Dictionary<string, object> { ["data-bs-dismiss"] = "offcanvas" }
            : null;

    private string GetAvatarInitial()
    {
        var value = SessionState.DisplayName;
        return string.IsNullOrWhiteSpace(value) ? "A" : value[..1].ToUpperInvariant();
    }

    private string GetProfileMeta() =>
        string.IsNullOrWhiteSpace(SessionState.Role)
            ? Language.T("header.default-context", "Admin session")
            : $"{Language.GetRoleLabel(SessionState.Role)} · {Language.GetStatusLabel(SessionState.CurrentUser?.Status ?? 0)}";

    private string GetInboxBadgeLabel() => InboxState.UnreadCount > 99
        ? "99+"
        : InboxState.UnreadCount.ToString();

    private string GetModerationBadgeLabel() => ModerationState.PendingCount > 99
        ? "99+"
        : ModerationState.PendingCount.ToString();

    private bool CanViewAdminSection =>
        SessionState.HasPermission(AdminPermissions.UserRead)
        || SessionState.HasPermission(AdminPermissions.ModerationView)
        || SessionState.HasPermission(AdminPermissions.ActivityLogView);

    private void HandleSessionChanged() => _ = RefreshForSessionAsync();

    private void HandleInboxStateChanged() => _ = InvokeAsync(StateHasChanged);
    private void HandleModerationStateChanged() => _ = InvokeAsync(StateHasChanged);
    private void HandleLanguageChanged() => _ = InvokeAsync(StateHasChanged);

    private async Task RefreshForSessionAsync()
    {
        var canViewInbox = SessionState.HasPermission(AdminPermissions.InboxView);
        var canViewModeration = SessionState.HasPermission(AdminPermissions.ModerationView);

        if (!canViewInbox && !canViewModeration)
        {
            await StopSidebarPollingAsync();
            InboxState.Reset();
            ModerationState.Reset();
            await InvokeAsync(StateHasChanged);
            return;
        }

        await RefreshSidebarCountsAsync();
        StartSidebarPolling();
        await InvokeAsync(StateHasChanged);
    }

    private async Task RefreshSidebarCountsAsync(CancellationToken cancellationToken = default)
    {
        if (SessionState.HasPermission(AdminPermissions.InboxView))
        {
            await InboxState.RefreshAsync(cancellationToken);
        }
        else
        {
            InboxState.Reset();
        }

        if (SessionState.HasPermission(AdminPermissions.ModerationView))
        {
            await ModerationState.RefreshAsync(cancellationToken);
        }
        else
        {
            ModerationState.Reset();
        }
    }

    private void StartSidebarPolling()
    {
        if (_sidebarPollingTask is { IsCompleted: false })
        {
            return;
        }

        _sidebarPollingCancellationSource = new CancellationTokenSource();
        _sidebarPollingTask = RunSidebarPollingAsync(_sidebarPollingCancellationSource.Token);
    }

    private async Task RunSidebarPollingAsync(CancellationToken cancellationToken)
    {
        try
        {
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(45));
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                await RefreshSidebarCountsAsync(cancellationToken);
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task StopSidebarPollingAsync()
    {
        if (_sidebarPollingCancellationSource is null)
        {
            return;
        }

        await _sidebarPollingCancellationSource.CancelAsync();

        if (_sidebarPollingTask is not null)
        {
            try
            {
                await _sidebarPollingTask;
            }
            catch (OperationCanceledException)
            {
            }
        }

        _sidebarPollingCancellationSource.Dispose();
        _sidebarPollingCancellationSource = null;
        _sidebarPollingTask = null;
    }

    public async ValueTask DisposeAsync()
    {
        SessionState.Changed -= HandleSessionChanged;
        InboxState.Changed -= HandleInboxStateChanged;
        ModerationState.Changed -= HandleModerationStateChanged;
        Language.Changed -= HandleLanguageChanged;
        await StopSidebarPollingAsync();
    }
}
