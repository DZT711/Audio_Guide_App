@inherits LayoutComponentBase
@inject AdminAuthService AuthService
@inject NavigationManager Navigation
@inject AdminShellState ShellState

@if (!_authChecked)
{
    <div class="layout-gate">
        <div class="layout-gate__card">
            <div class="skeleton skeleton--pill"></div>
            <div class="skeleton skeleton--title"></div>
            <div class="skeleton skeleton--line"></div>
            <div class="skeleton skeleton--line skeleton--line-short"></div>
        </div>
    </div>
}
else if (_isAuthenticated)
{
    <div class="@GetShellClass()">
        <aside class="admin-shell__sidebar d-none d-lg-flex">
            <Sidebar Collapsed="@ShellState.IsSidebarCollapsed" />
        </aside>

        <div class="offcanvas offcanvas-start admin-shell__drawer" tabindex="-1" id="admin-sidebar-drawer" aria-labelledby="admin-sidebar-drawer-label">
            <div class="offcanvas-header admin-shell__drawer-header">
                <h2 class="offcanvas-title" id="admin-sidebar-drawer-label">Navigation</h2>
                <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
            </div>
            <div class="offcanvas-body p-0">
                <Sidebar DismissOnNavigate="true" />
            </div>
        </div>

        <main class="admin-shell__main">
            <AdminHeader SidebarCollapsed="@ShellState.IsSidebarCollapsed" OnToggleSidebar="ToggleSidebarAsync" />

            <section class="admin-shell__content">
                @Body
            </section>
        </main>
    </div>
}

<NotificationCenter />

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    private bool _authChecked;
    private bool _isAuthenticated;

    private string GetShellClass() => ShellState.IsSidebarCollapsed
        ? "admin-shell admin-shell--collapsed"
        : "admin-shell";

    private Task ToggleSidebarAsync()
    {
        ShellState.IsSidebarCollapsed = !ShellState.IsSidebarCollapsed;
        return Task.CompletedTask;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        try
        {
            _isAuthenticated = await AuthService.IsAuthenticatedAsync();
        }
        finally
        {
            _authChecked = true;
        }

        if (!_isAuthenticated)
        {
            Navigation.NavigateTo("/", replace: true);
            return;
        }

        StateHasChanged();
    }
}
