@page "/moderation"
@inject AdminApiClient ApiClient
@inject NotificationService Notifications
@inject AdminSessionState SessionState

<PageTitle>Moderation Queue</PageTitle>

@if (!CanView)
{
    <div class="management-error">
        <strong>Access denied.</strong>
        <div>Your current role cannot view moderation items.</div>
    </div>
}
else
{
<div class="management-page moderation-page">
    <section class="management-hero" data-reveal>
        <div>
            <span class="management-hero__eyebrow">Moderation</span>
            <h1>Content Moderation</h1>
            <p>
                Review owner-submitted POI and audio requests, inspect the pending payload, and approve or reject the change.
            </p>
        </div>

        <div class="management-hero__actions">
            <button type="button" class="btn btn-outline-secondary btn-lg" @onclick="RefreshAsync" disabled="@_isLoading">
                <i class="bi bi-arrow-clockwise me-2"></i>
                Refresh
            </button>
        </div>
    </section>

    <div class="management-stat-grid" data-stagger data-stagger-step="80">
        <article class="management-stat" data-reveal>
            <span class="management-stat__icon"><i class="bi bi-inboxes"></i></span>
            <div>
                <strong class="management-stat__value">@_result.TotalCount</strong>
                <span class="management-stat__label">Matching Requests</span>
            </div>
        </article>
        <article class="management-stat" data-reveal>
            <span class="management-stat__icon"><i class="bi bi-geo-alt"></i></span>
            <div>
                <strong class="management-stat__value">@_items.Count(item => item.Type == "POI")</strong>
                <span class="management-stat__label">POI Requests</span>
            </div>
        </article>
        <article class="management-stat" data-reveal>
            <span class="management-stat__icon"><i class="bi bi-mic"></i></span>
            <div>
                <strong class="management-stat__value">@_items.Count(item => item.Type == "Audio")</strong>
                <span class="management-stat__label">Audio Requests</span>
            </div>
        </article>
        <article class="management-stat" data-reveal>
            <span class="management-stat__icon"><i class="bi bi-funnel"></i></span>
            <div>
                <strong class="management-stat__value">@(_statusFilter == "Pending" ? _result.TotalCount : _items.Count(item => item.Status == "Pending"))</strong>
                <span class="management-stat__label">Pending Queue</span>
            </div>
        </article>
    </div>

    <div class="management-layout">
        <section class="management-panel" data-reveal>
            <div class="management-panel__header">
                <div>
                    <span class="management-panel__eyebrow">Queue</span>
                    <h2>Requests</h2>
                </div>

                <div class="management-toolbar">
                    <label class="management-search">
                        <i class="bi bi-search"></i>
                        <input class="form-control" type="search" placeholder="Search item or owner..." @bind="_searchText" @bind:event="oninput" @bind:after="HandleFiltersChangedAsync" />
                    </label>

                    <select class="form-select management-filter" @bind="_typeFilter" @bind:after="HandleFiltersChangedAsync">
                        <option value="">All types</option>
                        <option value="POI">POIs</option>
                        <option value="Audio">Audio</option>
                    </select>

                    <select class="form-select management-filter" @bind="_actionFilter" @bind:after="HandleFiltersChangedAsync">
                        <option value="">All actions</option>
                        <option value="Add">Add</option>
                        <option value="Edit">Edit</option>
                        <option value="Delete">Delete</option>
                    </select>

                    <select class="form-select management-filter" @bind="_statusFilter" @bind:after="HandleFiltersChangedAsync">
                        <option value="Pending">Pending</option>
                        <option value="">All statuses</option>
                        <option value="Approved">Approved</option>
                        <option value="Rejected">Rejected</option>
                    </select>
                </div>
            </div>

            @if (_isLoading)
            {
                <div class="moderation-skeleton-list">
                    @for (var i = 0; i < 4; i++)
                    {
                        <article class="moderation-skeleton-card">
                            <div class="skeleton skeleton--title"></div>
                            <div class="skeleton skeleton--line"></div>
                            <div class="skeleton skeleton--line skeleton--line-short"></div>
                        </article>
                    }
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(_loadError))
            {
                <div class="management-error">
                    <strong>Unable to load moderation items.</strong>
                    <div>@_loadError</div>
                </div>
            }
            else if (_items.Count == 0)
            {
                <div class="app-empty-state">
                    No requests match the current filters.
                </div>
            }
            else
            {
                <div class="moderation-list">
                    @foreach (var item in _items)
                    {
                        <article class="@GetModerationCardClass(item)">
                            <div class="moderation-card__header">
                                <div>
                                    <div class="moderation-card__title">@item.Name</div>
                                    <small>@item.OwnerName</small>
                                </div>
                                <span class="@GetActionClass(item.ActionType)">@item.ActionType</span>
                            </div>

                            <div class="moderation-card__meta">
                                <span class="audio-card__tag">@item.Type</span>
                                <span class="audio-card__tag">@item.SubmittedAt.ToString("dd/MM/yyyy HH:mm")</span>
                                <span class="audio-card__tag">@item.Status</span>
                            </div>

                            <p class="audio-card__description">@GetSummary(item)</p>

                            <div class="management-inline-actions">
                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => SelectItem(item)">Details</button>
                                <button type="button" class="btn btn-sm btn-outline-success" disabled="@(!CanManage || item.Status != "Pending")" @onclick="() => ApproveAsync(item)">Approve</button>
                                <button type="button" class="btn btn-sm btn-outline-danger" disabled="@(!CanManage || item.Status != "Pending")" @onclick="() => RejectAsync(item)">Reject</button>
                            </div>
                        </article>
                    }
                </div>

                @if (_result.TotalPages > 1)
                {
                    <div class="management-pagination">
                        <span class="management-pagination__info">Page @_result.Page of @_result.TotalPages (@_result.TotalCount total requests)</span>
                        <div class="management-pagination__actions">
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="PreviousPageAsync" disabled="@(_result.Page <= 1)">
                                <i class="bi bi-chevron-left"></i> Previous
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="NextPageAsync" disabled="@(_result.Page >= _result.TotalPages)">
                                Next <i class="bi bi-chevron-right"></i>
                            </button>
                        </div>
                    </div>
                }
            }
        </section>

        <section class="management-panel moderation-detail" data-reveal>
            <div class="management-panel__header">
                <div>
                    <span class="management-panel__eyebrow">Details</span>
                    <h2>@(SelectedItem is null ? "Select a Request" : "Request Details")</h2>
                </div>
            </div>

            @if (SelectedItem is null)
            {
                <div class="app-empty-state">
                    Choose a request to inspect its full details before deciding.
                </div>
            }
            else
            {
                var item = SelectedItem;

                <div class="audio-readonly">
                    <div class="audio-readonly__notice">
                        Approve to apply the pending change. Reject to keep live data unchanged and notify the owner with your reason.
                    </div>

                    <div class="audio-detail-grid">
                        <article class="audio-detail-card">
                            <span>Item</span>
                            <strong>@item.Name</strong>
                            <small>@item.Type</small>
                        </article>
                        <article class="audio-detail-card">
                            <span>Action</span>
                            <strong>@item.ActionType</strong>
                            <small>@item.Status</small>
                        </article>
                        <article class="audio-detail-card">
                            <span>Owner</span>
                            <strong>@item.OwnerName</strong>
                            <small>@item.SubmittedAt.ToString("dd/MM/yyyy HH:mm")</small>
                        </article>
                        <article class="audio-detail-card">
                            <span>Owner Note</span>
                            <strong>@(string.IsNullOrWhiteSpace(item.Reason) ? "No submission note" : item.Reason)</strong>
                            <small>@(item.TargetId > 0 ? $"Live target #{item.TargetId}" : "New item request")</small>
                        </article>

                        @if (item.Location is not null)
                        {
                            <article class="audio-detail-card">
                                <span>Category</span>
                                <strong>@item.Location.Category</strong>
                                <small>@(string.IsNullOrWhiteSpace(item.Location.Address) ? "No address" : item.Location.Address)</small>
                            </article>
                            <article class="audio-detail-card">
                                <span>Coordinates</span>
                                <strong>@($"{item.Location.Latitude:F6}, {item.Location.Longitude:F6}")</strong>
                                <small>@($"{item.Location.Radius:F0}m trigger / {item.Location.StandbyRadius:F0}m standby")</small>
                            </article>
                            <article class="audio-detail-card audio-detail-card--wide">
                                <span>Description</span>
                                <strong>@(string.IsNullOrWhiteSpace(item.Location.Description) ? "No description provided." : item.Location.Description)</strong>
                            </article>
                            <article class="audio-detail-card">
                                <span>Media</span>
                                <strong>@item.Location.ImageUrls.Count image(s)</strong>
                                <small>@($"{item.Location.AudioCount} linked audio item(s)")</small>
                            </article>
                            <article class="audio-detail-card">
                                <span>Contact</span>
                                <strong>@(string.IsNullOrWhiteSpace(item.Location.Phone) ? "No phone" : item.Location.Phone)</strong>
                                <small>@(string.IsNullOrWhiteSpace(item.Location.Email) ? "No email" : item.Location.Email)</small>
                            </article>
                        }
                        else if (item.Audio is not null)
                        {
                            <article class="audio-detail-card">
                                <span>Location</span>
                                <strong>@item.Audio.LocationName</strong>
                                <small>@(string.IsNullOrWhiteSpace(item.Audio.OwnerName) ? "No owner" : item.Audio.OwnerName)</small>
                            </article>
                            <article class="audio-detail-card">
                                <span>Language</span>
                                <strong>@GetAudioLanguageLabel(item.Audio)</strong>
                                <small>@GetVoiceLabel(item.Audio.VoiceGender)</small>
                            </article>
                            <article class="audio-detail-card">
                                <span>Source</span>
                                <strong>@item.Audio.SourceType</strong>
                                <small>@($"{item.Audio.Duration} sec")</small>
                            </article>
                            <article class="audio-detail-card">
                                <span>Stored Audio</span>
                                <strong>@(string.IsNullOrWhiteSpace(item.Audio.AudioURL) ? "No stored file" : System.IO.Path.GetFileName(item.Audio.AudioURL))</strong>
                                <small>@(string.IsNullOrWhiteSpace(item.Audio.VoiceName) ? "No named voice" : item.Audio.VoiceName)</small>
                            </article>
                            <article class="audio-detail-card audio-detail-card--wide">
                                <span>Description</span>
                                <strong>@(string.IsNullOrWhiteSpace(item.Audio.Description) ? "No description provided." : item.Audio.Description)</strong>
                            </article>
                            <article class="audio-detail-card audio-detail-card--wide">
                                <span>Script</span>
                                <strong>@(string.IsNullOrWhiteSpace(item.Audio.Script) ? "No script provided." : item.Audio.Script)</strong>
                            </article>
                        }
                    </div>

                    <div class="management-field">
                        <label for="moderation-admin-note">Reviewer Note</label>
                        <InputTextArea id="moderation-admin-note" class="form-control" rows="4" @bind-Value="_reviewNote" />
                        <span class="management-field__hint">Required when rejecting. This note is delivered to the owner inbox.</span>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(item.AdminNote))
                    {
                        <div class="management-muted">Latest reviewer note: @item.AdminNote</div>
                    }

                    <div class="management-actions">
                        <button type="button" class="btn btn-success" disabled="@(!CanManage || _isReviewing || item.Status != "Pending")" @onclick="() => ApproveAsync(item)">
                            @(_isReviewing ? "Working..." : "Approve")
                        </button>
                        <button type="button" class="btn btn-outline-danger" disabled="@(!CanManage || _isReviewing || item.Status != "Pending")" @onclick="() => RejectAsync(item)">
                            @(_isReviewing ? "Working..." : "Reject")
                        </button>
                    </div>
                </div>
            }
        </section>
    </div>
</div>
}

@code {
    private readonly List<ChangeRequestDto> _items = new();
    private ChangeRequestListDto _result = new();
    private ChangeRequestDto? _selectedItem;
    private bool _isLoading = true;
    private bool _isReviewing;
    private int _currentPage = 1;
    private string _searchText = "";
    private string _typeFilter = "";
    private string _actionFilter = "";
    private string _statusFilter = "Pending";
    private string _reviewNote = "";
    private string? _loadError;

    private bool CanView => SessionState.HasPermission(AdminPermissions.ModerationView);
    private bool CanManage => SessionState.HasPermission(AdminPermissions.ModerationManage);
    private ChangeRequestDto? SelectedItem => ResolveSelectedItem();

    protected override async Task OnInitializedAsync()
    {
        await LoadItemsAsync();
    }

    private async Task RefreshAsync() => await LoadItemsAsync();

    private async Task HandleFiltersChangedAsync()
    {
        _currentPage = 1;
        await LoadItemsAsync();
    }

    private async Task NextPageAsync()
    {
        if (_result.Page >= _result.TotalPages)
        {
            return;
        }

        _currentPage = _result.Page + 1;
        await LoadItemsAsync();
    }

    private async Task PreviousPageAsync()
    {
        if (_result.Page <= 1)
        {
            return;
        }

        _currentPage = _result.Page - 1;
        await LoadItemsAsync();
    }

    private async Task LoadItemsAsync()
    {
        _isLoading = true;
        _loadError = null;

        try
        {
            _result = await ApiClient.GetChangeRequestsAsync(new ChangeRequestQueryDto
            {
                Page = _currentPage,
                PageSize = 10,
                Type = string.IsNullOrWhiteSpace(_typeFilter) ? null : _typeFilter,
                Action = string.IsNullOrWhiteSpace(_actionFilter) ? null : _actionFilter,
                Status = string.IsNullOrWhiteSpace(_statusFilter) ? null : _statusFilter,
                Search = string.IsNullOrWhiteSpace(_searchText) ? null : _searchText.Trim()
            });

            _currentPage = _result.Page;
            _items.Clear();
            _items.AddRange(_result.Items);
            SyncSelectedItem();
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
            Notifications.Error(ex.Message, "Moderation load failed");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void SelectItem(ChangeRequestDto item)
    {
        _selectedItem = item;
        _reviewNote = item.AdminNote ?? "";
    }

    private async Task ApproveAsync(ChangeRequestDto item)
    {
        if (!CanManage)
        {
            Notifications.Warning("Your role can view moderation items but cannot approve them.", "Read-only access");
            return;
        }

        _isReviewing = true;

        try
        {
            var updated = await ApiClient.ApproveChangeRequestAsync(item.Id, _reviewNote);
            Notifications.Success($"'{updated.Name}' was approved and applied to live data.", "Request approved");
            _reviewNote = "";
            await LoadItemsAsync();
        }
        catch (Exception ex)
        {
            Notifications.Error(ex.Message, "Approve failed");
        }
        finally
        {
            _isReviewing = false;
        }
    }

    private async Task RejectAsync(ChangeRequestDto item)
    {
        if (!CanManage)
        {
            Notifications.Warning("Your role can view moderation items but cannot reject them.", "Read-only access");
            return;
        }

        if (string.IsNullOrWhiteSpace(_reviewNote))
        {
            Notifications.Warning("Enter a rejection reason before rejecting this request.", "Reason required");
            return;
        }

        _isReviewing = true;

        try
        {
            var updated = await ApiClient.RejectChangeRequestAsync(item.Id, _reviewNote);
            Notifications.Info($"'{updated.Name}' was rejected and the owner was notified.", "Request rejected");
            _reviewNote = "";
            await LoadItemsAsync();
        }
        catch (Exception ex)
        {
            Notifications.Error(ex.Message, "Reject failed");
        }
        finally
        {
            _isReviewing = false;
        }
    }

    private ChangeRequestDto? ResolveSelectedItem()
    {
        if (_selectedItem is not null)
        {
            return _items.FirstOrDefault(item => item.Id == _selectedItem.Id) ?? _selectedItem;
        }

        return _items.FirstOrDefault();
    }

    private void SyncSelectedItem()
    {
        if (_selectedItem is not null)
        {
            _selectedItem = _items.FirstOrDefault(item => item.Id == _selectedItem.Id);
        }

        _selectedItem ??= _items.FirstOrDefault();

        if (_selectedItem is not null && string.IsNullOrWhiteSpace(_reviewNote))
        {
            _reviewNote = _selectedItem.AdminNote ?? "";
        }
    }

    private static string GetModerationCardClass(ChangeRequestDto item) =>
        item.ActionType == "Delete"
            ? "audio-card audio-card--inactive moderation-card moderation-card--delete"
            : "audio-card moderation-card";

    private static string GetActionClass(string actionType) => actionType switch
    {
        "Add" => "management-status management-status--active",
        "Edit" => "management-status management-status--pending",
        "Delete" => "management-status management-status--inactive",
        _ => "management-status management-status--info"
    };

    private static string GetSummary(ChangeRequestDto item) =>
        item.Location is not null
            ? $"Category: {item.Location.Category}. {(string.IsNullOrWhiteSpace(item.Location.Address) ? "No address" : item.Location.Address)}"
            : item.Audio is not null
                ? $"{item.Audio.LocationName} · {GetAudioLanguageLabel(item.Audio)} · {item.Audio.SourceType}"
                : "No summary available.";

    private static string GetVoiceLabel(string? voiceGender) =>
        string.IsNullOrWhiteSpace(voiceGender) ? "Unspecified voice" : $"{voiceGender} voice";

    private static string GetAudioLanguageLabel(AudioDto audio) =>
        string.IsNullOrWhiteSpace(audio.LanguageName) ? audio.Language : $"{audio.LanguageName} ({audio.Language})";
}
