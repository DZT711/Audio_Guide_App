@page "/languages"
@using System.Globalization
@inject AdminApiClient ApiClient
@inject NotificationService Notifications
@inject IJSRuntime JS
@inject AdminSessionState SessionState
@inject AdminUiLanguageService LanguageService

<PageTitle>@L("page.languages", "Language Management")</PageTitle>

@if (!CanView)
{
    <div class="management-page language-page">
        <div class="management-error">
            <strong>@L("languages.access.denied.title", "Access denied.")</strong>
            <div>@L("languages.access.denied.desc", "Your current role cannot view languages.")</div>
        </div>
    </div>
}
else
{
<div class="management-page language-page">
    <section class="management-hero" data-reveal>
        <div>
            <span class="management-hero__eyebrow">@L("languages.hero.eyebrow", "Locale Catalog")</span>
            <h1>@L("languages.hero.title", "Language Management")</h1>
            <p>@L("languages.hero.desc", "Control which audio languages are available in the admin web and whether browser preview should prefer a native system voice for that locale.")</p>
        </div>

        <div class="management-hero__actions">
            <button type="button" class="btn btn-outline-secondary btn-lg" @onclick="RefreshAsync">
                <i class="bi bi-arrow-clockwise me-2"></i>
                @L("languages.action.refresh", "Refresh")
            </button>
        </div>
    </section>

    <div class="management-stat-grid" data-stagger data-stagger-step="80">
        <article class="management-stat" data-reveal>
            <span class="management-stat__icon"><i class="bi bi-translate"></i></span>
            <div>
                <strong class="management-stat__value">@_languages.Count</strong>
                <span class="management-stat__label">@L("languages.stats.total", "Total Languages")</span>
            </div>
        </article>
        <article class="management-stat" data-reveal>
            <span class="management-stat__icon"><i class="bi bi-check2-circle"></i></span>
            <div>
                <strong class="management-stat__value">@_languages.Count(item => item.Status == 1)</strong>
                <span class="management-stat__label">@L("status.active", "Active")</span>
            </div>
        </article>
        <article class="management-stat" data-reveal>
            <span class="management-stat__icon"><i class="bi bi-volume-up"></i></span>
            <div>
                <strong class="management-stat__value">@_languages.Count(item => item.PreferNativeVoice && item.Status == 1)</strong>
                <span class="management-stat__label">@L("languages.stats.native-voice-on", "Native Voice On")</span>
            </div>
        </article>
        <article class="management-stat" data-reveal>
            <span class="management-stat__icon"><i class="bi bi-star-fill"></i></span>
            <div>
                <strong class="management-stat__value">@_languages.Count(item => item.IsDefault && item.Status == 1)</strong>
                <span class="management-stat__label">@L("languages.stats.default-language", "Default Language")</span>
            </div>
        </article>
    </div>

    <div class="management-layout">
        <section class="management-panel" data-reveal>
            <div class="management-panel__header">
                <div>
                    <span class="management-panel__eyebrow">@L("languages.directory.eyebrow", "Directory")</span>
                    <h2>@L("languages.directory.title", "Available Languages")</h2>
                </div>

                <label class="management-search">
                    <i class="bi bi-search"></i>
                    <input class="form-control" type="search" placeholder="@L("languages.search.placeholder", "Search languages...")" @bind="_searchText" @bind:event="oninput" />
                </label>
            </div>

            @if (_isLoading)
            {
                <div class="language-skeleton-list">
                    @for (var i = 0; i < 4; i++)
                    {
                        <div class="language-skeleton-card">
                            <div class="skeleton skeleton--title"></div>
                            <div class="skeleton skeleton--line"></div>
                            <div class="skeleton skeleton--line skeleton--line-short"></div>
                        </div>
                    }
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(_loadError))
            {
            <div class="management-error">
                <strong>@L("languages.load.failed.title", "Unable to load languages.")</strong>
                <div>@_loadError</div>
            </div>
        }
        else if (!FilteredLanguages.Any())
        {
            <div class="app-empty-state">
                    @L("languages.empty.filtered", "No languages match the current search.")
            </div>
        }
            else
            {
                <div class="management-page-swap" @key="CurrentLanguagePage">
                    <div class="language-list">
                        @foreach (var language in PagedLanguages)
                        {
                            <article class="@GetLanguageCardClass(language.Status)">
                                <div class="language-card__copy">
                                    <div class="language-card__top">
                                        <div class="language-card__identity">
                                            <span class="language-flag" title="@GetLanguageFlagLabel(language)">@GetLanguageFlagCode(language)</span>
                                            <div>
                                                <h3>@language.Name</h3>
                                                <p>@language.Code</p>
                                            </div>
                                        </div>
                                        <span class="@GetStatusClass(language.Status)">@GetStatusLabel(language.Status)</span>
                                    </div>

                                    <div class="language-card__meta">
                                        <span class="language-card__tag">@(string.IsNullOrWhiteSpace(language.NativeName) ? L("languages.native.empty", "No native name") : language.NativeName)</span>
                                        <span class="language-card__tag">@(language.PreferNativeVoice ? L("languages.preview.native", "Native voice preview") : L("languages.preview.flexible", "Flexible preview"))</span>
                                        @if (language.IsDefault)
                                        {
                                            <span class="language-card__tag language-card__tag--default">@L("languages.default", "Default")</span>
                                        }
                                    </div>
                                </div>

                                <div class="management-inline-actions">
                                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => StartEdit(language)">@(CanManage ? L("languages.action.edit", "Edit") : L("languages.action.view", "View"))</button>
                                    <button type="button" class="btn btn-sm btn-outline-danger" disabled="@(!CanManage || language.Status == 0)" @onclick="() => PromptArchiveLanguage(language)">
                                        @(language.Status == 0 ? L("status.inactive", "Inactive") : L("languages.action.archive", "Archive"))
                                    </button>
                                </div>
                            </article>
                        }
                    </div>
                </div>

                @if (TotalLanguagePages > 1)
                {
                <div class="management-pagination">
                    <span class="management-pagination__info">@LF("languages.pagination.info", "Page {0} of {1} ({2} total languages)", CurrentLanguagePage, TotalLanguagePages, FilteredLanguages.Count())</span>
                    <div class="management-pagination__actions">
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="PreviousLanguagePage" disabled="@(CurrentLanguagePage <= 1)">
                            <i class="bi bi-chevron-left"></i> @L("languages.pagination.previous", "Previous")
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="NextLanguagePage" disabled="@(CurrentLanguagePage >= TotalLanguagePages)">
                            @L("languages.pagination.next", "Next") <i class="bi bi-chevron-right"></i>
                        </button>
                    </div>
                </div>
                }
            }
        </section>

        <section class="management-panel language-editor" data-reveal>
            <div class="management-panel__header">
                <div>
                    <span class="management-panel__eyebrow">@(CanManage ? L("languages.editor.eyebrow", "Editor") : L("languages.readonly.eyebrow", "Read Only"))</span>
                    <h2>@(CanManage ? (_editingId is null ? L("languages.editor.create", "Create Language") : L("languages.editor.edit", "Edit Language")) : L("languages.readonly.title", "Language Details"))</h2>
                </div>
            </div>

            @if (CanManage)
            {
            <EditForm Model="_formModel" OnValidSubmit="SaveLanguageAsync" OnInvalidSubmit="HandleInvalidLanguageSubmit" class="management-form">
                <DataAnnotationsValidator />

                <div class="management-field">
                    <label for="language-code">@L("languages.form.code", "Language Code")</label>
                    <InputText id="language-code" class="form-control" @bind-Value="_formModel.Code" />
                    <ValidationMessage For="() => _formModel.Code" />
                </div>

                <div class="management-field">
                    <label for="language-name">@L("languages.form.name", "Language Name")</label>
                    <InputText id="language-name" class="form-control" @bind-Value="_formModel.Name" />
                    <ValidationMessage For="() => _formModel.Name" />
                </div>

                <div class="management-field management-field--full">
                    <label for="language-native-name">@L("languages.form.native-name", "Native Name")</label>
                    <InputText id="language-native-name" class="form-control" @bind-Value="_formModel.NativeName" />
                    <ValidationMessage For="() => _formModel.NativeName" />
                </div>

                <div class="management-field management-field--full">
                    <span class="management-field__label">@L("languages.form.preview-mode", "Preview Voice Mode")</span>
                    <div class="management-chip-group">
                        <button type="button" class="@GetBoolChipClass(true, _formModel.PreferNativeVoice)" @onclick="() => SetPreferNativeVoice(true)">@L("languages.preview.native.voice", "Native voice")</button>
                        <button type="button" class="@GetBoolChipClass(false, _formModel.PreferNativeVoice)" @onclick="() => SetPreferNativeVoice(false)">@L("languages.preview.flexible.fallback", "Flexible fallback")</button>
                    </div>
                    <span class="management-field__hint">@L("languages.preview.hint", "Native voice keeps preview in the chosen language when possible. Flexible fallback can use another installed voice if the browser lacks a strong locale match.")</span>
                </div>

                <div class="management-field management-field--full">
                    <span class="management-field__label">@L("languages.form.default-language", "Default Language")</span>
                    <div class="management-chip-group">
                        <button type="button" class="@GetBoolChipClass(true, _formModel.IsDefault)" @onclick="() => SetDefaultLanguage(true)">@L("languages.default", "Default")</button>
                        <button type="button" class="@GetBoolChipClass(false, _formModel.IsDefault)" @onclick="() => SetDefaultLanguage(false)">@L("languages.normal", "Normal")</button>
                    </div>
                </div>

                <div class="management-field management-field--full">
                    <span class="management-field__label">@L("languages.form.status", "Status")</span>
                    <div class="management-chip-group">
                        <button type="button" class="@GetChipClass(1, _formModel.Status)" @onclick="() => SetStatus(1)">@L("status.active", "Active")</button>
                        <button type="button" class="@GetChipClass(0, _formModel.Status)" @onclick="() => SetStatus(0)">@L("status.inactive", "Inactive")</button>
                    </div>
                </div>

                <div class="management-actions">
                    <button type="submit" class="btn btn-primary" disabled="@(_isSaving || !CanManage)">
                        @(_isSaving ? L("languages.save.saving", "Saving...") : _editingId is null ? L("languages.save.create", "Create Language") : L("languages.save.update", "Save Changes"))
                    </button>
                    <button type="button" class="btn btn-outline-secondary" @onclick="CancelEdit">@(CanManage ? (_editingId is null ? L("languages.action.reset", "Reset") : L("languages.action.cancel-edit", "Cancel Edit")) : L("languages.readonly.eyebrow", "Read Only"))</button>
                </div>
            </EditForm>
            }
            else if (SelectedLanguageForDisplay is null)
            {
                <div class="app-empty-state">
                    @L("languages.readonly.empty", "Select a language to review its details.")
                </div>
            }
            else
            {
                var selectedLanguage = SelectedLanguageForDisplay!;

                <div class="language-readonly">
                    <div class="language-readonly__notice">
                        @L("languages.readonly.notice", "Language changes require an Admin or Developer account.")
                    </div>

                    <div class="language-detail-card">
                        <span>@L("languages.form.code", "Code")</span>
                        <strong class="language-detail-card__headline">
                            <span class="language-flag" title="@GetLanguageFlagLabel(selectedLanguage)">@GetLanguageFlagCode(selectedLanguage)</span>
                            @selectedLanguage.Code
                        </strong>
                        <small>@GetStatusLabel(selectedLanguage.Status)</small>
                    </div>

                    <div class="language-detail-card">
                        <span>@L("languages.form.name", "Name")</span>
                        <strong>@selectedLanguage.Name</strong>
                        <small>@(string.IsNullOrWhiteSpace(selectedLanguage.NativeName) ? L("languages.native.empty", "No native name") : selectedLanguage.NativeName)</small>
                    </div>

                    <div class="language-detail-card">
                        <span>@L("languages.form.preview-mode.short", "Preview Mode")</span>
                        <strong>@(selectedLanguage.PreferNativeVoice ? L("languages.preview.native.voice", "Native voice") : L("languages.preview.flexible.fallback", "Flexible fallback"))</strong>
                        <small>@(selectedLanguage.IsDefault ? L("languages.default.language", "Default language") : L("languages.standard.entry", "Standard catalog entry"))</small>
                    </div>
                </div>
            }
        </section>
    </div>
</div>

<AdminConfirmDialog Visible="@(_pendingArchivedLanguage is not null)"
                    Eyebrow="@L("languages.archive.dialog.eyebrow", "Archive Language")"
                    Title="@L("languages.archive.dialog.title", "Archive this language?")"
                    Message="@GetPendingArchiveLanguageMessage()"
                    ConfirmLabel="@L("languages.archive.dialog.confirm", "Archive Language")"
                    ConfirmButtonClass="btn btn-danger"
                    OnConfirm="ConfirmArchiveLanguageAsync"
                    OnCancel="CancelArchiveLanguage" />
}

@code {
    private string L(string key, string fallback) => LanguageService.T(key, fallback);
    private string LF(string key, string fallback, params object?[] args) =>
        string.Format(CultureInfo.CurrentCulture, L(key, fallback), args);
    private readonly LanguageFormModel _formModel = new();
    private readonly List<LanguageDto> _languages = new();
    private LanguageDto? _selectedLanguage;
    private LanguageDto? _pendingArchivedLanguage;
    private bool _isLoading = true;
    private bool _isSaving;
    private int? _editingId;
    private string _searchText = "";
    private string? _loadError;
    private int _currentLanguagePage = 1;
    private const int LanguagesPerPage = 4;
    private bool CanView => SessionState.HasPermission(AdminPermissions.LanguageRead);
    private bool CanManage => SessionState.HasPermission(AdminPermissions.LanguageManage);
    private LanguageDto? SelectedLanguageForDisplay => ResolveSelectedLanguage();

    private IEnumerable<LanguageDto> FilteredLanguages =>
        _languages.Where(language =>
            string.IsNullOrWhiteSpace(_searchText)
            || language.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase)
            || language.Code.Contains(_searchText, StringComparison.OrdinalIgnoreCase)
            || (language.NativeName?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false));
    private int TotalLanguagePages => Math.Max(1, (int)Math.Ceiling((double)FilteredLanguages.Count() / LanguagesPerPage));
    private int CurrentLanguagePage => Math.Min(Math.Max(_currentLanguagePage, 1), TotalLanguagePages);
    private IReadOnlyList<LanguageDto> PagedLanguages => FilteredLanguages
        .Skip((CurrentLanguagePage - 1) * LanguagesPerPage)
        .Take(LanguagesPerPage)
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadLanguagesAsync();
    }

    private async Task RefreshAsync() => await LoadLanguagesAsync();

    private async Task LoadLanguagesAsync()
    {
        _isLoading = true;
        _loadError = null;

        try
        {
            var languages = await ApiClient.GetLanguagesAsync();
            _languages.Clear();
            _languages.AddRange(languages
                .OrderByDescending(item => item.Status)
                .ThenByDescending(item => item.IsDefault)
                .ThenBy(item => item.Name));

            SyncSelectedLanguage();
            _currentLanguagePage = 1;
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
            Notifications.Error(ex.Message, L("languages.load.failed.toast", "Language load failed"));
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void NextLanguagePage()
    {
        if (CurrentLanguagePage < TotalLanguagePages)
        {
            _currentLanguagePage = CurrentLanguagePage + 1;
        }
    }

    private void PreviousLanguagePage()
    {
        if (CurrentLanguagePage > 1)
        {
            _currentLanguagePage = CurrentLanguagePage - 1;
        }
    }

    private void StartCreate()
    {
        _editingId = null;
        ResetForm();
    }

    private void StartEdit(LanguageDto language)
    {
        _selectedLanguage = language;
        _editingId = language.Id;

        if (!CanManage)
        {
            _editingId = null;
            return;
        }

        var snapshot = LanguageFormModel.FromDto(language);
        _formModel.Code = snapshot.Code;
        _formModel.Name = snapshot.Name;
        _formModel.NativeName = snapshot.NativeName;
        _formModel.PreferNativeVoice = snapshot.PreferNativeVoice;
        _formModel.IsDefault = snapshot.IsDefault;
        _formModel.Status = snapshot.Status;
    }

    private async Task SaveLanguageAsync()
    {
        if (!CanManage)
        {
            Notifications.Warning(
                L("languages.save.readonly.message", "Your role can view languages but cannot save changes."),
                L("languages.readonly.short", "Read-only access"));
            return;
        }

        _isSaving = true;

        try
        {
            if (_editingId is null)
            {
                await ApiClient.CreateLanguageAsync(_formModel);
                Notifications.Success(
                    L("languages.save.created.message", "Language created successfully."),
                    L("languages.save.title", "Language saved"));
            }
            else
            {
                await ApiClient.UpdateLanguageAsync(_editingId.Value, _formModel);
                Notifications.Success(
                    L("languages.save.updated.message", "Language updated successfully."),
                    L("languages.save.title", "Language saved"));
            }

            await LoadLanguagesAsync();
            StartCreate();
        }
        catch (Exception ex)
        {
            Notifications.Error(ex.Message, L("languages.save.failed.title", "Language save failed"));
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void HandleInvalidLanguageSubmit(EditContext editContext)
    {
        var message = editContext.GetValidationMessages()
            .Where(item => !string.IsNullOrWhiteSpace(item))
            .Distinct(StringComparer.Ordinal)
            .Take(3)
            .ToList();

        Notifications.Warning(
            message.Count == 0
                ? L("languages.validation.generic", "Fix the highlighted language fields before saving.")
                : string.Join(" ", message),
            L("languages.validation.title", "Language form incomplete"));
    }

    private void PromptArchiveLanguage(LanguageDto language)
    {
        if (!CanManage)
        {
            Notifications.Warning(
                L("languages.archive.readonly.message", "Your role can view languages but cannot archive them."),
                L("languages.readonly.short", "Read-only access"));
            return;
        }

        _pendingArchivedLanguage = language;
    }

    private async Task ConfirmArchiveLanguageAsync()
    {
        if (!CanManage || _pendingArchivedLanguage is null)
        {
            return;
        }

        try
        {
            await ApiClient.DeleteLanguageAsync(_pendingArchivedLanguage.Id);
            Notifications.Info(
                LF("languages.archive.success.message", "'{0}' is now inactive.", _pendingArchivedLanguage.Name),
                L("languages.archive.success.title", "Language archived"));
            await LoadLanguagesAsync();

            if (_editingId == _pendingArchivedLanguage.Id)
            {
                StartCreate();
            }
        }
        catch (Exception ex)
        {
            Notifications.Error(ex.Message, L("languages.archive.failed.title", "Delete failed"));
        }
        finally
        {
            CancelArchiveLanguage();
        }
    }

    private void ResetForm()
    {
        _formModel.Code = "vi-VN";
        _formModel.Name = "";
        _formModel.NativeName = "";
        _formModel.PreferNativeVoice = true;
        _formModel.IsDefault = _languages.All(item => !item.IsDefault || item.Status == 0);
        _formModel.Status = 1;
    }

    private void CancelEdit()
    {
        _editingId = null;
        ResetForm();
    }

    private void SetPreferNativeVoice(bool preferNativeVoice) => _formModel.PreferNativeVoice = preferNativeVoice;

    private void SetDefaultLanguage(bool isDefault) => _formModel.IsDefault = isDefault;

    private void SetStatus(int status) => _formModel.Status = status;

    private LanguageDto? ResolveSelectedLanguage()
    {
        if (_selectedLanguage is not null)
        {
            return _languages.FirstOrDefault(item => item.Id == _selectedLanguage.Id) ?? _selectedLanguage;
        }

        return FilteredLanguages.FirstOrDefault() ?? _languages.FirstOrDefault();
    }

    private void SyncSelectedLanguage()
    {
        if (_selectedLanguage is not null)
        {
            _selectedLanguage = _languages.FirstOrDefault(item => item.Id == _selectedLanguage.Id);
        }

        if (!CanManage && _selectedLanguage is null)
        {
            _selectedLanguage = _languages.FirstOrDefault();
        }
    }

    private static string GetStatusClass(int status) => status == 1
        ? "management-status management-status--active"
        : "management-status management-status--inactive";

    private string GetStatusLabel(int status) => status == 1
        ? L("status.active", "Active")
        : L("status.inactive", "Inactive");

    private static string GetChipClass(int status, int currentStatus) => status == currentStatus
        ? "management-chip management-chip--selected"
        : "management-chip";

    private static string GetBoolChipClass(bool value, bool currentValue) => value == currentValue
        ? "management-chip management-chip--selected"
        : "management-chip";

    private static string GetLanguageCardClass(int status) => status == 1
        ? "language-card"
        : "language-card language-card--inactive";

    private static string GetLanguageFlagCode(LanguageDto language)
    {
        var code = language.Code?.Trim() ?? string.Empty;
        if (string.IsNullOrWhiteSpace(code))
        {
            return "GL";
        }

        var parts = code.Replace('_', '-').Split('-', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (parts.Length > 1 && parts[^1].Length == 2)
        {
            return parts[^1].ToUpperInvariant();
        }

        return parts[0].ToLowerInvariant() switch
        {
            "vi" => "VN",
            "en" => "US",
            "fr" => "FR",
            "de" => "DE",
            "es" => "ES",
            "it" => "IT",
            "ja" => "JP",
            "ko" => "KR",
            "zh" => "CN",
            "th" => "TH",
            "id" => "ID",
            "ms" => "MY",
            "pt" => "PT",
            "ru" => "RU",
            _ => parts[0][..Math.Min(parts[0].Length, 2)].ToUpperInvariant()
        };
    }

    private string GetLanguageFlagLabel(LanguageDto language) =>
        LF("languages.flag.locale", "{0} locale", GetLanguageFlagCode(language));

    private string GetPendingArchiveLanguageMessage() =>
        _pendingArchivedLanguage is null
            ? string.Empty
            : LF("languages.archive.dialog.message", "'{0}' will become inactive and can no longer be assigned to new or edited audio items.", _pendingArchivedLanguage.Name);

    private void CancelArchiveLanguage() => _pendingArchivedLanguage = null;
}
