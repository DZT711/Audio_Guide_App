@page "/users"
@using System.Globalization
@inject AdminApiClient ApiClient
@inject NotificationService Notifications
@inject IJSRuntime JS
@inject AdminSessionState SessionState
@inject AdminUiLanguageService LanguageService

<PageTitle>@L("page.users", "User Management")</PageTitle>

@if (!CanView)
{
    <div class="users-page">
        <div class="management-error">
            <strong>@L("users.access.denied.title", "Access denied.")</strong>
            <div>@L("users.access.denied.desc", "Your current role cannot view dashboard users.")</div>
        </div>
    </div>
}
else
{
<div class="users-page">
    <section class="users-hero" data-reveal>
        <div>
            <span class="users-hero__eyebrow">@L("users.hero.eyebrow", "Team & Access")</span>
            <h1>@L("users.hero.title", "User Management")</h1>
            <p>@L("users.hero.desc", "Manage dashboard accounts, assign roles from the POC schema, and control who can log into the admin web or own location content.")</p>
        </div>

        <div class="users-hero__actions">
            <button class="btn btn-primary btn-lg" type="button" disabled="@(!CanManage)" @onclick="StartCreate">
                <i class="bi bi-person-plus me-2"></i>
                @L("users.action.add", "Add User")
            </button>
            <button class="btn btn-outline-secondary btn-lg" type="button" disabled="@(!CanManage)" @onclick="StartInvite">
                <i class="bi bi-send me-2"></i>
                @L("users.action.invite", "Invite by Email")
            </button>
        </div>
    </section>

    <section class="users-toolbar" data-reveal>
        <label class="users-search" for="userSearch">
            <i class="bi bi-search"></i>
            <input id="userSearch" class="form-control" type="search" placeholder="@L("users.search.placeholder", "Search by username, role, or email")" @bind="_searchText" @bind:event="oninput">
        </label>

        <div class="users-filters">
            <button type="button" class="@GetFilterChipClass(null)" @onclick="() => SetRoleFilter(null)">@L("users.filter.all", "All Users")</button>
            <button type="button" class="@GetFilterChipClass(AdminRoles.Admin)" @onclick="() => SetRoleFilter(AdminRoles.Admin)">@L("users.filter.admins", "Admins")</button>
            <button type="button" class="@GetFilterChipClass(AdminRoles.User)" @onclick="() => SetRoleFilter(AdminRoles.User)">@L("users.filter.owners", "Owners")</button>
            <button type="button" class="@GetFilterChipClass(InactiveFilter)" @onclick="() => SetRoleFilter(InactiveFilter)">@L("users.filter.inactive", "Inactive")</button>
        </div>
    </section>

    <div class="row g-3" data-stagger data-stagger-step="80">
        @foreach (var summary in Summaries)
        {
            <div class="col-12 col-sm-6 col-xl-3">
                <article class="@GetSummaryCardClass(summary.Tone)" data-reveal>
                    <div class="summary-card__icon">
                        <i class="bi @summary.Icon"></i>
                    </div>
                    <div>
                        <span class="summary-card__label">@summary.Label</span>
                        <div class="summary-card__value">@summary.Value</div>
                        <p>@summary.Copy</p>
                    </div>
                </article>
            </div>
        }
    </div>

    <section class="users-table-card mt-4" data-reveal>
        <div class="users-table-card__header">
            <div>
                <span class="users-table-card__eyebrow">@L("users.table.eyebrow", "Directory")</span>
                <h2>@L("users.table.title", "Dashboard Accounts")</h2>
            </div>
            <span class="users-table-card__count">@LF("users.table.count", "{0} users", VisibleUsers.Count)</span>
        </div>

        @if (_isLoading)
        {
            <div class="users-skeleton-table">
                @for (var i = 0; i < 4; i++)
                {
                    <div class="skeleton-table-row">
                        <div class="skeleton skeleton--line"></div>
                        <div class="skeleton skeleton--line"></div>
                        <div class="skeleton skeleton--line"></div>
                        <div class="skeleton skeleton--line"></div>
                    </div>
                }
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(_loadError))
        {
            <div class="management-error">
                <strong>@L("users.load.failed.title", "Unable to load users.")</strong>
                <div>@_loadError</div>
            </div>
        }
        else
        {
            <div class="table-responsive management-page-swap" @key="CurrentUserPage">
                <table class="table users-table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>@L("users.table.user", "User")</th>
                            <th>@L("users.table.contact", "Contact")</th>
                            <th>@L("users.table.role", "Role")</th>
                            <th>@L("users.table.status", "Status")</th>
                            <th class="text-end">@L("users.table.actions", "Actions")</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in PagedUsers)
                        {
                            <tr>
                                <td>
                                    <div class="user-cell">
                                        <div class="user-avatar" style="@($"--avatar-hue:{GetAvatarHue(user)};")">@GetInitials(user)</div>
                                        <div class="user-cell__meta">
                                            <strong>@(user.FullName ?? user.Username)</strong>
                                            <span>@user.Username</span>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="user-contact">
                                        <span>@(string.IsNullOrWhiteSpace(user.Email) ? L("users.email.empty", "No email") : user.Email)</span>
                                        <small>@GetMetaLine(user)</small>
                                    </div>
                                </td>
                                <td>
                                    <span class="@GetRoleClass(user.Role)">@LanguageService.GetRoleLabel(user.Role)</span>
                                </td>
                                <td>
                                    <span class="@GetStatusClass(user.Status)">@GetStatusLabel(user.Status)</span>
                                </td>
                                <td class="text-end">
                                    <div class="row-actions justify-content-end">
                                        <button class="btn btn-sm btn-outline-secondary" type="button" disabled="@(!CanManage)" @onclick="() => StartEdit(user)">@L("users.table.edit", "Edit")</button>
                                        <button class="btn btn-sm btn-outline-danger" type="button" disabled="@(!CanToggleUserStatus(user))" title="@GetActionDisabledReason(user)" @onclick="() => PromptUserStatusChange(user)">@GetActionLabel(user)</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (TotalUserPages > 1)
            {
                <div class="management-pagination">
                    <span class="management-pagination__info">@LF("users.pagination.info", "Page {0} of {1} ({2} total users)", CurrentUserPage, TotalUserPages, VisibleUsers.Count)</span>
                    <div class="management-pagination__actions">
                        <button class="btn btn-sm btn-outline-secondary" type="button" @onclick="PreviousUserPage" disabled="@(CurrentUserPage <= 1)">
                            <i class="bi bi-chevron-left"></i> @L("users.pagination.previous", "Previous")
                        </button>
                        <button class="btn btn-sm btn-outline-secondary" type="button" @onclick="NextUserPage" disabled="@(CurrentUserPage >= TotalUserPages)">
                            @L("users.pagination.next", "Next") <i class="bi bi-chevron-right"></i>
                        </button>
                    </div>
                </div>
            }
        }
    </section>

    <section class="users-table-card users-editor-card mt-4" data-reveal>
        <div class="users-table-card__header">
            <div>
                <span class="users-table-card__eyebrow">@L("users.editor.eyebrow", "Editor")</span>
                <h2>@GetEditorTitle()</h2>
            </div>
            <span class="users-table-card__count users-editor-card__count">@GetEditorSubtitle()</span>
        </div>

        <EditForm Model="_formModel" OnValidSubmit="SaveUserAsync" OnInvalidSubmit="HandleInvalidUserSubmit" class="management-form users-editor-form">
            <DataAnnotationsValidator />

            <div class="management-form__grid users-editor-form__grid">
                <div class="management-field">
                    <label for="user-username">@L("users.form.username", "Username")</label>
                    <InputText id="user-username" class="form-control" @bind-Value="_formModel.Username" />
                    <ValidationMessage For="() => _formModel.Username" />
                </div>

                <div class="management-field">
                    <label for="user-fullname">@L("users.form.fullname", "Full Name")</label>
                    <InputText id="user-fullname" class="form-control" @bind-Value="_formModel.FullName" />
                    <ValidationMessage For="() => _formModel.FullName" />
                </div>

                <div class="management-field">
                    <label for="user-email">@L("users.form.email", "Email")</label>
                    <InputText id="user-email" class="form-control" @bind-Value="_formModel.Email" />
                    <ValidationMessage For="() => _formModel.Email" />
                </div>

                <div class="management-field">
                    <label for="user-phone">@L("users.form.phone", "Phone")</label>
                    <InputText id="user-phone" class="form-control" @bind-Value="_formModel.Phone" />
                    <ValidationMessage For="() => _formModel.Phone" />
                </div>

                <div class="management-field">
                    <label for="user-role">@L("users.form.role", "Role")</label>
                    <InputSelect id="user-role" class="form-select" @bind-Value="_formModel.Role" @bind-Value:after="HandleRoleChanged">
                        @foreach (var role in AdminRoles.All)
                        {
                            <option value="@role">@LanguageService.GetRoleLabel(role)</option>
                        }
                    </InputSelect>
                </div>

                <div class="management-field">
                    <label for="user-password">@L("users.form.password", "Password")</label>
                    <InputText id="user-password" type="password" class="form-control" @bind-Value="_formModel.Password" />
                    <span class="management-field__hint">@GetPasswordHint()</span>
                </div>

                <div class="management-field management-field--full">
                    <span class="management-field__label">@L("users.form.status", "Status")</span>
                    <div class="management-chip-group">
                        <button type="button" class="@GetChipClass(1, _formModel.Status)" disabled="@(!CanSetFormStatus(1))" @onclick="() => SetStatus(1)">@L("status.active", "Active")</button>
                        <button type="button" class="@GetChipClass(0, _formModel.Status)" disabled="@(!CanSetFormStatus(0))" @onclick="() => SetStatus(0)">@L("status.inactive", "Inactive")</button>
                    </div>
                    <span class="management-field__hint">@GetStatusEditorHint()</span>
                </div>
            </div>

            <div class="management-actions">
                <button type="submit" class="btn btn-primary" disabled="@(_isSaving || !CanManage)">
                    @GetSaveButtonLabel()
                </button>
                <button type="button" class="btn btn-outline-secondary" @onclick="CancelEdit">@L("users.form.reset", "Reset")</button>
            </div>
        </EditForm>
    </section>
</div>

<AdminConfirmDialog Visible="@(_pendingStatusUser is not null)"
                    Eyebrow="@L("users.dialog.status.eyebrow", "Account Status")"
                    Title="@GetPendingStatusTitle()"
                    Message="@GetPendingStatusMessage()"
                    ConfirmLabel="@GetPendingStatusConfirmLabel()"
                    ConfirmButtonClass="btn btn-danger"
                    OnConfirm="ConfirmPendingStatusAsync"
                    OnCancel="CancelPendingStatus" />
}

@code {
    private string L(string key, string fallback) => LanguageService.T(key, fallback);
    private string LF(string key, string fallback, params object?[] args) =>
        string.Format(CultureInfo.CurrentCulture, L(key, fallback), args);
    private readonly UserFormModel _formModel = new();
    private readonly List<DashboardUserDto> _users = new();
    private const string InactiveFilter = "inactive";
    private bool _isLoading = true;
    private bool _isSaving;
    private bool _inviteMode;
    private int? _editingId;
    private DashboardUserDto? _pendingStatusUser;
    private int _pendingStatusValue = 1;
    private string _searchText = "";
    private string? _roleFilter;
    private string? _loadError;
    private int _currentUserPage = 1;
    private const int UsersPerPage = 10;

    private bool CanView => SessionState.HasPermission(AdminPermissions.UserRead);
    private bool CanManage => SessionState.HasPermission(AdminPermissions.UserManage);
    private int CurrentUserId => SessionState.CurrentUser?.UserId ?? 0;
    private int TotalUserPages => Math.Max(1, (int)Math.Ceiling((double)VisibleUsers.Count / UsersPerPage));
    private int CurrentUserPage => Math.Min(Math.Max(_currentUserPage, 1), TotalUserPages);
    private IReadOnlyList<DashboardUserDto> PagedUsers => VisibleUsers
        .Skip((CurrentUserPage - 1) * UsersPerPage)
        .Take(UsersPerPage)
        .ToList();

    private List<DashboardUserDto> VisibleUsers =>
        _users
            .Where(user =>
                string.IsNullOrWhiteSpace(_searchText)
                || user.Username.Contains(_searchText, StringComparison.OrdinalIgnoreCase)
                || (user.FullName?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false)
                || (user.Email?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false)
                || user.Role.Contains(_searchText, StringComparison.OrdinalIgnoreCase))
            .Where(user => _roleFilter switch
            {
                null => true,
                InactiveFilter => user.Status == 0,
                _ => string.Equals(user.Role, _roleFilter, StringComparison.OrdinalIgnoreCase)
            })
            .OrderByDescending(user => user.Status)
            .ThenBy(user => user.FullName ?? user.Username)
            .ToList();

    private IReadOnlyList<UserSummaryItem> Summaries =>
    [
        new UserSummaryItem(L("users.summary.total.label", "Total Users"), _users.Count.ToString(), L("users.summary.total.copy", "Accounts available in the dashboard database"), "bi-people", "teal"),
        new UserSummaryItem(L("users.summary.active.label", "Active"), _users.Count(user => user.Status == 1).ToString(), L("users.summary.active.copy", "Users currently allowed to sign in"), "bi-person-check", "green"),
        new UserSummaryItem(L("users.summary.owners.label", "Owners"), _users.Count(user => string.Equals(user.Role, AdminRoles.User, StringComparison.OrdinalIgnoreCase)).ToString(), L("users.summary.owners.copy", "Accounts that can own POIs and audio"), "bi-person-workspace", "amber"),
        new UserSummaryItem(L("users.summary.locked.label", "Locked"), _users.Count(user => user.Status == 0).ToString(), L("users.summary.locked.copy", "Inactive users blocked from login"), "bi-shield-lock", "rose")
    ];

    protected override async Task OnInitializedAsync()
    {
        ResetForm();
        await LoadUsersAsync();
    }

    private async Task LoadUsersAsync()
    {
        _isLoading = true;
        _loadError = null;

        try
        {
            _users.Clear();
            _users.AddRange(await ApiClient.GetUsersAsync());
            _currentUserPage = 1;
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
            Notifications.Error(ex.Message, L("users.load.failed.toast", "User load failed"));
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void NextUserPage()
    {
        if (CurrentUserPage < TotalUserPages)
        {
            _currentUserPage = CurrentUserPage + 1;
        }
    }

    private void PreviousUserPage()
    {
        if (CurrentUserPage > 1)
        {
            _currentUserPage = CurrentUserPage - 1;
        }
    }

    private void SetRoleFilter(string? role) => _roleFilter = role;

    private string GetFilterChipClass(string? role) =>
        string.Equals(_roleFilter, role, StringComparison.OrdinalIgnoreCase)
            ? "filter-chip filter-chip--active"
            : "filter-chip";

    private void StartCreate()
    {
        if (!CanManage)
        {
            Notifications.Warning(
                L("users.create.readonly.message", "Your role can view users but cannot create them."),
                L("users.readonly.title", "Read-only access"));
            return;
        }

        _inviteMode = false;
        _editingId = null;
        ResetForm();
    }

    private void StartInvite()
    {
        if (!CanManage)
        {
            Notifications.Warning(
                L("users.invite.readonly.message", "Your role can view users but cannot invite them."),
                L("users.readonly.title", "Read-only access"));
            return;
        }

        _inviteMode = true;
        _editingId = null;
        ResetForm();
        _formModel.Status = 0;
    }

    private void StartEdit(DashboardUserDto user)
    {
        if (!CanManage)
        {
            Notifications.Warning(
                L("users.edit.readonly.message", "Your role can view users but cannot edit them."),
                L("users.readonly.title", "Read-only access"));
            return;
        }

        _inviteMode = false;
        _editingId = user.Id;
        var snapshot = UserFormModel.FromDto(user);
        _formModel.Username = snapshot.Username;
        _formModel.Password = "";
        _formModel.FullName = snapshot.FullName;
        _formModel.Role = snapshot.Role;
        _formModel.Email = snapshot.Email;
        _formModel.Phone = snapshot.Phone;
        _formModel.Status = snapshot.Status;
    }

    private async Task SaveUserAsync()
    {
        if (!CanManage)
        {
            Notifications.Warning(
                L("users.save.readonly.message", "Your role can view users but cannot save changes."),
                L("users.readonly.title", "Read-only access"));
            return;
        }

        if (!_inviteMode && _editingId is null && string.IsNullOrWhiteSpace(_formModel.Password))
        {
            Notifications.Warning(
                L("users.validation.password-required.message", "Enter an initial password before creating a new user."),
                L("users.validation.password-required.title", "Password required"));
            return;
        }

        _isSaving = true;

        try
        {
            if (_inviteMode)
            {
                var inviteResult = await ApiClient.InviteUserAsync(_formModel);
                var inviteSubject = "Smart Tourism Admin Invitation";
                var inviteBody = BuildInviteEmailBody(inviteResult);
                await JS.InvokeVoidAsync("smartTourAdmin.mail.composeInvite", inviteResult.User.Email, inviteSubject, inviteBody);
                Notifications.Success(
                    L("users.invite.success.message", "Invitation created. A prefilled email draft was opened and the message body was copied to the clipboard."),
                    L("users.invite.success.title", "Invite ready"),
                    6000);
            }
            else if (_editingId is null)
            {
                await ApiClient.CreateUserAsync(_formModel);
                Notifications.Success(
                    L("users.save.created.message", "User created successfully."),
                    L("users.save.title", "User saved"));
            }
            else
            {
                await ApiClient.UpdateUserAsync(_editingId.Value, _formModel);
                Notifications.Success(
                    L("users.save.updated.message", "User updated successfully."),
                    L("users.save.title", "User saved"));
            }

            await LoadUsersAsync();
            ResetForm();
            _editingId = null;
            _inviteMode = false;
        }
        catch (Exception ex)
        {
            Notifications.Error(ex.Message, L("users.save.failed.title", "User save failed"));
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void HandleInvalidUserSubmit(EditContext editContext)
    {
        var message = editContext.GetValidationMessages()
            .Where(item => !string.IsNullOrWhiteSpace(item))
            .Distinct(StringComparer.Ordinal)
            .Take(3)
            .ToList();

        Notifications.Warning(
            message.Count == 0
                ? L("users.validation.generic", "Fix the highlighted user fields before saving.")
                : string.Join(" ", message),
            L("users.validation.title", "User form incomplete"));
    }

    private void PromptUserStatusChange(DashboardUserDto user)
    {
        if (!CanToggleUserStatus(user))
        {
            Notifications.Warning(GetActionDisabledReason(user), L("users.status.change-unavailable.title", "Status change unavailable"));
            return;
        }

        _pendingStatusUser = user;
        _pendingStatusValue = user.Status == 1 ? 0 : 1;
    }

    private async Task ConfirmPendingStatusAsync()
    {
        if (_pendingStatusUser is null)
        {
            return;
        }

        try
        {
            var updateModel = UserFormModel.FromDto(_pendingStatusUser);
            updateModel.Status = _pendingStatusValue;
            await ApiClient.UpdateUserAsync(_pendingStatusUser.Id, updateModel);
            Notifications.Info(
                LF("users.status.updated.message", "'{0}' is now {1}.", _pendingStatusUser.Username, GetStatusLabel(_pendingStatusValue).ToLowerInvariant()),
                L("users.status.updated.title", "User updated"));
            await LoadUsersAsync();
        }
        catch (Exception ex)
        {
            Notifications.Error(ex.Message, L("users.status.update-failed.title", "Status update failed"));
        }
        finally
        {
            CancelPendingStatus();
        }
    }

    private void CancelEdit()
    {
        _inviteMode = false;
        _editingId = null;
        ResetForm();
    }

    private void ResetForm()
    {
        _formModel.Username = "";
        _formModel.Password = "";
        _formModel.FullName = "";
        _formModel.Role = AdminRoles.User;
        _formModel.Email = "";
        _formModel.Phone = "";
        _formModel.Status = 1;
    }

    private void SetStatus(int status)
    {
        if (!CanSetFormStatus(status))
        {
            return;
        }

        _formModel.Status = status;
    }

    private void HandleRoleChanged()
    {
        if (_formModel.Status == 0 && !CanSetFormStatus(0))
        {
            _formModel.Status = 1;
        }
    }

    private string GetEditorTitle() => _inviteMode
        ? L("users.editor.title.invite", "Invite User")
        : _editingId is null
            ? L("users.editor.title.create", "Create User")
            : L("users.editor.title.edit", "Edit User");

    private string GetEditorSubtitle() => CanManage
        ? L("users.editor.subtitle.manage", "All buttons now call live API actions")
        : L("users.editor.subtitle.readonly", "Read-only for your current role");

    private string GetPasswordHint() => _inviteMode
        ? L("users.password.hint.invite", "The API generates a temporary password for invited users.")
        : _editingId is null
            ? L("users.password.hint.create", "Set an initial password for the new account.")
            : L("users.password.hint.edit", "Leave blank to keep the current password.");

    private string GetSaveButtonLabel() =>
        _isSaving
            ? L("users.save.saving", "Saving...")
            : _inviteMode
                ? L("users.save.invite", "Create Invitation")
                : _editingId is null
                    ? L("users.save.create", "Create User")
                    : L("users.save.update", "Save Changes");

    private static int GetAvatarHue(DashboardUserDto user) =>
        Math.Abs(HashCode.Combine(user.Username, user.Role)) % 360;

    private static string GetInitials(DashboardUserDto user)
    {
        var source = user.FullName ?? user.Username;
        var parts = source.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (parts.Length == 0)
        {
            return "ST";
        }

        return string.Concat(parts.Take(2).Select(part => char.ToUpperInvariant(part[0])));
    }

    private string GetMetaLine(DashboardUserDto user)
    {
        var parts = new List<string>();
        if (!string.IsNullOrWhiteSpace(user.Phone))
        {
            parts.Add(user.Phone);
        }

        parts.Add(LF("users.meta.created", "Created {0}", user.CreatedAt.ToString("dd/MM/yyyy", CultureInfo.CurrentCulture)));
        return string.Join(" · ", parts);
    }

    private string GetSummaryCardClass(string tone) => tone switch
    {
        "teal" => "summary-card summary-card--teal",
        "green" => "summary-card summary-card--green",
        "amber" => "summary-card summary-card--amber",
        "rose" => "summary-card summary-card--rose",
        _ => "summary-card"
    };

    private string GetRoleClass(string role) => role switch
    {
        "Admin" => "role-pill role-pill--dark",
        "Developer" => "role-pill role-pill--blue",
        _ => "role-pill role-pill--soft"
    };

    private string GetStatusClass(int status) => status == 1
        ? "status-pill status-pill--active"
        : "status-pill status-pill--locked";

    private string GetStatusLabel(int status) => status == 1
        ? L("status.active", "Active")
        : L("status.inactive", "Inactive");

    private string GetActionLabel(DashboardUserDto user) => user.Status == 1
        ? L("users.action.block", "Block")
        : L("users.action.unlock", "Unlock");

    private bool CanToggleUserStatus(DashboardUserDto user) =>
        CanManage && AdminRolePolicies.CanSetUserStatus(
            SessionState.Role,
            CurrentUserId,
            user.Id,
            user.Role,
            user.Status == 1 ? 0 : 1);

    private bool CanSetFormStatus(int status) =>
        CanManage && AdminRolePolicies.CanSetUserStatus(
            SessionState.Role,
            CurrentUserId,
            _editingId,
            _formModel.Role,
            status);

    private string GetActionDisabledReason(DashboardUserDto user)
    {
        if (!CanManage)
        {
            return L("users.action.disabled.no-manage", "Your role does not allow user management.");
        }

        if (user.Status == 0)
        {
            return string.Empty;
        }

        if (user.Id == CurrentUserId)
        {
            return L("users.action.disabled.self-block", "You cannot block your own account.");
        }

        return string.Equals(SessionState.Role, AdminRoles.Admin, StringComparison.OrdinalIgnoreCase)
            && string.Equals(user.Role, AdminRoles.Developer, StringComparison.OrdinalIgnoreCase)
                ? L("users.action.disabled.admin-vs-dev", "Admin accounts cannot block Developer accounts.")
                : string.Empty;
    }

    private string GetStatusEditorHint()
    {
        if (!CanManage)
        {
            return L("users.status.hint.readonly", "Your current role can review users but cannot change account status.");
        }

        if (CanSetFormStatus(0))
        {
            return L("users.status.hint.available", "Active and inactive status changes are available for this account.");
        }

        if (_editingId == CurrentUserId)
        {
            return L("users.action.disabled.self-block", "You cannot block your own account.");
        }

        return string.Equals(SessionState.Role, AdminRoles.Admin, StringComparison.OrdinalIgnoreCase)
            && string.Equals(_formModel.Role, AdminRoles.Developer, StringComparison.OrdinalIgnoreCase)
                ? L("users.status.hint.admin-vs-dev", "Admin accounts cannot set Developer accounts to inactive.")
                : L("users.status.hint.unavailable", "This account cannot be switched to inactive from your current role.");
    }

    private string GetPendingStatusTitle() =>
        _pendingStatusValue == 1
            ? L("users.dialog.status.unlock.title", "Unlock this account?")
            : L("users.dialog.status.block.title", "Block this account?");

    private string GetPendingStatusMessage() =>
        _pendingStatusUser is null
            ? string.Empty
            : _pendingStatusValue == 1
                ? LF("users.dialog.status.unlock.message", "'{0}' will be able to sign in again.", _pendingStatusUser.Username)
                : LF("users.dialog.status.block.message", "'{0}' will be blocked from signing in until another privileged user restores access.", _pendingStatusUser.Username);

    private string GetPendingStatusConfirmLabel() => _pendingStatusValue == 1
        ? L("users.dialog.status.unlock.confirm", "Unlock Account")
        : L("users.dialog.status.block.confirm", "Block Account");

    private void CancelPendingStatus()
    {
        _pendingStatusUser = null;
        _pendingStatusValue = 1;
    }

    private static string BuildInviteEmailBody(DashboardUserInviteResultDto inviteResult) =>
        $"""
        Hello {inviteResult.User.FullName ?? inviteResult.User.Username},

        Your Smart Tourism admin account is ready.

        Username: {inviteResult.User.Username}
        Temporary password: {inviteResult.TemporaryPassword}
        Role: {inviteResult.User.Role}

        Open the Smart Tourism admin web and sign in with these credentials, then change the password after your first login.
        """;

    private static string GetChipClass(int status, int currentStatus) => status == currentStatus
        ? "management-chip management-chip--selected"
        : "management-chip";

    private sealed record UserSummaryItem(string Label, string Value, string Copy, string Icon, string Tone);
}
