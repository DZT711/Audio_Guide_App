@page "/users"
@using BlazorApp_AdminWeb.Components.Layout

<PageTitle>User Management</PageTitle>

<div class="users-page">
    <section class="users-hero" data-reveal>
        <div>
            <span class="users-hero__eyebrow">Team &amp; Access</span>
            <h1>User Management</h1>
            <p>
                Review admins, owners, and onboarding progress with a cleaner layout,
                better status cues, and smoother hover interactions.
            </p>
        </div>

        <div class="users-hero__actions">
            <button class="btn btn-primary btn-lg" type="button">
                <i class="bi bi-person-plus me-2"></i>
                Add User
            </button>
            <button class="btn btn-outline-secondary btn-lg" type="button">
                <i class="bi bi-send me-2"></i>
                Invite by Email
            </button>
        </div>
    </section>

    <section class="users-toolbar" data-reveal>
        <label class="users-search" for="userSearch">
            <i class="bi bi-search"></i>
            <input id="userSearch" class="form-control" type="search" placeholder="Search by name or email">
        </label>

        <div class="users-filters">
            <button type="button" class="filter-chip filter-chip--active">All Users</button>
            <button type="button" class="filter-chip">Admins</button>
            <button type="button" class="filter-chip">Owners</button>
            <button type="button" class="filter-chip">Pending</button>
        </div>
    </section>

    <div class="row g-3" data-stagger data-stagger-step="80">
        @foreach (var summary in Summaries)
        {
            <div class="col-12 col-sm-6 col-xl-3">
                <article class="@GetSummaryCardClass(summary.Tone)" data-reveal>
                    <div class="summary-card__icon">
                        <i class="bi @summary.Icon"></i>
                    </div>
                    <div>
                        <span class="summary-card__label">@summary.Label</span>
                        <div class="summary-card__value">@summary.Value</div>
                        <p>@summary.Copy</p>
                    </div>
                </article>
            </div>
        }
    </div>

    <section class="users-table-card" data-reveal>
        <div class="users-table-card__header">
            <div>
                <span class="users-table-card__eyebrow">Directory</span>
                <h2>Active Team Members</h2>
            </div>
            <span class="users-table-card__count">@Users.Count users</span>
        </div>

        <div class="table-responsive">
            <table class="table users-table align-middle mb-0">
                <thead>
                    <tr>
                        <th>User</th>
                        <th>Contact</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Users)
                    {
                        <tr>
                            <td>
                                <div class="user-cell">
                                    <div class="user-avatar" style="@($"--avatar-hue:{user.AvatarHue};")">@user.Initials</div>
                                    <div class="user-cell__meta">
                                        <strong>@user.Name</strong>
                                        <span>@user.Location</span>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="user-contact">
                                    <span>@user.Email</span>
                                    <small>Last seen @user.LastSeen</small>
                                </div>
                            </td>
                            <td>
                                <span class="@GetRoleClass(user.Role)">@user.Role</span>
                            </td>
                            <td>
                                <span class="@GetStatusClass(user.Status)">@user.Status</span>
                            </td>
                            <td class="text-end">
                                <div class="row-actions justify-content-end">
                                    <button class="btn btn-sm btn-outline-secondary" type="button">Edit</button>
                                    <button class="btn btn-sm btn-outline-danger" type="button">@GetActionLabel(user)</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
</div>

@code {
    private readonly List<UserSummary> Summaries = new()
    {
        new UserSummary { Label = "Total Users", Value = "2,450", Copy = "Across all admin spaces", Icon = "bi-people", Tone = "teal" },
        new UserSummary { Label = "Active", Value = "1,980", Copy = "Signed in during the last 30 days", Icon = "bi-person-check", Tone = "green" },
        new UserSummary { Label = "Pending", Value = "450", Copy = "Waiting for onboarding approval", Icon = "bi-hourglass-split", Tone = "amber" },
        new UserSummary { Label = "Locked", Value = "20", Copy = "Accounts requiring manual action", Icon = "bi-shield-lock", Tone = "rose" }
    };

    private readonly List<UserItem> Users = new()
    {
        new UserItem { Name = "Amanda Harvey", Initials = "AH", Location = "Hanoi, Vietnam", Email = "amanda@example.com", Role = "Admin", Status = "Active", LastSeen = "2 mins ago", AvatarHue = 184 },
        new UserItem { Name = "Anne Richard", Initials = "AR", Location = "Da Nang, Vietnam", Email = "anne@example.com", Role = "Owner", Status = "Pending", LastSeen = "12 mins ago", AvatarHue = 224 },
        new UserItem { Name = "David Harrison", Initials = "DH", Location = "Ho Chi Minh City, Vietnam", Email = "david@example.com", Role = "Moderator", Status = "Active", LastSeen = "1 hour ago", AvatarHue = 154 },
        new UserItem { Name = "Finch Hoot", Initials = "FH", Location = "Hue, Vietnam", Email = "finch@example.com", Role = "Owner", Status = "Locked", LastSeen = "3 hours ago", AvatarHue = 344 },
        new UserItem { Name = "Bob Smith", Initials = "BS", Location = "Ninh Binh, Vietnam", Email = "bob@example.com", Role = "Owner", Status = "Active", LastSeen = "Yesterday", AvatarHue = 278 },
    };

    private string GetSummaryCardClass(string tone) => tone switch
    {
        "teal" => "summary-card summary-card--teal",
        "green" => "summary-card summary-card--green",
        "amber" => "summary-card summary-card--amber",
        "rose" => "summary-card summary-card--rose",
        _ => "summary-card"
    };

    private string GetRoleClass(string role) => role switch
    {
        "Admin" => "role-pill role-pill--dark",
        "Moderator" => "role-pill role-pill--blue",
        _ => "role-pill role-pill--soft"
    };

    private string GetStatusClass(string status) => status switch
    {
        "Active" => "status-pill status-pill--active",
        "Pending" => "status-pill status-pill--pending",
        "Locked" => "status-pill status-pill--locked",
        _ => "status-pill"
    };

    private string GetActionLabel(UserItem user) => user.Status == "Locked" ? "Unlock" : "Block";

    public class UserSummary
    {
        public string Label { get; set; } = "";
        public string Value { get; set; } = "";
        public string Copy { get; set; } = "";
        public string Icon { get; set; } = "";
        public string Tone { get; set; } = "";
    }

    public class UserItem
    {
        public string Name { get; set; } = "";
        public string Initials { get; set; } = "";
        public string Location { get; set; } = "";
        public string Email { get; set; } = "";
        public string Role { get; set; } = "";
        public string Status { get; set; } = "";
        public string LastSeen { get; set; } = "";
        public int AvatarHue { get; set; }
    }
}
