@page "/inbox"
@using System.Globalization
@inject AdminApiClient ApiClient
@inject InboxState InboxState
@inject NotificationService Notifications
@inject AdminSessionState SessionState
@inject AdminUiLanguageService LanguageService

<PageTitle>@L("page.inbox", "Inbox")</PageTitle>

@if (!CanView)
{
    <div class="management-page">
        <div class="management-error">
            <strong>@L("inbox.access.denied.title", "Access denied.")</strong>
            <div>@L("inbox.access.denied.desc", "Your current role cannot view inbox messages.")</div>
        </div>
    </div>
}
else
{
<div class="management-page inbox-page">
    <section class="management-hero" data-reveal>
        <div>
            <span class="management-hero__eyebrow">@L("inbox.hero.eyebrow", "Inbox")</span>
            <h1>@L("inbox.hero.title", "Announcements and Request Updates")</h1>
            <p>@L("inbox.hero.desc", "Track approval updates, rejection reasons, and future system announcements in one persistent inbox.")</p>
        </div>

        <div class="management-hero__actions">
            <button type="button" class="btn btn-outline-secondary btn-lg" @onclick="RefreshAsync" disabled="@_isLoading">
                <i class="bi bi-arrow-clockwise me-2"></i>
                @L("inbox.action.refresh", "Refresh")
            </button>
        </div>
    </section>

    <div class="management-stat-grid" data-stagger data-stagger-step="80">
        <article class="management-stat" data-reveal>
            <span class="management-stat__icon"><i class="bi bi-envelope-paper-fill"></i></span>
            <div>
                <strong class="management-stat__value">@_result.TotalCount</strong>
                <span class="management-stat__label">@L("inbox.stats.matching", "Matching Messages")</span>
            </div>
        </article>
        <article class="management-stat" data-reveal>
            <span class="management-stat__icon"><i class="bi bi-envelope-exclamation-fill"></i></span>
            <div>
                <strong class="management-stat__value">@_result.UnreadCount</strong>
                <span class="management-stat__label">@L("inbox.stats.unread", "Unread")</span>
            </div>
        </article>
        <article class="management-stat" data-reveal>
            <span class="management-stat__icon"><i class="bi bi-check-circle-fill"></i></span>
            <div>
                <strong class="management-stat__value">@_messages.Count(item => item.IsRead)</strong>
                <span class="management-stat__label">@L("inbox.stats.read-on-page", "Read On Page")</span>
            </div>
        </article>
        <article class="management-stat" data-reveal>
            <span class="management-stat__icon"><i class="bi bi-filter-circle-fill"></i></span>
            <div>
                <strong class="management-stat__value">@(_unreadOnly ? L("inbox.filter.unread", "Unread") : L("inbox.filter.all", "All"))</strong>
                <span class="management-stat__label">@L("inbox.stats.current-filter", "Current Filter")</span>
            </div>
        </article>
    </div>

    <section class="management-panel" data-reveal>
        @if (CanBroadcast)
        {
            <div class="inbox-broadcast">
                <div class="management-panel__header inbox-broadcast__header">
                    <div>
                        <span class="management-panel__eyebrow">@L("inbox.broadcast.eyebrow", "Broadcast")</span>
                        <h2>@L("inbox.broadcast.title", "System Announcement")</h2>
                        <p class="management-muted mb-0">@L("inbox.broadcast.desc", "Send one highlighted inbox message to every account, including Admin and Developer users.")</p>
                    </div>
                    <div class="inbox-broadcast__actions">
                        <span class="inbox-card__eyebrow">@L("inbox.broadcast.badge", "SYSTEM ANNOUNCEMENT")</span>
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ToggleBroadcastComposer">
                            <i class="bi @(_broadcastComposerOpen ? "bi-chevron-up" : "bi-chevron-down") me-1"></i>
                            @(_broadcastComposerOpen ? L("inbox.broadcast.collapse", "Collapse") : L("inbox.broadcast.open", "Open composer"))
                        </button>
                    </div>
                </div>

                @if (_broadcastComposerOpen)
                {
                    <div class="management-form__grid inbox-broadcast__grid">
                        <div class="management-field">
                            <label for="announcement-title">@L("inbox.broadcast.form.title.label", "Highlighted Title")</label>
                            <InputText id="announcement-title" class="form-control" @bind-Value="_announcementTitle" />
                            <span class="management-field__hint">@L("inbox.broadcast.form.title.hint", "This title is emphasized in every recipient inbox.")</span>
                        </div>

                        <div class="management-field management-field--full">
                            <label for="announcement-body">@L("inbox.broadcast.form.message.label", "Message")</label>
                            <InputTextArea id="announcement-body" class="form-control" rows="5" @bind-Value="_announcementBody" />
                        </div>
                    </div>

                    <div class="management-actions">
                        <button type="button" class="btn btn-primary" disabled="@_isSendingAnnouncement" @onclick="SendAnnouncementAsync">
                            @(_isSendingAnnouncement ? L("inbox.broadcast.sending", "Sending...") : L("inbox.broadcast.send", "Send Announcement"))
                        </button>
                    </div>
                }
            </div>
        }

        <div class="management-panel__header">
            <div>
                <span class="management-panel__eyebrow">@L("inbox.messages.eyebrow", "Messages")</span>
                <h2>@L("inbox.messages.title", "Inbox Feed")</h2>
            </div>

            <div class="management-toolbar">
                <button type="button" class="@GetFilterChipClass(false)" @onclick="() => SetUnreadFilterAsync(false)">@L("inbox.filter.all", "All")</button>
                <button type="button" class="@GetFilterChipClass(true)" @onclick="() => SetUnreadFilterAsync(true)">@L("inbox.filter.unread-only", "Unread Only")</button>
            </div>
        </div>

        @if (_isLoading)
        {
            <div class="moderation-skeleton-list">
                @for (var i = 0; i < 4; i++)
                {
                    <article class="moderation-skeleton-card">
                        <div class="skeleton skeleton--title"></div>
                        <div class="skeleton skeleton--line"></div>
                        <div class="skeleton skeleton--line skeleton--line-short"></div>
                    </article>
                }
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(_loadError))
        {
            <div class="management-error">
                <strong>@L("inbox.load.failed.title", "Unable to load inbox messages.")</strong>
                <div>@_loadError</div>
            </div>
        }
        else if (_messages.Count == 0)
        {
            <div class="app-empty-state">
                @L("inbox.empty.filtered", "No inbox messages match the current filter.")
            </div>
        }
        else
        {
            <div class="management-page-swap" @key="_result.Page">
                <div class="inbox-list">
                    @foreach (var message in _messages)
                    {
                        <article class="@GetMessageCardClass(message)">
                            <div class="inbox-card__header">
                                <div>
                                    @if (IsAnnouncement(message))
                                    {
                                        <div class="inbox-card__eyebrow">@L("inbox.broadcast.badge", "SYSTEM ANNOUNCEMENT")</div>
                                    }
                                    <div class="inbox-card__title">@message.Title</div>
                                    <small>@message.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</small>
                                </div>

                                <div class="inbox-card__meta">
                                    <span class="@GetMessageTagClass(message.MessageType)">@TranslateMessageType(message.MessageType)</span>
                                    @if (!message.IsRead)
                                    {
                                        <span class="management-status management-status--pending">@L("inbox.stats.unread", "Unread")</span>
                                    }
                                </div>
                            </div>

                            <p class="audio-card__description">@message.Body</p>

                            <div class="inbox-card__footer">
                                <small class="management-muted">@GetMessageContext(message)</small>
                                <div class="management-inline-actions">
                                    @if (!message.IsRead)
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => MarkReadAsync(message)">@L("inbox.action.mark-read", "Mark Read")</button>
                                    }
                                    else
                                    {
                                        <span class="management-muted">@L("inbox.status.read-prefix", "Read") @message.ReadAt?.ToLocalTime().ToString("dd MMM HH:mm")</span>
                                    }
                                </div>
                            </div>
                        </article>
                    }
                </div>
            </div>

            @if (_result.TotalPages > 1)
            {
                <div class="management-pagination">
                    <span class="management-pagination__info">@LF("inbox.pagination.info", "Page {0} of {1} ({2} total messages)", _result.Page, _result.TotalPages, _result.TotalCount)</span>
                    <div class="management-pagination__actions">
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="PreviousPageAsync" disabled="@(_result.Page <= 1)">
                            <i class="bi bi-chevron-left"></i> @L("inbox.pagination.previous", "Previous")
                        </button>
                        <div class="management-pagination__pages">
                            @foreach (var pageNumber in GetVisiblePages())
                            {
                                <button type="button"
                                        class="@GetPaginationButtonClass(pageNumber == _result.Page)"
                                        @onclick="() => GoToPageAsync(pageNumber)"
                                        disabled="@(pageNumber == _result.Page)">
                                    @pageNumber
                                </button>
                            }
                        </div>
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="NextPageAsync" disabled="@(_result.Page >= _result.TotalPages)">
                            @L("inbox.pagination.next", "Next") <i class="bi bi-chevron-right"></i>
                        </button>
                    </div>
                </div>
            }
        }
    </section>
</div>
}

@code {
    private string L(string key, string fallback) => LanguageService.T(key, fallback);
    private string LF(string key, string fallback, params object?[] args) =>
        string.Format(CultureInfo.CurrentCulture, L(key, fallback), args);
    private readonly List<InboxMessageDto> _messages = new();
    private InboxOverviewDto _result = new();
    private bool _isLoading = true;
    private bool _isSendingAnnouncement;
    private bool _broadcastComposerOpen;
    private bool _unreadOnly;
    private int _currentPage = 1;
    private string _announcementTitle = "";
    private string _announcementBody = "";
    private string? _loadError;

    private bool CanView => SessionState.HasPermission(AdminPermissions.InboxView);
    private bool CanBroadcast => SessionState.HasPermission(AdminPermissions.ModerationManage);

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task RefreshAsync() => await LoadAsync();

    private void ToggleBroadcastComposer() => _broadcastComposerOpen = !_broadcastComposerOpen;

    private async Task SetUnreadFilterAsync(bool unreadOnly)
    {
        _unreadOnly = unreadOnly;
        _currentPage = 1;
        await LoadAsync();
    }

    private async Task NextPageAsync()
    {
        if (_result.Page >= _result.TotalPages)
        {
            return;
        }

        _currentPage = _result.Page + 1;
        await LoadAsync();
    }

    private async Task PreviousPageAsync()
    {
        if (_result.Page <= 1)
        {
            return;
        }

        _currentPage = _result.Page - 1;
        await LoadAsync();
    }

    private async Task GoToPageAsync(int pageNumber)
    {
        if (pageNumber < 1 || pageNumber > _result.TotalPages || pageNumber == _result.Page)
        {
            return;
        }

        _currentPage = pageNumber;
        await LoadAsync();
    }

    private async Task MarkReadAsync(InboxMessageDto message)
    {
        try
        {
            await ApiClient.MarkInboxMessageReadAsync(message.Id);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Notifications.Error(ex.Message, L("inbox.update.failed.title", "Unable to update inbox"));
        }
    }

    private async Task SendAnnouncementAsync()
    {
        var title = _announcementTitle.Trim();
        var body = _announcementBody.Trim();

        if (string.IsNullOrWhiteSpace(title))
        {
            Notifications.Warning(
                L("inbox.broadcast.validation.title-required.message", "Enter a highlighted announcement title before sending."),
                L("inbox.broadcast.validation.title-required.title", "Title required"));
            return;
        }

        if (string.IsNullOrWhiteSpace(body))
        {
            Notifications.Warning(
                L("inbox.broadcast.validation.message-required.message", "Enter an announcement message before sending."),
                L("inbox.broadcast.validation.message-required.title", "Message required"));
            return;
        }

        _isSendingAnnouncement = true;

        try
        {
            await ApiClient.CreateInboxAnnouncementAsync(new InboxAnnouncementRequest
            {
                Title = title,
                Body = body
            });

            _announcementTitle = "";
            _announcementBody = "";
            Notifications.Success(
                L("inbox.broadcast.success.message", "The system announcement was sent to every inbox."),
                L("inbox.broadcast.success.title", "Announcement sent"));
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Notifications.Error(ex.Message, L("inbox.broadcast.failed.title", "Announcement failed"));
        }
        finally
        {
            _isSendingAnnouncement = false;
        }
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _loadError = null;

        try
        {
            _result = await ApiClient.GetInboxAsync(new InboxQueryDto
            {
                Page = _currentPage,
                PageSize = 10,
                UnreadOnly = _unreadOnly
            });

            _currentPage = _result.Page;
            _messages.Clear();
            _messages.AddRange(_result.Items);
            InboxState.UpdateUnreadCount(_result.UnreadCount);
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
            Notifications.Error(ex.Message, L("inbox.load.failed.toast", "Inbox load failed"));
        }
        finally
        {
            _isLoading = false;
        }
    }

    private string GetFilterChipClass(bool unreadOnly) =>
        unreadOnly == _unreadOnly
            ? "management-chip management-chip--selected"
            : "management-chip";

    private static string GetMessageCardClass(InboxMessageDto message) =>
        string.Join(" ", new[]
        {
            "moderation-card",
            "inbox-card",
            !message.IsRead ? "inbox-card--unread" : null,
            IsAnnouncement(message) ? "inbox-card--announcement" : null
        }.Where(item => !string.IsNullOrWhiteSpace(item)));

    private static string GetMessageTagClass(string messageType) => messageType switch
    {
        "Approval" => "management-status management-status--active",
        "Rejection" => "management-status management-status--inactive",
        "Announcement" => "management-status management-status--info inbox-card__type--announcement",
        _ => "management-status management-status--info"
    };

    private static bool IsAnnouncement(InboxMessageDto message) =>
        string.Equals(message.MessageType, "Announcement", StringComparison.OrdinalIgnoreCase);

    private string GetMessageContext(InboxMessageDto message) =>
        IsAnnouncement(message)
            ? L("inbox.context.announcement", "System announcement for all dashboard accounts")
            : message.RelatedRequestId is null
                ? L("inbox.context.general", "General announcement")
                : LF("inbox.context.request", "Request #{0}", message.RelatedRequestId);

    private string TranslateMessageType(string? messageType) => messageType switch
    {
        "Approval" => L("inbox.message-type.approval", "Approval"),
        "Rejection" => L("inbox.message-type.rejection", "Rejection"),
        "Announcement" => L("inbox.message-type.announcement", "Announcement"),
        _ => messageType ?? string.Empty
    };

    private IReadOnlyList<int> GetVisiblePages()
    {
        const int maxButtons = 5;
        var start = Math.Max(1, _result.Page - 2);
        var end = Math.Min(_result.TotalPages, start + maxButtons - 1);
        start = Math.Max(1, end - maxButtons + 1);
        return Enumerable.Range(start, end - start + 1).ToList();
    }

    private static string GetPaginationButtonClass(bool isActive) =>
        isActive
            ? "management-pagination__page management-pagination__page--active"
            : "management-pagination__page";
}
