@page "/poi"
@implements IAsyncDisposable
@inject AdminApiClient ApiClient
@inject NotificationService Notifications
@inject IJSRuntime JS
@using Microsoft.AspNetCore.Components.Forms
@using System.IO
@using System.Text.Json.Serialization
@using Project_SharedClassLibrary.Constants
@inject AdminSessionState SessionState

<PageTitle>Location Management</PageTitle>

@if (!CanView)
{
    <div class="management-page poi-page">
        <div class="management-error">
            <strong>Access denied.</strong>
            <div>Your current role cannot view locations.</div>
        </div>
    </div>
}
else
{
<div class="management-page poi-page">
    <section class="management-hero" data-reveal>
        <div>
            <span class="management-hero__eyebrow">Locations</span>
            <h1>Location Management</h1>
            <p>
                Manage tourism destinations directly through the API, including category assignment,
                coordinates, contact information, and published status.
            </p>
        </div>

        <div class="management-hero__actions">
            @if (CanEditContent)
            {
                <button type="button" class="btn btn-primary btn-lg" @onclick="StartCreateAsync">
                    @(CanManage ? "New POI" : "Request New POI")
                </button>
            }
            <button type="button" class="btn btn-outline-secondary btn-lg" @onclick="RefreshAsync" disabled="@_isLoading">
                <i class="bi bi-arrow-clockwise me-2"></i>
                Refresh
            </button>
        </div>
    </section>

    <div class="management-stat-grid" data-stagger data-stagger-step="80">
        <article class="management-stat" data-reveal>
            <span class="management-stat__icon"><i class="bi bi-geo-alt"></i></span>
            <div>
                <strong class="management-stat__value">@_locations.Count</strong>
                <span class="management-stat__label">Total Locations</span>
            </div>
        </article>
        <article class="management-stat" data-reveal>
            <span class="management-stat__icon"><i class="bi bi-check2-circle"></i></span>
            <div>
                <strong class="management-stat__value">@_locations.Count(item => item.Status == 1)</strong>
                <span class="management-stat__label">Active</span>
            </div>
        </article>
        <article class="management-stat" data-reveal>
            <span class="management-stat__icon"><i class="bi bi-diagram-3"></i></span>
            <div>
                <strong class="management-stat__value">@CategoryOptions.Count()</strong>
                <span class="management-stat__label">Linked Categories</span>
            </div>
        </article>
        <article class="management-stat" data-reveal>
            <span class="management-stat__icon"><i class="bi bi-search"></i></span>
            <div>
                <strong class="management-stat__value">@FilteredLocations.Count()</strong>
                <span class="management-stat__label">Matching Search</span>
            </div>
        </article>
    </div>

    <div class="management-layout @(CanEditContent ? "poi-layout--editor-modal" : string.Empty)">
        <section class="management-panel" data-reveal>
            <div class="management-panel__header">
                <div>
                    <span class="management-panel__eyebrow">Directory</span>
                    <h2>Tourism Locations</h2>
                </div>

                <div class="management-toolbar">
                    <label class="management-search">
                        <i class="bi bi-search"></i>
                        <input class="form-control" type="search" placeholder="Search locations..." @bind="_searchText" @bind:event="oninput" />
                    </label>

                    <select class="form-select management-filter" @bind="_selectedCategoryName">
                        <option value="">All categories</option>
                        @foreach (var categoryName in CategoryOptions)
                        {
                            <option value="@categoryName">@categoryName</option>
                        }
                    </select>

                    <select class="form-select management-filter" @bind="_selectedStatus">
                        <option value="">All statuses</option>
                        <option value="1">Active</option>
                        <option value="0">Inactive</option>
                    </select>
                </div>
            </div>

            @if (_isLoading)
            {
                <div class="table-responsive">
                    <div class="poi-skeleton-table">
                        @for (var i = 0; i < 4; i++)
                        {
                            <div class="skeleton-table-row">
                                <div class="skeleton skeleton--line"></div>
                                <div class="skeleton skeleton--line"></div>
                                <div class="skeleton skeleton--line"></div>
                                <div class="skeleton skeleton--line"></div>
                            </div>
                        }
                    </div>
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(_loadError))
            {
                <div class="management-error">
                    <strong>Unable to load locations.</strong>
                    <div>@_loadError</div>
                </div>
            }
            else if (!FilteredLocations.Any())
            {
                <div class="app-empty-state">
                    No locations match the current filters.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table management-table">
                        <thead>
                            <tr>
                                <th>Avatar</th>
                                <th>Name</th>
                                <th>Category</th>
                                <th>Address</th>
                                <th>Coordinates</th>
                                <th>Status</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var location in PagedLocations)
                            {
                                <tr class="@GetRowClass(location.Status)">
                                    <td>
                                        <div class="poi-list-avatar">
                                            @if (GetLocationAvatarUrl(location) is { } avatarUrl)
                                            {
                                                <img class="poi-list-avatar__image" src="@avatarUrl" alt="@($"{location.Name} avatar")" />
                                            }
                                            else
                                            {
                                                <span class="poi-list-avatar__placeholder">
                                                    <i class="bi bi-image"></i>
                                                </span>
                                            }
                                        </div>
                                    </td>
                                    <td>
                                        <div class="poi-name">@location.Name</div>
                                        <small class="management-muted">@(string.IsNullOrWhiteSpace(location.OwnerName) ? "No owner assigned" : location.OwnerName)</small>
                                    </td>
                                    <td>@location.Category</td>
                                    <td>@(string.IsNullOrWhiteSpace(location.Address) ? "No address" : location.Address)</td>
                                    <td>@($"{location.Latitude:F4}, {location.Longitude:F4}")</td>
                                    <td>
                                        <span class="@GetStatusClass(location.Status)">@GetStatusLabel(location.Status)</span>
                                    </td>
                                    <td class="text-end">
                                        <div class="management-inline-actions">
                                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => StartEditAsync(location)">@(CanEditContent ? "Edit" : "View")</button>
                                            <button type="button" class="btn btn-sm btn-outline-danger" disabled="@(!CanManage && !CanSubmitRequests || location.Status == 0)" @onclick="() => PromptArchiveLocation(location)">
                                                @(location.Status == 0 ? "Inactive" : CanManage ? "Archive" : "Request Archive")
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (TotalLocationPages > 1)
                {
                    <div class="management-pagination">
                        <span class="management-pagination__info">Page @CurrentLocationPage of @TotalLocationPages (@FilteredLocations.Count() total locations)</span>
                        <div class="management-pagination__actions">
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="PreviousLocationPage" disabled="@(CurrentLocationPage <= 1)">
                                <i class="bi bi-chevron-left"></i> Previous
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="NextLocationPage" disabled="@(CurrentLocationPage >= TotalLocationPages)">
                                Next <i class="bi bi-chevron-right"></i>
                            </button>
                        </div>
                    </div>
                }
            }
        </section>

        <div class="@GetEditorShellClass()" @onclick="HandleEditorBackdropClick" aria-hidden="@(CanEditContent && !_isEditorOpen)">
        <section class="@GetEditorPanelClass()" data-reveal role="@(CanEditContent ? "dialog" : null)" aria-modal="@(CanEditContent ? "true" : null)" aria-labelledby="poi-editor-title" @onclick:stopPropagation="true">
            <div class="management-panel__header poi-editor__header">
                <div>
                    <span class="management-panel__eyebrow">@(CanEditContent ? (CanManage ? "Editor" : "Submission") : "Read Only")</span>
                    <h2 id="poi-editor-title">@(CanEditContent ? (_editingId is null ? "Create Location" : "Edit Location") : "Location Details")</h2>
                    @if (CanEditContent)
                    {
                        <p class="poi-editor__subtitle">Open the POI editor in a focused modal while keeping the location dataset visible behind it.</p>
                    }
                </div>
                @if (CanEditContent)
                {
                    <button type="button" class="btn-close" aria-label="Close POI editor" @onclick="CancelEditAsync"></button>
                }
            </div>

            @if (CanEditContent)
            {
            <EditForm Model="_formModel" OnValidSubmit="SaveLocationAsync" OnInvalidSubmit="HandleInvalidLocationSubmit" class="management-form">
                <DataAnnotationsValidator />

                <div class="poi-editor__summary">
                    <div class="poi-editor__summary-copy">
                        <span class="poi-editor__summary-kicker">@(_editingId is null ? "New Location Draft" : "Editing Existing POI")</span>
                        <strong>@(string.IsNullOrWhiteSpace(_formModel.Name) ? "Untitled POI" : _formModel.Name)</strong>
                        <small>@GetEditorCategorySummary()</small>
                    </div>
                    <div class="poi-editor__summary-badges">
                        <span class="poi-editor__badge">@(CanManage ? "Direct Save" : "Approval Request")</span>
                        <span class="poi-editor__badge">@(_editingId is null ? "Create" : "Edit")</span>
                        <span class="poi-editor__badge">@GetStatusLabel(_formModel.Status)</span>
                    </div>
                </div>

                <div class="poi-editor-tabs" role="tablist" aria-label="POI editor sections">
                    <button type="button" class='@GetEditorTabClass("basic")' @onclick='() => SetEditorTab("basic")'>
                        <i class="bi bi-info-circle"></i>
                        <span>Basic Info</span>
                    </button>
                    <button type="button" class='@GetEditorTabClass("details")' @onclick='() => SetEditorTab("details")'>
                        <i class="bi bi-layers"></i>
                        <span>Details</span>
                    </button>
                    <button type="button" class='@GetEditorTabClass("media")' @onclick='() => SetEditorTab("media")'>
                        <i class="bi bi-image"></i>
                        <span>Media</span>
                    </button>
                    <button type="button" class='@GetEditorTabClass("settings")' @onclick='() => SetEditorTab("settings")'>
                        <i class="bi bi-sliders"></i>
                        <span>Settings</span>
                    </button>
                </div>

                <div class="poi-editor-sections">
                    @if (IsEditorTabActive("basic"))
                    {
                    <section class="poi-editor-section">
                        <div class="poi-editor-section__header">
                            <h3>Basic Info</h3>
                            <p>The main identity, address, and summary shown in POI lists and detail screens.</p>
                        </div>
                        <div class="management-form__grid">
                    <div class="management-field">
                        <label for="location-name">Name</label>
                        <InputText id="location-name" class="form-control" @bind-Value="_formModel.Name" />
                        <ValidationMessage For="() => _formModel.Name" />
                    </div>

                    <div class="management-field">
                        <label for="location-category">Category</label>
                        <InputSelect id="location-category" class="form-select" @bind-Value="_formModel.CategoryId">
                            <option value="0">Choose category</option>
                            @foreach (var category in ActiveCategories)
                            {
                                <option value="@category.Id">@category.Name</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="() => _formModel.CategoryId" />
                        <span class="management-field__hint">@GetCategoryFieldHint()</span>
                    </div>

                    <div class="management-field management-field--full">
                        <label for="location-address">Address</label>
                        <InputText id="location-address" class="form-control" @bind-Value="_formModel.Address" />
                        <ValidationMessage For="() => _formModel.Address" />
                    </div>

                    <div class="management-field management-field--full">
                        <div class="location-picker">
                            <div class="location-picker__header">
                                <div>
                                    <span class="management-field__label">OpenStreetMap Picker</span>
                                    <div class="management-field__hint">Drag the pin or click the map to auto-fill the address, latitude, and longitude.</div>
                                </div>

                                <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="CenterMapOnCoordinatesAsync">
                                    <i class="bi bi-crosshair me-1"></i>
                                    Center On Coordinates
                                </button>
                                <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="UseDeviceLocationAsync">
                                    <i class="bi bi-geo-alt me-1"></i>
                                    Use My Device Location
                                </button>
                            </div>

                            <div class="location-picker__search">
                                <label class="location-picker__search-box" for="location-map-search">
                                    <i class="bi bi-search"></i>
                                    <input id="location-map-search"
                                           class="form-control"
                                           type="search"
                                           placeholder="Search a landmark, street, or address on the map"
                                           @bind="_mapSearchText"
                                           @bind:event="oninput" />
                                </label>

                                <button type="button"
                                        class="btn btn-outline-secondary btn-sm"
                                        @onclick="SearchMapAsync"
                                        disabled="@(_isMapSearching || string.IsNullOrWhiteSpace(_mapSearchText))">
                                    <i class="bi @(_isMapSearching ? "bi-hourglass-split" : "bi-search") me-1"></i>
                                    @(_isMapSearching ? "Searching..." : "Find Place")
                                </button>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(_mapSearchError))
                            {
                                <div class="location-picker__search-feedback" aria-live="polite">@_mapSearchError</div>
                            }
                            else if (_mapSearchResults.Count > 0)
                            {
                                <div class="location-picker__results" aria-live="polite">
                                    @foreach (var result in _mapSearchResults)
                                    {
                                        <button type="button" class="location-picker__result" @onclick="() => SelectMapSearchResultAsync(result)">
                                            <strong>@GetMapSearchResultTitle(result)</strong>
                                            @if (!string.IsNullOrWhiteSpace(result.Address))
                                            {
                                                <small>@result.Address</small>
                                            }
                                            <span class="location-picker__coords">@($"{result.Latitude:F6}, {result.Longitude:F6}")</span>
                                        </button>
                                    }
                                </div>
                            }

                            <div class="location-picker__map" @ref="_mapElement"></div>
                        </div>
                    </div>

                    <div class="management-field management-field--full">
                        <label for="location-description">Description</label>
                        <InputTextArea id="location-description" class="form-control" rows="4" @bind-Value="_formModel.Description" />
                        <ValidationMessage For="() => _formModel.Description" />
                    </div>

                        </div>
                    </section>
                    }

                    @if (IsEditorTabActive("details"))
                    {
                    <section class="poi-editor-section">
                        <div class="poi-editor-section__header">
                            <h3>Details</h3>
                            <p>Coordinates, ownership, contact, and trigger settings for the selected POI.</p>
                        </div>
                        <div class="management-form__grid">

                    <div class="management-field">
                        <label for="location-year">Established Year</label>
                        <InputNumber id="location-year" class="form-control" @bind-Value="_formModel.EstablishedYear" />
                        <ValidationMessage For="() => _formModel.EstablishedYear" />
                    </div>

                    <div class="management-field">
                        <label for="location-owner">Owner</label>
                        @if (CanSelectOwner)
                        {
                            <InputSelect id="location-owner" class="form-select" @bind-Value="_formModel.OwnerId">
                                <option value="">Unassigned</option>
                                @foreach (var owner in _owners)
                                {
                                    <option value="@owner.Id">@($"{owner.FullName ?? owner.Username} ({owner.Role})")</option>
                                }
                            </InputSelect>
                        }
                        else
                        {
                            <div class="management-muted">This location will stay assigned to your current account.</div>
                        }
                    </div>

                    <div class="management-field">
                        <label for="location-lat">Latitude</label>
                        <InputNumber id="location-lat" class="form-control" @bind-Value="_formModel.Latitude" />
                        <ValidationMessage For="() => _formModel.Latitude" />
                    </div>

                    <div class="management-field">
                        <label for="location-lng">Longitude</label>
                        <InputNumber id="location-lng" class="form-control" @bind-Value="_formModel.Longitude" />
                        <ValidationMessage For="() => _formModel.Longitude" />
                    </div>

                    <div class="management-field">
                        <label for="location-radius">Trigger Radius (m)</label>
                        <InputNumber id="location-radius" class="form-control" @bind-Value="_formModel.Radius" />
                        <ValidationMessage For="() => _formModel.Radius" />
                    </div>

                    <div class="management-field">
                        <label for="location-standby-radius">Standby Radius (m)</label>
                        <InputNumber id="location-standby-radius" class="form-control" @bind-Value="_formModel.StandbyRadius" />
                        <ValidationMessage For="() => _formModel.StandbyRadius" />
                    </div>

                    <div class="management-field">
                        <label for="location-priority">Priority</label>
                        <InputNumber id="location-priority" class="form-control" @bind-Value="_formModel.Priority" />
                        <ValidationMessage For="() => _formModel.Priority" />
                    </div>

                    <div class="management-field">
                        <label for="location-debounce">Cooldown (sec)</label>
                        <InputNumber id="location-debounce" class="form-control" @bind-Value="_formModel.DebounceSeconds" />
                        <ValidationMessage For="() => _formModel.DebounceSeconds" />
                    </div>

                    <div class="management-field">
                        <label for="location-web">Website</label>
                        <InputText id="location-web" class="form-control" @bind-Value="_formModel.WebURL" />
                        <ValidationMessage For="() => _formModel.WebURL" />
                    </div>

                    <div class="management-field">
                        <label for="location-phone">Phone</label>
                        <InputText id="location-phone" class="form-control" @bind-Value="_formModel.Phone" />
                        <ValidationMessage For="() => _formModel.Phone" />
                    </div>

                    <div class="management-field management-field--full">
                        <label for="location-email">Email</label>
                        <InputText id="location-email" class="form-control" @bind-Value="_formModel.Email" />
                        <ValidationMessage For="() => _formModel.Email" />
                    </div>

                        </div>
                    </section>
                    }

                    @if (IsEditorTabActive("media"))
                    {
                    <section class="poi-editor-section">
                        <div class="poi-editor-section__header">
                            <h3>Media</h3>
                            <p>Upload the preference image and gallery photos that will appear across the app.</p>
                        </div>
                        <div class="management-form__grid">

                    <div class="management-field management-field--full">
                        <label for="location-preference-image">Preference Image</label>
                        <InputFile @key="_preferenceImageInputVersion" id="location-preference-image" class="form-control" OnChange="HandlePreferenceImageSelected" accept="image/*" />
                        <ValidationMessage For="() => _formModel.PreferenceImageFile" />
                        <span class="management-field__hint">Required. This image becomes the POI avatar in lists, tours, and moderation details.</span>
                    </div>

                    <div class="management-field management-field--full">
                        <div class="poi-image-preview">
                            <div>
                                <span class="management-field__label">Preference Image Preview</span>
                                <div class="management-field__hint">@GetPreferenceImagePreviewHint()</div>
                            </div>

                            @if (_isPreparingImagePreview)
                            {
                                <div class="management-muted">Preparing image previews...</div>
                            }
                            else if (GetPreferenceImagePreviewUrl() is { } preferencePreviewUrl)
                            {
                                <div class="poi-preference-preview">
                                    <div class="poi-image-tile poi-image-tile--feature">
                                        <img class="poi-image-thumb" src="@preferencePreviewUrl" alt="Preference location image" />
                                        @if (_formModel.PreferenceImageFile is not null)
                                        {
                                            <button type="button" class="poi-image-remove" title="Revert preference image" aria-label="Revert preference image" @onclick="RemovePendingPreferenceImageAsync">
                                                <i class="bi bi-arrow-counterclockwise"></i>
                                            </button>
                                        }
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="management-muted">Upload a preference image to set the POI avatar.</div>
                            }
                        </div>
                    </div>

                    <div class="management-field management-field--full">
                        <label for="location-images">Additional Gallery Images</label>
                        <InputFile @key="_imageInputVersion" id="location-images" class="form-control" OnChange="HandleLocationImagesSelected" accept="image/*" multiple />
                        <span class="management-field__hint">Upload one or more extra images. Each new selection is added to the current upload queue.</span>
                        <span class="management-field__hint">Use the `X` button on a preview tile to remove a stored image or cancel a pending upload before saving.</span>
                    </div>

                    <div class="management-field management-field--full">
                        <div class="poi-image-preview">
                            <div>
                                <span class="management-field__label">Gallery Preview</span>
                                <div class="management-field__hint">@GetImagePreviewHint()</div>
                            </div>

                            @if (_isPreparingImagePreview)
                            {
                                <div class="management-muted">Preparing image previews...</div>
                            }
                            else if (_formModel.ExistingImageUrls.Count > 0 || _imagePreviewUrls.Count > 0)
                            {
                                <div class="poi-image-grid">
                                    @foreach (var storedImageUrl in _formModel.ExistingImageUrls)
                                    {
                                        var resolvedStoredImageUrl = ApiClient.ResolveImageUrl(storedImageUrl);
                                        if (string.IsNullOrWhiteSpace(resolvedStoredImageUrl))
                                        {
                                            continue;
                                        }

                                        <div class="poi-image-tile">
                                            <img class="poi-image-thumb" src="@resolvedStoredImageUrl" alt="Stored location image" />
                                            <button type="button" class="poi-image-remove" title="Remove image" aria-label="Remove image" @onclick="() => RemoveStoredImage(storedImageUrl)">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        </div>
                                    }

                                    @for (var imageIndex = 0; imageIndex < _formModel.ImageFiles.Count; imageIndex++)
                                    {
                                        var currentImageIndex = imageIndex;
                                        var pendingImage = _formModel.ImageFiles[imageIndex];
                                        var previewUrl = imageIndex < _imagePreviewUrls.Count
                                            ? _imagePreviewUrls[imageIndex]
                                            : null;

                                        <div class="poi-image-tile">
                                            @if (!string.IsNullOrWhiteSpace(previewUrl))
                                            {
                                                <img class="poi-image-thumb" src="@previewUrl" alt="@($"New location image {pendingImage.Name}")" />
                                            }
                                            else
                                            {
                                                <div class="poi-image-thumb poi-image-thumb--placeholder" title="@pendingImage.Name">
                                                    <span>@pendingImage.Name</span>
                                                </div>
                                            }
                                            <button type="button" class="poi-image-remove" title="Remove upload" aria-label="Remove upload" @onclick="() => RemovePendingImageAsync(currentImageIndex)">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="management-muted">Upload extra images or edit a location that already has stored gallery photos.</div>
                            }
                        </div>
                    </div>

                        </div>
                    </section>
                    }

                    @if (IsEditorTabActive("settings"))
                    {
                    <section class="poi-editor-section">
                        <div class="poi-editor-section__header">
                            <h3>Publishing</h3>
                            <p>Finish trigger behavior and live status before saving or submitting the request.</p>
                        </div>
                        <div class="management-form__grid">

                    <div class="management-field management-field--full">
                        <span class="management-field__label">GPS Trigger</span>
                        <div class="management-chip-group">
                            <button type="button" class="@GetBoolChipClass(true, _formModel.IsGpsTriggerEnabled)" @onclick="() => SetGpsTrigger(true)">Enabled</button>
                            <button type="button" class="@GetBoolChipClass(false, _formModel.IsGpsTriggerEnabled)" @onclick="() => SetGpsTrigger(false)">Disabled</button>
                        </div>
                    </div>

                    <div class="management-field management-field--full">
                        <span class="management-field__label">Status</span>
                        <div class="management-chip-group">
                            <button type="button" class="@GetChipClass(1, _formModel.Status)" @onclick="() => SetStatus(1)">Active</button>
                            <button type="button" class="@GetChipClass(0, _formModel.Status)" @onclick="() => SetStatus(0)">Inactive</button>
                        </div>
                    </div>

                    @if (CanSubmitRequests && !CanManage)
                    {
                        <div class="management-field management-field--full">
                            <label for="location-request-reason">Submission Note</label>
                            <InputTextArea id="location-request-reason" class="form-control" rows="3" @bind-Value="_submissionReason" />
                            <span class="management-field__hint">Optional note for Admin or Developer review.</span>
                        </div>
                    }
                        </div>
                    </section>
                    }
                </div>

                <div class="management-actions">
                    <button type="submit" class="btn btn-primary" disabled="@(_isSaving || !HasActiveCategories || !CanEditContent)">
                        @GetSaveButtonLabel()
                    </button>
                    <button type="button" class="btn btn-outline-secondary" @onclick="CancelEditAsync">@(_editingId is null ? "Close" : "Cancel")</button>
                </div>
            </EditForm>
            }
            else if (SelectedLocationForDisplay is null)
            {
                <div class="app-empty-state">
                    Select a location to review its details.
                </div>
            }
            else
            {
                var selectedLocation = SelectedLocationForDisplay!;
                var imageUrls = GetResolvedImageUrls(selectedLocation);

                <div class="poi-readonly">
                    <div class="poi-readonly__notice">
                        This role can review location details only.
                    </div>

                    @if (imageUrls.Count > 0)
                    {
                        <div class="poi-image-grid">
                            @foreach (var imageUrl in imageUrls)
                            {
                                <img class="poi-image-thumb" src="@imageUrl" alt="@selectedLocation.Name" />
                            }
                        </div>
                    }

                    <div class="poi-detail-grid">
                        <article class="poi-detail-card">
                            <span>Name</span>
                            <strong>@selectedLocation.Name</strong>
                            <small>@selectedLocation.Category</small>
                        </article>
                        <article class="poi-detail-card">
                            <span>Status</span>
                            <strong>@GetStatusLabel(selectedLocation.Status)</strong>
                            <small>@(selectedLocation.OwnerName ?? "No owner assigned")</small>
                        </article>
                        <article class="poi-detail-card poi-detail-card--wide">
                            <span>Address</span>
                            <strong>@(string.IsNullOrWhiteSpace(selectedLocation.Address) ? "No address" : selectedLocation.Address)</strong>
                        </article>
                        <article class="poi-detail-card">
                            <span>Coordinates</span>
                            <strong>@($"{selectedLocation.Latitude:F6}, {selectedLocation.Longitude:F6}")</strong>
                            <small>@($"{selectedLocation.Radius:F0}m trigger / {selectedLocation.StandbyRadius:F0}m standby")</small>
                        </article>
                        <article class="poi-detail-card">
                            <span>Priority</span>
                            <strong>@selectedLocation.Priority</strong>
                            <small>@($"{selectedLocation.DebounceSeconds}s cooldown")</small>
                        </article>
                        <article class="poi-detail-card">
                            <span>Contact</span>
                            <strong>@(string.IsNullOrWhiteSpace(selectedLocation.Phone) ? "No phone" : selectedLocation.Phone)</strong>
                            <small>@(string.IsNullOrWhiteSpace(selectedLocation.Email) ? "No email" : selectedLocation.Email)</small>
                        </article>
                        <article class="poi-detail-card poi-detail-card--wide">
                            <span>Description</span>
                            <strong>@(string.IsNullOrWhiteSpace(selectedLocation.Description) ? "No description provided." : selectedLocation.Description)</strong>
                        </article>
                        <article class="poi-detail-card">
                            <span>Website</span>
                            <strong>@(string.IsNullOrWhiteSpace(selectedLocation.WebURL) ? "No website" : selectedLocation.WebURL)</strong>
                        </article>
                        <article class="poi-detail-card">
                            <span>Audio</span>
                            <strong>@selectedLocation.AudioCount linked files</strong>
                            <small>@(selectedLocation.IsGpsTriggerEnabled ? "GPS trigger enabled" : "GPS trigger disabled")</small>
                        </article>
                    </div>
                </div>
            }
        </section>
        </div>
    </div>
</div>

<AdminConfirmDialog Visible="@(_pendingArchivedLocation is not null)"
                    Eyebrow="@(CanManage ? "Archive Location" : "Request Archive")"
                    Title="@(CanManage ? "Archive this location?" : "Submit an archive request?")"
                    Message="@GetPendingArchiveLocationMessage()"
                    ConfirmLabel="@(CanManage ? "Archive Location" : "Submit Request")"
                    ConfirmButtonClass="btn btn-danger"
                    OnConfirm="ConfirmArchiveLocationAsync"
                    OnCancel="CancelArchiveLocation">
    @if (CanSubmitRequests && !CanManage)
    {
        <div class="management-field">
            <label for="poi-archive-reason">Submission Note</label>
            <InputTextArea id="poi-archive-reason" class="form-control" rows="3" @bind-Value="_archiveReason" />
            <span class="management-field__hint">Optional note for the reviewer.</span>
        </div>
    }
</AdminConfirmDialog>
}

@code {
    private const double DefaultLatitude = LocationDefaults.District4Latitude;
    private const double DefaultLongitude = LocationDefaults.District4Longitude;
    private const long MaxLocationImageBytes = 15L * 1024 * 1024;
    private const int MaxQueuedGalleryImages = 24;
    private const int MaxPreviewableGalleryImages = 6;
    private readonly LocationFormModel _formModel = new();
    private readonly List<LocationDto> _locations = new();
    private readonly List<CategoryDto> _categories = new();
    private readonly List<DashboardUserDto> _owners = new();
    private readonly List<string?> _imagePreviewUrls = new();
    private readonly List<MapSearchResult> _mapSearchResults = new();
    private readonly HashSet<string> _imageObjectUrls = new(StringComparer.OrdinalIgnoreCase);
    private string? _preferenceImagePreviewUrl;
    private string? _preferenceImageObjectUrl;
    private DotNetObjectReference<POIList>? _mapReference;
    private LocationDto? _selectedLocation;
    private LocationDto? _pendingArchivedLocation;
    private bool _isLoading = true;
    private bool _isSaving;
    private bool _isEditorOpen;
    private bool _isPreparingImagePreview;
    private bool _isMapSearching;
    private bool _deviceLocationPending = true;
    private bool _mapInitializationPending = true;
    private bool _mapSyncPending;
    private bool? _bodyScrollLockState;
    private int _imageInputVersion;
    private int _preferenceImageInputVersion;
    private int? _editingId;
    private string _editorTab = "basic";
    private string _searchText = "";
    private string _mapSearchText = "";
    private string _selectedCategoryName = "";
    private string _selectedStatus = "";
    private string _submissionReason = "";
    private string _archiveReason = "";
    private string? _loadError;
    private string? _mapSearchError;
    private ElementReference _mapElement;
    private bool CanView => SessionState.HasPermission(AdminPermissions.LocationRead);
    private bool CanManage => SessionState.HasPermission(AdminPermissions.LocationManage);
    private bool CanSubmitRequests => SessionState.HasPermission(AdminPermissions.LocationRequest);
    private bool CanEditContent => CanManage || CanSubmitRequests;
    private bool CanSelectOwner => SessionState.HasPermission(AdminPermissions.UserRead) && CanManage;
    private LocationDto? SelectedLocationForDisplay => ResolveSelectedLocation();
    private int _currentLocationPage = 1;
    private const int LocationsPerPage = 8;
    private IEnumerable<CategoryDto> ActiveCategories => _categories
        .Where(item => item.Status == 1)
        .OrderBy(item => item.Name);
    private bool HasActiveCategories => ActiveCategories.Any();
    private IEnumerable<string> CategoryOptions => _categories.Count > 0
        ? _categories.Select(item => item.Name)
        : _locations
            .Select(item => item.Category)
            .Where(item => !string.IsNullOrWhiteSpace(item))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(item => item, StringComparer.OrdinalIgnoreCase);

    private IEnumerable<LocationDto> FilteredLocations =>
        _locations.Where(location =>
                string.IsNullOrWhiteSpace(_searchText)
                || location.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase)
                || (location.Address?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false)
                || location.Category.Contains(_searchText, StringComparison.OrdinalIgnoreCase))
            .Where(location =>
                string.IsNullOrWhiteSpace(_selectedCategoryName)
                || string.Equals(location.Category, _selectedCategoryName, StringComparison.OrdinalIgnoreCase))
            .Where(location =>
                string.IsNullOrWhiteSpace(_selectedStatus)
                || location.Status.ToString() == _selectedStatus);
    private int TotalLocationPages => Math.Max(1, (int)Math.Ceiling((double)FilteredLocations.Count() / LocationsPerPage));
    private int CurrentLocationPage => Math.Min(Math.Max(_currentLocationPage, 1), TotalLocationPages);
    private IReadOnlyList<LocationDto> PagedLocations => FilteredLocations
        .Skip((CurrentLocationPage - 1) * LocationsPerPage)
        .Take(LocationsPerPage)
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        ResetForm();
        await RefreshLocationImagePreviewsAsync();
        await LoadDataAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && CanEditContent)
        {
            _mapReference = DotNetObjectReference.Create(this);
        }

        if (CanEditContent && _isEditorOpen && IsEditorTabActive("basic") && _mapInitializationPending)
        {
            _mapInitializationPending = false;
            await InitializeMapAsync();
            _mapSyncPending = true;
        }

        if (CanEditContent && _isEditorOpen && IsEditorTabActive("basic") && _mapSyncPending)
        {
            _mapSyncPending = false;
            await SyncMapAsync();
        }

        if (CanEditContent && _deviceLocationPending && _editingId is null)
        {
            _deviceLocationPending = false;
            await TryUseDeviceLocationAsync(showFallbackNotice: false);
        }

        if (CanEditContent && _bodyScrollLockState != _isEditorOpen)
        {
            await SyncBodyScrollLockAsync(_isEditorOpen);
        }
    }

    private async Task RefreshAsync() => await LoadDataAsync();

    private async Task LoadDataAsync()
    {
        _isLoading = true;
        _loadError = null;

        try
        {
            var categoriesTask = CanEditContent || SessionState.HasPermission(AdminPermissions.CategoryRead)
                ? ApiClient.GetCategoriesAsync()
                : Task.FromResult<IReadOnlyList<CategoryDto>>([]);
            var locationsTask = ApiClient.GetLocationsAsync();
            var ownersTask = CanSelectOwner
                ? ApiClient.GetUsersAsync()
                : Task.FromResult<IReadOnlyList<DashboardUserDto>>([]);

            await Task.WhenAll(categoriesTask, locationsTask, ownersTask);

            _categories.Clear();
            _categories.AddRange((await categoriesTask)
                .OrderByDescending(item => item.Status)
                .ThenBy(item => item.Name));

            _locations.Clear();
            _locations.AddRange((await locationsTask)
                .OrderByDescending(item => item.Status)
                .ThenBy(item => item.Name));

            _owners.Clear();
            _owners.AddRange((await ownersTask)
                .Where(item => item.Status == 1)
                .OrderBy(item => item.FullName ?? item.Username));

            EnsureFormCategorySelection();
            SyncSelectedLocation();
            _currentLocationPage = 1;
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
            Notifications.Error(ex.Message, "Location load failed");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void NextLocationPage()
    {
        if (CurrentLocationPage < TotalLocationPages)
        {
            _currentLocationPage = CurrentLocationPage + 1;
        }
    }

    private void PreviousLocationPage()
    {
        if (CurrentLocationPage > 1)
        {
            _currentLocationPage = CurrentLocationPage - 1;
        }
    }

    private async Task InitializeMapAsync()
    {
        try
        {
            var isInitialized = await JS.InvokeAsync<bool>(
                "smartTourAdmin.map.initializeLocationPicker",
                _mapElement,
                _mapReference,
                _formModel.Latitude,
                _formModel.Longitude);

            if (!isInitialized)
            {
                Notifications.Warning("The OpenStreetMap picker is unavailable right now.", "Map unavailable");
            }
            else
            {
                _mapSyncPending = false;
            }
        }
        catch (JSException)
        {
            Notifications.Warning("The OpenStreetMap picker is unavailable right now.", "Map unavailable");
        }
    }

    private async Task SyncMapAsync()
    {
        try
        {
            await JS.InvokeAsync<bool>(
                "smartTourAdmin.map.syncLocationPicker",
                _mapElement,
                _formModel.Latitude,
                _formModel.Longitude);
        }
        catch (JSException)
        {
        }
    }

    private async Task SyncBodyScrollLockAsync(bool isLocked)
    {
        try
        {
            await JS.InvokeVoidAsync("smartTourAdmin.shell.setBodyScrollLock", isLocked);
            _bodyScrollLockState = isLocked;
        }
        catch (JSException)
        {
        }
        catch (TaskCanceledException)
        {
        }
    }

    private async Task CenterMapOnCoordinatesAsync() => await SyncMapAsync();

    private async Task SearchMapAsync()
    {
        var query = _mapSearchText.Trim();
        _mapSearchResults.Clear();
        _mapSearchError = null;

        if (string.IsNullOrWhiteSpace(query))
        {
            _mapSearchError = "Enter a landmark, street, or address to search the map.";
            return;
        }

        _isMapSearching = true;

        try
        {
            var results = await JS.InvokeAsync<MapSearchResult[]>(
                "smartTourAdmin.map.searchLocationPicker",
                query);

            _mapSearchResults.Clear();
            _mapSearchResults.AddRange(results
                .Where(item => item.HasCoordinates)
                .Take(6));

            if (_mapSearchResults.Count == 0)
            {
                _mapSearchError = $"No places were found for '{query}'.";
            }
        }
        catch (JSException)
        {
            _mapSearchError = "Map search is unavailable right now.";
        }
        finally
        {
            _isMapSearching = false;
        }
    }

    private async Task SelectMapSearchResultAsync(MapSearchResult result)
    {
        _formModel.Latitude = Math.Round(result.Latitude, 6);
        _formModel.Longitude = Math.Round(result.Longitude, 6);

        if (!string.IsNullOrWhiteSpace(result.Address))
        {
            _formModel.Address = result.Address.Length > 500 ? result.Address[..500] : result.Address;
            _mapSearchText = _formModel.Address;
        }
        else if (!string.IsNullOrWhiteSpace(result.Name))
        {
            _mapSearchText = result.Name;
        }

        _mapSearchResults.Clear();
        _mapSearchError = null;
        await SyncMapAsync();
    }

    private async Task StartCreateAsync()
    {
        _isEditorOpen = CanEditContent;
        _editorTab = "basic";
        _mapInitializationPending = true;
        _editingId = null;
        _selectedLocation = null;
        ResetForm();
        await RefreshLocationImagePreviewsAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task StartEditAsync(LocationDto location)
    {
        _selectedLocation = location;

        if (!CanEditContent)
        {
            _editingId = null;
            return;
        }

        _isEditorOpen = true;
        _editorTab = "basic";
        _mapInitializationPending = true;
        _editingId = location.Id;
        _deviceLocationPending = false;
        var snapshot = LocationFormModel.FromDto(location, _categories);
        ApplyForm(snapshot);
        ResetMapSearchState(snapshot.Address ?? snapshot.Name);
        await RefreshLocationImagePreviewsAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task SaveLocationAsync()
    {
        if (!CanEditContent)
        {
            Notifications.Warning("Your role can view locations but cannot save changes.", "Read-only access");
            return;
        }

        _isSaving = true;

        try
        {
            if (CanManage && _editingId is null)
            {
                await ApiClient.CreateLocationAsync(_formModel);
                Notifications.Success("Location created successfully.", "Location saved");
            }
            else if (CanManage && _editingId is int editingId)
            {
                await ApiClient.UpdateLocationAsync(editingId, _formModel);
                Notifications.Success("Location updated successfully.", "Location saved");
            }
            else
            {
                await ApiClient.SubmitLocationChangeRequestAsync(
                    _formModel,
                    _editingId is null ? "CREATE" : "UPDATE",
                    _editingId,
                    _submissionReason);
                Notifications.Success(
                    _editingId is null
                        ? "Your new POI request was submitted for Admin or Developer approval."
                        : "Your POI update request was submitted for Admin or Developer approval.",
                    "Request submitted");
            }

            await LoadDataAsync();
            await CloseEditorAsync(clearSelectedLocation: false);
        }
        catch (Exception ex)
        {
            Notifications.Error(ex.Message, "Location save failed");
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void HandleInvalidLocationSubmit(EditContext editContext)
    {
        var message = editContext.GetValidationMessages()
            .Where(item => !string.IsNullOrWhiteSpace(item))
            .Distinct(StringComparer.Ordinal)
            .Take(3)
            .ToList();

        Notifications.Warning(
            message.Count == 0
                ? "Fix the highlighted POI fields before saving."
                : string.Join(" ", message),
            "Location form incomplete");
    }

    private void PromptArchiveLocation(LocationDto location)
    {
        if (!CanManage && !CanSubmitRequests)
        {
            Notifications.Warning("Your role can view locations but cannot archive them.", "Read-only access");
            return;
        }

        _pendingArchivedLocation = location;
    }

    private async Task ConfirmArchiveLocationAsync()
    {
        if ((!CanManage && !CanSubmitRequests) || _pendingArchivedLocation is null)
        {
            return;
        }

        try
        {
            if (CanManage)
            {
                await ApiClient.DeleteLocationAsync(_pendingArchivedLocation.Id);
                Notifications.Info($"'{_pendingArchivedLocation.Name}' is now inactive.", "Location archived");
            }
            else
            {
                await ApiClient.SubmitLocationChangeRequestAsync(
                    LocationFormModel.FromDto(_pendingArchivedLocation, _categories),
                    "DELETE",
                    _pendingArchivedLocation.Id,
                    _archiveReason);
                Notifications.Info($"Archive request for '{_pendingArchivedLocation.Name}' was submitted for approval.", "Request submitted");
            }

            await LoadDataAsync();

            if (_editingId == _pendingArchivedLocation.Id)
            {
                await CloseEditorAsync(clearSelectedLocation: true);
            }
        }
        catch (Exception ex)
        {
            Notifications.Error(ex.Message, "Delete failed");
        }
        finally
        {
            CancelArchiveLocation();
        }
    }

    private void ResetForm()
    {
        _editorTab = "basic";
        _mapInitializationPending = true;
        ApplyForm(new LocationFormModel
        {
            EstablishedYear = DateTime.UtcNow.Year,
            Latitude = DefaultLatitude,
            Longitude = DefaultLongitude,
            Radius = 30,
            StandbyRadius = 12,
            DebounceSeconds = 300,
            IsGpsTriggerEnabled = true,
            Status = 1
        });
        ResetMapSearchState();
        _submissionReason = "";
        _archiveReason = "";
        _deviceLocationPending = CanEditContent;
    }

    private async Task CancelEditAsync()
    {
        await CloseEditorAsync(clearSelectedLocation: true);
    }

    private async Task CloseEditorAsync(bool clearSelectedLocation)
    {
        _isEditorOpen = false;
        _editorTab = "basic";
        _mapInitializationPending = true;
        _editingId = null;

        if (clearSelectedLocation)
        {
            _selectedLocation = null;
        }

        ResetForm();
        await RefreshLocationImagePreviewsAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleEditorBackdropClick()
    {
        if (!CanEditContent || !_isEditorOpen)
        {
            return;
        }

        await CancelEditAsync();
    }

    private void ApplyForm(LocationFormModel model)
    {
        _formModel.Name = model.Name;
        _formModel.Address = model.Address;
        _formModel.CategoryId = model.CategoryId;
        _formModel.OwnerId = model.OwnerId;
        _formModel.EstablishedYear = model.EstablishedYear;
        _formModel.Description = model.Description;
        _formModel.Latitude = model.Latitude;
        _formModel.Longitude = model.Longitude;
        _formModel.Radius = model.Radius;
        _formModel.StandbyRadius = model.StandbyRadius;
        _formModel.Priority = model.Priority;
        _formModel.DebounceSeconds = model.DebounceSeconds;
        _formModel.IsGpsTriggerEnabled = model.IsGpsTriggerEnabled;
        _formModel.WebURL = model.WebURL;
        _formModel.Phone = model.Phone;
        _formModel.Email = model.Email;
        _formModel.Status = model.Status;
        _formModel.ExistingPreferenceImageUrl = model.ExistingPreferenceImageUrl;
        _formModel.PreferenceImageFile = null;
        _formModel.ExistingImageUrls = model.ExistingImageUrls.ToList();
        _formModel.ImageFiles = [];
        EnsureFormCategorySelection();
        _imageInputVersion++;
        _preferenceImageInputVersion++;
        _mapSyncPending = CanEditContent;
    }

    private async Task UseDeviceLocationAsync() => await TryUseDeviceLocationAsync(showFallbackNotice: true);

    private async Task HandlePreferenceImageSelected(InputFileChangeEventArgs eventArgs)
    {
        _formModel.PreferenceImageFile = await BufferLocationImageAsync(eventArgs.File, "Preference image");
        _preferenceImageInputVersion++;
        await RefreshLocationImagePreviewsAsync();
    }

    private async Task HandleLocationImagesSelected(InputFileChangeEventArgs eventArgs)
    {
        IReadOnlyList<IBrowserFile> selectedFiles;

        try
        {
            selectedFiles = eventArgs.GetMultipleFiles(MaxQueuedGalleryImages);
        }
        catch (InvalidOperationException)
        {
            Notifications.Warning(
                $"Select up to {MaxQueuedGalleryImages} gallery images at a time.",
                "Too many gallery images");
            _imageInputVersion++;
            return;
        }

        var remainingSlots = MaxQueuedGalleryImages - _formModel.ImageFiles.Count;
        if (remainingSlots <= 0)
        {
            Notifications.Info(
                $"The gallery upload queue already has {MaxQueuedGalleryImages} image(s). Remove one before adding more.",
                "Gallery queue full");
            _imageInputVersion++;
            return;
        }

        var nextFiles = _formModel.ImageFiles.ToList();
        foreach (var browserFile in selectedFiles.Take(remainingSlots))
        {
            var bufferedFile = await BufferLocationImageAsync(browserFile, "Gallery image");
            if (bufferedFile is not null)
            {
                nextFiles.Add(bufferedFile);
            }
        }

        if (selectedFiles.Count > remainingSlots)
        {
            Notifications.Info(
                $"Only {remainingSlots} more gallery image(s) fit in the current queue.",
                "Gallery queue trimmed");
        }

        _formModel.ImageFiles = nextFiles;
        _imageInputVersion++;
        await RefreshLocationImagePreviewsAsync();
    }

    private async Task RemovePendingPreferenceImageAsync()
    {
        if (!CanEditContent)
        {
            return;
        }

        _formModel.PreferenceImageFile = null;
        _preferenceImageInputVersion++;
        await RefreshLocationImagePreviewsAsync();
    }

    private void RemoveStoredImage(string imageUrl)
    {
        if (!CanEditContent)
        {
            return;
        }

        _formModel.ExistingImageUrls = _formModel.ExistingImageUrls
            .Where(item => !string.Equals(item, imageUrl, StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

    private async Task RemovePendingImageAsync(int imageIndex)
    {
        if (!CanEditContent)
        {
            return;
        }

        var nextFiles = _formModel.ImageFiles.ToList();
        if (imageIndex < 0 || imageIndex >= nextFiles.Count)
        {
            return;
        }

        nextFiles.RemoveAt(imageIndex);
        _formModel.ImageFiles = nextFiles;
        _imageInputVersion++;
        await RefreshLocationImagePreviewsAsync();
    }

    private async Task TryUseDeviceLocationAsync(bool showFallbackNotice)
    {
        try
        {
            var usedDeviceLocation = await JS.InvokeAsync<bool>(
                "smartTourAdmin.map.tryUseDeviceLocation",
                _mapElement,
                DefaultLatitude,
                DefaultLongitude);

            if (!usedDeviceLocation && showFallbackNotice)
            {
                Notifications.Info(
                    $"Device location is unavailable, so the pin was placed at {LocationDefaults.District4Label}.",
                    "Using default location");
            }
        }
        catch (JSException)
        {
            if (showFallbackNotice)
            {
                Notifications.Warning(
                    $"The browser could not access device location. The pin remains at {LocationDefaults.District4Label}.",
                    "Location unavailable");
            }
        }
    }

    private void SetStatus(int status) => _formModel.Status = status;

    private string GetCategoryFieldHint()
    {
        if (!HasActiveCategories)
        {
            return "Activate or create at least one category before saving a location.";
        }

        return _formModel.CategoryId > 0
            ? "Only active categories are available for location assignments."
            : "Archived categories are hidden. Choose an active category before saving.";
    }

    private void SetGpsTrigger(bool isEnabled) => _formModel.IsGpsTriggerEnabled = isEnabled;

    private string GetImagePreviewHint()
    {
        if (_formModel.ImageFiles.Count > 0)
        {
            return _formModel.ImageFiles.Count > MaxPreviewableGalleryImages
                ? $"{_formModel.ImageFiles.Count} gallery image file(s) queued for upload. Showing inline previews for the first {MaxPreviewableGalleryImages}."
                : $"{_formModel.ImageFiles.Count} gallery image file(s) queued for upload.";
        }

        if (_formModel.ExistingImageUrls.Count > 0)
        {
            return $"{_formModel.ExistingImageUrls.Count} stored gallery image(s) linked to this location.";
        }

        return "Stored gallery images and newly selected uploads are previewed here.";
    }

    private List<string> GetResolvedImageUrls(LocationDto? location) =>
        location?.ImageUrls
            .Select(ApiClient.ResolveImageUrl)
            .Where(item => !string.IsNullOrWhiteSpace(item))
            .Cast<string>()
            .ToList() ?? [];

    private string? GetPreferenceImagePreviewUrl()
    {
        if (!string.IsNullOrWhiteSpace(_preferenceImagePreviewUrl))
        {
            return _preferenceImagePreviewUrl;
        }

        return string.IsNullOrWhiteSpace(_formModel.ExistingPreferenceImageUrl)
            ? null
            : ApiClient.ResolveImageUrl(_formModel.ExistingPreferenceImageUrl);
    }

    private string GetPreferenceImagePreviewHint()
    {
        if (_formModel.PreferenceImageFile is not null)
        {
            return $"Previewing the new preference image: {_formModel.PreferenceImageFile.Name}";
        }

        if (!string.IsNullOrWhiteSpace(_formModel.ExistingPreferenceImageUrl))
        {
            return "This stored image is the current POI avatar.";
        }

        return "A preference image is required for each POI.";
    }

    private string? GetLocationAvatarUrl(LocationDto? location)
    {
        if (location is null)
        {
            return null;
        }

        return ApiClient.ResolveImageUrl(location.PreferenceImageUrl ?? location.CoverImageUrl);
    }

    private LocationDto? ResolveSelectedLocation()
    {
        if (_selectedLocation is not null)
        {
            return _locations.FirstOrDefault(item => item.Id == _selectedLocation.Id) ?? _selectedLocation;
        }

        return FilteredLocations.FirstOrDefault() ?? _locations.FirstOrDefault();
    }

    private void SyncSelectedLocation()
    {
        if (_selectedLocation is not null)
        {
            _selectedLocation = _locations.FirstOrDefault(item => item.Id == _selectedLocation.Id);
        }

        if (!CanEditContent && _selectedLocation is null)
        {
            _selectedLocation = _locations.FirstOrDefault();
        }
    }

    private async Task RefreshLocationImagePreviewsAsync()
    {
        _isPreparingImagePreview = true;

        try
        {
            await ClearLocationImagePreviewsAsync();
            var previewUnavailable = false;

            if (_formModel.PreferenceImageFile is not null)
            {
                _preferenceImagePreviewUrl = await TryCreateImagePreviewUrlAsync(_formModel.PreferenceImageFile);
                previewUnavailable |= string.IsNullOrWhiteSpace(_preferenceImagePreviewUrl);
                _preferenceImageObjectUrl = _preferenceImagePreviewUrl;
            }

            foreach (var imageFile in _formModel.ImageFiles.Take(MaxPreviewableGalleryImages))
            {
                var objectUrl = await TryCreateImagePreviewUrlAsync(imageFile);
                previewUnavailable |= string.IsNullOrWhiteSpace(objectUrl);
                _imagePreviewUrls.Add(objectUrl);

                if (!string.IsNullOrWhiteSpace(objectUrl))
                {
                    _imageObjectUrls.Add(objectUrl);
                }
            }

            while (_imagePreviewUrls.Count < _formModel.ImageFiles.Count)
            {
                _imagePreviewUrls.Add(null);
            }

            if (previewUnavailable)
            {
                Notifications.Warning("Some location images could not be previewed, but you can still save them.", "Preview unavailable");
            }
        }
        catch (Exception ex) when (ex is JSException or TaskCanceledException)
        {
            Notifications.Warning("Some location images could not be previewed, but you can still save them.", "Preview unavailable");
        }
        finally
        {
            _isPreparingImagePreview = false;
        }
    }

    private async Task<BufferedUploadFile?> BufferLocationImageAsync(IBrowserFile? browserFile, string imageRole)
    {
        if (browserFile is null)
        {
            return null;
        }

        var displayName = Path.GetFileName(browserFile.Name);
        if (browserFile.Size > MaxLocationImageBytes)
        {
            Notifications.Warning(
                $"{displayName} is larger than 15 MB. Choose a smaller image and try again.",
                $"{imageRole} too large");
            return null;
        }

        try
        {
            await using var sourceStream = browserFile.OpenReadStream(MaxLocationImageBytes);
            using var memoryStream = new MemoryStream();
            await sourceStream.CopyToAsync(memoryStream);

            return new BufferedUploadFile
            {
                Name = displayName,
                ContentType = browserFile.ContentType,
                Content = memoryStream.ToArray()
            };
        }
        catch (Exception ex) when (ex is IOException or InvalidOperationException or JSException or TaskCanceledException)
        {
            Notifications.Warning(
                $"{displayName} could not be added to the upload queue. Try selecting it again.",
                $"{imageRole} unavailable");
            return null;
        }
    }

    private async Task<string?> TryCreateImagePreviewUrlAsync(BufferedUploadFile file)
    {
        if (file.Content.Length == 0)
        {
            return null;
        }

        try
        {
            await using var sourceStream = new MemoryStream(file.Content, writable: false);
            using var streamReference = new DotNetStreamReference(sourceStream);

            return await JS.InvokeAsync<string>(
                "smartTourAdmin.filePreview.createObjectUrlFromStream",
                streamReference,
                file.ContentType);
        }
        catch (Exception ex) when (ex is JSException or IOException or InvalidOperationException or TaskCanceledException)
        {
            return null;
        }
    }

    private async Task ClearLocationImagePreviewsAsync()
    {
        if (!string.IsNullOrWhiteSpace(_preferenceImageObjectUrl))
        {
            try
            {
                await JS.InvokeVoidAsync("smartTourAdmin.filePreview.revokeObjectUrl", _preferenceImageObjectUrl);
            }
            catch (JSException)
            {
            }
        }

        foreach (var objectUrl in _imageObjectUrls)
        {
            try
            {
                await JS.InvokeVoidAsync("smartTourAdmin.filePreview.revokeObjectUrl", objectUrl);
            }
            catch (JSException)
            {
            }
        }

        _preferenceImageObjectUrl = null;
        _preferenceImagePreviewUrl = null;
        _imageObjectUrls.Clear();
        _imagePreviewUrls.Clear();
    }

    [JSInvokable]
    public Task ApplyLocationFromMap(double latitude, double longitude, string? address)
    {
        _formModel.Latitude = Math.Round(latitude, 6);
        _formModel.Longitude = Math.Round(longitude, 6);
        _mapSearchResults.Clear();
        _mapSearchError = null;

        if (!string.IsNullOrWhiteSpace(address))
        {
            _formModel.Address = address.Length > 500 ? address[..500] : address;
            _mapSearchText = _formModel.Address;
        }

        return InvokeAsync(StateHasChanged);
    }

    private void ResetMapSearchState(string? query = null)
    {
        _mapSearchResults.Clear();
        _mapSearchError = null;
        _isMapSearching = false;
        _mapSearchText = query ?? "";
    }

    private static string GetMapSearchResultTitle(MapSearchResult result)
    {
        if (!string.IsNullOrWhiteSpace(result.Name))
        {
            return result.Name;
        }

        if (!string.IsNullOrWhiteSpace(result.Address))
        {
            return result.Address;
        }

        return "Map result";
    }

    private static string GetStatusClass(int status) => status == 1
        ? "management-status management-status--active"
        : "management-status management-status--inactive";

    private static string GetStatusLabel(int status) => status == 1 ? "Active" : "Inactive";

    private static string GetRowClass(int status) => status == 1
        ? string.Empty
        : "poi-row--inactive";

    private static string GetChipClass(int status, int currentStatus) => status == currentStatus
        ? "management-chip management-chip--selected"
        : "management-chip";

    private static string GetBoolChipClass(bool value, bool currentValue) => value == currentValue
        ? "management-chip management-chip--selected"
        : "management-chip";

    private string GetEditorShellClass() =>
        CanEditContent
            ? _isEditorOpen
                ? "poi-editor-shell poi-editor-shell--modal poi-editor-shell--open"
                : "poi-editor-shell poi-editor-shell--modal"
            : "poi-editor-shell";

    private string GetEditorPanelClass() =>
        CanEditContent
            ? "management-panel app-modal-panel poi-editor poi-editor--modal"
            : "management-panel poi-editor";

    private void SetEditorTab(string tabId)
    {
        _editorTab = tabId;

        if (string.Equals(tabId, "basic", StringComparison.OrdinalIgnoreCase))
        {
            _mapInitializationPending = true;
            _mapSyncPending = true;
        }
    }

    private bool IsEditorTabActive(string tabId) =>
        string.Equals(_editorTab, tabId, StringComparison.OrdinalIgnoreCase);

    private string GetEditorTabClass(string tabId) =>
        IsEditorTabActive(tabId)
            ? "poi-editor-tab poi-editor-tab--active"
            : "poi-editor-tab";

    private string GetEditorCategorySummary()
    {
        if (_formModel.CategoryId <= 0)
        {
            return "Choose a category and complete each section before saving.";
        }

        return _categories.FirstOrDefault(item => item.Id == _formModel.CategoryId)?.Name
            ?? "Category selected";
    }

    private string GetSaveButtonLabel()
    {
        if (_isSaving)
        {
            return CanManage ? "Saving..." : "Submitting...";
        }

        if (CanManage)
        {
            return _editingId is null ? "Create Location" : "Save Changes";
        }

        return _editingId is null ? "Submit New POI" : "Submit Update Request";
    }

    private void EnsureFormCategorySelection()
    {
        if (_categories.Count == 0)
        {
            _formModel.CategoryId = 0;
            return;
        }

        var isActiveCategorySelected = _categories.Any(item =>
            item.Status == 1 && item.Id == _formModel.CategoryId);

        if (!isActiveCategorySelected)
        {
            _formModel.CategoryId = 0;
        }
    }

    private string GetPendingArchiveLocationMessage() =>
        _pendingArchivedLocation is null
            ? string.Empty
            : CanManage
                ? $"'{_pendingArchivedLocation.Name}' will become inactive and its audio items will stop accepting new changes until the location is active again."
                : $"An Admin or Developer will review the archive request for '{_pendingArchivedLocation.Name}' before the live POI is changed.";

    private void CancelArchiveLocation()
    {
        _pendingArchivedLocation = null;
        _archiveReason = "";
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (_bodyScrollLockState == true)
            {
                await JS.InvokeVoidAsync("smartTourAdmin.shell.setBodyScrollLock", false);
            }

            if (CanEditContent)
            {
                await JS.InvokeVoidAsync("smartTourAdmin.map.disposeLocationPicker", _mapElement);
            }

            await ClearLocationImagePreviewsAsync();
        }
        catch (JSException)
        {
        }
        catch (TaskCanceledException)
        {
        }

        _mapReference?.Dispose();
    }

    private sealed class MapSearchResult
    {
        [JsonPropertyName("name")]
        public string Name { get; init; } = "";

        [JsonPropertyName("address")]
        public string Address { get; init; } = "";

        [JsonPropertyName("latitude")]
        public double Latitude { get; init; }

        [JsonPropertyName("longitude")]
        public double Longitude { get; init; }

        [JsonIgnore]
        public bool HasCoordinates => double.IsFinite(Latitude) && double.IsFinite(Longitude);
    }
