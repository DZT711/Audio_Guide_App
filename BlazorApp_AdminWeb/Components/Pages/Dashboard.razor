@page "/dashboard"
@inject AdminApiClient ApiClient
@inject NotificationService Notifications
@inject IJSRuntime JS
@inject AdminSessionState SessionState
@inject AdminUiLanguageService LanguageService

<PageTitle>@L("page.dashboard", "Dashboard")</PageTitle>

@if (!CanView)
{
    <div class="dashboard-page">
        <div class="management-error">
            <strong>@L("dashboard.access.denied.title", "Access denied.")</strong>
            <div>@L("dashboard.access.denied.desc", "Your current role cannot view the dashboard.")</div>
        </div>
    </div>
}
else if (_isLoading)
{
    <div class="dashboard-page">
        <section class="dashboard-hero" data-reveal>
            <div class="dashboard-hero__content">
                <div class="skeleton skeleton--pill"></div>
                <div class="skeleton skeleton--title"></div>
                <div class="skeleton skeleton--line"></div>
                <div class="skeleton skeleton--line skeleton--line-short"></div>
            </div>
            <div class="dashboard-hero__stats">
                @for (var i = 0; i < 3; i++)
                {
                    <article class="hero-stat">
                        <div class="skeleton skeleton--title"></div>
                        <div class="skeleton skeleton--line"></div>
                    </article>
                }
            </div>
        </section>

        <div class="row g-4">
            @for (var i = 0; i < 4; i++)
            {
                <div class="col-12 col-md-6 col-xl-3">
                    <div class="skeleton-card"></div>
                </div>
            }
        </div>

        <div class="row g-4">
            <div class="col-12 col-xxl-8">
                <section class="dashboard-panel">
                    <div class="skeleton-table-row">
                        <div class="skeleton skeleton--line"></div>
                        <div class="skeleton skeleton--line"></div>
                        <div class="skeleton skeleton--line"></div>
                        <div class="skeleton skeleton--line"></div>
                    </div>
                    <div class="skeleton-table-row">
                        <div class="skeleton skeleton--line"></div>
                        <div class="skeleton skeleton--line"></div>
                        <div class="skeleton skeleton--line"></div>
                        <div class="skeleton skeleton--line"></div>
                    </div>
                </section>
            </div>
            <div class="col-12 col-xxl-4">
                <section class="dashboard-panel">
                    @for (var i = 0; i < 3; i++)
                    {
                        <div class="skeleton skeleton--title"></div>
                        <div class="skeleton skeleton--line"></div>
                    }
                </section>
            </div>
        </div>
    </div>
}
else if (!string.IsNullOrWhiteSpace(_loadError))
{
    <div class="dashboard-page">
        <div class="management-error">
            <strong>@L("dashboard.load.failed.title", "Unable to load dashboard data.")</strong>
            <div>@_loadError</div>
        </div>
    </div>
}
else
{
<div class="dashboard-page">
    <section class="dashboard-hero" data-reveal>
        <div class="dashboard-hero__content">
            <span class="dashboard-hero__eyebrow">@L("dashboard.hero.eyebrow", "Overview")</span>
            <h1>@L("dashboard.hero.title", "Admin Dashboard")</h1>
            <p>@L("dashboard.hero.desc", "Track content health, moderation, and platform activity with clearer hierarchy, smoother reveals, and more polished feedback states.")</p>

            <div class="dashboard-hero__actions">
                @if (CanViewUsage)
                {
                    <a class="btn btn-light btn-lg" href="/usage">
                        <i class="bi bi-clock-history me-2"></i>
                        @L("dashboard.action.usage", "Usage History")
                    </a>
                }
                @if (CanViewStatistics)
                {
                    <a class="btn btn-outline-light btn-lg" href="/statistics">
                        <i class="bi bi-graph-up-arrow me-2"></i>
                        @L("dashboard.action.statistics", "Statistics")
                    </a>
                }
                @if (CanViewTours)
                {
                    <a class="btn btn-outline-light btn-lg" href="/tours">
                        <i class="bi bi-signpost-split me-2"></i>
                        @L("dashboard.action.tours", "Tour Management")
                    </a>
                }
                @if (CanViewUsers)
                {
                    <a class="btn btn-light btn-lg" href="/users">
                        <i class="bi bi-people me-2"></i>
                        @L("dashboard.action.users", "Manage Users")
                    </a>
                }
                else
                {
                    <button class="btn btn-light btn-lg" type="button" @onclick="ShowUserAccessNotice">
                        <i class="bi bi-people me-2"></i>
                        @L("dashboard.action.users", "Manage Users")
                    </button>
                }
                <button class="btn btn-outline-light btn-lg" type="button" disabled="@(!CanExport || _isExporting)" @onclick="ExportSnapshotAsync">
                    <i class="bi bi-download me-2"></i>
                    @(_isExporting ? L("dashboard.action.exporting", "Exporting...") : L("dashboard.action.export", "Export Snapshot"))
                </button>
            </div>
        </div>

        <div class="dashboard-hero__stats" data-stagger data-stagger-step="90">
            <article class="hero-stat" data-reveal>
                <strong>94%</strong>
                <span>@L("dashboard.hero.stat.sla", "Review SLA met this week")</span>
            </article>
            <article class="hero-stat" data-reveal>
                <strong>28</strong>
                <span>@L("dashboard.hero.stat.guides", "New guides drafted today")</span>
            </article>
            <article class="hero-stat" data-reveal>
                <strong>3.8k</strong>
                <span>@L("dashboard.hero.stat.audio-plays", "Audio plays in the last 24 hours")</span>
            </article>
        </div>
    </section>

    <div class="row g-4" data-stagger data-stagger-step="80">
        @foreach (var metric in Metrics)
        {
            <div class="col-12 col-md-6 col-xl-3">
                <article class="metric-card card border-0 h-100" data-reveal style="@GetMetricStyle(metric)">
                    <div class="card-body">
                        <div class="metric-card__top">
                            <span class="metric-icon">
                                <i class="bi @metric.Icon"></i>
                            </span>
                            <span class="@GetTrendClass(metric.TrendTone)">@TranslateDashboardText(metric.Trend)</span>
                        </div>

                        <div class="metric-value">@metric.Value</div>
                        <h2 class="metric-title">@TranslateDashboardText(metric.Title)</h2>
                        <p class="metric-copy">@TranslateDashboardText(metric.Description)</p>
                    </div>
                </article>
            </div>
        }
    </div>

    <div class="row g-4">
        <div class="col-12 col-xxl-8">
            <section class="dashboard-panel dashboard-panel--table" data-reveal>
                <div class="dashboard-panel__header">
                    <div>
                        <span class="dashboard-panel__eyebrow">@L("dashboard.feed.eyebrow", "Live Feed")</span>
                        <h2>@L("dashboard.feed.title", "Recent Activity")</h2>
                    </div>
                    @if (CanViewModeration)
                    {
                        <a class="btn btn-outline-secondary btn-sm" href="/moderation">@L("dashboard.feed.action.view-all", "View All")</a>
                    }
                    else
                    {
                        <a class="btn btn-outline-secondary btn-sm" href="/audio">@L("dashboard.feed.action.view-audio", "View Audio")</a>
                    }
                </div>

                <div class="table-responsive">
                    <table class="table dashboard-table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>@L("dashboard.table.user", "User")</th>
                                <th>@L("dashboard.table.action", "Action")</th>
                                <th>@L("dashboard.table.target", "Target")</th>
                                <th>@L("dashboard.table.time", "Time")</th>
                                <th>@L("dashboard.table.status", "Status")</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var act in Activities)
                            {
                                <tr>
                                    <td>
                                        <div class="activity-user">
                                            <div class="activity-avatar">@act.UserInitials</div>
                                            <div>
                                                <strong class="d-block">@act.UserName</strong>
                                                <span class="text-muted small">@L("dashboard.table.workspace", "Admin workspace")</span>
                                            </div>
                                        </div>
                                    </td>
                                    <td>@TranslateDashboardText(act.Action)</td>
                                    <td>@act.TargetName</td>
                                    <td>@TranslateDashboardText(act.TimeAgo)</td>
                                    <td>
                                        <span class="@GetStatusBadgeClass(act.Status)">@TranslateDashboardText(act.Status)</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        </div>

        <div class="col-12 col-xxl-4">
            <section class="dashboard-panel dashboard-panel--stack" data-reveal>
                <div class="dashboard-panel__header">
                    <div>
                        <span class="dashboard-panel__eyebrow">@L("dashboard.focus.eyebrow", "Focus Area")</span>
                        <h2>@L("dashboard.focus.title", "Team Priorities")</h2>
                    </div>
                </div>

                <div class="focus-list" data-stagger data-stagger-step="90">
                    @foreach (var item in FocusItems)
                    {
                        <article class="@GetFocusCardClass(item.Tone)" data-reveal>
                            <div class="focus-card__icon">
                                <i class="bi @item.Icon"></i>
                            </div>
                            <div class="focus-card__body">
                                <div class="focus-card__top">
                                    <h3>@TranslateDashboardText(item.Title)</h3>
                                    <span>@item.Progress%</span>
                                </div>
                                <p>@TranslateDashboardText(item.Description)</p>
                                <div class="focus-progress">
                                    <span style="@($"width: {item.Progress}%")"></span>
                                </div>
                            </div>
                        </article>
                    }
                </div>
            </section>
        </div>
    </div>
</div>
}

@code {
    private string L(string key, string fallback) => LanguageService.T(key, fallback);
    private List<DashboardMetricDto> Metrics { get; set; } = [];
    private List<DashboardActivityDto> Activities { get; set; } = [];
    private List<FocusItemDto> FocusItems { get; set; } = [];
    private bool _isLoading = true;
    private bool _isExporting;
    private string? _loadError;
    private bool CanView => SessionState.HasPermission(AdminPermissions.DashboardView);
    private bool CanExport => SessionState.HasPermission(AdminPermissions.DashboardExport);
    private bool CanViewUsage => SessionState.HasPermission(AdminPermissions.UsageHistoryView);
    private bool CanViewStatistics => SessionState.HasPermission(AdminPermissions.AnalyticsView);
    private bool CanViewTours => SessionState.HasPermission(AdminPermissions.TourRead);
    private bool CanViewUsers => SessionState.HasPermission(AdminPermissions.UserRead);
    private bool CanViewModeration => SessionState.HasPermission(AdminPermissions.ModerationView);

    protected override async Task OnInitializedAsync()
    {
        await LoadOverviewAsync();
    }

    private async Task LoadOverviewAsync()
    {
        _isLoading = true;
        _loadError = null;

        try
        {
            var overview = await ApiClient.GetDashboardOverviewAsync();
            Metrics = overview.Metrics.ToList();
            Activities = overview.Activities.ToList();
            FocusItems = overview.FocusItems.ToList();
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
            Notifications.Error(ex.Message, L("dashboard.load.failed.toast", "Dashboard load failed"));
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task ExportSnapshotAsync()
    {
        if (!CanExport)
        {
            Notifications.Warning(
                L("dashboard.export.blocked.message", "Your role can view the dashboard but cannot export it."),
                L("dashboard.export.blocked.title", "Export blocked"));
            return;
        }

        _isExporting = true;
        try
        {
            var snapshot = await ApiClient.GetDashboardSnapshotAsync();
            var payload = JsonSerializer.Serialize(snapshot, new JsonSerializerOptions(JsonSerializerDefaults.Web)
            {
                WriteIndented = true
            });

            var fileName = $"smart-tourism-snapshot-{DateTime.UtcNow:yyyyMMdd-HHmmss}.json";
            await JS.InvokeVoidAsync("smartTourAdmin.download.text", fileName, payload, "application/json");
            Notifications.Success(
                L("dashboard.export.success.message", "The dashboard snapshot was exported as JSON."),
                L("dashboard.export.success.title", "Export ready"));
        }
        catch (Exception ex)
        {
            Notifications.Error(ex.Message, L("dashboard.export.failed.title", "Export failed"));
        }
        finally
        {
            _isExporting = false;
        }
    }

    private void ShowUserAccessNotice()
    {
        Notifications.Info(
            L("dashboard.users.limited.message", "Your current role can open the dashboard but cannot access the user management screen."),
            L("dashboard.users.limited.title", "Limited access"));
    }

    private string TranslateDashboardText(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        return value switch
        {
            "Total POIs" => L("dashboard.metric.total-pois", "Total POIs"),
            "Total Audios" => L("dashboard.metric.total-audios", "Total Audios"),
            "Curated Tours" => L("dashboard.metric.curated-tours", "Curated Tours"),
            "Dashboard Users" => L("dashboard.metric.dashboard-users", "Dashboard Users"),
            "Telemetry Events" => L("dashboard.metric.telemetry-events", "Telemetry Events"),
            "Published and draft points of interest in the POC database." => L("dashboard.metric.total-pois.desc", "Published and draft points of interest in the POC database."),
            "Narration items supporting GPS, QR, and manual playback." => L("dashboard.metric.total-audios.desc", "Narration items supporting GPS, QR, and manual playback."),
            "Route collections connecting active POIs into guided journeys." => L("dashboard.metric.curated-tours.desc", "Route collections connecting active POIs into guided journeys."),
            "Accounts divided by role and status for the admin web." => L("dashboard.metric.dashboard-users.desc", "Accounts divided by role and status for the admin web."),
            "Playback and GPS tracking entries collected for the POC analytics layer." => L("dashboard.metric.telemetry-events.desc", "Playback and GPS tracking entries collected for the POC analytics layer."),
            "4 active" => L("dashboard.metric.total-pois.trend", "4 active"),
            "18 active" => L("dashboard.metric.total-audios.trend", "18 active"),
            "3 active" => L("dashboard.metric.curated-tours.trend", "3 active"),
            "5 active" => L("dashboard.metric.dashboard-users.trend", "5 active"),
            "54 playback logs" => L("dashboard.metric.telemetry-events.trend", "54 playback logs"),
            "Resolve ownership conflicts" => L("dashboard.focus.ownership.title", "Resolve ownership conflicts"),
            "Verify category ownership for six pending POI submissions before moderation closes." => L("dashboard.focus.ownership.desc", "Verify category ownership for six pending POI submissions before moderation closes."),
            "Publish evening audio updates" => L("dashboard.focus.audio.title", "Publish evening audio updates"),
            "Coordinate with the audio team to publish revised bilingual narration packs." => L("dashboard.focus.audio.desc", "Coordinate with the audio team to publish revised bilingual narration packs."),
            "Review route telemetry drift" => L("dashboard.focus.route.title", "Review route telemetry drift"),
            "Investigate tracking gaps on ward routes with low completion in the last 48 hours." => L("dashboard.focus.route.desc", "Investigate tracking gaps on ward routes with low completion in the last 48 hours."),
            "Completed" => L("dashboard.status.completed", "Completed"),
            "Processing" => L("dashboard.status.processing", "Processing"),
            "Pending" => L("dashboard.status.pending", "Pending"),
            "Failed" => L("dashboard.status.failed", "Failed"),
            "Create" => L("dashboard.action-type.create", "Create"),
            "Edit" => L("dashboard.action-type.edit", "Edit"),
            "Delete" => L("dashboard.action-type.delete", "Delete"),
            "Approve" => L("dashboard.action-type.approve", "Approve"),
            "Reject" => L("dashboard.action-type.reject", "Reject"),
            _ => value
        };
    }

    private string GetMetricStyle(DashboardMetricDto metric) => $"--metric-start:{metric.AccentStart}; --metric-end:{metric.AccentEnd};";

    private string GetTrendClass(string tone) => tone switch
    {
        "positive" => "trend-pill trend-pill--positive",
        "warning" => "trend-pill trend-pill--warning",
        "negative" => "trend-pill trend-pill--negative",
        _ => "trend-pill"
    };

    private string GetStatusBadgeClass(string status) => status switch
    {
        "Completed" => "status-pill status-pill--success",
        "Processing" => "status-pill status-pill--processing",
        "Pending" => "status-pill status-pill--pending",
        "Failed" => "status-pill status-pill--failed",
        _ => "status-pill"
    };

    private string GetFocusCardClass(string tone) => tone switch
    {
        "teal" => "focus-card focus-card--teal",
        "amber" => "focus-card focus-card--amber",
        "blue" => "focus-card focus-card--blue",
        _ => "focus-card"
    };

}
