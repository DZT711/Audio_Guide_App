@page "/history"
@using System.Globalization
@inject AdminApiClient ApiClient
@inject NotificationService Notifications
@inject AdminSessionState SessionState
@inject AdminUiLanguageService LanguageService

<PageTitle>@L("page.history", "Activity History")</PageTitle>

@if (!CanView)
{
    <div class="management-page activity-history-page">
        <div class="management-error">
            <strong>@L("history.access.denied.title", "Access denied.")</strong>
            <div>@L("history.access.denied.desc", "Your current role cannot view activity history.")</div>
        </div>
    </div>
}
else
{
<div class="management-page activity-history-page">
    <section class="management-hero" data-reveal>
        <div>
            <span class="management-hero__eyebrow">@L("history.hero.eyebrow", "Admin Log")</span>
            <h1>@L("history.hero.title", "Activity History")</h1>
            <p>@L("history.hero.desc", "Review create, edit, delete, approval, rejection, and broadcast actions across the admin console. This page is visible to Admin and Developer roles only.")</p>
        </div>

        <div class="management-hero__actions">
            <button type="button" class="btn btn-outline-secondary btn-lg" @onclick="RefreshAsync" disabled="@_isLoading">
                <i class="bi bi-arrow-clockwise me-2"></i>
                @L("history.action.refresh", "Refresh")
            </button>
        </div>
    </section>

    <div class="management-stat-grid" data-stagger data-stagger-step="80">
        <article class="management-stat" data-reveal>
            <span class="management-stat__icon"><i class="bi bi-clock-history"></i></span>
            <div>
                <strong class="management-stat__value">@_result.TotalCount</strong>
                <span class="management-stat__label">@L("history.stats.matching-events", "Matching Events")</span>
            </div>
        </article>
        <article class="management-stat" data-reveal>
            <span class="management-stat__icon"><i class="bi bi-people"></i></span>
            <div>
                <strong class="management-stat__value">@DistinctActorCount</strong>
                <span class="management-stat__label">@L("history.stats.actors-on-page", "Actors On Page")</span>
            </div>
        </article>
        <article class="management-stat" data-reveal>
            <span class="management-stat__icon"><i class="bi bi-funnel"></i></span>
            <div>
                <strong class="management-stat__value">@GetFilterSummary()</strong>
                <span class="management-stat__label">@L("history.stats.current-filters", "Current Filters")</span>
            </div>
        </article>
        <article class="management-stat" data-reveal>
            <span class="management-stat__icon"><i class="bi bi-calendar-event"></i></span>
            <div>
                <strong class="management-stat__value">@GetLatestLogLabel()</strong>
                <span class="management-stat__label">@L("history.stats.latest-event", "Latest Event")</span>
            </div>
        </article>
    </div>

    <section class="management-panel" data-reveal>
        <div class="management-panel__header">
            <div>
                <span class="management-panel__eyebrow">@L("history.timeline.eyebrow", "Timeline")</span>
                <h2>@L("history.timeline.title", "System Activity Feed")</h2>
            </div>

            <div class="management-toolbar">
                <label class="management-search">
                    <i class="bi bi-search"></i>
                    <input class="form-control" type="search" placeholder="@L("history.search.placeholder", "Search user, entity, or summary...")" @bind="_searchText" @bind:event="oninput" @bind:after="HandleFiltersChangedAsync" />
                </label>

                <select class="form-select management-filter" @bind="_actionFilter" @bind:after="HandleFiltersChangedAsync">
                    <option value="">@L("history.filter.actions.all", "All actions")</option>
                    @foreach (var action in ActionOptions)
                    {
                        <option value="@action">@TranslateAction(action)</option>
                    }
                </select>

                <select class="form-select management-filter" @bind="_entityFilter" @bind:after="HandleFiltersChangedAsync">
                    <option value="">@L("history.filter.entities.all", "All entities")</option>
                    @foreach (var entity in EntityOptions)
                    {
                        <option value="@entity">@TranslateEntity(entity)</option>
                    }
                </select>
            </div>
        </div>

        @if (_isLoading)
        {
            <div class="moderation-skeleton-list">
                @for (var i = 0; i < 4; i++)
                {
                    <article class="moderation-skeleton-card">
                        <div class="skeleton skeleton--title"></div>
                        <div class="skeleton skeleton--line"></div>
                        <div class="skeleton skeleton--line skeleton--line-short"></div>
                    </article>
                }
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(_loadError))
        {
            <div class="management-error">
                <strong>@L("history.load.failed.title", "Unable to load activity history.")</strong>
                <div>@_loadError</div>
            </div>
        }
        else if (_items.Count == 0)
        {
            <div class="app-empty-state">
                @L("history.empty.filtered", "No activity events match the current filters.")
            </div>
        }
        else
        {
            <div class="table-responsive management-page-swap" @key="_result.Page">
                <table class="table management-table activity-log-table">
                    <thead>
                        <tr>
                            <th>@L("history.table.time", "Time")</th>
                            <th>@L("history.table.user", "User")</th>
                            <th>@L("history.table.action", "Action")</th>
                            <th>@L("history.table.entity", "Entity")</th>
                            <th>@L("history.table.details", "Details")</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in _items)
                        {
                            <tr>
                                <td>
                                    <div>@item.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</div>
                                    <small class="management-muted">@GetRelativeTimeLabel(item.CreatedAt)</small>
                                </td>
                                <td>
                                    <div class="activity-log-actor">
                                        <strong>@GetActorName(item)</strong>
                                        <small class="management-muted">@item.UserName</small>
                                        <span class="audio-card__tag">@GetRoleLabel(item.Role)</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="@GetActionClass(item.ActionType)">@TranslateAction(item.ActionType)</span>
                                </td>
                                <td>
                                    <div class="activity-log-summary">
                                        <div class="activity-log-chip-row">
                                            <span class="audio-card__tag">@TranslateEntity(item.EntityType)</span>
                                            @if (item.EntityId is > 0)
                                            {
                                                <span class="audio-card__tag">#@item.EntityId</span>
                                            }
                                        </div>
                                        <strong>@(string.IsNullOrWhiteSpace(item.EntityName) ? L("history.entity.unnamed", "Unnamed target") : item.EntityName)</strong>
                                    </div>
                                </td>
                                <td>
                                    <div class="activity-log-summary">
                                        <div>@item.Summary</div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (_result.TotalPages > 1)
            {
                <div class="management-pagination">
                    <span class="management-pagination__info">@LF("history.pagination.info", "Page {0} of {1} ({2} total events)", _result.Page, _result.TotalPages, _result.TotalCount)</span>
                    <div class="management-pagination__actions">
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="PreviousPageAsync" disabled="@(_result.Page <= 1)">
                            <i class="bi bi-chevron-left"></i> @L("history.pagination.previous", "Previous")
                        </button>
                        <div class="management-pagination__pages">
                            @foreach (var pageNumber in GetVisiblePages())
                            {
                                <button type="button"
                                        class="@GetPaginationButtonClass(pageNumber == _result.Page)"
                                        @onclick="() => GoToPageAsync(pageNumber)"
                                        disabled="@(pageNumber == _result.Page)">
                                    @pageNumber
                                </button>
                            }
                        </div>
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="NextPageAsync" disabled="@(_result.Page >= _result.TotalPages)">
                            @L("history.pagination.next", "Next") <i class="bi bi-chevron-right"></i>
                        </button>
                    </div>
                </div>
            }
        }
    </section>
</div>
}

@code {
    private string L(string key, string fallback) => LanguageService.T(key, fallback);
    private string LF(string key, string fallback, params object?[] args) =>
        string.Format(CultureInfo.CurrentCulture, L(key, fallback), args);
    private static readonly string[] ActionOptions =
    [
        "Create",
        "Edit",
        "Delete",
        "Approve",
        "Reject",
        "Invite"
    ];

    private static readonly string[] EntityOptions =
    [
        "Announcement",
        "Audio",
        "Audio Request",
        "Category",
        "Language",
        "POI",
        "POI Request",
        "Tour",
        "User"
    ];

    private readonly List<ActivityLogEntryDto> _items = [];
    private ActivityLogListDto _result = new();
    private bool _isLoading = true;
    private int _currentPage = 1;
    private string _searchText = "";
    private string _actionFilter = "";
    private string _entityFilter = "";
    private string? _loadError;

    private bool CanView => SessionState.HasPermission(AdminPermissions.ActivityLogView);

    private int DistinctActorCount => _items
        .Select(item => item.UserId?.ToString() ?? item.UserName)
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .Count();

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task RefreshAsync() => await LoadAsync();

    private async Task HandleFiltersChangedAsync()
    {
        _currentPage = 1;
        await LoadAsync();
    }

    private async Task NextPageAsync()
    {
        if (_result.Page >= _result.TotalPages)
        {
            return;
        }

        _currentPage = _result.Page + 1;
        await LoadAsync();
    }

    private async Task PreviousPageAsync()
    {
        if (_result.Page <= 1)
        {
            return;
        }

        _currentPage = _result.Page - 1;
        await LoadAsync();
    }

    private async Task GoToPageAsync(int pageNumber)
    {
        if (pageNumber < 1 || pageNumber > _result.TotalPages || pageNumber == _result.Page)
        {
            return;
        }

        _currentPage = pageNumber;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _loadError = null;

        try
        {
            _result = await ApiClient.GetActivityLogsAsync(new ActivityLogQueryDto
            {
                Page = _currentPage,
                PageSize = 12,
                Search = string.IsNullOrWhiteSpace(_searchText) ? null : _searchText.Trim(),
                Action = string.IsNullOrWhiteSpace(_actionFilter) ? null : _actionFilter,
                Entity = string.IsNullOrWhiteSpace(_entityFilter) ? null : _entityFilter
            });

            _currentPage = _result.Page;
            _items.Clear();
            _items.AddRange(_result.Items);
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
            Notifications.Error(ex.Message, L("history.load.failed.toast", "Activity history load failed"));
        }
        finally
        {
            _isLoading = false;
        }
    }

    private string GetFilterSummary()
    {
        var action = string.IsNullOrWhiteSpace(_actionFilter)
            ? L("history.filter.actions.all", "All actions")
            : TranslateAction(_actionFilter);
        var entity = string.IsNullOrWhiteSpace(_entityFilter)
            ? L("history.filter.entities.all-lower", "all entities")
            : TranslateEntity(_entityFilter);
        return LF("history.filter.summary", "{0} / {1}", action, entity);
    }

    private string GetLatestLogLabel() => _items.Count == 0
        ? L("history.latest.no-data", "No data")
        : _items[0].CreatedAt.ToLocalTime().ToString("dd MMM");

    private static string GetActorName(ActivityLogEntryDto item) =>
        string.IsNullOrWhiteSpace(item.FullName) ? item.UserName : item.FullName;

    private string GetRoleLabel(string role) =>
        string.IsNullOrWhiteSpace(role)
            ? L("history.role.unknown", "Unknown role")
            : LanguageService.GetRoleLabel(role);

    private static string GetActionClass(string actionType) => actionType switch
    {
        "Create" => "management-status management-status--active",
        "Approve" => "management-status management-status--active",
        "Edit" => "management-status management-status--pending",
        "Invite" => "management-status management-status--info",
        "Delete" => "management-status management-status--inactive",
        "Reject" => "management-status management-status--inactive",
        _ => "management-status management-status--info"
    };

    private string GetRelativeTimeLabel(DateTime createdAt)
    {
        var delta = DateTime.UtcNow - createdAt;
        if (delta.TotalMinutes < 1)
        {
            return L("history.time.just-now", "Just now");
        }

        if (delta.TotalHours < 1)
        {
            return LF("history.time.minutes-ago", "{0} min ago", Math.Max(1, (int)delta.TotalMinutes));
        }

        if (delta.TotalDays < 1)
        {
            return LF("history.time.hours-ago", "{0} hr ago", Math.Max(1, (int)delta.TotalHours));
        }

        return LF("history.time.days-ago", "{0} day(s) ago", Math.Max(1, (int)delta.TotalDays));
    }

    private string TranslateAction(string? action) => action switch
    {
        "Create" => L("history.action.create", "Create"),
        "Edit" => L("history.action.edit", "Edit"),
        "Delete" => L("history.action.delete", "Delete"),
        "Approve" => L("history.action.approve", "Approve"),
        "Reject" => L("history.action.reject", "Reject"),
        "Invite" => L("history.action.invite", "Invite"),
        _ => action ?? string.Empty
    };

    private string TranslateEntity(string? entity) => entity switch
    {
        "Announcement" => L("history.entity.announcement", "Announcement"),
        "Audio" => L("history.entity.audio", "Audio"),
        "Audio Request" => L("history.entity.audio-request", "Audio Request"),
        "Category" => L("history.entity.category", "Category"),
        "Language" => L("history.entity.language", "Language"),
        "POI" => L("history.entity.poi", "POI"),
        "POI Request" => L("history.entity.poi-request", "POI Request"),
        "Tour" => L("history.entity.tour", "Tour"),
        "User" => L("history.entity.user", "User"),
        _ => entity ?? string.Empty
    };

    private IReadOnlyList<int> GetVisiblePages()
    {
        const int maxButtons = 5;
        var start = Math.Max(1, _result.Page - 2);
        var end = Math.Min(_result.TotalPages, start + maxButtons - 1);
        start = Math.Max(1, end - maxButtons + 1);
        return Enumerable.Range(start, end - start + 1).ToList();
    }

    private static string GetPaginationButtonClass(bool isActive) =>
        isActive
            ? "management-pagination__page management-pagination__page--active"
            : "management-pagination__page";
}
