@page "/categories"
@using System.Globalization
@inject AdminApiClient ApiClient
@inject NotificationService Notifications
@inject IJSRuntime JS
@inject AdminSessionState SessionState
@inject AdminUiLanguageService LanguageService

<PageTitle>@L("page.categories", "Category Management")</PageTitle>

@if (!CanView)
{
    <div class="management-page category-page">
        <div class="management-error">
            <strong>@L("categories.access.denied.title", "Access denied.")</strong>
            <div>@L("categories.access.denied.desc", "Your current role cannot view categories.")</div>
        </div>
    </div>
}
else
{
<div class="management-page category-page">
    <section class="management-hero" data-reveal>
        <div>
            <span class="management-hero__eyebrow">@L("categories.hero.eyebrow", "Taxonomy")</span>
            <h1>@L("categories.hero.title", "Category Management")</h1>
            <p>@L("categories.hero.desc", "Organize tourism content with live API-backed category management, quick editing, and lightweight loading feedback while SQLite-backed data is loading.")</p>
        </div>

        <div class="management-hero__actions">
            <button type="button" class="btn btn-outline-secondary btn-lg" @onclick="RefreshAsync">
                <i class="bi bi-arrow-clockwise me-2"></i>
                @L("categories.action.refresh", "Refresh")
            </button>
        </div>
    </section>

    <div class="management-stat-grid" data-stagger data-stagger-step="80">
        <article class="management-stat" data-reveal>
            <span class="management-stat__icon"><i class="bi bi-diagram-3"></i></span>
            <div>
                <strong class="management-stat__value">@_categories.Count</strong>
                <span class="management-stat__label">@L("categories.stats.total", "Total Categories")</span>
            </div>
        </article>
        <article class="management-stat" data-reveal>
            <span class="management-stat__icon"><i class="bi bi-check2-circle"></i></span>
            <div>
                <strong class="management-stat__value">@_categories.Count(item => item.Status == 1)</strong>
                <span class="management-stat__label">@L("status.active", "Active")</span>
            </div>
        </article>
        <article class="management-stat" data-reveal>
            <span class="management-stat__icon"><i class="bi bi-pause-circle"></i></span>
            <div>
                <strong class="management-stat__value">@_categories.Count(item => item.Status == 0)</strong>
                <span class="management-stat__label">@L("status.inactive", "Inactive")</span>
            </div>
        </article>
        <article class="management-stat" data-reveal>
            <span class="management-stat__icon"><i class="bi bi-search"></i></span>
            <div>
                <strong class="management-stat__value">@FilteredCategories.Count()</strong>
                <span class="management-stat__label">@L("categories.stats.matching", "Matching Search")</span>
            </div>
        </article>
    </div>

    <div class="management-layout">
        <section class="management-panel" data-reveal>
            <div class="management-panel__header">
                <div>
                    <span class="management-panel__eyebrow">@L("categories.directory.eyebrow", "Directory")</span>
                    <h2>@L("categories.directory.title", "Available Categories")</h2>
                </div>

                <label class="management-search">
                    <i class="bi bi-search"></i>
                    <input class="form-control" type="search" placeholder="@L("categories.search.placeholder", "Search categories...")" @bind="_searchText" @bind:event="oninput" />
                </label>
            </div>

            @if (_isLoading)
            {
                <div class="category-skeleton-list">
                    @for (var i = 0; i < 4; i++)
                    {
                        <div class="category-skeleton-card">
                            <div class="skeleton skeleton--title"></div>
                            <div class="skeleton skeleton--line"></div>
                            <div class="skeleton skeleton--line skeleton--line-short"></div>
                        </div>
                    }
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(_loadError))
            {
            <div class="management-error">
                <strong>@L("categories.load.failed.title", "Unable to load categories.")</strong>
                <div>@_loadError</div>
            </div>
        }
        else if (!FilteredCategories.Any())
        {
            <div class="app-empty-state">
                    @L("categories.empty.filtered", "No categories match the current search.")
            </div>
        }
            else
            {
                <div class="management-page-swap" @key="CurrentCategoryPage">
                    <div class="category-list">
                        @foreach (var category in PagedCategories)
                        {
                            <article class="@GetCategoryCardClass(category.Status)">
                                <div class="category-card__copy">
                                    <div class="category-card__top">
                                        <div class="category-card__heading">
                                            <span class="category-icon @CategoryVisuals.GetToneClass(category.Name)">
                                                <i class="@CategoryVisuals.GetIconClass(category.Name)"></i>
                                            </span>
                                            <h3>@TranslateCategoryName(category.Name)</h3>
                                        </div>
                                        <span class="@GetStatusClass(category.Status)">@GetStatusLabel(category.Status)</span>
                                    </div>
                                    <p>@(string.IsNullOrWhiteSpace(category.Description) ? L("categories.description.empty", "No description provided yet.") : category.Description)</p>
                                </div>

                                <div class="management-inline-actions">
                                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => StartEdit(category)">@(CanManage ? L("categories.action.edit", "Edit") : L("categories.action.view", "View"))</button>
                                    <button type="button" class="btn btn-sm btn-outline-danger" disabled="@(!CanManage || category.Status == 0)" @onclick="() => PromptArchiveCategory(category)">
                                        @(category.Status == 0 ? L("status.inactive", "Inactive") : L("categories.action.archive", "Archive"))
                                    </button>
                                </div>
                            </article>
                        }
                    </div>
                </div>

                @if (TotalCategoryPages > 1)
                {
                <div class="management-pagination">
                    <span class="management-pagination__info">@LF("categories.pagination.info", "Page {0} of {1} ({2} total categories)", CurrentCategoryPage, TotalCategoryPages, FilteredCategories.Count())</span>
                    <div class="management-pagination__actions">
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="PreviousCategoryPage" disabled="@(CurrentCategoryPage <= 1)">
                            <i class="bi bi-chevron-left"></i> @L("categories.pagination.previous", "Previous")
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="NextCategoryPage" disabled="@(CurrentCategoryPage >= TotalCategoryPages)">
                            @L("categories.pagination.next", "Next") <i class="bi bi-chevron-right"></i>
                        </button>
                    </div>
                </div>
                }
            }
        </section>

        <section class="management-panel category-editor" data-reveal>
            <div class="management-panel__header">
                <div>
                    <span class="management-panel__eyebrow">@(CanManage ? L("categories.editor.eyebrow", "Editor") : L("categories.readonly.eyebrow", "Read Only"))</span>
                    <h2>@(CanManage ? (_editingId is null ? L("categories.editor.create", "Create Category") : L("categories.editor.edit", "Edit Category")) : L("categories.readonly.title", "Category Details"))</h2>
                </div>
            </div>

            @if (CanManage)
            {
            <EditForm Model="_formModel" OnValidSubmit="SaveCategoryAsync" OnInvalidSubmit="HandleInvalidCategorySubmit" class="management-form">
                <DataAnnotationsValidator />

                <div class="management-field management-field--full">
                    <label for="category-name">@L("categories.form.name", "Name")</label>
                    <InputText id="category-name" class="form-control" @bind-Value="_formModel.Name" />
                    <ValidationMessage For="() => _formModel.Name" />
                </div>

                <div class="management-field management-field--full">
                    <label for="category-description">@L("categories.form.description", "Description")</label>
                    <InputTextArea id="category-description" class="form-control" rows="4" @bind-Value="_formModel.Description" />
                    <ValidationMessage For="() => _formModel.Description" />
                </div>

                <div class="management-field">
                    <label for="category-theme-name">@L("categories.form.theme", "Theme name")</label>
                    <InputText id="category-theme-name" class="form-control" @bind-Value="_formModel.ThemeName" placeholder="hotpot" />
                    <ValidationMessage For="() => _formModel.ThemeName" />
                </div>

                <div class="management-field">
                    <label for="category-icon-emoji">@L("categories.form.emoji", "Icon emoji")</label>
                    <InputText id="category-icon-emoji" class="form-control" @bind-Value="_formModel.IconEmoji" placeholder="🍲" />
                    <ValidationMessage For="() => _formModel.IconEmoji" />
                </div>

                <div class="management-field">
                    <label for="category-primary-color">@L("categories.form.primary-color", "Primary color")</label>
                    <InputText id="category-primary-color" class="form-control" @bind-Value="_formModel.PrimaryColor" placeholder="#C0392B" />
                    <ValidationMessage For="() => _formModel.PrimaryColor" />
                </div>

                <div class="management-field">
                    <label for="category-secondary-color">@L("categories.form.secondary-color", "Secondary color")</label>
                    <InputText id="category-secondary-color" class="form-control" @bind-Value="_formModel.SecondaryColor" placeholder="#7B241C" />
                    <ValidationMessage For="() => _formModel.SecondaryColor" />
                </div>

                <div class="management-field management-field--full">
                    <span class="management-field__label">@L("categories.form.preview", "Landing preview")</span>
                    <div class="category-theme-preview" style="@BuildCategoryThemePreviewStyle(_formModel.PrimaryColor, _formModel.SecondaryColor)">
                        <strong>@(string.IsNullOrWhiteSpace(_formModel.IconEmoji) ? "🍽️" : _formModel.IconEmoji) @(_formModel.Name.Length == 0 ? L("categories.form.preview.name", "Sample Category") : _formModel.Name)</strong>
                        <small>@(string.IsNullOrWhiteSpace(_formModel.ThemeName) ? L("categories.form.preview.theme", "Theme name pending") : _formModel.ThemeName)</small>
                    </div>
                </div>

                <div class="management-field management-field--full">
                    <span class="management-field__label">@L("categories.form.status", "Status")</span>
                    <div class="management-chip-group">
                        <button type="button" class="@GetChipClass(1, _formModel.Status)" @onclick="() => SetStatus(1)">@L("status.active", "Active")</button>
                        <button type="button" class="@GetChipClass(0, _formModel.Status)" @onclick="() => SetStatus(0)">@L("status.inactive", "Inactive")</button>
                    </div>
                </div>

                <div class="management-actions">
                    <button type="submit" class="btn btn-primary" disabled="@(_isSaving || !CanManage)">
                        @(_isSaving ? L("categories.save.saving", "Saving...") : _editingId is null ? L("categories.save.create", "Create Category") : L("categories.save.update", "Save Changes"))
                    </button>
                    <button type="button" class="btn btn-outline-secondary" @onclick="CancelEdit">@(CanManage ? (_editingId is null ? L("categories.action.reset", "Reset") : L("categories.action.cancel-edit", "Cancel Edit")) : L("categories.readonly.eyebrow", "Read Only"))</button>
                </div>
            </EditForm>
            }
            else if (SelectedCategoryForDisplay is null)
            {
                <div class="app-empty-state">
                    @L("categories.readonly.empty", "Select a category to review its details.")
                </div>
            }
            else
            {
                var selectedCategory = SelectedCategoryForDisplay!;

                <div class="category-readonly">
                    <div class="category-readonly__notice">
                        @L("categories.readonly.notice", "Category changes require an Admin or Developer account.")
                    </div>

                    <div class="category-detail-card">
                        <span>@L("categories.form.name", "Name")</span>
                        <strong class="category-detail-card__name">
                            <span class="category-icon @CategoryVisuals.GetToneClass(selectedCategory.Name)">
                                <i class="@CategoryVisuals.GetIconClass(selectedCategory.Name)"></i>
                            </span>
                            @TranslateCategoryName(selectedCategory.Name)
                        </strong>
                        <small>@GetStatusLabel(selectedCategory.Status)</small>
                    </div>

                    <div class="category-detail-card">
                        <span>@L("categories.form.description", "Description")</span>
                        <strong>@(string.IsNullOrWhiteSpace(selectedCategory.Description) ? L("categories.description.empty", "No description provided yet.") : selectedCategory.Description)</strong>
                    </div>

                    <div class="category-detail-card">
                        <span>@L("categories.form.theme", "Theme")</span>
                        <strong>@(string.IsNullOrWhiteSpace(selectedCategory.ThemeName) ? L("categories.readonly.theme.empty", "No QR landing theme assigned.") : selectedCategory.ThemeName)</strong>
                        <small>@($"{selectedCategory.IconEmoji ?? "🍽️"} {selectedCategory.PrimaryColor ?? "#C0392B"} / {selectedCategory.SecondaryColor ?? "#7B241C"}")</small>
                    </div>
                </div>
            }
        </section>
    </div>
</div>

<AdminConfirmDialog Visible="@(_pendingArchivedCategory is not null)"
                    Eyebrow="@L("categories.archive.dialog.eyebrow", "Archive Category")"
                    Title="@L("categories.archive.dialog.title", "Archive this category?")"
                    Message="@GetPendingArchiveCategoryMessage()"
                    ConfirmLabel="@L("categories.archive.dialog.confirm", "Archive Category")"
                    ConfirmButtonClass="btn btn-danger"
                    OnConfirm="ConfirmArchiveCategoryAsync"
                    OnCancel="CancelArchiveCategory" />
}

@code {
    private string L(string key, string fallback) => LanguageService.T(key, fallback);
    private string LF(string key, string fallback, params object?[] args) =>
        string.Format(CultureInfo.CurrentCulture, L(key, fallback), args);
    private readonly CategoryFormModel _formModel = new();
    private readonly List<CategoryDto> _categories = new();
    private CategoryDto? _selectedCategory;
    private CategoryDto? _pendingArchivedCategory;
    private bool _isLoading = true;
    private bool _isSaving;
    private int? _editingId;
    private string _searchText = "";
    private string? _loadError;
    private int _currentCategoryPage = 1;
    private const int CategoriesPerPage = 4;
    private bool CanView => SessionState.HasPermission(AdminPermissions.CategoryRead);
    private bool CanManage => SessionState.HasPermission(AdminPermissions.CategoryManage);
    private CategoryDto? SelectedCategoryForDisplay => ResolveSelectedCategory();

    private IEnumerable<CategoryDto> FilteredCategories =>
        _categories.Where(category =>
            string.IsNullOrWhiteSpace(_searchText)
            || category.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase)
            || (category.Description?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false));
    private int TotalCategoryPages => Math.Max(1, (int)Math.Ceiling((double)FilteredCategories.Count() / CategoriesPerPage));
    private int CurrentCategoryPage => Math.Min(Math.Max(_currentCategoryPage, 1), TotalCategoryPages);
    private IReadOnlyList<CategoryDto> PagedCategories => FilteredCategories
        .Skip((CurrentCategoryPage - 1) * CategoriesPerPage)
        .Take(CategoriesPerPage)
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadCategoriesAsync();
    }

    private async Task RefreshAsync() => await LoadCategoriesAsync();

    private async Task LoadCategoriesAsync()
    {
        _isLoading = true;
        _loadError = null;

        try
        {
            var categories = await ApiClient.GetCategoriesAsync();
            _categories.Clear();
            _categories.AddRange(categories
                .OrderByDescending(item => item.Status)
                .ThenBy(item => item.Name));

            SyncSelectedCategory();
            _currentCategoryPage = 1;
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
            Notifications.Error(ex.Message, L("categories.load.failed.toast", "Category load failed"));
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void NextCategoryPage()
    {
        if (CurrentCategoryPage < TotalCategoryPages)
        {
            _currentCategoryPage = CurrentCategoryPage + 1;
        }
    }

    private void PreviousCategoryPage()
    {
        if (CurrentCategoryPage > 1)
        {
            _currentCategoryPage = CurrentCategoryPage - 1;
        }
    }

    private void StartCreate()
    {
        _editingId = null;
        ResetForm();
    }

    private void StartEdit(CategoryDto category)
    {
        _selectedCategory = category;
        _editingId = category.Id;

        if (!CanManage)
        {
            _editingId = null;
            return;
        }

        var snapshot = CategoryFormModel.FromDto(category);
        _formModel.Name = snapshot.Name;
        _formModel.Description = snapshot.Description;
        _formModel.ThemeName = snapshot.ThemeName;
        _formModel.IconEmoji = snapshot.IconEmoji;
        _formModel.PrimaryColor = snapshot.PrimaryColor;
        _formModel.SecondaryColor = snapshot.SecondaryColor;
        _formModel.Status = snapshot.Status;
    }

    private async Task SaveCategoryAsync()
    {
        if (!CanManage)
        {
            Notifications.Warning(
                L("categories.save.readonly.message", "Your role can view categories but cannot save changes."),
                L("categories.readonly.title.short", "Read-only access"));
            return;
        }

        _isSaving = true;

        try
        {
            if (_editingId is null)
            {
                await ApiClient.CreateCategoryAsync(_formModel);
                Notifications.Success(
                    L("categories.save.created.message", "Category created successfully."),
                    L("categories.save.title", "Category saved"));
            }
            else
            {
                await ApiClient.UpdateCategoryAsync(_editingId.Value, _formModel);
                Notifications.Success(
                    L("categories.save.updated.message", "Category updated successfully."),
                    L("categories.save.title", "Category saved"));
            }

            await LoadCategoriesAsync();
            StartCreate();
        }
        catch (Exception ex)
        {
            Notifications.Error(ex.Message, L("categories.save.failed.title", "Category save failed"));
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void HandleInvalidCategorySubmit(EditContext editContext)
    {
        var message = editContext.GetValidationMessages()
            .Where(item => !string.IsNullOrWhiteSpace(item))
            .Distinct(StringComparer.Ordinal)
            .Take(3)
            .ToList();

        Notifications.Warning(
            message.Count == 0
                ? L("categories.validation.generic", "Fix the highlighted category fields before saving.")
                : string.Join(" ", message),
            L("categories.validation.title", "Category form incomplete"));
    }

    private void PromptArchiveCategory(CategoryDto category)
    {
        if (!CanManage)
        {
            Notifications.Warning(
                L("categories.archive.readonly.message", "Your role can view categories but cannot archive them."),
                L("categories.readonly.title.short", "Read-only access"));
            return;
        }

        _pendingArchivedCategory = category;
    }

    private async Task ConfirmArchiveCategoryAsync()
    {
        if (!CanManage || _pendingArchivedCategory is null)
        {
            return;
        }

        try
        {
            await ApiClient.DeleteCategoryAsync(_pendingArchivedCategory.Id);
            Notifications.Info(
                LF("categories.archive.success.message", "'{0}' is now inactive.", _pendingArchivedCategory.Name),
                L("categories.archive.success.title", "Category archived"));
            await LoadCategoriesAsync();

            if (_editingId == _pendingArchivedCategory.Id)
            {
                StartCreate();
            }
        }
        catch (Exception ex)
        {
            Notifications.Error(ex.Message, L("categories.archive.failed.title", "Delete failed"));
        }
        finally
        {
            CancelArchiveCategory();
        }
    }

    private void ResetForm()
    {
        _formModel.Name = "";
        _formModel.Description = "";
        _formModel.ThemeName = "";
        _formModel.IconEmoji = "";
        _formModel.PrimaryColor = "";
        _formModel.SecondaryColor = "";
        _formModel.Status = 1;
    }

    private void CancelEdit()
    {
        _editingId = null;
        ResetForm();
    }

    private void SetStatus(int status) => _formModel.Status = status;

    private static string BuildCategoryThemePreviewStyle(string? primaryColor, string? secondaryColor)
    {
        var primary = NormalizePreviewColor(primaryColor, "#C0392B");
        var secondary = NormalizePreviewColor(secondaryColor, "#7B241C");
        return $"background: linear-gradient(135deg, {primary}, {secondary}); color: #fff; border-radius: 18px; padding: 1rem 1.1rem; display: grid; gap: 0.2rem;";
    }

    private static string NormalizePreviewColor(string? color, string fallback) =>
        string.IsNullOrWhiteSpace(color) ? fallback : color.Trim();

    private CategoryDto? ResolveSelectedCategory()
    {
        if (_selectedCategory is not null)
        {
            return _categories.FirstOrDefault(item => item.Id == _selectedCategory.Id) ?? _selectedCategory;
        }

        return FilteredCategories.FirstOrDefault() ?? _categories.FirstOrDefault();
    }

    private void SyncSelectedCategory()
    {
        if (_selectedCategory is not null)
        {
            _selectedCategory = _categories.FirstOrDefault(item => item.Id == _selectedCategory.Id);
        }

        if (!CanManage && _selectedCategory is null)
        {
            _selectedCategory = _categories.FirstOrDefault();
        }
    }

    private static string GetStatusClass(int status) => status == 1
        ? "management-status management-status--active"
        : "management-status management-status--inactive";

    private string GetStatusLabel(int status) => status == 1
        ? L("status.active", "Active")
        : L("status.inactive", "Inactive");

    private static string TranslateCategoryName(string? categoryName) => (categoryName ?? string.Empty).Trim() switch
    {
        "Drinks" => "Đồ uống",
        "Food" => "Ẩm thực",
        "Historical Site" => "Di tích lịch sử",
        "Landmark" => "Địa danh",
        "Markets & Food Halls" => "Chợ & khu ẩm thực",
        _ => categoryName ?? string.Empty
    };

    private static string GetChipClass(int status, int currentStatus) => status == currentStatus
        ? "management-chip management-chip--selected"
        : "management-chip";

    private static string GetCategoryCardClass(int status) => status == 1
        ? "category-card"
        : "category-card category-card--inactive";

    private string GetPendingArchiveCategoryMessage() =>
        _pendingArchivedCategory is null
            ? string.Empty
            : LF("categories.archive.dialog.message", "'{0}' will become inactive and will no longer be available for new or edited location assignments.", _pendingArchivedCategory.Name);

    private void CancelArchiveCategory() => _pendingArchivedCategory = null;
}
