@page "/"
@layout LoginLayout

<div class="login-container d-flex align-items-center justify-content-center vh-100 bg-light">
    <div class="card border-0 shadow-lg" style="width: 100%; max-width: 400px;">
        <div class="card-body p-5">
            <div class="text-center mb-4">
                <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 64px; height: 64px;">
                    <i class="bi bi-soundwave fs-2"></i>
                </div>
                <h3 class="fw-bold text-primary">Smart Tour Admin Site</h3>
                <p class="text-muted">Welcome back! Please login.</p>
            </div>

            <form>
                <div class="mb-3">
                    <label for="email" class="form-label">Email Address</label>
                    <input type="email" class="form-control form-control-lg" id="email" placeholder="name@example.com" >
                </div>
                <div class="mb-3">
                    <label for="password" class="form-label">Password</label>
                    <input type="password" class="form-control form-control-lg" id="password" placeholder="••••••••">
                </div>
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="rememberMe">
                        <label class="form-check-label" for="rememberMe">Remember me</label>
                    </div>
                    <a href="#" class="text-decoration-none small">Forgot password?</a>
                </div>
                <button type="submit" class="btn btn-primary btn-lg w-100" @onclick="window.location.href='dashboard'">Sign In</button>
            </form>
            
            <div class="text-center mt-4">
                <small class="text-muted">Don't have an account? <a href="#" class="text-decoration-none">Contact Support</a></small>
            </div>
        </div>
    </div>
</div>

@using BlazorApp_AdminWeb.Components.Layout
@code {
    [Inject] NavigationManager Navigation { get; set; } = default!;

    private void HandleLogin()
    {
        // Mock login - redirect to dashboard
        Navigation.NavigateTo("dashboard");
    }
}