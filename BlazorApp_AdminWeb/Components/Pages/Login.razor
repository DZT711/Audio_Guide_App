@page "/"
@layout LoginLayout
@inject AdminAuthService AuthService
@inject NotificationService Notifications
@inject NavigationManager Navigation

<PageTitle>Login</PageTitle>

<div class="login-page">
    <div class="login-orb login-orb--one"></div>
    <div class="login-orb login-orb--two"></div>

    <div class="container login-shell">
        <section class="login-copy" data-reveal>
            <span class="login-copy__eyebrow">Smart Tourism Admin</span>
            <h1>Manage locations, categories, and voice content from one dashboard.</h1>
            <p>
                The admin portal now connects directly to the API for live management screens,
                loading states, and notifications across the workflow.
            </p>

            <div class="login-copy__highlights" data-stagger data-stagger-step="110">
                <article class="login-highlight" data-reveal>
                    <i class="bi bi-geo-alt"></i>
                    <div>
                        <h2>Live Location Control</h2>
                        <p>Create and update destination content directly from the web admin.</p>
                    </div>
                </article>

                <article class="login-highlight" data-reveal>
                    <i class="bi bi-diagram-3"></i>
                    <div>
                        <h2>Category Management</h2>
                        <p>Keep tourism categories organized and available for the mobile experience.</p>
                    </div>
                </article>

                <article class="login-highlight" data-reveal>
                    <i class="bi bi-mic"></i>
                    <div>
                        <h2>Audio &amp; Voice</h2>
                        <p>Manage linked audio, scripts, and male or female speech labels in one place.</p>
                    </div>
                </article>
            </div>
        </section>

        <section class="login-panel card border-0" data-reveal>
            <div class="card-body p-4 p-lg-5">
                <div class="login-brand" data-reveal>
                    <div class="login-brand__icon">
                        <i class="bi bi-person-lock"></i>
                    </div>
                    <div>
                        <span class="login-brand__tag">Admin Access</span>
                        <h2>Welcome back</h2>
                        <p>Use the sample form below to jump into the dashboard experience.</p>
                    </div>
                </div>

                <EditForm Model="_credentials" OnValidSubmit="HandleLoginAsync" FormName="login-form" class="login-form" data-stagger data-stagger-step="90">
                    <DataAnnotationsValidator />

                    <label class="login-field" for="username" data-reveal>
                        <span class="login-field__label">Username</span>
                        <span class="login-field__shell">
                            <i class="bi bi-person"></i>
                            <InputText id="username" class="form-control login-field__input" @bind-Value="_credentials.UserName" autocomplete="username" placeholder="Enter username" />
                        </span>
                        <ValidationMessage For="() => _credentials.UserName" class="login-validation" />
                    </label>

                    <label class="login-field" for="password" data-reveal>
                        <span class="login-field__label">Password</span>
                        <span class="login-field__shell">
                            <i class="bi bi-lock"></i>
                            <InputText id="password" type="password" class="form-control login-field__input" @bind-Value="_credentials.Password" autocomplete="current-password" placeholder="Enter password" />
                        </span>
                        <ValidationMessage For="() => _credentials.Password" class="login-validation" />
                    </label>

                    <div class="login-options" data-reveal>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="rememberMe">
                            <label class="form-check-label" for="rememberMe">Remember me</label>
                        </div>
                        <a href="#" class="login-text-link">Forgot password?</a>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_errorMessage))
                    {
                        <div class="login-error" data-reveal>@_errorMessage</div>
                    }

                    <button type="submit" class="btn login-submit w-100" disabled="@_isSubmitting" data-reveal>
                        <span>@(_isSubmitting ? "Signing In..." : "Sign In")</span>
                        <i class="bi bi-arrow-right-short"></i>
                    </button>
                </EditForm>

                <div class="login-footer" data-reveal>
                    <small>Start the API app before logging in.</small>
                </div>
            </div>
        </section>
    </div>
</div>

@code {
    private readonly AdminCredentialsModel _credentials = new();
    private bool _isSubmitting;
    private string? _errorMessage;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        if (await AuthService.IsAuthenticatedAsync())
        {
            Navigation.NavigateTo("/dashboard");
        }
    }

    private async Task HandleLoginAsync()
    {
        _isSubmitting = true;
        _errorMessage = null;

        var isAuthenticated = await AuthService.LoginAsync(_credentials.UserName, _credentials.Password);

        if (!isAuthenticated)
        {
            _errorMessage = "Invalid credentials. Use the static admin/admin account.";
            Notifications.Warning(_errorMessage, "Login failed");
            _isSubmitting = false;
            return;
        }

        Notifications.Success("Welcome back, admin.", "Login successful");
        Navigation.NavigateTo("/dashboard");
    }
}
