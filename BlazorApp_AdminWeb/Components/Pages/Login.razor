@page "/"
@using BlazorApp_AdminWeb.Components.Layout
@layout LoginLayout

<PageTitle>Login</PageTitle>

<div class="login-page">
    <div class="login-orb login-orb--one"></div>
    <div class="login-orb login-orb--two"></div>

    <div class="container login-shell">
        <section class="login-copy" data-reveal>
            <span class="login-copy__eyebrow">Smart Tourism Admin</span>
            <h1>One place to manage tours, audio guides, and moderation.</h1>
            <p>
                This mock login view now uses a direct link to the dashboard and adds cleaner spacing,
                animation, and focus states across the page.
            </p>

            <div class="login-copy__highlights" data-stagger data-stagger-step="110">
                <article class="login-highlight" data-reveal>
                    <i class="bi bi-compass"></i>
                    <div>
                        <h2>Content Control</h2>
                        <p>Review POIs, update routes, and keep destination pages consistent.</p>
                    </div>
                </article>

                <article class="login-highlight" data-reveal>
                    <i class="bi bi-headphones"></i>
                    <div>
                        <h2>Audio Pipeline</h2>
                        <p>Track uploads, approvals, and publishing from the same admin surface.</p>
                    </div>
                </article>

                <article class="login-highlight" data-reveal>
                    <i class="bi bi-shield-check"></i>
                    <div>
                        <h2>Moderation Flow</h2>
                        <p>Handle pending items faster with clearer status cues and motion feedback.</p>
                    </div>
                </article>
            </div>
        </section>

        <section class="login-panel card border-0" data-reveal>
            <div class="card-body p-4 p-lg-5">
                <div class="login-brand" data-reveal>
                    <div class="login-brand__icon">
                        <i class="bi bi-soundwave"></i>
                    </div>
                    <div>
                        <span class="login-brand__tag">Admin Access</span>
                        <h2>Welcome back</h2>
                        <p>Use the sample form below to jump into the dashboard experience.</p>
                    </div>
                </div>

                <div class="login-form" data-stagger data-stagger-step="90">
                    <label class="login-field" for="email" data-reveal>
                        <span class="login-field__label">Email Address</span>
                        <span class="login-field__shell">
                            <i class="bi bi-envelope"></i>
                            <input type="email" class="form-control login-field__input" id="email" placeholder="name@example.com" autocomplete="username">
                        </span>
                    </label>

                    <label class="login-field" for="password" data-reveal>
                        <span class="login-field__label">Password</span>
                        <span class="login-field__shell">
                            <i class="bi bi-lock"></i>
                            <input type="password" class="form-control login-field__input" id="password" placeholder="••••••••" autocomplete="current-password">
                        </span>
                    </label>

                    <div class="login-options" data-reveal>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="rememberMe">
                            <label class="form-check-label" for="rememberMe">Remember me</label>
                        </div>
                        <a href="#" class="login-text-link">Forgot password?</a>
                    </div>

                    <a href="/dashboard" class="btn login-submit w-100" data-reveal>
                        <span>Sign In to Dashboard</span>
                        <i class="bi bi-arrow-right-short"></i>
                    </a>

                    <div class="login-demo-note" data-reveal>
                        Demo mode: the button above uses a simple `href="/dashboard"` navigation.
                    </div>
                </div>

                <div class="login-footer" data-reveal>
                    <small>Need access? <a href="#" class="login-text-link">Contact support</a></small>
                </div>
            </div>
        </section>
    </div>
</div>
