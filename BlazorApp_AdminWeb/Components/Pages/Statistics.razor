    private string? GetPoiImageUrl(string? imagePath) => ApiClient.ResolveImageUrl(imagePath);
    private static string FormatDistance(double value) => $"{value.ToString("0.00", CultureInfo.InvariantCulture)} km";
    private static string FormatSeconds(double value)
    {
        if (value <= 0)
        {
            return "0 sec";
        }

        var roundedSeconds = (int)Math.Round(value, 0, MidpointRounding.AwayFromZero);
        if (roundedSeconds < 60)
        {
            return $"{roundedSeconds} sec";
        }

        return $"{roundedSeconds / 60} min {roundedSeconds % 60} sec";
    }

    private static double GetChartBarHeight(double value, IReadOnlyList<StatisticsChartPointDto> points)
    {
        var maxValue = points.Count == 0 ? 1d : Math.Max(1d, points.Max(item => item.Value));
        return 18d + (value / maxValue) * 82d;
    }

    private void EnsureSelectedRouteVisibleOnCurrentPage()
    {
        if (PaginatedRoutes.Count == 0)
        {
            _selectedSessionKey = _overview.RouteHistory.FirstOrDefault()?.SessionKey;
            _statisticsMapSyncPending = true;
            return;
        }

        if (!PaginatedRoutes.Any(item => string.Equals(item.SessionKey, _selectedSessionKey, StringComparison.OrdinalIgnoreCase)))
        {
            _selectedSessionKey = PaginatedRoutes[0].SessionKey;
            _statisticsMapSyncPending = true;
        }
    }

    private async Task<IReadOnlyList<StatisticsRoutePointDto>> ResolveSelectedTourRouteForMapAsync(
        IReadOnlyList<StatisticsRoutePointDto> selectedTourRoute)
    {
        var routeKey = BuildSelectedTourRouteKey(selectedTourRoute);
        if (string.IsNullOrWhiteSpace(routeKey))
        {
            _selectedTourRouteForMapKey = string.Empty;
            return [];
        }

        if (string.Equals(routeKey, _selectedTourRouteForMapKey, StringComparison.Ordinal))
        {
            return _selectedTourRouteForMap;
        }

        var fallbackRoute = selectedTourRoute
            .Select(item => new StatisticsRoutePointDto
            {
                Latitude = item.Latitude,
                Longitude = item.Longitude,
                CapturedAt = DateTime.UnixEpoch
            })
            .ToList();

        if (fallbackRoute.Count <= 1)
        {
            _selectedTourRouteForMapKey = routeKey;
            return fallbackRoute;
        }

        if (fallbackRoute.Count > 12)
        {
            _selectedTourRouteForMapKey = routeKey;
            return fallbackRoute;
        }

        var previewStops = fallbackRoute
            .Select((item, index) => new TourRoutePreviewStopRequest
            {
                LocationId = index + 1,
                SequenceOrder = index + 1,
                Latitude = item.Latitude,
                Longitude = item.Longitude
            })
            .ToList();

        try
        {
            var preview = await ApiClient.PreviewTourRouteAsync(new TourRoutePreviewRequest
            {
                Stops = previewStops
            });

            var routedPath = preview.Path
                .Where(item => double.IsFinite(item.Latitude) && double.IsFinite(item.Longitude))
                .Select(item => new StatisticsRoutePointDto
                {
                    Latitude = item.Latitude,
                    Longitude = item.Longitude,
                    CapturedAt = DateTime.UnixEpoch
                })
                .ToList();

            if (routedPath.Count > 1)
            {
                _selectedTourRouteForMapKey = routeKey;
                return routedPath;
            }
        }
        catch
        {
            // Keep statistics responsive and fall back to the tour stop line if route preview fails.
        }

        _selectedTourRouteForMapKey = routeKey;
        return fallbackRoute;
    }

    private static string BuildSelectedTourRouteKey(IReadOnlyList<StatisticsRoutePointDto> selectedTourRoute) =>
        selectedTourRoute.Count == 0
            ? string.Empty
            : string.Join("|", selectedTourRoute.Select(item =>
                $"{Math.Round(item.Latitude, 6).ToString(CultureInfo.InvariantCulture)},{Math.Round(item.Longitude, 6).ToString(CultureInfo.InvariantCulture)}"));

    private object CreateStatisticsMapState() => new
    {
        view = _savedStatisticsMapView is null
            ? null
            : new
            {
                latitude = _savedStatisticsMapView.Latitude,
                longitude = _savedStatisticsMapView.Longitude,
                zoom = _savedStatisticsMapView.Zoom
            },
        heatPoints = _overview.HeatmapPoints.Select(item => new
        {
            latitude = item.Latitude,
            longitude = item.Longitude,
            sessionCount = item.SessionCount,
            intensity = item.Intensity,
            totalWeight = item.TotalWeight,
            engagementScore = item.EngagementScore,
            ward = item.Ward
        }).ToList(),
        locations = _overview.Locations.Select(item => new
        {
            latitude = item.Latitude,
            longitude = item.Longitude,
            name = item.Name,
            ward = item.Ward,
            preferenceImageUrl = GetPoiImageUrl(item.PreferenceImageUrl),
            ownerName = item.OwnerName
        }).ToList(),
        selectedTourRoute = _selectedTourRouteForMap.Select(item => new
        {
            latitude = item.Latitude,
            longitude = item.Longitude
        }).ToList(),
        selectedRoute = SelectedRoute is null
            ? null
            : new
            {
                label = GetRouteLabel(SelectedRoute),
                primaryWard = SelectedRoute.PrimaryWard,
                routeDistanceKm = SelectedRoute.RouteDistanceKm,
                trackingPointCount = SelectedRoute.TrackingPointCount,
                points = SelectedRoute.Points.Select(item => new
                {
                    latitude = item.Latitude,
                    longitude = item.Longitude,
                    capturedAt = item.CapturedAt
                }).ToList()
            }
    };

    private async Task<bool> InitializeStatisticsMapAsync()
    {
        try
        {
            var isInitialized = await JS.InvokeAsync<bool>(
                "smartTourAdmin.map.initializeStatisticsMap",
                _statisticsMapElement,
                CreateStatisticsMapState());

            if (!isInitialized)
            {
                Notifications.Warning("The analytics map is unavailable right now.", "Map unavailable");
                _statisticsMapSyncPending = true;
            }

            return isInitialized;
        }
        catch (JSException)
        {
            Notifications.Warning("The analytics map is unavailable right now.", "Map unavailable");
            return false;
        }
    }

