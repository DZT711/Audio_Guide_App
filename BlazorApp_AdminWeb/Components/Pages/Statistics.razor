@page "/statistics"
@implements IAsyncDisposable
@using System.Globalization
@using System.Text.Json.Serialization
@inject AdminApiClient ApiClient
@inject NotificationService Notifications
@inject AdminSessionState SessionState
@inject IJSRuntime JS

<PageTitle>Statistics</PageTitle>

@if (!CanView)
{
    <div class="@GetStatisticsPageClass()">
        <div class="management-error">
            <strong>Access denied.</strong>
            <div>Your current role cannot view statistics.</div>
        </div>
    </div>
}
else
{
    <div class="@GetStatisticsPageClass()">
        <section class="management-hero statistics-hero" data-reveal>
            <div>
                <span class="management-hero__eyebrow">Overview</span>
                <h1>Statistics</h1>
                <p>Track anonymous route history, playback trends, heatmap hotspots, and POI listening quality with filters
                    for date range, tour, ward, and audio or POI names.</p>
                    @if (!_isLoading && string.IsNullOrWhiteSpace(_loadError))
                    {
                        <div class="statistics-scope">@_overview.ScopeLabel</div>
                    }
                </div>
                <div class="management-hero__actions">
                    <button type="button" class="btn btn-outline-secondary btn-lg" @onclick="ResetFiltersAsync"
                            disabled="@_isLoading">Reset</button>
                    <button type="button" class="btn btn-primary btn-lg" @onclick="RefreshAsync"
                            disabled="@_isLoading">@(_isLoading ? "Loading..." : "Refresh")</button>
                </div>
            </section>

            <section class="management-panel" data-reveal>
                <div class="management-panel__header">
                    <div>
                        <span class="management-panel__eyebrow">Filters</span>
                        <h2>Analytics Scope</h2>
                    </div>
                </div>

                <div class="statistics-filters">
                    <div class="management-field">
                        <label for="statistics-from">From</label>
                        <InputDate id="statistics-from" class="form-control" @bind-Value="_fromDate" />
                    </div>
                    <div class="management-field">
                        <label for="statistics-to">To</label>
                        <InputDate id="statistics-to" class="form-control" @bind-Value="_toDate" />
                    </div>
                    <div class="management-field">
                        <label for="statistics-tour">Tour</label>
                        <select id="statistics-tour" class="form-select" @bind="_selectedTourValue">
                            <option value="">All tours</option>
                            @foreach (var option in _overview.TourOptions)
                            {
                                <option value="@option.Value">@option.Label (@option.Count)</option>
                            }
                        </select>
                    </div>
                    <div class="management-field">
                        <label for="statistics-ward">Ward</label>
                        <select id="statistics-ward" class="form-select" @bind="_selectedWard">
                            <option value="">All wards</option>
                            @foreach (var option in _overview.WardOptions)
                            {
                                <option value="@option.Value">@option.Label (@option.Count)</option>
                            }
                        </select>
                    </div>
                    <div class="management-field management-field--full">
                        <label for="statistics-search">Search audio or POI</label>
                        <div class="management-search statistics-search">
                            <i class="bi bi-search"></i>
                            <input id="statistics-search" class="form-control" type="search"
                                   placeholder="Search by audio title, POI name, ward, or tour..." @bind="_searchText"
                                   @bind:event="oninput" />
                        </div>
                    </div>
                </div>
            </section>

            <div class="management-stat-grid statistics-stat-grid" data-stagger data-stagger-step="70">
                <article class="management-stat" data-reveal>
                    <span class="management-stat__icon"><i class="bi bi-headphones"></i></span>
                    <div><strong class="management-stat__value">@_overview.Summary.TotalPlaybackEvents</strong><span
                        class="management-stat__label">Playback Events</span></div>
                    </article>
                    <article class="management-stat" data-reveal>
                        <span class="management-stat__icon"><i class="bi bi-geo"></i></span>
                        <div><strong class="management-stat__value">@_overview.Summary.TotalTrackingPoints</strong><span
                            class="management-stat__label">Tracking Points</span></div>
                        </article>
                        <article class="management-stat" data-reveal>
                            <span class="management-stat__icon"><i class="bi bi-signpost-2"></i></span>
                            <div><strong class="management-stat__value">@_overview.Summary.RouteSessions</strong><span
                                class="management-stat__label">Anonymous Routes</span></div>
                            </article>
                                <article class="management-stat" data-reveal>
                                    <span class="management-stat__icon"><i class="bi bi-people"></i></span>
                                    <div><strong class="management-stat__value">@_overview.Summary.UniqueGuests</strong><span
                                        class="management-stat__label">Anonymous Guests</span></div>
                                </article>
                                <article class="management-stat" data-reveal>
                                    <span class="management-stat__icon"><i class="bi bi-broadcast-pin"></i></span>
                                    <div><strong class="management-stat__value">@_overview.Summary.OnlineGuests</strong><span
                                        class="management-stat__label">Online Guests</span></div>
                                </article>
                                <article class="management-stat" data-reveal>
                                    <span class="management-stat__icon"><i class="bi bi-hourglass-split"></i></span>
                                    <div><strong
                                        class="management-stat__value">@FormatSeconds(_overview.Summary.AverageListeningSeconds)</strong><span
                                        class="management-stat__label">Average Listening</span></div>
                                    </article>
                                    <article class="management-stat" data-reveal>
                                        <span class="management-stat__icon"><i class="bi bi-pin-map"></i></span>
                                        <div><strong class="management-stat__value">@_overview.Summary.VisiblePois</strong><span
                                            class="management-stat__label">Visible POIs</span></div>
                                        </article>
                                    </div>

                                    @if (_isLoading)
                                    {
                                        <section class="management-panel">
                                            <div class="tour-skeleton-table">
                                                @for (var i = 0; i < 5; i++)
                                                {
                                                    <div class="skeleton-table-row">
                                                        <div class="skeleton skeleton--line"></div>
                                                        <div class="skeleton skeleton--line"></div>
                                                        <div class="skeleton skeleton--line"></div>
                                                        <div class="skeleton skeleton--line"></div>
                                                    </div>
                                                }
                                            </div>
                                        </section>
                                    }
                                    else if (!string.IsNullOrWhiteSpace(_loadError))
                                    {
                                        <div class="management-error">
                                            <strong>Unable to load statistics.</strong>
                                            <div>@_loadError</div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="statistics-layout">
                                            <div class="@GetHeatmapSlotClass()" @ref="_heatmapSlotElement">
                                            <section class="@GetHeatmapPanelClass()" @ref="_heatmapPanelElement" aria-modal="@_isHeatmapExpanded" role="@(_isHeatmapExpanded ? "dialog" : "region")">
                                                <div class="management-panel__header statistics-panel__header">
                                                    <div>
                                                        <span class="management-panel__eyebrow">Heatmap</span>
                                                        <h2>User Position Hotspots</h2>
                                                    </div>
                                                    <div class="statistics-panel__tools">
                                                        <div class="statistics-legend">
                                                            <span><svg class="legend-icon" viewBox="0 0 20 20" aria-hidden="true">
                                                                <polygon points="10,1.5 16.5,5.25 16.5,12.75 10,16.5 3.5,12.75 3.5,5.25" fill="#FF9736" opacity="0.9" />
                                                            </svg> Warm: 1 user/area</span>
                                                            <span><svg class="legend-icon" viewBox="0 0 20 20" aria-hidden="true">
                                                                <polygon points="10,1.5 16.5,5.25 16.5,12.75 10,16.5 3.5,12.75 3.5,5.25" fill="#FFD24A" opacity="0.9" />
                                                            </svg> Gold: 2-5 users/area</span>
                                                            <span><svg class="legend-icon" viewBox="0 0 20 20" aria-hidden="true">
                                                                <polygon points="10,1.5 16.5,5.25 16.5,12.75 10,16.5 3.5,12.75 3.5,5.25" fill="#EF4444" opacity="0.92" />
                                                            </svg> Red: 6+ users/area</span>
                                                            <span><i class="bi bi-bezier2"></i> Selected route</span>
                                                            <span><i class="bi bi-geo-alt-fill"></i> POIs</span>
                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="statistics-map-tools">
                                                    <div class="statistics-map-tools__actions">
                                                        <button type="button"
                                                                class="btn btn-outline-secondary btn-sm statistics-panel__expand"
                                                                @onclick="ToggleHeatmapExpandedAsync"
                                                                aria-expanded="@_isHeatmapExpanded"
                                                                aria-label="@(_isHeatmapExpanded ? "Close full heatmap view" : "Open heatmap in full view")">
                                                            <i class="@(_isHeatmapExpanded ? "bi bi-fullscreen-exit" : "bi bi-arrows-fullscreen") me-1"></i>
                                                            @(_isHeatmapExpanded ? "Close full view" : "Full view")
                                                        </button>
                                                        <button type="button"
                                                                class="btn btn-outline-secondary btn-sm"
                                                                @onclick="CenterStatisticsMapAsync"
                                                                disabled="@(!_statisticsMapInitialized)">
                                                            <i class="bi bi-bullseye me-1"></i>
                                                            Center map
                                                        </button>
                                                        <button type="button"
                                                                class="btn btn-outline-secondary btn-sm"
                                                                @onclick="ToggleCurrentLocationTrackingAsync"
                                                                disabled="@_isLocationTrackingBusy">
                                                            <i class="bi @(_isLocationTrackingBusy ? "bi-hourglass-split" : _isTrackingCurrentLocation ? "bi-pause-circle" : "bi-crosshair") me-1"></i>
                                                            @(_isLocationTrackingBusy
                                                                ? "Updating..."
                                                                : _isTrackingCurrentLocation
                                                                    ? "Stop tracking"
                                                                    : "Track my location")
                                                        </button>
                                                    </div>

                                                    <div class="statistics-map-search">
                                                        <label class="statistics-map-search__box" for="statistics-map-search">
                                                            <i class="bi bi-search"></i>
                                                            <input id="statistics-map-search"
                                                                   class="form-control"
                                                                   type="search"
                                                                   placeholder="Search a landmark, street, or address on the heatmap"
                                                                   @bind="_mapSearchText"
                                                                   @bind:event="oninput" />
                                                        </label>

                                                        <button type="button"
                                                                class="btn btn-outline-secondary btn-sm"
                                                                @onclick="SearchMapAsync"
                                                                disabled="@(_isMapSearching || string.IsNullOrWhiteSpace(_mapSearchText))">
                                                            <i class="bi @(_isMapSearching ? "bi-hourglass-split" : "bi-search") me-1"></i>
                                                            @(_isMapSearching ? "Searching..." : "Find place")
                                                        </button>
                                                    </div>
                                                </div>

                                                @if (!string.IsNullOrWhiteSpace(_mapSearchError))
                                                {
                                                    <div class="statistics-map-search__feedback" aria-live="polite">@_mapSearchError</div>
                                                }
                                                else if (_mapSearchResults.Count > 0)
                                                {
                                                    <div class="statistics-map-results" aria-live="polite">
                                                        @foreach (var result in _mapSearchResults)
                                                        {
                                                            <button type="button" class="statistics-map-result" @onclick="() => SelectMapSearchResultAsync(result)">
                                                                <strong>@GetMapSearchResultTitle(result)</strong>
                                                                @if (!string.IsNullOrWhiteSpace(result.Address))
                                                                {
                                                                    <small>@result.Address</small>
                                                                }
                                                                <span class="statistics-map-result__coords">@($"{result.Latitude:F6}, {result.Longitude:F6}")</span>
                                                            </button>
                                                        }
                                                    </div>
                                                }

                                                <div class="statistics-map">
                                                    <div class="statistics-map__canvas" @ref="_statisticsMapElement" role="img" aria-label="Anonymous route heatmap"></div>
                                                </div>

                                                @if (_overview.HeatmapPoints.Count == 0 && _overview.Locations.Count == 0 && (SelectedRoute?.Points.Count ?? 0) == 0)
                                                {
                                                    <div class="app-empty-state statistics-map__notice">No heatmap data matches the current filters.</div>
                                                }

                                                @if (SelectedRoute is not null)
                                                {
                                                    <div class="statistics-route-highlight">
                                                        <strong>@GetRouteLabel(SelectedRoute)</strong>
                                                        <span>@SelectedRoute.PrimaryWard</span>
                                                        <span>@FormatDistance(SelectedRoute.RouteDistanceKm)</span>
                                                        <span>@SelectedRoute.TrackingPointCount points</span>
                                                    </div>
                                                }
                                            </section>
                                            </div>

                                            <section class="management-panel statistics-panel" data-reveal>
                                                <div class="management-panel__header">
                                                    <div>
                                                        <span class="management-panel__eyebrow">Routes</span>
                                                        <h2>Anonymous Route History</h2>
                                                    </div>
                                                </div>

                                                @if (_overview.RouteHistory.Count == 0)
                                                {
                                                    <div class="app-empty-state">No anonymous route sessions match the current filters.</div>
                                                }
                                                else
                                                {
                                                    <div class="management-page-swap" @key="CurrentRoutePage">
                                                        <div class="statistics-route-list">
                                                            @foreach (var route in PaginatedRoutes)
                                                            {
                                                                <button type="button" class="@GetRouteCardClass(route)"
                                                                        @onclick="@(() => SelectRoute(route.SessionKey))">
                                                                    <div class="statistics-route-card__top">
                                                                        <strong>@GetRouteLabel(route)</strong>
                                                                        <span>@route.PrimaryWard</span>
                                                                    </div>
                                                                    <div class="statistics-route-card__meta">@route.StartedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm") to @route.EndedAt.ToLocalTime().ToString("HH:mm")</div>
                                                                    <div class="statistics-route-card__chips">
                                                                        <span>@FormatDistance(route.RouteDistanceKm)</span>
                                                                        <span>@route.PlaybackCount plays</span>
                                                                        <span>@route.TrackingPointCount points</span>
                                                                    </div>
                                                                    <div class="statistics-route-card__copy">
                                                                        <strong>POIs:</strong> @JoinItems(route.LocationNames)
                                                                    </div>
                                                                    <div class="statistics-route-card__copy">
                                                                        <strong>Audio:</strong> @JoinItems(route.AudioTitles)
                                                                    </div>
                                                                </button>
                                                            }
                                                        </div>
                                                    </div>
                                                    @if (TotalRoutePages > 1)
                                                    {
                                                        <div class="management-pagination">
                                                            <span class="management-pagination__info">Page @CurrentRoutePage of @TotalRoutePages (@_overview.RouteHistory.Count
                                                                total)</span>
                                                            <div class="management-pagination__actions">
                                                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="PreviousRoutePage"
                                                                        disabled="@(CurrentRoutePage <= 1)">
                                                                    <i class="bi bi-chevron-left"></i> Previous
                                                                </button>
                                                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="NextRoutePage"
                                                                        disabled="@(CurrentRoutePage >= TotalRoutePages)">
                                                                    Next <i class="bi bi-chevron-right"></i>
                                                                </button>
                                                            </div>
                                                        </div>
                                                        }
                                                    }
                                                </section>
                                            </div>

                                            <div class="statistics-chart-grid">
                                                <section class="management-panel statistics-panel" data-reveal>
                                                    <div class="management-panel__header">
                                                        <div>
                                                            <span class="management-panel__eyebrow">Chart</span>
                                                            <h2>Playback Timeline</h2>
                                                        </div>
                                                        <span class="statistics-panel__hint">Daily plays inside the selected date range.</span>
                                                    </div>
                                                    @if (_overview.PlaybackTimeline.Count == 0)
                                                    {
                                                        <div class="app-empty-state">No playback trend data matches the current filters.</div>
                                                    }
                                                    else
                                                    {
                                                        <div class="statistics-chart" tabindex="0">
                                                            @foreach (var point in _overview.PlaybackTimeline)
                                                            {
                                                                <div class="statistics-chart__bar" title="@point.Hint">
                                                                    <span class="statistics-chart__value">@point.Value.ToString("0",
                                                                                                CultureInfo.InvariantCulture)</span>
                                                                        <span class="statistics-chart__fill"
                                                                              style="@($"height:{GetChartBarHeight(point.Value, _overview.PlaybackTimeline).ToString("0.0", CultureInfo.InvariantCulture)}%")"></span>
                                                                        <span class="statistics-chart__label">@point.Label</span>
                                                                    </div>
                                                                }
                                                            </div>
                                                        }
                                                    </section>

                                                    <section class="management-panel statistics-panel" data-reveal>
                                                        <div class="management-panel__header">
                                                            <div>
                                                                <span class="management-panel__eyebrow">Chart</span>
                                                                <h2>Plays By Ward</h2>
                                                            </div>
                                                            <span class="statistics-panel__hint">Ward-level activity from filtered playback sessions.</span>
                                                        </div>
                                                        @if (_overview.PlaysByWard.Count == 0)
                                                        {
                                                            <div class="app-empty-state">No ward activity matches the current filters.</div>
                                                        }
                                                        else
                                                        {
                                                            <div class="statistics-chart statistics-chart--compact" tabindex="0">
                                                                @foreach (var point in _overview.PlaysByWard)
                                                                {
                                                                    <div class="statistics-chart__bar" title="@point.Hint">
                                                                        <span class="statistics-chart__value">@point.Value.ToString("0",
                                                                                                    CultureInfo.InvariantCulture)</span>
                                                                            <span class="statistics-chart__fill"
                                                                                  style="@($"height:{GetChartBarHeight(point.Value, _overview.PlaysByWard).ToString("0.0", CultureInfo.InvariantCulture)}%")"></span>
                                                                            <span class="statistics-chart__label">@point.Label</span>
                                                                        </div>
                                                                    }
                                                                </div>
                                                            }
                                                        </section>

                                                        <section class="management-panel statistics-panel" data-reveal>
                                                            <div class="management-panel__header">
                                                                <div>
                                                                    <span class="management-panel__eyebrow">Chart</span>
                                                                    <h2>Plays By Tour</h2>
                                                                </div>
                                                                <span class="statistics-panel__hint">Tour-level playback counts after the current filters.</span>
                                                            </div>
                                                            @if (_overview.PlaysByTour.Count == 0)
                                                            {
                                                                <div class="app-empty-state">No tour activity matches the current filters.</div>
                                                            }
                                                            else
                                                            {
                                                                <div class="statistics-chart statistics-chart--compact" tabindex="0">
                                                                    @foreach (var point in _overview.PlaysByTour)
                                                                    {
                                                                        <div class="statistics-chart__bar" title="@point.Hint">
                                                                            <span class="statistics-chart__value">@point.Value.ToString("0",
                                                                                                        CultureInfo.InvariantCulture)</span>
                                                                                <span class="statistics-chart__fill"
                                                                                      style="@($"height:{GetChartBarHeight(point.Value, _overview.PlaysByTour).ToString("0.0", CultureInfo.InvariantCulture)}%")"></span>
                                                                                <span class="statistics-chart__label">@point.Label</span>
                                                                            </div>
                                                                        }
                                                                    </div>
                                                                }
                                                            </section>
                                                        </div>

                                                        <div class="statistics-report-grid">
                                                            <section class="management-panel statistics-panel" data-reveal>
                                                                <div class="management-panel__header">
                                                                    <div>
                                                                        <span class="management-panel__eyebrow">Report</span>
                                                                        <h2>Top POIs by audio play count</h2>
                                                                    </div>
                                                                </div>
                                                                @if (_overview.TopPoisByPlayCount.Count == 0)
                                                                {
                                                                    <div class="app-empty-state">No POI playback report rows match the current filters.</div>
                                                                }
                                                                else
                                                                {
                                                                    <div class="table-responsive">
                                                                        <table class="table management-table">
                                                                            <thead>
                                                                                <tr>
                                                                                    <th>Avatar</th>
                                                                                    <th>POI</th>
                                                                                    <th>Ward</th>
                                                                                    <th>Plays</th>
                                                                                    <th>Avg Listening</th>
                                                                                    <th>Top Audio</th>
                                                                                </tr>
                                                                            </thead>
                                                                            <tbody>
                                                                                @foreach (var row in _overview.TopPoisByPlayCount)
                                                                                {
                                                                                    <tr>
                                                                                        <td>
                                                                                            @if (GetPoiImageUrl(row.PreferenceImageUrl) is { } imageUrl)
                                                                                            {
                                                                                                <img class="statistics-poi-avatar" src="@imageUrl" alt="@($"{row.LocationName} avatar")" />
                                                                                            }
                                                                                            else
                                                                                            {
                                                                                                <span class="statistics-poi-avatar statistics-poi-avatar--placeholder">
                                                                                                    <i class="bi bi-image"></i>
                                                                                                </span>
                                                                                            }
                                                                                        </td>
                                                                                        <td>
                                                                                            <div>@row.LocationName</div>
                                                                                            <small class="management-muted">@(row.OwnerName ?? "No owner")</small>
                                                                                        </td>
                                                                                        <td>@row.Ward</td>
                                                                                        <td>@row.PlayCount</td>
                                                                                        <td>@FormatSeconds(row.AverageListeningSeconds)</td>
                                                                                        <td>@(row.TopAudioTitle ?? "No linked audio")</td>
                                                                                    </tr>
                                                                                }
                                                                            </tbody>
                                                                        </table>
                                                                    </div>
                                                                }
                                                            </section>

                                                            <section class="management-panel statistics-panel" data-reveal>
                                                                <div class="management-panel__header">
                                                                    <div>
                                                                        <span class="management-panel__eyebrow">Report</span>
                                                                        <h2>Average listening time per POI</h2>
                                                                    </div>
                                                                </div>
                                                                @if (_overview.AverageListeningByPoi.Count == 0)
                                                                {
                                                                    <div class="app-empty-state">No listening-time report rows match the current filters.</div>
                                                                }
                                                                else
                                                                {
                                                                    <div class="table-responsive">
                                                                        <table class="table management-table">
                                                                            <thead>
                                                                                <tr>
                                                                                    <th>Avatar</th>
                                                                                    <th>POI</th>
                                                                                    <th>Ward</th>
                                                                                    <th>Avg Listening</th>
                                                                                    <th>Samples</th>
                                                                                    <th>Plays</th>
                                                                                </tr>
                                                                            </thead>
                                                                            <tbody>
                                                                                @foreach (var row in _overview.AverageListeningByPoi)
                                                                                {
                                                                                    <tr>
                                                                                        <td>
                                                                                            @if (GetPoiImageUrl(row.PreferenceImageUrl) is { } imageUrl)
                                                                                            {
                                                                                                <img class="statistics-poi-avatar" src="@imageUrl" alt="@($"{row.LocationName} avatar")" />
                                                                                            }
                                                                                            else
                                                                                            {
                                                                                                <span class="statistics-poi-avatar statistics-poi-avatar--placeholder">
                                                                                                    <i class="bi bi-image"></i>
                                                                                                </span>
                                                                                            }
                                                                                        </td>
                                                                                        <td>
                                                                                            <div>@row.LocationName</div>
                                                                                            <small class="management-muted">@JoinItems(row.TourNames)</small>
                                                                                        </td>
                                                                                        <td>@row.Ward</td>
                                                                                        <td>@FormatSeconds(row.AverageListeningSeconds)</td>
                                                                                        <td>@row.ListeningSamples</td>
                                                                                        <td>@row.PlayCount</td>
                                                                                    </tr>
                                                                                }
                                                                            </tbody>
                                                                        </table>
                                                                    </div>
                                                                }
                                                            </section>
                                                        </div>
                                                    }
                                                </div>
                                            }

@code {
    private const string DefaultReportTimezone = "Asia/Ho_Chi_Minh";
    private static readonly TimeZoneInfo DefaultReportTimeZone = ResolveReportTimeZone(DefaultReportTimezone);
    private StatisticsOverviewDto _overview = new();
    private DateTime? _fromDate = GetDefaultReportToday().AddDays(-14);
    private DateTime? _toDate = GetDefaultReportToday();
    private readonly List<MapSearchResult> _mapSearchResults = new();
    private string _selectedTourValue = "";
    private string _selectedWard = "";
    private string _searchText = "";
    private string _mapSearchText = "";
    private string? _selectedSessionKey;
    private bool _isLoading = true;
    private bool _isMapSearching;
    private bool _isTrackingCurrentLocation;
    private bool _isLocationTrackingBusy;
    private string? _loadError;
    private string? _mapSearchError;
    private IReadOnlyList<StatisticsRoutePointDto> _selectedTourRouteForMap = [];
    private string _selectedTourRouteForMapKey = "";
    private ElementReference _statisticsMapElement;
    private ElementReference _heatmapPanelElement;
    private ElementReference _heatmapSlotElement;
    private bool _statisticsMapInitialized;
    private bool _statisticsMapSyncPending;
    private bool _statisticsMapLayoutRefreshPending;
    private bool _statisticsMapTrackingRefreshPending;
    private bool _isHeatmapExpanded;
    private bool? _bodyScrollLockState;
    private bool _clearPinnedHeatmapSlotHeightPending;
    private StatisticsMapViewState? _savedStatisticsMapView;
    private static readonly TimeSpan AutoRefreshInterval = TimeSpan.FromSeconds(3);
    private readonly SemaphoreSlim _loadLock = new(1, 1);
    private CancellationTokenSource? _autoRefreshCts;
    private Task? _autoRefreshTask;
    private bool _isDisposed;

    private int _currentRoutePage = 1;
    private const int RoutesPerPage = 4;

    private bool CanView => SessionState.HasPermission(AdminPermissions.AnalyticsView);
    private StatisticsRouteHistoryDto? SelectedRoute => _overview.RouteHistory.FirstOrDefault(item =>
string.Equals(item.SessionKey, _selectedSessionKey, StringComparison.OrdinalIgnoreCase));
    private int TotalRoutePages => Math.Max(1, (int)Math.Ceiling((double)_overview.RouteHistory.Count / RoutesPerPage));
    private int CurrentRoutePage => Math.Min(Math.Max(_currentRoutePage, 1), TotalRoutePages);
    private IReadOnlyList<StatisticsRouteHistoryDto> PaginatedRoutes => _overview.RouteHistory
        .Skip((CurrentRoutePage - 1) * RoutesPerPage)
        .Take(RoutesPerPage)
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        StartAutoRefreshLoop();
    }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!CanView || _isLoading || !string.IsNullOrWhiteSpace(_loadError))
        {
            return;
        }

        if (!_statisticsMapInitialized)
        {
            _statisticsMapInitialized = await InitializeStatisticsMapAsync();
            if (!_statisticsMapInitialized)
            {
                _statisticsMapSyncPending = false;
                _statisticsMapLayoutRefreshPending = false;
                return;
            }

            _statisticsMapSyncPending = false;
        }

        if (_statisticsMapSyncPending)
        {
            _statisticsMapSyncPending = false;
            await SyncStatisticsMapAsync();
        }

        if (_statisticsMapLayoutRefreshPending)
        {
            _statisticsMapLayoutRefreshPending = false;
            await RefreshStatisticsMapLayoutAsync();
        }

        if (_statisticsMapTrackingRefreshPending)
        {
            _statisticsMapTrackingRefreshPending = false;
            await RestoreCurrentLocationTrackingAsync();
        }

        if (_bodyScrollLockState != _isHeatmapExpanded)
        {
            await SyncBodyScrollLockAsync(_isHeatmapExpanded);
        }

        if (_clearPinnedHeatmapSlotHeightPending && !_isHeatmapExpanded)
        {
            _clearPinnedHeatmapSlotHeightPending = false;
            await ClearPinnedHeatmapSlotHeightAsync();
        }
    }

    private async Task RefreshAsync() => await LoadAsync();

    private async Task ResetFiltersAsync()
    {
        var reportToday = GetDefaultReportToday();
        _fromDate = reportToday.AddDays(-14);
        _toDate = reportToday;
        _selectedTourValue = "";
        _selectedWard = "";
        _searchText = "";
        _currentRoutePage = 1;
        await LoadAsync();
    }

    private async Task LoadAsync(bool isAutoRefresh = false)
    {
        if (_isDisposed)
        {
            return;
        }

        if (!await _loadLock.WaitAsync(0))
        {
            return;
        }

        try
        {
            if (!isAutoRefresh)
            {
                _savedStatisticsMapView = await CaptureStatisticsMapViewAsync();
                await DisposeStatisticsMapAsync();
                _statisticsMapTrackingRefreshPending = _isTrackingCurrentLocation;
                _isLoading = true;
                _loadError = null;
                _currentRoutePage = 1;
            }

            var reportTimezone = DefaultReportTimezone;
            _overview = await ApiClient.GetStatisticsAsync(new StatisticsQueryDto
            {
                From = ToUtcFromDate(_fromDate, reportTimezone),
                To = ToUtcToDate(_toDate, reportTimezone),
                Timezone = reportTimezone,
                TourId = int.TryParse(_selectedTourValue, out var tourId) ? tourId : null,
                Ward = string.IsNullOrWhiteSpace(_selectedWard) ? null : _selectedWard,
                Search = string.IsNullOrWhiteSpace(_searchText) ? null : _searchText.Trim()
            });
            _selectedTourRouteForMap = await ResolveSelectedTourRouteForMapAsync(_overview.SelectedTourRoute);

            _selectedSessionKey = _overview.RouteHistory.Any(item => string.Equals(item.SessionKey, _selectedSessionKey,
StringComparison.OrdinalIgnoreCase))
                ? _selectedSessionKey
                : _overview.RouteHistory.FirstOrDefault()?.SessionKey;

            EnsureSelectedRouteVisibleOnCurrentPage();
            _statisticsMapSyncPending = true;

            if (isAutoRefresh)
            {
                _loadError = null;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (Exception ex)
        {
            if (!isAutoRefresh)
            {
                _loadError = ex.Message;
                Notifications.Error(ex.Message, "Statistics load failed");
            }
        }
        finally
        {
            if (!isAutoRefresh)
            {
                _isLoading = false;
            }

            _loadLock.Release();
        }
    }

    private void StartAutoRefreshLoop()
    {
        if (!CanView || _isDisposed || _autoRefreshTask is not null)
        {
            return;
        }

        _autoRefreshCts = new CancellationTokenSource();
        _autoRefreshTask = RunAutoRefreshLoopAsync(_autoRefreshCts.Token);
    }

    private async Task RunAutoRefreshLoopAsync(CancellationToken cancellationToken)
    {
        try
        {
            using var timer = new PeriodicTimer(AutoRefreshInterval);
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                await InvokeAsync(() => LoadAsync(isAutoRefresh: true));
            }
        }
        catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
        {
        }
    }

    private void SelectRoute(string sessionKey)
    {
        _selectedSessionKey = sessionKey;
        _statisticsMapSyncPending = true;
    }

    private async Task ToggleHeatmapExpandedAsync()
    {
        if (_isHeatmapExpanded)
        {
            _isHeatmapExpanded = false;
            _clearPinnedHeatmapSlotHeightPending = true;
            _statisticsMapLayoutRefreshPending = true;
            _statisticsMapSyncPending = true;
            await InvokeAsync(StateHasChanged);
            return;
        }

        await PinHeatmapSlotHeightAsync();
        _isHeatmapExpanded = true;
        _statisticsMapLayoutRefreshPending = true;
        _statisticsMapSyncPending = true;
        await InvokeAsync(StateHasChanged);
    }

