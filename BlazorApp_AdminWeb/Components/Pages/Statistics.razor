    private async Task RestoreCurrentLocationTrackingAsync()
    {
        if (!_isTrackingCurrentLocation || !_statisticsMapInitialized)
        {
            return;
        }

        var stateChanged = false;

        try
        {
            var started = await JS.InvokeAsync<bool>(
                "smartTourAdmin.map.startStatisticsMapTracking",
                _statisticsMapElement);

            if (!started)
            {
                _isTrackingCurrentLocation = false;
                stateChanged = true;
            }
        }
        catch (JSException)
        {
            _isTrackingCurrentLocation = false;
            stateChanged = true;
        }

        if (stateChanged)
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task DisposeStatisticsMapAsync()
    {
        if (!_statisticsMapInitialized)
        {
            return;
        }

        try
        {
            await JS.InvokeVoidAsync("smartTourAdmin.map.disposeStatisticsMap", _statisticsMapElement);
        }
        catch (JSDisconnectedException)
        {
        }
        catch (JSException)
        {
        }
        catch (TaskCanceledException)
        {
        }
        finally
        {
            _statisticsMapInitialized = false;
            _statisticsMapSyncPending = false;
            _statisticsMapLayoutRefreshPending = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        _isDisposed = true;
        if (_autoRefreshCts is not null)
        {
            try
            {
                await _autoRefreshCts.CancelAsync();
            }
            catch
            {
            }
        }

        if (_autoRefreshTask is not null)
        {
            try
            {
                await _autoRefreshTask;
            }
            catch (OperationCanceledException)
            {
            }
        }

        _autoRefreshCts?.Dispose();

        await DisposeStatisticsMapAsync();

        try
        {
            if (_bodyScrollLockState == true)
            {
                await JS.InvokeVoidAsync("smartTourAdmin.shell.setBodyScrollLock", false);
            }
        }
        catch (JSDisconnectedException)
        {
        }
        catch (JSException)
        {
        }
        catch (TaskCanceledException)
        {
        }

        _loadLock.Dispose();
    }

    private sealed class MapSearchResult
    {
        [JsonPropertyName("name")]
        public string Name { get; init; } = "";

        [JsonPropertyName("address")]
        public string Address { get; init; } = "";

        [JsonPropertyName("latitude")]
        public double Latitude { get; init; }

        [JsonPropertyName("longitude")]
        public double Longitude { get; init; }

        [JsonIgnore]
        public bool HasCoordinates => double.IsFinite(Latitude) && double.IsFinite(Longitude);
    }

    private sealed class StatisticsMapViewState
    {
        [JsonPropertyName("latitude")]
        public double Latitude { get; init; }

        [JsonPropertyName("longitude")]
        public double Longitude { get; init; }

        [JsonPropertyName("zoom")]
        public double Zoom { get; init; }
    }
