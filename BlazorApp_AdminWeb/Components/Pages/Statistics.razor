    private async Task SearchMapAsync()
    {
        var query = _mapSearchText.Trim();
        _mapSearchResults.Clear();
        _mapSearchError = null;

        if (string.IsNullOrWhiteSpace(query))
        {
            _mapSearchError = "Enter a landmark, street, or address to search the heatmap.";
            return;
        }

        _isMapSearching = true;

        try
        {
            var results = await JS.InvokeAsync<MapSearchResult[]>(
                "smartTourAdmin.map.searchLocationPicker",
                query);

            _mapSearchResults.Clear();
            _mapSearchResults.AddRange(results
                .Where(item => item.HasCoordinates)
                .Take(6));

            if (_mapSearchResults.Count == 0)
            {
                _mapSearchError = $"No places were found for '{query}'.";
            }
        }
        catch (JSException)
        {
            _mapSearchError = "Map search is unavailable right now.";
        }
        finally
        {
            _isMapSearching = false;
        }
    }

    private async Task SelectMapSearchResultAsync(MapSearchResult result)
    {
        if (!_statisticsMapInitialized)
        {
            _mapSearchError = "The heatmap is still loading. Try again in a moment.";
            return;
        }

        _mapSearchError = null;
        _mapSearchResults.Clear();

        if (!string.IsNullOrWhiteSpace(result.Address))
        {
            _mapSearchText = result.Address;
        }
        else if (!string.IsNullOrWhiteSpace(result.Name))
        {
            _mapSearchText = result.Name;
        }

        try
        {
            await JS.InvokeVoidAsync(
                "smartTourAdmin.map.focusStatisticsMapLocation",
                _statisticsMapElement,
                Math.Round(result.Latitude, 6),
                Math.Round(result.Longitude, 6),
                GetMapSearchResultTitle(result),
                result.Address);
        }
        catch (JSException)
        {
            _mapSearchError = "The heatmap could not focus on that place right now.";
        }
    }

    private async Task ToggleCurrentLocationTrackingAsync()
    {
        if (_isLocationTrackingBusy)
        {
            return;
        }

        _isLocationTrackingBusy = true;

        try
        {
            if (_isTrackingCurrentLocation)
            {
                await JS.InvokeAsync<bool>(
                    "smartTourAdmin.map.stopStatisticsMapTracking",
                    _statisticsMapElement);

                _isTrackingCurrentLocation = false;
                Notifications.Info("Live location tracking stopped for the heatmap.", "Tracking stopped");
                return;
            }

            var started = await JS.InvokeAsync<bool>(
                "smartTourAdmin.map.startStatisticsMapTracking",
                _statisticsMapElement);

            if (!started)
            {
                Notifications.Warning("The browser could not start live location tracking for the heatmap.", "Location unavailable");
                return;
            }

            _isTrackingCurrentLocation = true;
            Notifications.Success("Live location tracking is active on the heatmap.", "Tracking enabled");
        }
        catch (JSException)
        {
            Notifications.Warning("The browser could not access your location for the heatmap.", "Location unavailable");
        }
        finally
        {
            _isLocationTrackingBusy = false;
        }
    }

    private void NextRoutePage()
    {
        if (CurrentRoutePage < TotalRoutePages)
        {
            _currentRoutePage = CurrentRoutePage + 1;
            EnsureSelectedRouteVisibleOnCurrentPage();
        }
    }

    private void PreviousRoutePage()
    {
        if (CurrentRoutePage > 1)
        {
            _currentRoutePage = CurrentRoutePage - 1;
            EnsureSelectedRouteVisibleOnCurrentPage();
        }
    }

