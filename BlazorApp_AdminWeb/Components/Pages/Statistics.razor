    private static string JoinItems(IReadOnlyList<string> items) => items.Count == 0 ? "No linked content" : string.Join(", ", items);
    private static string GetRouteLabel(StatisticsRouteHistoryDto route) => route.SessionId ?? route.DeviceId ??
route.SessionKey;
    private static DateTime? ToUtcFromDate(DateTime? value, string reportTimezone)
    {
        if (!value.HasValue)
        {
            return null;
        }

        var reportTimeZone = ResolveReportTimeZone(reportTimezone);
        var reportLocalStart = DateTime.SpecifyKind(value.Value.Date, DateTimeKind.Unspecified);
        return TimeZoneInfo.ConvertTimeToUtc(reportLocalStart, reportTimeZone);
    }

    private static DateTime? ToUtcToDate(DateTime? value, string reportTimezone)
    {
        if (!value.HasValue)
        {
            return null;
        }

        var reportTimeZone = ResolveReportTimeZone(reportTimezone);
        var reportLocalEnd = DateTime.SpecifyKind(value.Value.Date.AddDays(1).AddTicks(-1), DateTimeKind.Unspecified);
        return TimeZoneInfo.ConvertTimeToUtc(reportLocalEnd, reportTimeZone);
    }

    private static DateTime GetDefaultReportToday() =>
        TimeZoneInfo.ConvertTimeFromUtc(DateTime.UtcNow, DefaultReportTimeZone).Date;

    private static TimeZoneInfo ResolveReportTimeZone(string? timezone)
    {
        var candidate = string.IsNullOrWhiteSpace(timezone)
            ? DefaultReportTimezone
            : timezone.Trim();

        if (TryFindTimeZone(candidate, out var reportTimeZone))
        {
            return reportTimeZone;
        }

        if (TimeZoneInfo.TryConvertIanaIdToWindowsId(candidate, out var windowsId)
            && !string.IsNullOrWhiteSpace(windowsId)
            && TryFindTimeZone(windowsId, out reportTimeZone))
        {
            return reportTimeZone;
        }

        if (string.Equals(candidate, DefaultReportTimezone, StringComparison.OrdinalIgnoreCase)
            && TryFindTimeZone("SE Asia Standard Time", out reportTimeZone))
        {
            return reportTimeZone;
        }

        return TimeZoneInfo.Utc;
    }

    private static bool TryFindTimeZone(string timeZoneId, out TimeZoneInfo timeZoneInfo)
    {
        try
        {
            timeZoneInfo = TimeZoneInfo.FindSystemTimeZoneById(timeZoneId);
            return true;
        }
        catch (TimeZoneNotFoundException)
        {
            timeZoneInfo = TimeZoneInfo.Utc;
            return false;
        }
        catch (InvalidTimeZoneException)
        {
            timeZoneInfo = TimeZoneInfo.Utc;
            return false;
        }
    }

