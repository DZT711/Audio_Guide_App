@page "/usage"
@implements IAsyncDisposable
@using System.Globalization
@inject AdminApiClient ApiClient
@inject NotificationService Notifications
@inject AdminSessionState SessionState
@inject AdminUiLanguageService LanguageService

<PageTitle>@L("page.usage", "Usage History")</PageTitle>

@if (!CanView)
{
    <div class="management-page usage-page">
        <div class="management-error">
            <strong>@L("usage.access.denied.title", "Access denied.")</strong>
            <div>@L("usage.access.denied.desc", "Your current role cannot view usage history.")</div>
        </div>
    </div>
}
else
{
<div class="management-page usage-page">
    <section class="management-hero" data-reveal>
        <div>
            <span class="management-hero__eyebrow">@L("usage.hero.eyebrow", "Overview")</span>
            <h1>@L("usage.hero.title", "Guest Usage History")</h1>
            <p>@L("usage.hero.desc", "Review playback events, guest sessions, trigger sources, and listening time. Owner accounts only see usage from their owned locations.")</p>
        </div>
        <div class="management-hero__actions">
            <button type="button" class="btn btn-outline-secondary btn-lg" @onclick="RefreshAsync" disabled="@_isLoading">@L("usage.action.refresh", "Refresh")</button>
        </div>
    </section>

    <div class="management-stat-grid" data-stagger data-stagger-step="80">
        <article class="management-stat" data-reveal>
            <span class="management-stat__icon"><i class="bi bi-activity"></i></span>
            <div>
                <strong class="management-stat__value">@_overview.TotalEvents</strong>
                <span class="management-stat__label">@L("usage.stats.playback-events", "Playback Events")</span>
            </div>
        </article>
        <article class="management-stat" data-reveal>
            <span class="management-stat__icon"><i class="bi bi-people"></i></span>
            <div>
                <strong class="management-stat__value">@_overview.UniqueGuests</strong>
                <span class="management-stat__label">@L("usage.stats.unique-guests", "Unique Guests")</span>
            </div>
        </article>
        <article class="management-stat" data-reveal>
            <span class="management-stat__icon"><i class="bi bi-broadcast-pin"></i></span>
            <div>
                <strong class="management-stat__value">@_overview.OnlineGuests</strong>
                <span class="management-stat__label">@L("usage.stats.online-guests", "Online Guests")</span>
            </div>
        </article>
        <article class="management-stat" data-reveal>
            <span class="management-stat__icon"><i class="bi bi-geo-alt"></i></span>
            <div>
                <strong class="management-stat__value">@_overview.DistinctLocations</strong>
                <span class="management-stat__label">@L("usage.stats.locations-used", "Locations Used")</span>
            </div>
        </article>
        <article class="management-stat" data-reveal>
            <span class="management-stat__icon"><i class="bi bi-hourglass-split"></i></span>
            <div>
                <strong class="management-stat__value">@_overview.AverageListeningSeconds.ToString("0.#")s</strong>
                <span class="management-stat__label">@L("usage.stats.average-listening", "Average Listening")</span>
            </div>
        </article>
    </div>

    <section class="management-panel" data-reveal>
        <div class="management-panel__header">
            <div>
                <span class="management-panel__eyebrow">@L("usage.log.eyebrow", "History")</span>
                <h2>@L("usage.log.title", "Playback Log")</h2>
            </div>
            <div class="management-toolbar">
                <label class="management-search">
                    <i class="bi bi-search"></i>
                    <input class="form-control" type="search" placeholder="@L("usage.search.placeholder", "Search usage...")" @bind="_searchText" @bind:event="oninput" @bind:after="ResetUsagePage" />
                </label>
                <select class="form-select management-filter" @bind="_selectedLocation" @bind:after="ResetUsagePage">
                    <option value="">@L("usage.filter.locations.all", "All locations")</option>
                    @foreach (var locationName in LocationOptions)
                    {
                        <option value="@locationName">@locationName</option>
                    }
                </select>
                <select class="form-select management-filter" @bind="_selectedEventType" @bind:after="ResetUsagePage">
                    <option value="">@L("usage.filter.events.all", "All events")</option>
                    @foreach (var eventType in EventTypeOptions)
                    {
                        <option value="@eventType">@GetUsageEventTypeLabel(eventType)</option>
                    }
                </select>
            </div>
        </div>

        @if (_isLoading)
        {
            <div class="tour-skeleton-table">
                @for (var i = 0; i < 4; i++)
                {
                    <div class="skeleton-table-row">
                        <div class="skeleton skeleton--line"></div>
                        <div class="skeleton skeleton--line"></div>
                        <div class="skeleton skeleton--line"></div>
                        <div class="skeleton skeleton--line"></div>
                    </div>
                }
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(_loadError))
        {
            <div class="management-error">
                <strong>@L("usage.load.failed.title", "Unable to load usage history.")</strong>
                <div>@_loadError</div>
            </div>
        }
        else if (!FilteredItems.Any())
        {
            <div class="app-empty-state">@L("usage.empty.filtered", "No playback events match the current filters.")</div>
        }
        else
        {
            <div class="table-responsive management-page-swap" @key="_currentPage">
                <table class="table management-table usage-table">
                    <thead>
                        <tr>
                            <th>@L("usage.table.time", "Time")</th>
                            <th>@L("usage.table.avatar", "Avatar")</th>
                            <th>@L("usage.table.location", "Location")</th>
                            <th>@L("usage.table.audio", "Audio")</th>
                            <th>@L("usage.table.trigger", "Trigger")</th>
                            <th>@L("usage.table.guest", "Guest")</th>
                            <th>@L("usage.table.listening", "Listening")</th>
                            <th>@L("usage.table.tours", "Tours")</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in PagedItems)
                        {
                            <tr>
                                <td>
                                    <div>@item.EventAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</div>
                                    <small class="management-muted">@GetUsageRelativeTimeLabel(item.TimeAgo)</small>
                                </td>
                                <td>
                                    @if (GetUsageImageUrl(item) is { } imageUrl)
                                    {
                                        <img class="usage-avatar" src="@imageUrl" alt="@LF("usage.avatar.alt", "{0} avatar", item.LocationName)" />
                                    }
                                    else
                                    {
                                        <span class="usage-avatar usage-avatar--placeholder">
                                            <i class="bi bi-image"></i>
                                        </span>
                                    }
                                </td>
                                <td>
                                    <div>@item.LocationName</div>
                                    <small class="management-muted">@(item.OwnerName ?? L("usage.owner.empty", "No owner"))</small>
                                </td>
                                <td>@(item.AudioTitle ?? L("usage.audio.empty", "No audio linked"))</td>
                                <td>
                                    <div>@GetUsageTriggerSourceLabel(item.TriggerSource)</div>
                                    <small class="management-muted">@GetUsageEventTypeLabel(item.EventType)</small>
                                </td>
                                <td>
                                    <div>@(item.SessionId ?? item.DeviceId ?? L("usage.guest.anonymous", "Anonymous"))</div>
                                    <small class="management-muted">@GetUsageNetworkLabel(item.NetworkType)</small>
                                </td>
                                <td>@FormatListening(item.ListeningSeconds)</td>
                                <td>@GetUsageTourLabel(item.TourNames)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (TotalPages > 1)
            {
                <div class="management-pagination">
                    <span class="management-pagination__info">@LF("usage.pagination.info", "Page {0} of {1} ({2} matching events)", _currentPage, TotalPages, FilteredItems.Count())</span>
                    <div class="management-pagination__actions">
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="PreviousPage" disabled="@(_currentPage <= 1)">
                            <i class="bi bi-chevron-left"></i> @L("usage.pagination.previous", "Previous")
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="NextPage" disabled="@(_currentPage >= TotalPages)">
                            @L("usage.pagination.next", "Next") <i class="bi bi-chevron-right"></i>
                        </button>
                    </div>
                </div>
            }
        }
    </section>
</div>
}

@code {
    private string L(string key, string fallback) => LanguageService.T(key, fallback);
    private string LF(string key, string fallback, params object?[] args) =>
        string.Format(CultureInfo.CurrentCulture, L(key, fallback), args);
    private UsageHistoryOverviewDto _overview = new();
    private bool _isLoading = true;
    private int _currentPage = 1;
    private string _searchText = "";
    private string _selectedLocation = "";
    private string _selectedEventType = "";
    private string? _loadError;
    private const int PageSize = 12;
    private static readonly TimeSpan AutoRefreshInterval = TimeSpan.FromSeconds(3);
    private readonly SemaphoreSlim _loadLock = new(1, 1);
    private CancellationTokenSource? _autoRefreshCts;
    private Task? _autoRefreshTask;
    private bool _isDisposed;

    private bool CanView => SessionState.HasPermission(AdminPermissions.UsageHistoryView);
    private IEnumerable<UsageHistoryItemDto> FilteredItems => _overview.Items
        .Where(item =>
            string.IsNullOrWhiteSpace(_searchText)
            || item.LocationName.Contains(_searchText, StringComparison.OrdinalIgnoreCase)
            || (item.AudioTitle?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false)
            || item.TriggerSource.Contains(_searchText, StringComparison.OrdinalIgnoreCase)
            || item.EventType.Contains(_searchText, StringComparison.OrdinalIgnoreCase)
            || (item.SessionId?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false)
            || (item.DeviceId?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false))
        .Where(item =>
            string.IsNullOrWhiteSpace(_selectedLocation)
            || string.Equals(item.LocationName, _selectedLocation, StringComparison.OrdinalIgnoreCase))
        .Where(item =>
            string.IsNullOrWhiteSpace(_selectedEventType)
            || string.Equals(item.EventType, _selectedEventType, StringComparison.OrdinalIgnoreCase));
    private int TotalPages => Math.Max(1, (int)Math.Ceiling(FilteredItems.Count() / (double)PageSize));
    private IEnumerable<UsageHistoryItemDto> PagedItems => FilteredItems
        .Skip((_currentPage - 1) * PageSize)
        .Take(PageSize);

    private IEnumerable<string> LocationOptions => _overview.Items
        .Select(item => item.LocationName)
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(item => item, StringComparer.OrdinalIgnoreCase);

    private IEnumerable<string> EventTypeOptions => _overview.Items
        .Select(item => item.EventType)
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(item => item, StringComparer.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        StartAutoRefreshLoop();
    }

    private async Task RefreshAsync() => await LoadAsync();

    private async Task LoadAsync(bool isAutoRefresh = false)
    {
        if (_isDisposed)
        {
            return;
        }

        if (!await _loadLock.WaitAsync(0))
        {
            return;
        }

        try
        {
            if (!isAutoRefresh)
            {
                _isLoading = true;
                _loadError = null;
            }

            _overview = await ApiClient.GetUsageHistoryAsync();
            _loadError = null;
            _currentPage = Math.Min(_currentPage, TotalPages);

            if (isAutoRefresh)
            {
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (Exception ex)
        {
            if (!isAutoRefresh)
            {
                _loadError = ex.Message;
                Notifications.Error(ex.Message, L("usage.load.failed.toast", "Usage history load failed"));
            }
        }
        finally
        {
            if (!isAutoRefresh)
            {
                _isLoading = false;
            }

            _loadLock.Release();
        }
    }

    private void StartAutoRefreshLoop()
    {
        if (!CanView || _isDisposed || _autoRefreshTask is not null)
        {
            return;
        }

        _autoRefreshCts = new CancellationTokenSource();
        _autoRefreshTask = RunAutoRefreshLoopAsync(_autoRefreshCts.Token);
    }

    private async Task RunAutoRefreshLoopAsync(CancellationToken cancellationToken)
    {
        try
        {
            using var timer = new PeriodicTimer(AutoRefreshInterval);
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                await InvokeAsync(() => LoadAsync(isAutoRefresh: true));
            }
        }
        catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
        {
        }
    }

    private void NextPage()
    {
        if (_currentPage < TotalPages)
        {
            _currentPage++;
        }
    }

    private void PreviousPage()
    {
        if (_currentPage > 1)
        {
            _currentPage--;
        }
    }

    private Task ResetUsagePage()
    {
        _currentPage = 1;
        return Task.CompletedTask;
    }

    private string? GetUsageImageUrl(UsageHistoryItemDto item) =>
        ApiClient.ResolveImageUrl(item.PreferenceImageUrl);

    private string FormatListening(int? seconds) =>
        seconds is null or <= 0
            ? L("usage.duration.zero", "0 sec")
            : seconds < 60
                ? LF("usage.duration.seconds", "{0} sec", seconds)
                : LF("usage.duration.minutes-seconds", "{0} min {1} sec", seconds / 60, seconds % 60);

    private string GetUsageEventTypeLabel(string? eventType) => (eventType ?? string.Empty).Trim() switch
    {
        "AppOpen" => L("usage.event.app-open", "App Open"),
        "PlayAudio" => L("usage.event.play-audio", "Play Audio"),
        "ViewMap" => L("usage.event.view-map", "View Map"),
        "ViewPoi" => L("usage.event.view-poi", "View POI"),
        _ => eventType ?? string.Empty
    };

    private string GetUsageTriggerSourceLabel(string? triggerSource) => (triggerSource ?? string.Empty).Trim() switch
    {
        "MobileApp" => L("usage.trigger.mobile-app", "Mobile App"),
        _ => triggerSource ?? string.Empty
    };

    private string GetUsageNetworkLabel(string? networkType) =>
        string.IsNullOrWhiteSpace(networkType)
            ? L("usage.network.unknown", "Unknown network")
            : networkType!;

    private string GetUsageTourLabel(IReadOnlyList<string> tours) =>
        tours.Count == 0
            ? L("usage.tour.empty", "No tour")
            : string.Join(", ", tours);

    private string GetUsageRelativeTimeLabel(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        var normalized = value.Trim();
        if (string.Equals(normalized, "Just now", StringComparison.OrdinalIgnoreCase))
        {
            return L("usage.time.just-now", "Just now");
        }

        if (normalized.EndsWith("m ago", StringComparison.OrdinalIgnoreCase)
            && int.TryParse(normalized.Split(' ')[0], out var minutes))
        {
            return LF("usage.time.minutes-ago", "{0} min ago", minutes);
        }

        if (normalized.EndsWith("h ago", StringComparison.OrdinalIgnoreCase)
            && int.TryParse(normalized.Split(' ')[0], out var hours))
        {
            return LF("usage.time.hours-ago", "{0} hr ago", hours);
        }

        if (normalized.EndsWith("d ago", StringComparison.OrdinalIgnoreCase)
            && int.TryParse(normalized.Split(' ')[0], out var days))
        {
            return LF("usage.time.days-ago", "{0} day(s) ago", days);
        }

        return normalized;
    }

    public async ValueTask DisposeAsync()
    {
        _isDisposed = true;
        if (_autoRefreshCts is not null)
        {
            try
            {
                await _autoRefreshCts.CancelAsync();
            }
            catch
            {
            }
        }

        if (_autoRefreshTask is not null)
        {
            try
            {
                await _autoRefreshTask;
            }
            catch (OperationCanceledException)
            {
            }
        }

        _autoRefreshCts?.Dispose();
        _loadLock.Dispose();
    }
}
