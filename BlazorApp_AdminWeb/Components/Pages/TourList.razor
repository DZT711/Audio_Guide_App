@page "/tours"
@implements IAsyncDisposable
@inject AdminApiClient ApiClient
@inject NotificationService Notifications
@inject IJSRuntime JS
@inject AdminSessionState SessionState

<PageTitle>Tour Management</PageTitle>

@if (!CanView)
{
    <div class="management-page tour-page">
        <div class="management-error">
            <strong>Access denied.</strong>
            <div>Your current role cannot view tours.</div>
        </div>
    </div>
}
else
{
<div class="management-page tour-page">
    <section class="management-hero" data-reveal>
        <div>
            <span class="management-hero__eyebrow">Tours</span>
            <h1>Tour Management</h1>
            <p>Build walking routes from POIs on the map, set the order, and calculate total distance, duration, and finish time.</p>
        </div>
        <div class="management-hero__actions">
            @if (CanManage)
            {
                <button type="button" class="btn btn-primary btn-lg" @onclick="StartCreateAsync">New Tour</button>
            }
            <button type="button" class="btn btn-outline-secondary btn-lg" @onclick="RefreshAsync" disabled="@_isLoading">Refresh</button>
        </div>
    </section>

    <div class="management-stat-grid" data-stagger data-stagger-step="80">
        <article class="management-stat" data-reveal>
            <span class="management-stat__icon"><i class="bi bi-signpost-2"></i></span>
            <div>
                <strong class="management-stat__value">@_tours.Count</strong>
                <span class="management-stat__label">Visible Tours</span>
            </div>
        </article>
        <article class="management-stat" data-reveal>
            <span class="management-stat__icon"><i class="bi bi-check2-circle"></i></span>
            <div>
                <strong class="management-stat__value">@_tours.Count(item => item.Status == 1)</strong>
                <span class="management-stat__label">Active Tours</span>
            </div>
        </article>
        <article class="management-stat" data-reveal>
            <span class="management-stat__icon"><i class="bi bi-geo-alt"></i></span>
            <div>
                <strong class="management-stat__value">@(CanManage ? PlannerLocations.Count : _tours.Sum(item => item.StopCount))</strong>
                <span class="management-stat__label">@(CanManage ? "Planner POIs" : "Visible Stops")</span>
            </div>
        </article>
        <article class="management-stat" data-reveal>
            <span class="management-stat__icon"><i class="bi bi-search"></i></span>
            <div>
                <strong class="management-stat__value">@FilteredTours.Count()</strong>
                <span class="management-stat__label">Matching Results</span>
            </div>
        </article>
    </div>

    <div class="management-layout">
        <section class="management-panel" data-reveal>
            <div class="management-panel__header">
                <div>
                    <span class="management-panel__eyebrow">Directory</span>
                    <h2>Routes</h2>
                </div>
                <div class="management-toolbar">
                    <label class="management-search">
                        <i class="bi bi-search"></i>
                        <input class="form-control" type="search" placeholder="Search tours..." @bind="_searchText" @bind:event="oninput" />
                    </label>
                    <select class="form-select management-filter" @bind="_selectedStatus">
                        <option value="">All statuses</option>
                        <option value="1">Active</option>
                        <option value="0">Inactive</option>
                    </select>
                </div>
            </div>

            @if (_isLoading)
            {
                <div class="tour-skeleton-table">
                    @for (var i = 0; i < 4; i++)
                    {
                        <div class="skeleton-table-row">
                            <div class="skeleton skeleton--line"></div>
                            <div class="skeleton skeleton--line"></div>
                            <div class="skeleton skeleton--line"></div>
                            <div class="skeleton skeleton--line"></div>
                        </div>
                    }
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(_loadError))
            {
                <div class="management-error">
                    <strong>Unable to load tours.</strong>
                    <div>@_loadError</div>
                </div>
            }
            else if (!FilteredTours.Any())
            {
                <div class="app-empty-state">No tours match the current filters.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table management-table">
                        <thead>
                            <tr>
                                <th>Tour</th>
                                <th>Stops</th>
                                <th>Distance</th>
                                <th>Duration</th>
                                <th>Status</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tour in FilteredTours)
                            {
                                <tr class="@GetTourRowClass(tour.Status)">
                                    <td>
                                        <div class="tour-name">@tour.Name</div>
                                        <small class="management-muted">@(tour.OwnerName ?? "No owner label")</small>
                                    </td>
                                    <td>@tour.StopCount</td>
                                    <td>@tour.TotalDistanceKm.ToString("0.##") km</td>
                                    <td>@FormatDuration(tour.EstimatedDurationMinutes)</td>
                                    <td><span class="@GetStatusClass(tour.Status)">@GetStatusLabel(tour.Status)</span></td>
                                    <td class="text-end">
                                        <div class="management-inline-actions">
                                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => StartEditAsync(tour)">@(CanManage ? "Edit" : "View")</button>
                                            <button type="button" class="btn btn-sm btn-outline-danger" disabled="@(!CanManage || tour.Status == 0)" @onclick="() => PromptArchiveTour(tour)">@(tour.Status == 0 ? "Inactive" : "Archive")</button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>

        <section class="management-panel tour-editor" data-reveal>
            <div class="management-panel__header">
                <div>
                    <span class="management-panel__eyebrow">@(CanManage ? "Planner" : "Read Only")</span>
                    <h2>@(CanManage ? (_editingId is null ? "Create Tour" : "Edit Tour") : "Tour Details")</h2>
                </div>
            </div>

            @if (CanManage)
            {
                <EditForm Model="_formModel" OnValidSubmit="SaveTourAsync" class="management-form">
                    <DataAnnotationsValidator />

                    <div class="management-form__grid">
                        <div class="management-field">
                            <label for="tour-name">Tour Name</label>
                            <InputText id="tour-name" class="form-control" @bind-Value="_formModel.Name" />
                            <ValidationMessage For="() => _formModel.Name" />
                        </div>

                        <div class="management-field">
                            <label for="tour-speed">Walking Speed (km/h)</label>
                            <InputNumber id="tour-speed" class="form-control" @bind-Value="_formModel.WalkingSpeedKph" />
                            <ValidationMessage For="() => _formModel.WalkingSpeedKph" />
                        </div>

                        <div class="management-field management-field--full">
                            <label for="tour-description">Description</label>
                            <InputTextArea id="tour-description" class="form-control" rows="3" @bind-Value="_formModel.Description" />
                            <ValidationMessage For="() => _formModel.Description" />
                        </div>

                        <div class="management-field">
                            <label for="tour-start">Start Time</label>
                            <InputText id="tour-start" class="form-control" type="time" @bind-Value="_formModel.StartTime" />
                            <ValidationMessage For="() => _formModel.StartTime" />
                        </div>

                        <div class="management-field">
                            <span class="management-field__label">Status</span>
                            <div class="management-chip-group">
                                <button type="button" class="@GetChipClass(1, _formModel.Status)" @onclick="() => SetStatus(1)">Active</button>
                                <button type="button" class="@GetChipClass(0, _formModel.Status)" @onclick="() => SetStatus(0)">Inactive</button>
                            </div>
                        </div>

                        <div class="management-field management-field--full">
                            <div class="tour-summary-grid">
                                <article class="tour-summary-card">
                                    <span>Total Distance</span>
                                    <strong>@CalculatedDistanceKm.ToString("0.##") km</strong>
                                    <small>Summed from each selected POI segment.</small>
                                </article>
                                <article class="tour-summary-card">
                                    <span>Estimated Duration</span>
                                    <strong>@FormatDuration(CalculatedDurationMinutes)</strong>
                                    <small>Calculated from distance and walking speed.</small>
                                </article>
                                <article class="tour-summary-card">
                                    <span>Expected Finish</span>
                                    <strong>@GetCalculatedFinishTimeLabel()</strong>
                                    <small>Based on the chosen start time.</small>
                                </article>
                            </div>
                        </div>

                        <div class="management-field management-field--full">
                            <div class="tour-planner">
                                <div class="tour-planner__header">
                                    <div>
                                        <span class="management-field__label">Map Planner</span>
                                        <div class="management-field__hint">Click a marker to add or remove a POI from the route.</div>
                                    </div>
                                    <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="RefitMapAsync">Refit Route</button>
                                </div>
                                <div class="tour-planner__map" @ref="_mapElement"></div>
                            </div>
                        </div>

                        <div class="management-field management-field--full">
                            <div class="tour-stop-layout">
                                <div class="tour-stop-catalog">
                                    <div class="tour-stop-catalog__header">
                                        <div>
                                            <span class="management-field__label">POI Catalog</span>
                                            <div class="management-field__hint">Only active POIs can be added as new stops.</div>
                                        </div>
                                        <label class="management-search tour-stop-search">
                                            <i class="bi bi-search"></i>
                                            <input class="form-control" type="search" placeholder="Search POIs..." @bind="_locationSearchText" @bind:event="oninput" />
                                        </label>
                                    </div>

                                    <div class="tour-stop-catalog__list">
                                        @foreach (var location in FilteredPlannerLocations)
                                        {
                                            var isSelected = _formModel.StopLocationIds.Contains(location.Id);
                                            <article class="tour-catalog-card">
                                                <div>
                                                    <strong>@location.Name</strong>
                                                    <div class="management-muted">@(location.OwnerName ?? "No owner")</div>
                                                </div>
                                                <button type="button" class="btn btn-sm @(isSelected ? "btn-outline-secondary" : "btn-outline-primary")" disabled="@(!isSelected && location.Status != 1)" @onclick="() => ToggleStop(location.Id)">
                                                    @(isSelected ? "Remove" : "Add")
                                                </button>
                                            </article>
                                        }
                                    </div>
                                </div>

                                <div class="tour-stop-sequence">
                                    <div>
                                        <span class="management-field__label">Selected Route</span>
                                        <div class="management-field__hint">Move stops to change the route order and recalculate the route.</div>
                                    </div>
                                    <ValidationMessage For="() => _formModel.StopLocationIds" />

                                    @if (SelectedStopLocations.Count == 0)
                                    {
                                        <div class="app-empty-state">Choose at least one POI to build a tour.</div>
                                    }
                                    else
                                    {
                                        <div class="tour-stop-sequence__list">
                                            @for (var index = 0; index < SelectedStopLocations.Count; index++)
                                            {
                                                var stop = SelectedStopLocations[index];
                                                <article class="tour-stop-card">
                                                    <div class="tour-stop-card__index">@(@index + 1)</div>
                                                    <div class="tour-stop-card__body">
                                                        <div class="tour-stop-card__top">
                                                            <strong>@stop.Name</strong>
                                                            <span class="@GetStatusClass(stop.Status)">@GetStatusLabel(stop.Status)</span>
                                                        </div>
                                                        <div class="management-muted">@(stop.OwnerName ?? "No owner")</div>
                                                        @if (index > 0)
                                                        {
                                                            <div class="tour-stop-card__segment">+ @GetSegmentDistanceKm(index).ToString("0.##") km from previous stop</div>
                                                        }
                                                    </div>
                                                    <div class="tour-stop-card__actions">
                                                        <button type="button" class="btn btn-sm btn-outline-secondary" disabled="@(index == 0)" @onclick="() => MoveStop(index, -1)"><i class="bi bi-arrow-up"></i></button>
                                                        <button type="button" class="btn btn-sm btn-outline-secondary" disabled="@(index == SelectedStopLocations.Count - 1)" @onclick="() => MoveStop(index, 1)"><i class="bi bi-arrow-down"></i></button>
                                                        <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => RemoveStop(index)"><i class="bi bi-x-lg"></i></button>
                                                    </div>
                                                </article>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="management-actions">
                        <button type="submit" class="btn btn-primary" disabled="@_isSaving">@(_isSaving ? "Saving..." : _editingId is null ? "Create Tour" : "Save Changes")</button>
                        <button type="button" class="btn btn-outline-secondary" @onclick="CancelEditAsync">@(_editingId is null ? "Reset" : "Cancel Edit")</button>
                    </div>
                </EditForm>
            }
            else if (SelectedTourForDisplay is null)
            {
                <div class="app-empty-state">Select a tour to review its route.</div>
            }
            else
            {
                var selectedTour = SelectedTourForDisplay!;
                <div class="tour-readonly">
                    <div class="tour-readonly__notice">Tours are read-only for your current role.</div>
                    <div class="tour-summary-grid">
                        <article class="tour-summary-card">
                            <span>Total Distance</span>
                            <strong>@selectedTour.TotalDistanceKm.ToString("0.##") km</strong>
                            <small>@selectedTour.StopCount stops</small>
                        </article>
                        <article class="tour-summary-card">
                            <span>Estimated Duration</span>
                            <strong>@FormatDuration(selectedTour.EstimatedDurationMinutes)</strong>
                            <small>@($"{selectedTour.WalkingSpeedKph:0.##} km/h walking pace")</small>
                        </article>
                        <article class="tour-summary-card">
                            <span>Route Window</span>
                            <strong>@GetReadonlyScheduleLabel(selectedTour)</strong>
                            <small>Saved walking route timing.</small>
                        </article>
                    </div>

                    <div class="tour-stop-sequence__list">
                        @foreach (var stop in selectedTour.Stops.OrderBy(item => item.SequenceOrder))
                        {
                            <article class="tour-stop-card">
                                <div class="tour-stop-card__index">@stop.SequenceOrder</div>
                                <div class="tour-stop-card__body">
                                    <div class="tour-stop-card__top">
                                        <strong>@stop.LocationName</strong>
                                        <span class="@GetStatusClass(stop.Status)">@GetStatusLabel(stop.Status)</span>
                                    </div>
                                    <div class="management-muted">@(stop.OwnerName ?? "No owner")</div>
                                    @if (stop.SequenceOrder > 1)
                                    {
                                        <div class="tour-stop-card__segment">+ @stop.SegmentDistanceKm.ToString("0.##") km from previous stop</div>
                                    }
                                </div>
                            </article>
                        }
                    </div>
                </div>
            }
        </section>
    </div>
</div>

<AdminConfirmDialog Visible="@(_pendingArchivedTour is not null)"
                    Eyebrow="Archive Tour"
                    Title="Archive this tour?"
                    Message="@GetPendingArchiveTourMessage()"
                    ConfirmLabel="Archive Tour"
                    ConfirmButtonClass="btn btn-danger"
                    OnConfirm="ConfirmArchiveTourAsync"
                    OnCancel="CancelArchiveTour" />
}

@code {
    private readonly TourFormModel _formModel = new();
    private readonly List<TourDto> _tours = [];
    private readonly List<LocationDto> _locations = [];
    private DotNetObjectReference<TourList>? _mapReference;
    private TourDto? _selectedTour;
    private TourDto? _pendingArchivedTour;
    private bool _isLoading = true;
    private bool _isSaving;
    private bool _mapSyncPending;
    private int? _editingId;
    private string _searchText = "";
    private string _selectedStatus = "";
    private string _locationSearchText = "";
    private string? _loadError;
    private ElementReference _mapElement;

    private bool CanView => SessionState.HasPermission(AdminPermissions.TourRead);
    private bool CanManage => SessionState.HasPermission(AdminPermissions.TourManage);

    private IReadOnlyList<LocationDto> PlannerLocations => _locations
        .Where(item => item.Status == 1 || _formModel.StopLocationIds.Contains(item.Id))
        .OrderByDescending(item => item.Status)
        .ThenBy(item => item.Name)
        .ToList();

    private IEnumerable<LocationDto> FilteredPlannerLocations =>
        PlannerLocations.Where(item =>
            string.IsNullOrWhiteSpace(_locationSearchText)
            || item.Name.Contains(_locationSearchText, StringComparison.OrdinalIgnoreCase)
            || (item.OwnerName?.Contains(_locationSearchText, StringComparison.OrdinalIgnoreCase) ?? false));

    private IEnumerable<TourDto> FilteredTours =>
        _tours
            .Where(item =>
                (string.IsNullOrWhiteSpace(_searchText)
                || item.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase)
                || (item.Description?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false)
                || item.Stops.Any(stop => stop.LocationName.Contains(_searchText, StringComparison.OrdinalIgnoreCase)))
                && (string.IsNullOrWhiteSpace(_selectedStatus) || item.Status.ToString() == _selectedStatus))
            .OrderByDescending(item => item.Status)
            .ThenBy(item => item.Name);

    private IReadOnlyList<LocationDto> SelectedStopLocations => _formModel.StopLocationIds
        .Select(GetLocationById)
        .Where(item => item is not null)
        .Cast<LocationDto>()
        .ToList();

    private TourDto? SelectedTourForDisplay => _selectedTour
        ?? _tours.OrderByDescending(item => item.Status).ThenBy(item => item.Name).FirstOrDefault();

    private double CalculatedDistanceKm => Math.Round(CalculateTotalDistanceKm(SelectedStopLocations), 2, MidpointRounding.AwayFromZero);

    private int CalculatedDurationMinutes => _formModel.WalkingSpeedKph <= 0
        ? 0
        : (int)Math.Ceiling(CalculatedDistanceKm / _formModel.WalkingSpeedKph * 60d);

    protected override async Task OnInitializedAsync()
    {
        ResetForm();
        await LoadDataAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && CanManage)
        {
            _mapReference = DotNetObjectReference.Create(this);
            await InitializeMapAsync();
        }

        if (CanManage && _mapSyncPending)
        {
            _mapSyncPending = false;
            await SyncMapAsync();
        }
    }

    private async Task LoadDataAsync(int? preferredTourId = null)
    {
        _isLoading = true;
        _loadError = null;

        try
        {
            var toursTask = ApiClient.GetToursAsync();
            var locationsTask = CanManage
                ? ApiClient.GetLocationsAsync()
                : Task.FromResult<IReadOnlyList<LocationDto>>([]);

            await Task.WhenAll(toursTask, locationsTask);

            _tours.Clear();
            _tours.AddRange(await toursTask);

            _locations.Clear();
            _locations.AddRange((await locationsTask)
                .OrderByDescending(item => item.Status)
                .ThenBy(item => item.Name));

            var selectedId = preferredTourId ?? _selectedTour?.Id;
            _selectedTour = selectedId.HasValue
                ? _tours.FirstOrDefault(item => item.Id == selectedId.Value)
                : _tours.OrderByDescending(item => item.Status).ThenBy(item => item.Name).FirstOrDefault();

            QueueMapSync();
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
            Notifications.Error(ex.Message, "Tour load failed");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task InitializeMapAsync()
    {
        try
        {
            var ok = await JS.InvokeAsync<bool>(
                "smartTourAdmin.map.initializeTourPlanner",
                _mapElement,
                _mapReference,
                BuildPlannerPoints());

            if (!ok)
            {
                Notifications.Warning("The tour map planner is unavailable right now.", "Map unavailable");
            }
        }
        catch (JSException)
        {
            Notifications.Warning("The tour map planner is unavailable right now.", "Map unavailable");
        }
    }

    private async Task SyncMapAsync()
    {
        try
        {
            await JS.InvokeAsync<bool>("smartTourAdmin.map.syncTourPlanner", _mapElement, BuildPlannerPoints());
        }
        catch (JSException)
        {
        }
    }

    private async Task RefreshAsync() => await LoadDataAsync(_selectedTour?.Id);

    private async Task RefitMapAsync()
    {
        QueueMapSync();
        await InvokeAsync(StateHasChanged);
    }

    private Task StartCreateAsync()
    {
        _editingId = null;
        _selectedTour = null;
        ResetForm();
        return InvokeAsync(StateHasChanged);
    }

    private Task StartEditAsync(TourDto tour)
    {
        _selectedTour = tour;
        if (CanManage)
        {
            _editingId = tour.Id;
            ApplyForm(TourFormModel.FromDto(tour));
        }

        return InvokeAsync(StateHasChanged);
    }

    private async Task SaveTourAsync()
    {
        if (!CanManage)
        {
            Notifications.Warning("Your role can view tours but cannot save changes.", "Read-only access");
            return;
        }

        _isSaving = true;
        try
        {
            if (_editingId is null)
            {
                await ApiClient.CreateTourAsync(_formModel);
                Notifications.Success("Tour created successfully.", "Tour saved");
                await LoadDataAsync();
                await StartCreateAsync();
            }
            else
            {
                await ApiClient.UpdateTourAsync(_editingId.Value, _formModel);
                Notifications.Success("Tour updated successfully.", "Tour saved");
                await LoadDataAsync(_editingId.Value);
                if (_selectedTour is not null)
                {
                    ApplyForm(TourFormModel.FromDto(_selectedTour));
                    _editingId = _selectedTour.Id;
                }
            }
        }
        catch (Exception ex)
        {
            Notifications.Error(ex.Message, "Tour save failed");
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void PromptArchiveTour(TourDto tour)
    {
        if (!CanManage)
        {
            Notifications.Warning("Your role can view tours but cannot archive them.", "Read-only access");
            return;
        }

        _pendingArchivedTour = tour;
    }

    private async Task ConfirmArchiveTourAsync()
    {
        if (!CanManage || _pendingArchivedTour is null)
        {
            return;
        }

        try
        {
            var archivedId = _pendingArchivedTour.Id;
            await ApiClient.DeleteTourAsync(archivedId);
            Notifications.Info($"'{_pendingArchivedTour.Name}' is now inactive.", "Tour archived");
            await LoadDataAsync(_selectedTour?.Id == archivedId ? null : _selectedTour?.Id);
            if (_editingId == archivedId)
            {
                await StartCreateAsync();
            }
        }
        catch (Exception ex)
        {
            Notifications.Error(ex.Message, "Archive failed");
        }
        finally
        {
            CancelArchiveTour();
        }
    }

    private void ToggleStop(int locationId)
    {
        var location = GetLocationById(locationId);
        if (location is null)
        {
            return;
        }

        var currentIndex = _formModel.StopLocationIds.IndexOf(locationId);
        if (currentIndex >= 0)
        {
            _formModel.StopLocationIds.RemoveAt(currentIndex);
            QueueMapSync();
            return;
        }

        if (location.Status != 1)
        {
            Notifications.Warning("Only active POIs can be added to a tour.", "POI unavailable");
            return;
        }

        _formModel.StopLocationIds.Add(locationId);
        QueueMapSync();
    }

    [JSInvokable]
    public Task ToggleStopFromMap(int locationId)
    {
        if (CanManage)
        {
            ToggleStop(locationId);
        }

        return InvokeAsync(StateHasChanged);
    }

    private void RemoveStop(int index)
    {
        if (index < 0 || index >= _formModel.StopLocationIds.Count)
        {
            return;
        }

        _formModel.StopLocationIds.RemoveAt(index);
        QueueMapSync();
    }

    private void MoveStop(int index, int delta)
    {
        var nextIndex = index + delta;
        if (index < 0 || nextIndex < 0 || index >= _formModel.StopLocationIds.Count || nextIndex >= _formModel.StopLocationIds.Count)
        {
            return;
        }

        (_formModel.StopLocationIds[index], _formModel.StopLocationIds[nextIndex]) =
            (_formModel.StopLocationIds[nextIndex], _formModel.StopLocationIds[index]);

        QueueMapSync();
    }

    private Task CancelEditAsync() => StartCreateAsync();

    private void SetStatus(int status) => _formModel.Status = status;

    private void CancelArchiveTour() => _pendingArchivedTour = null;

    private void ResetForm()
    {
        _formModel.Name = "";
        _formModel.Description = "";
        _formModel.WalkingSpeedKph = 4.5d;
        _formModel.StartTime = "08:00";
        _formModel.Status = 1;
        _formModel.StopLocationIds.Clear();
        QueueMapSync();
    }

    private void ApplyForm(TourFormModel model)
    {
        _formModel.Name = model.Name;
        _formModel.Description = model.Description;
        _formModel.WalkingSpeedKph = model.WalkingSpeedKph;
        _formModel.StartTime = model.StartTime;
        _formModel.Status = model.Status;
        _formModel.StopLocationIds = model.StopLocationIds.ToList();
        QueueMapSync();
    }

    private IReadOnlyList<TourPlannerPoint> BuildPlannerPoints()
    {
        var orderLookup = _formModel.StopLocationIds
            .Select((locationId, index) => new { locationId, index })
            .ToDictionary(item => item.locationId, item => item.index + 1);

        return PlannerLocations
            .Select(item => new TourPlannerPoint(
                item.Id,
                item.Name,
                item.OwnerName,
                item.Latitude,
                item.Longitude,
                orderLookup.TryGetValue(item.Id, out var order),
                order))
            .ToList();
    }

    private LocationDto? GetLocationById(int locationId) => _locations.FirstOrDefault(item => item.Id == locationId);

    private void QueueMapSync() => _mapSyncPending = CanManage;

    private string GetPendingArchiveTourMessage() =>
        _pendingArchivedTour is null
            ? string.Empty
            : $"'{_pendingArchivedTour.Name}' will become inactive. Guests can still view historical usage, but the route will no longer be active.";

    private static string GetStatusClass(int status) => status == 1
        ? "management-status management-status--active"
        : "management-status management-status--inactive";

    private static string GetStatusLabel(int status) => status == 1 ? "Active" : "Inactive";

    private static string GetChipClass(int status, int currentStatus) => status == currentStatus
        ? "management-chip management-chip--selected"
        : "management-chip";

    private static string GetTourRowClass(int status) => status == 1
        ? string.Empty
        : "tour-row--inactive";

    private static string GetReadonlyScheduleLabel(TourDto tour) =>
        string.IsNullOrWhiteSpace(tour.StartTime)
            ? string.IsNullOrWhiteSpace(tour.FinishTime)
                ? "No saved start time"
                : $"Finishes at {tour.FinishTime}"
            : string.IsNullOrWhiteSpace(tour.FinishTime)
                ? $"Starts at {tour.StartTime}"
                : $"{tour.StartTime} to {tour.FinishTime}";

    private static string FormatDuration(int totalMinutes)
    {
        if (totalMinutes <= 0)
        {
            return "0 min";
        }

        var hours = totalMinutes / 60;
        var minutes = totalMinutes % 60;
        return hours == 0
            ? $"{minutes} min"
            : minutes == 0
                ? $"{hours} hr"
                : $"{hours} hr {minutes} min";
    }

    private string GetCalculatedFinishTimeLabel() =>
        TryCalculateFinishTime(_formModel.StartTime, CalculatedDurationMinutes) ?? "Set a valid start time";

    private double GetSegmentDistanceKm(int currentIndex)
    {
        if (currentIndex <= 0 || currentIndex >= SelectedStopLocations.Count)
        {
            return 0d;
        }

        return Math.Round(
            CalculateDistanceKm(SelectedStopLocations[currentIndex - 1], SelectedStopLocations[currentIndex]),
            2,
            MidpointRounding.AwayFromZero);
    }

    private static double CalculateTotalDistanceKm(IReadOnlyList<LocationDto> orderedStops)
    {
        var totalDistance = 0d;
        for (var index = 1; index < orderedStops.Count; index++)
        {
            totalDistance += CalculateDistanceKm(orderedStops[index - 1], orderedStops[index]);
        }

        return totalDistance;
    }

    private static double CalculateDistanceKm(LocationDto from, LocationDto to)
    {
        const double EarthRadiusKm = 6371d;
        var latDelta = DegreesToRadians(to.Latitude - from.Latitude);
        var lonDelta = DegreesToRadians(to.Longitude - from.Longitude);
        var originLatitude = DegreesToRadians(from.Latitude);
        var destinationLatitude = DegreesToRadians(to.Latitude);
        var haversine =
            Math.Pow(Math.Sin(latDelta / 2d), 2d)
            + Math.Cos(originLatitude) * Math.Cos(destinationLatitude) * Math.Pow(Math.Sin(lonDelta / 2d), 2d);
        var arc = 2d * Math.Atan2(Math.Sqrt(haversine), Math.Sqrt(1d - haversine));
        return EarthRadiusKm * arc;
    }

    private static double DegreesToRadians(double value) => value * Math.PI / 180d;

    private static string? TryCalculateFinishTime(string? startTime, int durationMinutes) =>
        !string.IsNullOrWhiteSpace(startTime)
        && TimeSpan.TryParseExact(startTime, @"hh\:mm", null, out var parsedStartTime)
            ? parsedStartTime.Add(TimeSpan.FromMinutes(Math.Max(0, durationMinutes))).ToString(@"hh\:mm")
            : null;

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (CanManage)
            {
                await JS.InvokeVoidAsync("smartTourAdmin.map.disposeTourPlanner", _mapElement);
            }
        }
        catch (JSException)
        {
        }
        catch (TaskCanceledException)
        {
        }

        _mapReference?.Dispose();
    }

    private sealed record TourPlannerPoint(
        int Id,
        string Name,
        string? OwnerName,
        double Latitude,
        double Longitude,
        bool IsSelected,
        int Order);
}
