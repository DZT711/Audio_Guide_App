    private string FormatDuration(int totalMinutes)
    {
        if (totalMinutes <= 0)
        {
            return L("tours.duration.zero", "0 min");
        }

        var hours = totalMinutes / 60;
        var minutes = totalMinutes % 60;
        return hours == 0
            ? LF("tours.duration.minutes", "{0} min", minutes)
            : minutes == 0
                ? LF("tours.duration.hours", "{0} hr", hours)
                : LF("tours.duration.hours-minutes", "{0} hr {1} min", hours, minutes);
    }

