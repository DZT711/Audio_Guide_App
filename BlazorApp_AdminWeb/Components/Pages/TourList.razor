    private async Task SaveTourAsync()
    {
        if (!CanManage)
        {
            Notifications.Warning(
                L("tours.save.readonly.message", "Your role can view tours but cannot save changes."),
                L("tours.readonly.short", "Read-only access"));
            return;
        }

        _isSaving = true;
        try
        {
            if (_editingId is null)
            {
                var createdTour = await ApiClient.CreateTourAsync(_formModel, _routePreview);
                Notifications.Success(
                    L("tours.save.created.message", "Tour created successfully."),
                    L("tours.save.title", "Tour saved"));
                _selectedTour = createdTour;
                await LoadDataAsync(createdTour.Id);
            }
            else
            {
                await ApiClient.UpdateTourAsync(_editingId.Value, _formModel, _routePreview);
                Notifications.Success(
                    L("tours.save.updated.message", "Tour updated successfully."),
                    L("tours.save.title", "Tour saved"));
                await LoadDataAsync(_editingId.Value);
            }

            await CancelEditAsync();
        }
        catch (Exception ex)
        {
            Notifications.Error(ex.Message, L("tours.save.failed.title", "Tour save failed"));
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void HandleInvalidTourSubmit(EditContext editContext)
    {
        var message = editContext.GetValidationMessages()
            .Where(item => !string.IsNullOrWhiteSpace(item))
            .Distinct(StringComparer.Ordinal)
            .Take(3)
            .ToList();

        Notifications.Warning(
            message.Count == 0
                ? L("tours.validation.generic", "Fix the highlighted tour fields before saving.")
                : string.Join(" ", message),
            L("tours.validation.title", "Tour form incomplete"));
    }

    private void PromptArchiveTour(TourDto tour)
    {
        if (!CanManage)
        {
            Notifications.Warning(
                L("tours.archive.readonly.message", "Your role can view tours but cannot archive them."),
                L("tours.readonly.short", "Read-only access"));
            return;
        }

        _pendingArchivedTour = tour;
    }

    private async Task ConfirmArchiveTourAsync()
    {
        if (!CanManage || _pendingArchivedTour is null)
        {
            return;
        }

        try
        {
            var archivedId = _pendingArchivedTour.Id;
            await ApiClient.DeleteTourAsync(archivedId);
            Notifications.Info(
                LF("tours.archive.success.message", "'{0}' is now inactive.", _pendingArchivedTour.Name),
                L("tours.archive.success.title", "Tour archived"));
            await LoadDataAsync(_selectedTour?.Id == archivedId ? null : _selectedTour?.Id);
            if (_editingId == archivedId)
            {
                await CancelEditAsync();
            }
        }
        catch (Exception ex)
        {
            Notifications.Error(ex.Message, L("tours.archive.failed.title", "Archive failed"));
        }
        finally
        {
            CancelArchiveTour();
        }
    }

    private async Task ToggleStopAsync(int locationId)
    {
        var location = GetLocationById(locationId);
        if (location is null)
        {
            return;
        }

        var currentIndex = _formModel.StopLocationIds.IndexOf(locationId);
        if (currentIndex >= 0)
        {
            _formModel.StopLocationIds.RemoveAt(currentIndex);
            await RefreshRoutePreviewAsync();
            return;
        }

        if (location.Status != 1)
        {
            Notifications.Warning(
                L("tours.poi.unavailable.message", "Only active POIs can be added to a tour."),
                L("tours.poi.unavailable.title", "POI unavailable"));
            return;
        }

        _formModel.StopLocationIds.Add(locationId);
        await RefreshRoutePreviewAsync();
    }

