        return string.IsNullOrWhiteSpace(_routePreview.FinishTime)
            ? LF("tours.schedule.pending", "{0} - --:--", normalizedStartTime)
            : LF("tours.schedule.resolved", "{0} - {1}", normalizedStartTime, _routePreview.FinishTime);
