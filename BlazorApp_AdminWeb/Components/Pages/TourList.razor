@page "/tours"
@using Project_SharedClassLibrary.Constants
@using System.Globalization
@using Microsoft.AspNetCore.Components.Forms
@implements IAsyncDisposable
@inject AdminApiClient ApiClient
@inject NotificationService Notifications
@inject IJSRuntime JS
@inject AdminSessionState SessionState
@inject AdminUiLanguageService LanguageService

<PageTitle>@L("page.tours", "Tour Management")</PageTitle>

@if (!CanView)
{
    <div class="management-page tour-page">
        <div class="management-error">
            <strong>@L("tours.access.denied.title", "Access denied.")</strong>
            <div>@L("tours.access.denied.desc", "Your current role cannot view tours.")</div>
        </div>
    </div>
}
else
{
<div class="management-page tour-page">
    <section class="management-hero" data-reveal>
        <div>
            <span class="management-hero__eyebrow">@L("tours.hero.eyebrow", "Tours")</span>
            <h1>@L("tours.hero.title", "Tour Management")</h1>
            <p>@L("tours.hero.desc", "Build walking routes from POIs on the map, set the order, and calculate total distance, duration, and finish time.")</p>
        </div>
        <div class="management-hero__actions">
            @if (CanManage)
            {
                <button type="button" class="btn btn-primary btn-lg" @onclick="StartCreateAsync">@L("tours.action.new", "New Tour")</button>
            }
            <button type="button" class="btn btn-outline-secondary btn-lg" @onclick="RefreshAsync" disabled="@_isLoading">@L("tours.action.refresh", "Refresh")</button>
        </div>
    </section>

    <div class="management-stat-grid" data-stagger data-stagger-step="80">
        <article class="management-stat" data-reveal>
            <span class="management-stat__icon"><i class="bi bi-signpost-2"></i></span>
            <div>
                <strong class="management-stat__value">@_tours.Count</strong>
                <span class="management-stat__label">@L("tours.stats.visible", "Visible Tours")</span>
            </div>
        </article>
        <article class="management-stat" data-reveal>
            <span class="management-stat__icon"><i class="bi bi-check2-circle"></i></span>
            <div>
                <strong class="management-stat__value">@_tours.Count(item => item.Status == 1)</strong>
                <span class="management-stat__label">@L("tours.stats.active", "Active Tours")</span>
            </div>
        </article>
        <article class="management-stat" data-reveal>
            <span class="management-stat__icon"><i class="bi bi-geo-alt"></i></span>
            <div>
                <strong class="management-stat__value">@(CanManage ? PlannerLocations.Count : _tours.Sum(item => item.StopCount))</strong>
                <span class="management-stat__label">@(CanManage ? L("tours.stats.planner-pois", "Planner POIs") : L("tours.stats.visible-stops", "Visible Stops"))</span>
            </div>
        </article>
        <article class="management-stat" data-reveal>
            <span class="management-stat__icon"><i class="bi bi-search"></i></span>
            <div>
                <strong class="management-stat__value">@FilteredTours.Count()</strong>
                <span class="management-stat__label">@L("tours.stats.matching", "Matching Results")</span>
            </div>
        </article>
    </div>

    <div class="management-layout @(CanManage ? "tour-layout--planner-modal" : string.Empty)">
        <section class="management-panel" data-reveal>
            <div class="management-panel__header">
                <div>
                    <span class="management-panel__eyebrow">@L("tours.directory.eyebrow", "Directory")</span>
                    <h2>@L("tours.directory.title", "Routes")</h2>
                </div>
                <div class="management-toolbar">
                    <label class="management-search">
                        <i class="bi bi-search"></i>
                        <input class="form-control" type="search" placeholder="@L("tours.search.placeholder", "Search tours...")" @bind="_searchText" @bind:event="oninput" />
                    </label>
                    <select class="form-select management-filter" @bind="_selectedStatus">
                        <option value="">@L("tours.filter.status.all", "All statuses")</option>
                        <option value="1">@L("status.active", "Active")</option>
                        <option value="0">@L("status.inactive", "Inactive")</option>
                    </select>
                </div>
            </div>

            @if (_isLoading)
            {
                <div class="tour-skeleton-table">
                    @for (var i = 0; i < 4; i++)
                    {
                        <div class="skeleton-table-row">
                            <div class="skeleton skeleton--line"></div>
                            <div class="skeleton skeleton--line"></div>
                            <div class="skeleton skeleton--line"></div>
                            <div class="skeleton skeleton--line"></div>
                        </div>
                    }
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(_loadError))
            {
                <div class="management-error">
                    <strong>@L("tours.load.failed.title", "Unable to load tours.")</strong>
                    <div>@_loadError</div>
                </div>
            }
            else if (!FilteredTours.Any())
            {
                <div class="app-empty-state">@L("tours.empty.filtered", "No tours match the current filters.")</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table management-table">
                        <thead>
                            <tr>
                                <th>@L("tours.table.tour", "Tour")</th>
                                <th>@L("tours.table.stops", "Stops")</th>
                                <th>@L("tours.table.distance", "Distance")</th>
                                <th>@L("tours.table.duration", "Duration")</th>
                                <th>@L("tours.table.status", "Status")</th>
                                <th class="text-end">@L("tours.table.actions", "Actions")</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tour in FilteredTours)
                            {
                                <tr class="@GetTourRowClass(tour)" @onclick="() => SelectTour(tour)">
                                    <td>
                                        <div class="tour-name">@tour.Name</div>
                                        <small class="management-muted">@(tour.OwnerName ?? L("tours.owner.empty", "No owner label"))</small>
                                    </td>
                                    <td>@tour.StopCount</td>
                                    <td>@tour.TotalDistanceKm.ToString("0.##") km</td>
                                    <td>@FormatDuration(tour.EstimatedDurationMinutes)</td>
                                    <td><span class="@GetStatusClass(tour.Status)">@GetStatusLabel(tour.Status)</span></td>
                                    <td class="text-end">
                                        <div class="management-inline-actions">
                                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => StartEditAsync(tour)">@(CanManage ? L("tours.action.edit", "Edit") : L("tours.action.view", "View"))</button>
                                            <button type="button" class="btn btn-sm btn-outline-danger" disabled="@(!CanManage || tour.Status == 0)" @onclick="() => PromptArchiveTour(tour)">@(tour.Status == 0 ? L("status.inactive", "Inactive") : L("tours.action.archive", "Archive"))</button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>

        @if (SelectedTourForDisplay is null)
        {
            if (!CanManage)
            {
                <section class="management-panel tour-editor" data-reveal>
                    <div class="app-empty-state">@L("tours.readonly.empty", "Select a tour to review its route.")</div>
                </section>
            }
        }
        else if (!CanManage)
        {
            var selectedTour = SelectedTourForDisplay!;
            <section class="management-panel tour-editor" data-reveal>
                <div class="management-panel__header">
                    <div>
                        <span class="management-panel__eyebrow">@L("tours.readonly.eyebrow", "Read Only")</span>
                        <h2>@L("tours.readonly.title", "Tour Details")</h2>
                    </div>
                </div>

                <div class="tour-readonly">
                    <div class="tour-readonly__notice">@L("tours.readonly.notice", "Tours are read-only for your current role.")</div>
                    <div class="tour-summary-grid">
                        <article class="tour-summary-card">
                            <span>@L("tours.summary.distance", "Total Distance")</span>
                            <strong>@selectedTour.TotalDistanceKm.ToString("0.##") km</strong>
                            <small>@LF("tours.summary.stops", "{0} stops", selectedTour.StopCount)</small>
                        </article>
                        <article class="tour-summary-card">
                            <span>@L("tours.summary.duration", "Estimated Duration")</span>
                            <strong>@FormatDuration(selectedTour.EstimatedDurationMinutes)</strong>
                            <small>@LF("tours.summary.walking-pace", "{0} km/h walking pace", selectedTour.WalkingSpeedKph.ToString("0.##", CultureInfo.InvariantCulture))</small>
                        </article>
                        <article class="tour-summary-card">
                            <span>@L("tours.summary.window", "Route Window")</span>
                            <strong>@GetReadonlyScheduleLabel(selectedTour)</strong>
                            <small>@L("tours.summary.window.hint", "Saved walking route timing.")</small>
                        </article>
                    </div>

                    <div class="tour-stop-sequence__list">
                        @foreach (var stop in selectedTour.Stops.OrderBy(item => item.SequenceOrder))
                        {
                            <article class="tour-stop-card">
                                <div class="tour-stop-card__index">@stop.SequenceOrder</div>
                                <div class="tour-stop-card__media">
                                    @if (GetStopAvatarUrl(stop) is { } stopAvatarUrl)
                                    {
                                        <img class="tour-stop-card__avatar" src="@stopAvatarUrl" alt="@($"{stop.LocationName} avatar")" />
                                    }
                                    else
                                    {
                                        <span class="tour-stop-card__avatar tour-stop-card__avatar--placeholder">
                                            <i class="bi bi-image"></i>
                                        </span>
                                    }
                                </div>
                                <div class="tour-stop-card__body">
                                    <div class="tour-stop-card__top">
                                        <strong>@stop.LocationName</strong>
                                        <span class="@GetStatusClass(stop.Status)">@GetStatusLabel(stop.Status)</span>
                                    </div>
                                    <div class="management-muted">@(stop.OwnerName ?? L("tours.owner.empty.short", "No owner"))</div>
                                    @if (stop.SequenceOrder > 1 && stop.SegmentDistanceKm > 0)
                                    {
                                        <div class="tour-stop-card__segment">+ @stop.SegmentDistanceKm.ToString("0.##") km @L("tours.stop.segment.from-previous", "from previous stop")</div>
                                    }
                                </div>
                            </article>
                        }
                    </div>
                </div>
            </section>
        }
</div>
</div>

@if (CanManage)
{
    <div class="@GetEditorModalClass()" @onclick="CancelEditAsync" aria-hidden="@(!_isEditorOpen)">
        <section class="management-panel app-modal-panel tour-editor tour-editor--modal" role="dialog" aria-modal="true" aria-labelledby="tour-editor-title" @onclick:stopPropagation="true">
            <div class="tour-editor__topbar">
                <div>
                    <span class="management-panel__eyebrow">@L("tours.editor.eyebrow", "Planner")</span>
                    <h2 id="tour-editor-title">@(_editingId is null ? L("tours.editor.create", "Create Tour") : L("tours.editor.edit", "Edit Tour"))</h2>
                    <div class="management-field__hint">@L("tours.editor.hint", "Create and edit tours in a focused popup planner without shrinking the main table view.")</div>
                </div>
                <button type="button" class="btn-close" aria-label="@L("tours.editor.close-aria", "Close planner")" @onclick="CancelEditAsync"></button>
            </div>

            <EditForm Model="_formModel" OnValidSubmit="SaveTourAsync" OnInvalidSubmit="HandleInvalidTourSubmit" class="management-form">
                <DataAnnotationsValidator />

                <div class="management-form__grid">
                    <div class="management-field">
                        <label for="tour-name">@L("tours.form.name", "Tour Name")</label>
                        <InputText id="tour-name" class="form-control" @bind-Value="_formModel.Name" />
                        <ValidationMessage For="() => _formModel.Name" />
                    </div>

                    <div class="management-field">
                        <label for="tour-start">@L("tours.form.start-time", "Start Time")</label>
                        <input id="tour-start" class="form-control" type="time" step="60" value="@_startTimeInput" @onchange="HandleStartTimeChangedAsync" />
                        <ValidationMessage For="() => _formModel.StartTime" />
                    </div>

                    <div class="management-field management-field--full">
                        <label for="tour-description">@L("tours.form.description", "Description")</label>
                        <InputTextArea id="tour-description" class="form-control" rows="3" @bind-Value="_formModel.Description" />
                        <ValidationMessage For="() => _formModel.Description" />
                    </div>

                    <div class="management-field">
                        <span class="management-field__label">@L("tours.form.status", "Status")</span>
                        <div class="management-chip-group">
                            <button type="button" class="@GetChipClass(1, _formModel.Status)" @onclick="() => SetStatus(1)">@L("status.active", "Active")</button>
                            <button type="button" class="@GetChipClass(0, _formModel.Status)" @onclick="() => SetStatus(0)">@L("status.inactive", "Inactive")</button>
                        </div>
                    </div>

                    <div class="management-field">
                        <span class="management-field__label">@L("tours.form.walking-pace", "Walking Pace")</span>
                        <div class="tour-editor__hint-card">@LF("tours.form.walking-pace.hint", "Automatic {0} km/h default for every tour.", TourDefaults.DefaultWalkingSpeedKph.ToString("0.#", CultureInfo.InvariantCulture))</div>
                    </div>

                    <div class="management-field management-field--full">
                        <div class="tour-summary-grid">
                            <article class="tour-summary-card">
                                <span>@L("tours.summary.distance", "Total Distance")</span>
                                <strong>@CalculatedDistanceKm.ToString("0.##") km</strong>
                                <small>@GetDistanceSummaryHint()</small>
                            </article>
                            <article class="tour-summary-card">
                                <span>@L("tours.summary.duration", "Estimated Duration")</span>
                                <strong>@FormatDuration(CalculatedDurationMinutes)</strong>
                                <small>@GetDurationSummaryHint()</small>
                            </article>
                            <article class="tour-summary-card">
                                <span>@L("tours.summary.expected-time", "Expected Time")</span>
                                <strong>@GetCalculatedScheduleLabel()</strong>
                                    <small>@L("tours.summary.expected-time.hint", "Start time and calculated finish time.")</small>
                            </article>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_routePreviewMessage))
                    {
                        <div class="management-field management-field--full">
                            <div class="tour-editor__notice">@_routePreviewMessage</div>
                        </div>
                    }

                    <div class="management-field management-field--full">
                        <div class="tour-planner">
                            <div class="tour-planner__header">
                                <div>
                                    <span class="management-field__label">@L("tours.planner.map.label", "Map Planner")</span>
                                    <div class="management-field__hint">@L("tours.planner.map.hint", "Click a marker to add or remove a POI from the route.")</div>
                                </div>
                                <div class="tour-planner__actions">
                                    @if (_isRoutePreviewLoading)
                                    {
                                        <span class="tour-planner__status">@L("tours.planner.map.refreshing", "Refreshing route...")</span>
                                    }
                                    <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="RefitMapAsync">@L("tours.planner.map.refit", "Refit Route")</button>
                                </div>
                            </div>
                            <div class="tour-planner__map" @ref="_mapElement"></div>
                        </div>
                    </div>

                    <div class="management-field management-field--full">
                        <div class="tour-stop-layout">
                            <div class="tour-stop-catalog">
                                <div class="tour-stop-catalog__header">
                                    <div>
                                        <span class="management-field__label">@L("tours.planner.catalog.label", "POI Catalog")</span>
                                        <div class="management-field__hint">@L("tours.planner.catalog.hint", "Only active POIs can be added as new stops.")</div>
                                    </div>
                                    <label class="management-search tour-stop-search">
                                        <i class="bi bi-search"></i>
                                        <input class="form-control" type="search" placeholder="@L("tours.planner.catalog.search", "Search POIs...")" value="@_locationSearchText" @oninput="HandlePlannerSearchInput" />
                                    </label>
                                </div>

                                @if (PagedPlannerLocations.Count == 0)
                                {
                                    <div class="app-empty-state">@L("tours.planner.catalog.empty", "No POIs match the current catalog search.")</div>
                                }
                                else
                                {
                                    <div class="tour-stop-catalog__list management-page-swap" @key="CurrentPlannerPage">
                                        @foreach (var location in PagedPlannerLocations)
                                        {
                                            var isSelected = _formModel.StopLocationIds.Contains(location.Id);
                                            <article class="tour-catalog-card">
                                                <div class="tour-catalog-card__media">
                                                    @if (GetLocationAvatarUrl(location) is { } avatarUrl)
                                                    {
                                                        <img class="tour-catalog-card__avatar" src="@avatarUrl" alt="@($"{location.Name} avatar")" />
                                                    }
                                                    else
                                                    {
                                                        <span class="tour-catalog-card__avatar tour-catalog-card__avatar--placeholder">
                                                            <i class="bi bi-image"></i>
                                                        </span>
                                                    }
                                                </div>
                                                <div>
                                                    <strong>@location.Name</strong>
                                                    <div class="management-muted">@(location.OwnerName ?? L("tours.owner.empty.short", "No owner"))</div>
                                                </div>
                                                <button type="button" class="btn btn-sm @(isSelected ? "btn-outline-secondary" : "btn-outline-primary")" disabled="@(!isSelected && location.Status != 1)" @onclick="() => ToggleStopAsync(location.Id)">
                                                    @(isSelected ? L("tours.action.remove-stop", "Remove") : L("tours.action.add-stop", "Add"))
                                                </button>
                                            </article>
                                        }
                                    </div>
                                }

                                @if (TotalPlannerPages > 1)
                                {
                                    <div class="management-pagination tour-stop-catalog__pagination">
                                        <span class="management-pagination__info">@LF("tours.planner.pagination.info", "Page {0} of {1} ({2} total POIs)", CurrentPlannerPage, TotalPlannerPages, FilteredPlannerLocations.Count)</span>
                                        <div class="management-pagination__actions">
                                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="PreviousPlannerPage" disabled="@(CurrentPlannerPage <= 1)">
                                                <i class="bi bi-chevron-left"></i> @L("tours.pagination.previous", "Previous")
                                            </button>
                                            <div class="management-pagination__pages">
                                                @foreach (var pageNumber in GetVisiblePlannerPages())
                                                {
                                                    <button type="button"
                                                            class="@GetPaginationButtonClass(pageNumber == CurrentPlannerPage)"
                                                            @onclick="() => GoToPlannerPage(pageNumber)"
                                                            disabled="@(pageNumber == CurrentPlannerPage)">
                                                        @pageNumber
                                                    </button>
                                                }
                                            </div>
                                            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="NextPlannerPage" disabled="@(CurrentPlannerPage >= TotalPlannerPages)">
                                                @L("tours.pagination.next", "Next") <i class="bi bi-chevron-right"></i>
                                            </button>
                                        </div>
                                    </div>
                                }
                            </div>

                            <div class="tour-stop-sequence">
                                <div>
                                    <span class="management-field__label">@L("tours.planner.route.label", "Selected Route")</span>
                                    <div class="management-field__hint">@L("tours.planner.route.hint", "Move stops to change the route order and recalculate the walking route.")</div>
                                </div>
                                <ValidationMessage For="() => _formModel.StopLocationIds" />

                                @if (SelectedStopLocations.Count == 0)
                                {
                                    <div class="app-empty-state">@L("tours.planner.route.empty", "Choose at least one POI to build a tour.")</div>
                                }
                                else
                                {
                                    <div class="tour-stop-sequence__list">
                                        @for (var index = 0; index < SelectedStopLocations.Count; index++)
                                        {
                                            var currentIndex = index;
                                            var stop = SelectedStopLocations[currentIndex];
                                            <article class="tour-stop-card" @key="stop.Id">
                                                <div class="tour-stop-card__index">@(currentIndex + 1)</div>
                                                <div class="tour-stop-card__media">
                                                    @if (GetLocationAvatarUrl(stop) is { } stopAvatarUrl)
                                                    {
                                                        <img class="tour-stop-card__avatar" src="@stopAvatarUrl" alt="@($"{stop.Name} avatar")" />
                                                    }
                                                    else
                                                    {
                                                        <span class="tour-stop-card__avatar tour-stop-card__avatar--placeholder">
                                                            <i class="bi bi-image"></i>
                                                        </span>
                                                    }
                                                </div>
                                                <div class="tour-stop-card__body">
                                                    <div class="tour-stop-card__top">
                                                        <strong>@stop.Name</strong>
                                                        <span class="@GetStatusClass(stop.Status)">@GetStatusLabel(stop.Status)</span>
                                                    </div>
                                                    <div class="management-muted">@(stop.OwnerName ?? L("tours.owner.empty.short", "No owner"))</div>
                                                    @if (currentIndex > 0)
                                                    {
                                                        <div class="tour-stop-card__segment">+ @GetSegmentDistanceKm(currentIndex).ToString("0.##") km @L("tours.stop.segment.from-previous", "from previous stop")</div>
                                                    }
                                                </div>
                                                <div class="tour-stop-card__actions">
                                                    <button type="button" class="btn btn-sm btn-outline-secondary" disabled="@(currentIndex == 0)" @onclick="() => MoveStopAsync(currentIndex, -1)"><i class="bi bi-arrow-up"></i></button>
                                                    <button type="button" class="btn btn-sm btn-outline-secondary" disabled="@(currentIndex == SelectedStopLocations.Count - 1)" @onclick="() => MoveStopAsync(currentIndex, 1)"><i class="bi bi-arrow-down"></i></button>
                                                    <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => RemoveStopAsync(currentIndex)"><i class="bi bi-x-lg"></i></button>
                                                </div>
                                            </article>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <div class="management-actions">
                    <button type="submit" class="btn btn-primary" disabled="@(_isSaving || _isRoutePreviewLoading)">@(_isSaving ? L("tours.save.saving", "Saving...") : _editingId is null ? L("tours.save.create", "Create Tour") : L("tours.save.update", "Save Changes"))</button>
                    <button type="button" class="btn btn-outline-secondary" @onclick="CancelEditAsync">@L("common.action.cancel", "Cancel")</button>
                </div>
            </EditForm>
        </section>
    </div>
}

<AdminConfirmDialog Visible="@(_pendingArchivedTour is not null)"
                    Eyebrow="@L("tours.archive.dialog.eyebrow", "Archive Tour")"
                    Title="@L("tours.archive.dialog.title", "Archive this tour?")"
                    Message="@GetPendingArchiveTourMessage()"
                    ConfirmLabel="@L("tours.archive.dialog.confirm", "Archive Tour")"
                    ConfirmButtonClass="btn btn-danger"
                    OnConfirm="ConfirmArchiveTourAsync"
                    OnCancel="CancelArchiveTour" />
}

@code {
    private string L(string key, string fallback) => LanguageService.T(key, fallback);
    private string LF(string key, string fallback, params object?[] args) =>
        string.Format(CultureInfo.CurrentCulture, L(key, fallback), args);
    private readonly TourFormModel _formModel = new();
    private readonly List<TourDto> _tours = [];
    private readonly List<LocationDto> _locations = [];
    private DotNetObjectReference<TourList>? _mapReference;
    private TourDto? _selectedTour;
    private TourDto? _pendingArchivedTour;
    private CancellationTokenSource? _routePreviewCts;
    private bool _isLoading = true;
    private bool _isSaving;
    private bool _isEditorOpen;
    private bool _isRoutePreviewLoading;
    private bool _mapSyncPending;
    private bool? _bodyScrollLockState;
    private int? _editingId;
    private string _searchText = "";
    private string _selectedStatus = "";
    private string _locationSearchText = "";
    private int _currentPlannerPage = 1;
    private string _startTimeInput = TourDefaults.DefaultStartTime;
    private string? _loadError;
    private string? _routePreviewMessage;
    private ElementReference _mapElement;
    private TourRoutePreviewDto _routePreview = new()
    {
        WalkingSpeedKph = TourDefaults.DefaultWalkingSpeedKph,
        StartTime = TourDefaults.DefaultStartTime,
        FinishTime = TourDefaults.DefaultStartTime
    };

    private bool CanView => SessionState.HasPermission(AdminPermissions.TourRead);
    private bool CanManage => SessionState.HasPermission(AdminPermissions.TourManage);

    private IReadOnlyList<LocationDto> PlannerLocations => _locations
        .Where(item => item.Status == 1)
        .OrderBy(item => item.Name)
        .ToList();

    private const int PlannerLocationsPerPage = 6;

    private IReadOnlyList<LocationDto> FilteredPlannerLocations =>
        PlannerLocations.Where(item =>
            string.IsNullOrWhiteSpace(_locationSearchText)
            || item.Name.Contains(_locationSearchText, StringComparison.OrdinalIgnoreCase)
            || (item.OwnerName?.Contains(_locationSearchText, StringComparison.OrdinalIgnoreCase) ?? false))
            .ToList();

    private int TotalPlannerPages => Math.Max(1, (int)Math.Ceiling((double)FilteredPlannerLocations.Count / PlannerLocationsPerPage));

    private int CurrentPlannerPage => Math.Min(Math.Max(_currentPlannerPage, 1), TotalPlannerPages);

    private IReadOnlyList<LocationDto> PagedPlannerLocations => FilteredPlannerLocations
        .Skip((CurrentPlannerPage - 1) * PlannerLocationsPerPage)
        .Take(PlannerLocationsPerPage)
        .ToList();

    private IEnumerable<TourDto> FilteredTours =>
        _tours
            .Where(item =>
                (string.IsNullOrWhiteSpace(_searchText)
                || item.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase)
                || (item.Description?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false)
                || item.Stops.Any(stop => stop.LocationName.Contains(_searchText, StringComparison.OrdinalIgnoreCase)))
                && (string.IsNullOrWhiteSpace(_selectedStatus) || item.Status.ToString() == _selectedStatus))
            .OrderByDescending(item => item.Status)
            .ThenBy(item => item.Name);

    private IReadOnlyList<LocationDto> SelectedStopLocations => _formModel.StopLocationIds
        .Select(GetLocationById)
        .Where(item => item is not null)
        .Cast<LocationDto>()
        .ToList();

    private TourDto? SelectedTourForDisplay => _selectedTour
        ?? _tours.OrderByDescending(item => item.Status).ThenBy(item => item.Name).FirstOrDefault();

    private double CalculatedDistanceKm => _routePreview.TotalDistanceKm;

    private int CalculatedDurationMinutes => _routePreview.EstimatedDurationMinutes;

    protected override async Task OnInitializedAsync()
    {
        ResetForm();
        await RefreshRoutePreviewAsync();
        await LoadDataAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && CanManage)
        {
            _mapReference = DotNetObjectReference.Create(this);
            await InitializeMapAsync();
        }

        if (CanManage && _mapSyncPending)
        {
            _mapSyncPending = false;
            await SyncMapAsync();
        }

        if (CanManage && _bodyScrollLockState != _isEditorOpen)
        {
            await SyncBodyScrollLockAsync(_isEditorOpen);
        }
    }

    private async Task LoadDataAsync(int? preferredTourId = null)
    {
        _isLoading = true;
        _loadError = null;

        try
        {
            var toursTask = ApiClient.GetToursAsync();
            var locationsTask = CanManage
                ? ApiClient.GetLocationsAsync()
                : Task.FromResult<IReadOnlyList<LocationDto>>([]);

            await Task.WhenAll(toursTask, locationsTask);

            _tours.Clear();
            _tours.AddRange(await toursTask);

            _locations.Clear();
            _locations.AddRange((await locationsTask)
                .OrderByDescending(item => item.Status)
                .ThenBy(item => item.Name));
            RemoveInactiveStopsFromForm();

            var selectedId = preferredTourId ?? _selectedTour?.Id;
            _selectedTour = selectedId.HasValue
                ? _tours.FirstOrDefault(item => item.Id == selectedId.Value)
                : _tours.OrderByDescending(item => item.Status).ThenBy(item => item.Name).FirstOrDefault();

            QueueMapSync();
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
            Notifications.Error(ex.Message, L("tours.load.failed.toast", "Tour load failed"));
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task InitializeMapAsync()
    {
        try
        {
            var ok = await JS.InvokeAsync<bool>(
                "smartTourAdmin.map.initializeTourPlanner",
                _mapElement,
                _mapReference,
                BuildPlannerState());

            if (!ok)
            {
                Notifications.Warning(
                    L("tours.map.unavailable.message", "The tour map planner is unavailable right now."),
                    L("tours.map.unavailable.title", "Map unavailable"));
            }
        }
        catch (JSException)
        {
            Notifications.Warning(
                L("tours.map.unavailable.message", "The tour map planner is unavailable right now."),
                L("tours.map.unavailable.title", "Map unavailable"));
        }
    }

    private async Task SyncMapAsync()
    {
        try
        {
            await JS.InvokeAsync<bool>("smartTourAdmin.map.syncTourPlanner", _mapElement, BuildPlannerState());
        }
        catch (JSException)
        {
        }
    }

