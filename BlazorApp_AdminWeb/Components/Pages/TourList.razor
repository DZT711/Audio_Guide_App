    private async Task RemoveStopAsync(int index)
    {
        if (index < 0 || index >= _formModel.StopLocationIds.Count)
        {
            return;
        }

        _formModel.StopLocationIds.RemoveAt(index);
        await RefreshRoutePreviewAsync();
    }

    private async Task MoveStopAsync(int index, int delta)
    {
        var nextIndex = index + delta;
        if (index < 0 || nextIndex < 0 || index >= _formModel.StopLocationIds.Count || nextIndex >= _formModel.StopLocationIds.Count)
        {
            return;
        }

        (_formModel.StopLocationIds[index], _formModel.StopLocationIds[nextIndex]) =
            (_formModel.StopLocationIds[nextIndex], _formModel.StopLocationIds[index]);

        await RefreshRoutePreviewAsync();
    }

