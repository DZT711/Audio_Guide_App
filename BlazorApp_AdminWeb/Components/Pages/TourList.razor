    private void RemoveInactiveStopsFromForm(bool notifyWhenRemoved = false)
    {
        if (_formModel.StopLocationIds.Count == 0 || _locations.Count == 0)
        {
            return;
        }

        var activeLocationIds = _locations
            .Where(item => item.Status == 1)
            .Select(item => item.Id)
            .ToHashSet();
        var removedCount = _formModel.StopLocationIds.RemoveAll(locationId => !activeLocationIds.Contains(locationId));

        if (notifyWhenRemoved && removedCount > 0)
        {
            Notifications.Warning(
                L("tours.inactive-poi.hidden.message", "Inactive POIs were removed from this tour editor. Only active POIs can be edited in a route."),
                L("tours.inactive-poi.hidden.title", "Inactive POIs hidden"));
        }
    }

