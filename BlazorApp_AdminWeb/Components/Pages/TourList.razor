    private async Task RefreshRoutePreviewAsync()
    {
        if (!CanManage)
        {
            return;
        }

        _routePreviewCts?.Cancel();
        _routePreviewCts?.Dispose();
        _routePreviewCts = null;
        _routePreviewMessage = null;

        var previewStops = BuildRoutePreviewStops();
        var normalizedStartTime = NormalizeTime(_formModel.StartTime);
        _routePreview = BuildFallbackRoutePreview(previewStops, normalizedStartTime, previewStops.Count <= 1);
        QueueMapSync();

        if (previewStops.Count <= 1)
        {
            _isRoutePreviewLoading = false;
            await InvokeAsync(StateHasChanged);
            return;
        }

        var cts = new CancellationTokenSource();
        _routePreviewCts = cts;
        _isRoutePreviewLoading = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            var preview = await TryBuildRoutePreviewAsync(previewStops, normalizedStartTime, cts.Token);

            if (!ReferenceEquals(_routePreviewCts, cts) || cts.IsCancellationRequested)
            {
                return;
            }

            _routePreview = preview;
            if (!preview.UsesRoadRouting)
            {
                _routePreviewMessage = L("tours.route-preview.warning.partial", "Road routing is temporarily unavailable for one or more segments, so the preview is using a straight-line fallback.");
            }

            QueueMapSync();
        }
        catch (OperationCanceledException) when (cts.IsCancellationRequested)
        {
            return;
        }
        catch (Exception)
        {
            if (!ReferenceEquals(_routePreviewCts, cts) || cts.IsCancellationRequested)
            {
                return;
            }

            _routePreviewMessage = L("tours.route-preview.warning.full", "Road routing is temporarily unavailable, so the preview is using straight-line distance until the service responds again.");
            QueueMapSync();
        }
        finally
        {
            if (ReferenceEquals(_routePreviewCts, cts))
            {
                _isRoutePreviewLoading = false;
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private async Task<TourRoutePreviewDto> TryBuildRoutePreviewAsync(
        IReadOnlyList<TourRoutePreviewStopRequest> previewStops,
        string? normalizedStartTime,
        CancellationToken cancellationToken)
    {
        var browserPreview = await TryBuildBrowserRoutePreviewAsync(previewStops, normalizedStartTime, cancellationToken);
        var apiPreview = await ApiClient.PreviewTourRouteAsync(new TourRoutePreviewRequest
        {
            StartTime = normalizedStartTime,
            Stops = previewStops.ToList()
        }, cancellationToken);

        if (HasMatchingRoutePreview(previewStops, browserPreview) && browserPreview!.UsesRoadRouting)
        {
            return browserPreview;
        }

        if (HasMatchingRoutePreview(previewStops, apiPreview) && apiPreview.UsesRoadRouting)
        {
            return apiPreview;
        }

        return HasMatchingRoutePreview(previewStops, browserPreview)
            ? browserPreview!
            : HasMatchingRoutePreview(previewStops, apiPreview)
                ? apiPreview
            : BuildFallbackRoutePreview(previewStops, normalizedStartTime, usesRoadRouting: false);
    }

    private async Task<TourRoutePreviewDto?> TryBuildBrowserRoutePreviewAsync(
        IReadOnlyList<TourRoutePreviewStopRequest> previewStops,
        string? normalizedStartTime,
        CancellationToken cancellationToken)
    {
        try
        {
            return await JS.InvokeAsync<TourRoutePreviewDto>(
                "smartTourAdmin.map.calculateTourRoute",
                cancellationToken,
                previewStops,
                normalizedStartTime,
                TourDefaults.DefaultWalkingSpeedKph);
        }
        catch (JSException)
        {
            return null;
        }
        catch (InvalidOperationException)
        {
            return null;
        }
    }

    private static bool HasMatchingRoutePreview(
        IReadOnlyList<TourRoutePreviewStopRequest> previewStops,
        TourRoutePreviewDto? preview)
    {
        if (preview is null
            || preview.TotalDistanceKm < 0
            || preview.EstimatedDurationMinutes < 0)
        {
            return false;
        }

        var orderedStops = previewStops
            .OrderBy(item => item.SequenceOrder)
            .ToList();
        var orderedSegments = preview.Segments
            .OrderBy(item => item.SequenceOrder)
            .ToList();

        if (orderedStops.Count != orderedSegments.Count)
        {
            return false;
        }

        for (var index = 0; index < orderedStops.Count; index++)
        {
            var stop = orderedStops[index];
            var segment = orderedSegments[index];
            if (segment.SequenceOrder != stop.SequenceOrder
                || segment.LocationId != stop.LocationId
                || segment.DistanceKm < 0)
            {
                return false;
            }
        }

        return true;
    }

    private TourRoutePreviewDto BuildFallbackRoutePreview(
        IReadOnlyList<TourRoutePreviewStopRequest> orderedStops,
        string? startTime,
        bool usesRoadRouting)
    {
        var segments = new List<TourRouteSegmentDto>(orderedStops.Count);
        var path = new List<TourRoutePointDto>();
        var totalDistanceKm = 0d;

        for (var index = 0; index < orderedStops.Count; index++)
        {
            var stop = orderedStops[index];
            if (index == 0)
            {
                segments.Add(new TourRouteSegmentDto
                {
                    SequenceOrder = stop.SequenceOrder,
                    LocationId = stop.LocationId,
                    DistanceKm = 0d
                });

                AppendPath(path, new TourRoutePointDto
                {
                    Latitude = stop.Latitude,
                    Longitude = stop.Longitude
                });

                continue;
            }

            var previousStop = orderedStops[index - 1];
            var distanceKm = CalculateDistanceKm(previousStop.Latitude, previousStop.Longitude, stop.Latitude, stop.Longitude);
            totalDistanceKm += distanceKm;
            segments.Add(new TourRouteSegmentDto
            {
                SequenceOrder = stop.SequenceOrder,
                LocationId = stop.LocationId,
                DistanceKm = Math.Round(distanceKm, 2, MidpointRounding.AwayFromZero)
            });

            AppendPath(path, new TourRoutePointDto
            {
                Latitude = previousStop.Latitude,
                Longitude = previousStop.Longitude
            });
            AppendPath(path, new TourRoutePointDto
            {
                Latitude = stop.Latitude,
                Longitude = stop.Longitude
            });
        }

        var roundedDistance = Math.Round(totalDistanceKm, 2, MidpointRounding.AwayFromZero);
        var normalizedStartTime = NormalizeTime(startTime);
        var durationMinutes = CalculateDurationMinutes(roundedDistance);

        return new TourRoutePreviewDto
        {
            TotalDistanceKm = roundedDistance,
            EstimatedDurationMinutes = durationMinutes,
            WalkingSpeedKph = TourDefaults.DefaultWalkingSpeedKph,
            StartTime = normalizedStartTime,
            FinishTime = TryCalculateFinishTime(normalizedStartTime, durationMinutes),
            UsesRoadRouting = usesRoadRouting,
            Segments = segments,
            Path = path
        };
    }

    private TourPlannerState BuildPlannerState() => new(
        BuildPlannerPoints(),
        _routePreview.Path
            .Select(item => new TourPlannerRoutePoint(item.Latitude, item.Longitude))
            .ToList(),
        _routePreview.UsesRoadRouting);

    private IReadOnlyList<TourPlannerPoint> BuildPlannerPoints()
    {
        var orderLookup = _formModel.StopLocationIds
            .Select((locationId, index) => new { locationId, index })
            .ToDictionary(item => item.locationId, item => item.index + 1);

        return PlannerLocations
            .Select(item => new TourPlannerPoint(
                item.Id,
                item.Name,
                item.OwnerName,
                item.Latitude,
                item.Longitude,
                orderLookup.TryGetValue(item.Id, out var order),
                order))
            .ToList();
    }

