        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml AudioSequenceVi\ntitle 6. Audio\n\nhide footbox\n\nskinparam shadowing false\nskinparam sequence {\n  ArrowColor #2F4858\n  LifeLineBorderColor #2F4858\n  LifeLineBackgroundColor #EAF3F7\n  ParticipantBorderColor #2F4858\n  ParticipantBackgroundColor white\n  ParticipantFontColor #1F2D3D\n  ActorBorderColor #2F4858\n  ActorBackgroundColor white\n  ActorFontColor #1F2D3D\n}\n\nautonumber 1\n\nboundary \&quot;AudioList.razor\&quot; as AudioPage\ncontrol \&quot;AdminApiClient\&quot; as ApiClient\ncontrol \&quot;AudioController\&quot; as AudioController\ncontrol \&quot;ChangeRequestController\&quot; as ChangeRequestController\nentity \&quot;DBContext\&quot; as DBContext\n\nactivate AudioPage\n\nAudioPage -&gt; ApiClient : Gui yeu cau lay danh sach audio\\n(GetAudioAsync())\nactivate ApiClient\n\nApiClient -&gt; AudioController : Goi API lay audio\\n(GET /Audio)\nactivate AudioController\n\nAudioController -&gt; DBContext : Lay danh sach audio theo quyen\nactivate DBContext\nDBContext --&gt; AudioController : Danh sach am thanh\ndeactivate DBContext\n\nAudioController --&gt; ApiClient : Tra ve du lieu audio\\n(AudioDto[])\ndeactivate AudioController\nApiClient --&gt; AudioPage : Hien thi danh sach audio\ndeactivate ApiClient\n\nalt Tao preview TTS\n    AudioPage -&gt; ApiClient : Gui yeu cau tao preview TTS\\n(GenerateAudioTtsPreviewAsync())\n    activate ApiClient\n\n    ApiClient -&gt; AudioController : Goi API preview TTS\\n(POST /Audio/preview-tts)\n    activate AudioController\n\n    AudioController --&gt; ApiClient : Tra ve audio preview\n    deactivate AudioController\n    ApiClient --&gt; AudioPage : Hien thi hoac phat preview\n    deactivate ApiClient\n\nelse Luu audio\n    alt Co quyen quan ly\n        AudioPage -&gt; ApiClient : Gui yeu cau tao moi / cap nhat audio\\n(CreateAudioAsync() / UpdateAudioAsync())\n        activate ApiClient\n\n        ApiClient -&gt; AudioController : Goi API luu audio\\n(POST /Audio / PUT /Audio/{id})\n        activate AudioController\n\n        AudioController -&gt; DBContext : Kiem tra du lieu va luu audio\n        activate DBContext\n        DBContext --&gt; AudioController : Luu thanh cong / Loi du lieu\n        deactivate DBContext\n\n        AudioController --&gt; ApiClient : Tra ket qua luu\n        deactivate AudioController\n        ApiClient --&gt; AudioPage : Cap nhat giao dien\n        deactivate ApiClient\n\n    else Gui yeu cau thay doi\n        AudioPage -&gt; ApiClient : Gui yeu cau thay doi audio\\n(SubmitAudioChangeRequestAsync())\n        activate ApiClient\n\n        ApiClient -&gt; ChangeRequestController : Goi API tao change request\\n(POST /ChangeRequest/audio)\n        activate ChangeRequestController\n\n        ChangeRequestController -&gt; DBContext : Tao change request\n        activate DBContext\n        DBContext --&gt; ChangeRequestController : Tao thanh cong\n        deactivate DBContext\n\n        ChangeRequestController --&gt; ApiClient : Tra ket qua yeu cau\n        deactivate ChangeRequestController\n        ApiClient --&gt; AudioPage : Gui yeu cau thanh cong\n        deactivate ApiClient\n    end\n\nelse Archive\n    alt Co quyen quan ly\n        AudioPage -&gt; ApiClient : Gui yeu cau archive audio\\n(DeleteAudioAsync())\n        activate ApiClient\n\n        ApiClient -&gt; AudioController : Goi API archive audio\\n(DELETE /Audio/{id})\n        activate AudioController\n\n        AudioController -&gt; DBContext : Archive audio\n        activate DBContext\n        DBContext --&gt; AudioController : Archive thanh cong\n        deactivate DBContext\n\n        AudioController --&gt; ApiClient : Tra ket qua archive\n        deactivate AudioController\n        ApiClient --&gt; AudioPage : Cap nhat giao dien\n        deactivate ApiClient\n\n    else Gui yeu cau archive\n        AudioPage -&gt; ApiClient : Gui yeu cau archive audio\\n(SubmitAudioChangeRequestAsync())\n        activate ApiClient\n\n        ApiClient -&gt; ChangeRequestController : Goi API tao change request\\n(POST /ChangeRequest/audio)\n        activate ChangeRequestController\n\n        ChangeRequestController -&gt; DBContext : Tao change request\n        activate DBContext\n        DBContext --&gt; ChangeRequestController : Tao thanh cong\n        deactivate DBContext\n\n        ChangeRequestController --&gt; ApiClient : Tra ket qua yeu cau\n        deactivate ChangeRequestController\n        ApiClient --&gt; AudioPage : Gui yeu cau thanh cong\n        deactivate ApiClient\n    end\nend\n\ndeactivate AudioPage\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="vAADwkPExonPpisjlmIm-3">
