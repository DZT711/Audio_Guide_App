        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml AudioPlaybackMobileSequenceVi\ntitle 8.17. Audio Playback\n\nhide footbox\n\nskinparam shadowing false\nskinparam sequence {\n  ArrowColor #2F4858\n  LifeLineBorderColor #2F4858\n  LifeLineBackgroundColor #EAF3F7\n  ParticipantBorderColor #2F4858\n  ParticipantBackgroundColor white\n  ParticipantFontColor #1F2D3D\n  ActorBorderColor #2F4858\n  ActorBackgroundColor white\n  ActorFontColor #1F2D3D\n}\n\nautonumber 1\n\nactor \&quot;Nguoi dung\&quot; as User\nboundary \&quot;Place Detail Screen\&quot; as PlaceDetailScreen\ncontrol \&quot;AudioDownloadService\&quot; as AudioDownloadService\ncontrol \&quot;HistoryService\&quot; as HistoryService\ncontrol \&quot;PlaybackCoordinatorService\&quot; as PlaybackCoordinatorService\ncontrol \&quot;AudioPlaybackService\&quot; as AudioPlaybackService\nentity \&quot;Local Download Manifest/File\&quot; as LocalDownload\n\nactivate User\n\nUser -&gt; PlaceDetailScreen : Chon audio track de phat\nactivate PlaceDetailScreen\n\nPlaceDetailScreen -&gt; PlaceDetailScreen : Xac dinh track duoc chon\\nva chuan bi hang doi phat\n\nPlaceDetailScreen -&gt; AudioDownloadService : ResolvePlayableTrackAsync()\nactivate AudioDownloadService\n\nAudioDownloadService -&gt; LocalDownload : Kiem tra file audio cuc bo\nactivate LocalDownload\nLocalDownload --&gt; AudioDownloadService : Local file / chua co file\ndeactivate LocalDownload\n\nAudioDownloadService --&gt; PlaceDetailScreen : Playable track / queue item\ndeactivate AudioDownloadService\n\nPlaceDetailScreen -&gt; HistoryService : Luu lich su dia diem\\n(AddToHistory())\nactivate HistoryService\nHistoryService --&gt; PlaceDetailScreen : Da xu ly lich su\ndeactivate HistoryService\n\nPlaceDetailScreen -&gt; PlaybackCoordinatorService : Phat hang doi audio\\n(PlayQueueAsync())\nactivate PlaybackCoordinatorService\n\nPlaybackCoordinatorService -&gt; AudioPlaybackService : Phat track hien tai\\n(PlayAsync())\nactivate AudioPlaybackService\nAudioPlaybackService --&gt; PlaybackCoordinatorService : Trang thai phat audio\ndeactivate AudioPlaybackService\n\nalt Nguoi dung dung thu cong\n    PlaceDetailScreen -&gt; PlaybackCoordinatorService : Dung phat hang doi\\n(StopAsync())\n    PlaybackCoordinatorService --&gt; PlaceDetailScreen : Da dung phat\nelse Con track tiep theo\n    PlaybackCoordinatorService -&gt; PlaybackCoordinatorService : Tu chuyen sang track tiep theo\n    PlaybackCoordinatorService --&gt; PlaceDetailScreen : Tiep tuc phat\nelse Het queue\n    PlaybackCoordinatorService --&gt; PlaceDetailScreen : Ket thuc phat hang doi\nend\n\nPlaceDetailScreen --&gt; User : Cap nhat trang thai phat audio\n\ndeactivate PlaybackCoordinatorService\ndeactivate PlaceDetailScreen\ndeactivate User\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="PuR3pW1kyNaqQgFaz-QU-4">
