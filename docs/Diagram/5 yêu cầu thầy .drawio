        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml SettingsMobileSequenceVi\ntitle 9. Settings\n\nhide footbox\n\nskinparam shadowing false\nskinparam sequence {\n  ArrowColor #2F4858\n  LifeLineBorderColor #2F4858\n  LifeLineBackgroundColor #EAF3F7\n  ParticipantBorderColor #2F4858\n  ParticipantBackgroundColor white\n  ParticipantFontColor #1F2D3D\n  ActorBorderColor #2F4858\n  ActorBackgroundColor white\n  ActorFontColor #1F2D3D\n}\n\nautonumber 1\n\nactor \&quot;Nguoi dung\&quot; as User\nboundary \&quot;Settings Screen\&quot; as SettingsScreen\ncontrol \&quot;AppSettingsService\&quot; as AppSettingsService\ncontrol \&quot;LocalizationService\&quot; as LocalizationService\ncontrol \&quot;ThemeService\&quot; as ThemeService\ncontrol \&quot;AppDataModeService\&quot; as AppDataModeService\ncontrol \&quot;AudioPlaybackService\&quot; as AudioPlaybackService\ncontrol \&quot;LocationTrackingService\&quot; as LocationTrackingService\nentity \&quot;SQLite/App Settings\&quot; as AppSettingsDb\n\nactivate User\n\nUser -&gt; SettingsScreen : Mo man hinh Settings\nactivate SettingsScreen\n\nSettingsScreen -&gt; AppSettingsService : Tai cai dat hien tai\\n(CreateSnapshot())\nactivate AppSettingsService\nAppSettingsService --&gt; SettingsScreen : Cai dat hien tai\ndeactivate AppSettingsService\n\nSettingsScreen --&gt; User : Hien thi cac tuy chon cai dat\n\nopt Xem truoc ngon ngu / giao dien / API mode\n    User -&gt; SettingsScreen : Chon ngon ngu / giao dien / API mode\n\n    SettingsScreen -&gt; LocalizationService : Ap dung ngon ngu neu can\n    activate LocalizationService\n    LocalizationService --&gt; SettingsScreen : Giao dien cap nhat\n    deactivate LocalizationService\n\n    SettingsScreen -&gt; ThemeService : Ap dung giao dien neu can\n    activate ThemeService\n    ThemeService --&gt; SettingsScreen : Theme updated\n    deactivate ThemeService\n\n    SettingsScreen -&gt; AppDataModeService : Ap dung API mode neu can\n    activate AppDataModeService\n    AppDataModeService --&gt; SettingsScreen : API mode updated\n    deactivate AppDataModeService\nend\n\nopt Test voice\n    User -&gt; SettingsScreen : Chon test voice\n    SettingsScreen -&gt; AudioPlaybackService : Test voice hien tai\\n(TestCurrentVoiceAsync())\n    activate AudioPlaybackService\n    AudioPlaybackService --&gt; SettingsScreen : Voice preview\n    deactivate AudioPlaybackService\nend\n\nUser -&gt; SettingsScreen : Nhan Save\n\nSettingsScreen -&gt; AppSettingsService : Luu cai dat\\n(SaveAsync())\nactivate AppSettingsService\n\nAppSettingsService -&gt; AppSettingsDb : Luu app settings\nactivate AppSettingsDb\nAppSettingsDb --&gt; AppSettingsService : Settings updated\ndeactivate AppSettingsDb\n\nAppSettingsService --&gt; SettingsScreen : Save success\ndeactivate AppSettingsService\n\nSettingsScreen -&gt; AudioPlaybackService : Ap dung am luong runtime\\n(ApplyRuntimeVolumeAsync())\nactivate AudioPlaybackService\nAudioPlaybackService --&gt; SettingsScreen : Volume applied\ndeactivate AudioPlaybackService\n\nSettingsScreen -&gt; LocationTrackingService : Cap nhat tracking theo settings\\n(StartTrackingFromSettingsAsync())\nactivate LocationTrackingService\nLocationTrackingService --&gt; SettingsScreen : Tracking updated\ndeactivate LocationTrackingService\n\nSettingsScreen --&gt; User : Thong bao luu cai dat thanh cong\n\ndeactivate SettingsScreen\ndeactivate User\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="WX9SQTEdD-ieiS3XrT58-3">
