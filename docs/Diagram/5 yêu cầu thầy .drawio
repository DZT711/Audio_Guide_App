        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml MapMobileSequenceVi\ntitle 4. View Map and Search POI\n\nhide footbox\n\nskinparam shadowing false\nskinparam sequence {\n  ArrowColor #2F4858\n  LifeLineBorderColor #2F4858\n  LifeLineBackgroundColor #EAF3F7\n  ParticipantBorderColor #2F4858\n  ParticipantBackgroundColor white\n  ParticipantFontColor #1F2D3D\n  ActorBorderColor #2F4858\n  ActorBackgroundColor white\n  ActorFontColor #1F2D3D\n}\n\nautonumber 1\n\nactor \&quot;Nguoi dung\&quot; as User\nboundary \&quot;Map Screen\&quot; as MapScreen\ncontrol \&quot;PlaceCatalogService\&quot; as PlaceCatalogService\ncontrol \&quot;UserLocationService / LocationTrackingService\&quot; as LocationService\nentity \&quot;Local Cache\&quot; as LocalCache\ncontrol \&quot;Public Catalog API\&quot; as PublicCatalogApi\ncontrol \&quot;Online Search API\&quot; as OnlineSearchApi\n\nactivate User\n\nUser -&gt; MapScreen : Mo man hinh ban do\nactivate MapScreen\n\nMapScreen -&gt; MapScreen : Tai WebView ban do\\n(LoadMapAsync())\n\nMapScreen -&gt; PlaceCatalogService : Tai du lieu POI cho ban do\\n(GetMapPointsAsync())\nactivate PlaceCatalogService\n\nalt Co the dung cache / offline data\n    PlaceCatalogService -&gt; LocalCache : Doc catalog da luu\n    activate LocalCache\n    LocalCache --&gt; PlaceCatalogService : Danh sach POI\n    deactivate LocalCache\n\nelse Dong bo tu server\n    PlaceCatalogService -&gt; PublicCatalogApi : Lay public catalog\n    activate PublicCatalogApi\n    PublicCatalogApi --&gt; PlaceCatalogService : Danh sach POI\n    deactivate PublicCatalogApi\nend\n\nPlaceCatalogService --&gt; MapScreen : Danh sach POI\ndeactivate PlaceCatalogService\n\nMapScreen -&gt; MapScreen : Dong bo marker POI len ban do\\n(SyncPlacesToMapAsync())\n\nMapScreen -&gt; LocationService : Lay / lam moi vi tri hien tai khi can\\n(RefreshLocationAsync() / StartTrackingFromSettingsAsync())\nactivate LocationService\nLocationService --&gt; MapScreen : Vi tri nguoi dung\ndeactivate LocationService\n\nMapScreen -&gt; MapScreen : Hien thi marker POI va vi tri hien tai tren ban do\n\nMapScreen --&gt; User : Hien thi ban do POI\n\nalt Nguoi dung chon marker\n    User -&gt; MapScreen : Chon marker POI\n    MapScreen -&gt; MapScreen : Focus POI tren ban do\\n(focusPlaceById())\n    MapScreen --&gt; User : Hien thi chi tiet POI\n\nelse Nguoi dung tim POI\n    User -&gt; MapScreen : Nhap tu khoa ten POI\n    MapScreen -&gt; PlaceCatalogService : Tim POI theo ten\\n(SearchByName())\n    activate PlaceCatalogService\n    PlaceCatalogService --&gt; MapScreen : Ket qua POI\n    deactivate PlaceCatalogService\n\n    MapScreen -&gt; MapScreen : Cap nhat marker va ket qua tim kiem\n    MapScreen --&gt; User : Hien thi ket qua tren ban do\n\nelse Nguoi dung tim dia chi\n    User -&gt; MapScreen : Nhap tu khoa dia chi\n    MapScreen -&gt; OnlineSearchApi : Tim dia chi online\\n(SearchOnlineAsync())\n    activate OnlineSearchApi\n    OnlineSearchApi --&gt; MapScreen : Ket qua dia chi\n    deactivate OnlineSearchApi\n\n    MapScreen -&gt; MapScreen : Hien thi vi tri ket qua tren ban do\\n(showSearchResult())\n    MapScreen --&gt; User : Cap nhat ket qua tren ban do\nend\n\ndeactivate MapScreen\ndeactivate User\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="WX9SQTEdD-ieiS3XrT58-4">
