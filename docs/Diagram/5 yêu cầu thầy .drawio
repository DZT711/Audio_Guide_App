        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml OfflineManagementMobileSequenceVi\ntitle 5. Offline Management\n\nhide footbox\n\nskinparam shadowing false\nskinparam sequence {\n  ArrowColor #2F4858\n  LifeLineBorderColor #2F4858\n  LifeLineBackgroundColor #EAF3F7\n  ParticipantBorderColor #2F4858\n  ParticipantBackgroundColor white\n  ParticipantFontColor #1F2D3D\n  ActorBorderColor #2F4858\n  ActorBackgroundColor white\n  ActorFontColor #1F2D3D\n}\n\nautonumber 1\n\nactor \&quot;Nguoi dung\&quot; as User\nboundary \&quot;Offline Screen\&quot; as OfflineScreen\ncontrol \&quot;PlaceCatalogService\&quot; as PlaceCatalogService\ncontrol \&quot;AudioDownloadService\&quot; as AudioDownloadService\ncontrol \&quot;Public Catalog API\&quot; as PublicCatalogApi\nentity \&quot;Local Cache / Downloaded Files\&quot; as LocalCache\n\nactivate User\n\nUser -&gt; OfflineScreen : Mo man hinh Offline\nactivate OfflineScreen\n\nOfflineScreen -&gt; PlaceCatalogService : Tai danh sach offline pack\\n(GetCatalogAsync())\nactivate PlaceCatalogService\n\nalt Dung du lieu da luu\n    PlaceCatalogService -&gt; LocalCache : Doc catalog da luu\n    activate LocalCache\n    LocalCache --&gt; PlaceCatalogService : Danh sach POI / audio cache\n    deactivate LocalCache\n\nelse Lam moi du lieu\n    PlaceCatalogService -&gt; PublicCatalogApi : Dong bo public catalog\n    activate PublicCatalogApi\n    PublicCatalogApi --&gt; PlaceCatalogService : Du lieu offline pack\n    deactivate PublicCatalogApi\n\n    PlaceCatalogService -&gt; LocalCache : Cap nhat cache catalog\n    activate LocalCache\n    LocalCache --&gt; PlaceCatalogService : Cache updated\n    deactivate LocalCache\nend\n\nPlaceCatalogService --&gt; OfflineScreen : Danh sach offline pack\ndeactivate PlaceCatalogService\n\nOfflineScreen -&gt; AudioDownloadService : Kiem tra trang thai da tai\\n(GetSnapshotsForLocationAsync())\nactivate AudioDownloadService\nAudioDownloadService -&gt; LocalCache : Doc manifest / downloaded files\nactivate LocalCache\nLocalCache --&gt; AudioDownloadService : Trang thai da tai\ndeactivate LocalCache\nAudioDownloadService --&gt; OfflineScreen : Trang thai offline pack\ndeactivate AudioDownloadService\n\nOfflineScreen --&gt; User : Hien thi danh sach offline pack\n\nalt Tai pack\n    User -&gt; OfflineScreen : Chon tai audio pack\n\n    OfflineScreen -&gt; OfflineScreen : Kiem tra Internet va API mode\n\n    OfflineScreen -&gt; PlaceCatalogService : Lay audio track co the tai\\n(GetAudioTracksAsync())\n    activate PlaceCatalogService\n    PlaceCatalogService --&gt; OfflineScreen : Danh sach audio co the tai\n    deactivate PlaceCatalogService\n\n    OfflineScreen -&gt; AudioDownloadService : Tai audio pack\\n(DownloadAsync())\n    activate AudioDownloadService\n    AudioDownloadService -&gt; LocalCache : Luu file audio va manifest\n    activate LocalCache\n    LocalCache --&gt; AudioDownloadService : Pack updated\n    deactivate LocalCache\n    AudioDownloadService --&gt; OfflineScreen : Tai pack thanh cong\n    deactivate AudioDownloadService\n\n    OfflineScreen --&gt; User : Cap nhat trang thai da tai\n\nelse Xoa pack\n    User -&gt; OfflineScreen : Chon xoa audio pack\n\n    OfflineScreen -&gt; AudioDownloadService : Xoa audio pack khoi may\\n(DeleteLocationTracksAsync())\n    activate AudioDownloadService\n    AudioDownloadService -&gt; LocalCache : Xoa file audio da tai va manifest\n    activate LocalCache\n    LocalCache --&gt; AudioDownloadService : Pack removed\n    deactivate LocalCache\n    AudioDownloadService --&gt; OfflineScreen : Xoa pack thanh cong\n    deactivate AudioDownloadService\n\n    OfflineScreen --&gt; User : Cap nhat trang thai chua tai\nend\n\ndeactivate OfflineScreen\ndeactivate User\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="WX9SQTEdD-ieiS3XrT58-1">
