        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml UserSequenceVi\ntitle 8. Nguoi dung dashboard\n\nhide footbox\n\nskinparam shadowing false\nskinparam sequence {\n  ArrowColor #2F4858\n  LifeLineBorderColor #2F4858\n  LifeLineBackgroundColor #EAF3F7\n  ParticipantBorderColor #2F4858\n  ParticipantBackgroundColor white\n  ParticipantFontColor #1F2D3D\n  ActorBorderColor #2F4858\n  ActorBackgroundColor white\n  ActorFontColor #1F2D3D\n}\n\nautonumber 1\n\nboundary \&quot;UserList.razor\&quot; as UserPage\ncontrol \&quot;AdminApiClient\&quot; as ApiClient\ncontrol \&quot;DashboardUserController\&quot; as UserController\nentity \&quot;DBContext/DashboardUsers\&quot; as DBContext\n\nactivate UserPage\n\nUserPage -&gt; ApiClient : Gui yeu cau lay danh sach user\\n(GetUsersAsync())\nactivate ApiClient\n\nApiClient -&gt; UserController : Goi API lay user\\n(GET /DashboardUser)\nactivate UserController\n\nUserController -&gt; DBContext : Lay danh sach user va so POI/audio so huu\nactivate DBContext\nDBContext --&gt; UserController : Danh sach nguoi dung\ndeactivate DBContext\n\nUserController --&gt; ApiClient : Tra ve du lieu user\ndeactivate UserController\nApiClient --&gt; UserPage : Hien thi danh sach nguoi dung\ndeactivate ApiClient\n\nalt Tao moi\n    UserPage -&gt; ApiClient : Gui yeu cau tao user\\n(CreateUserAsync())\n    activate ApiClient\n\n    ApiClient -&gt; UserController : Goi API tao user\\n(POST /DashboardUser)\n    activate UserController\n\n    UserController -&gt; DBContext : Kiem tra role, username,\\nemail, phone va hash password\n    activate DBContext\n    DBContext --&gt; UserController : Tao moi thanh cong\n    deactivate DBContext\n\n    UserController --&gt; ApiClient : Tra ket qua tao moi\n    deactivate UserController\n    ApiClient --&gt; UserPage : Cap nhat giao dien\n    deactivate ApiClient\n\nelse Moi nguoi dung\n    UserPage -&gt; ApiClient : Gui yeu cau moi user\\n(InviteUserAsync())\n    activate ApiClient\n\n    ApiClient -&gt; UserController : Goi API moi user\\n(POST /DashboardUser/invite)\n    activate UserController\n\n    UserController -&gt; DBContext : Sinh username neu can,\\ntao mat khau tam, hash va luu user status = 0\n    activate DBContext\n    DBContext --&gt; UserController : Ket qua moi nguoi dung\n    deactivate DBContext\n\n    UserController --&gt; ApiClient : Tra ket qua moi user\n    deactivate UserController\n    ApiClient --&gt; UserPage : Cap nhat giao dien\n    deactivate ApiClient\n\nelse Cap nhat / doi trang thai\n    UserPage -&gt; ApiClient : Gui yeu cau cap nhat user\\n(UpdateUserAsync())\n    activate ApiClient\n\n    ApiClient -&gt; UserController : Goi API cap nhat user\\n(PUT /DashboardUser/{id})\n    activate UserController\n\n    UserController -&gt; DBContext : Tim user, kiem tra trung,\\ncap nhat va hash mat khau neu co\n    activate DBContext\n    DBContext --&gt; UserController : Cap nhat thanh cong\n    deactivate DBContext\n\n    UserController --&gt; ApiClient : Tra ket qua cap nhat\n    deactivate UserController\n    ApiClient --&gt; UserPage : Cap nhat giao dien\n    deactivate ApiClient\n\nelse Archive\n    UserPage -&gt; ApiClient : Gui yeu cau archive user\\n(DeleteUserAsync())\n    activate ApiClient\n\n    ApiClient -&gt; UserController : Goi API archive user\\n(DELETE /DashboardUser/{id})\n    activate UserController\n\n    UserController -&gt; DBContext : Dat Status = 0 neu hop le\n    activate DBContext\n    DBContext --&gt; UserController : Archive thanh cong\n    deactivate DBContext\n\n    UserController --&gt; ApiClient : Tra ket qua archive\n    deactivate UserController\n    ApiClient --&gt; UserPage : Cap nhat giao dien\n    deactivate ApiClient\nend\n\ndeactivate UserPage\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="zvPKj-v926YrVPgkOCL9-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1204" width="977" x="20" y="20" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml InboxSequenceVi\ntitle 9. Hop thu\n\nhide footbox\n\nskinparam shadowing false\nskinparam sequence {\n  ArrowColor #2F4858\n  LifeLineBorderColor #2F4858\n  LifeLineBackgroundColor #EAF3F7\n  ParticipantBorderColor #2F4858\n  ParticipantBackgroundColor white\n  ParticipantFontColor #1F2D3D\n  ActorBorderColor #2F4858\n  ActorBackgroundColor white\n  ActorFontColor #1F2D3D\n}\n\nautonumber 1\n\nboundary \&quot;Inbox.razor\&quot; as InboxPage\ncontrol \&quot;AdminApiClient\&quot; as ApiClient\ncontrol \&quot;InboxController\&quot; as InboxController\ncontrol \&quot;ChangeRequestWorkflowService\&quot; as WorkflowService\nentity \&quot;DBContext\&quot; as DBContext\n\nactivate InboxPage\n\nalt Xem hop thu\n    InboxPage -&gt; ApiClient : Gui yeu cau lay hop thu\\n(GetInboxAsync())\n    activate ApiClient\n\n    ApiClient -&gt; InboxController : Goi API lay hop thu\\n(GET /Inbox?page=...&amp;pageSize=...&amp;unreadOnly=...)\n    activate InboxController\n\n    InboxController -&gt; WorkflowService : Lay hop thu theo user hien tai\\n(GetInboxAsync())\n    activate WorkflowService\n\n    WorkflowService -&gt; DBContext : Lay danh sach message,\\nphan trang va unread count\n    activate DBContext\n    DBContext --&gt; WorkflowService : Du lieu tong quan hop thu\n    deactivate DBContext\n\n    WorkflowService --&gt; InboxController : InboxOverviewDto\n    deactivate WorkflowService\n\n    InboxController --&gt; ApiClient : Tra ve du lieu hop thu\n    deactivate InboxController\n\n    ApiClient --&gt; InboxPage : Hien thi danh sach hop thu\n    deactivate ApiClient\n\nelse Danh dau da doc\n    InboxPage -&gt; ApiClient : Gui yeu cau danh dau da doc\\n(MarkInboxMessageReadAsync())\n    activate ApiClient\n\n    ApiClient -&gt; InboxController : Goi API danh dau da doc\\n(POST /Inbox/{id}/read)\n    activate InboxController\n\n    InboxController -&gt; WorkflowService : Danh dau message da doc\\n(MarkInboxReadAsync())\n    activate WorkflowService\n\n    WorkflowService -&gt; DBContext : Kiem tra message theo user\\nva cap nhat trang thai da doc\n    activate DBContext\n    DBContext --&gt; WorkflowService : Danh dau da doc thanh cong\n    deactivate DBContext\n\n    WorkflowService --&gt; InboxController : Ket qua cap nhat\n    deactivate WorkflowService\n\n    InboxController --&gt; ApiClient : Tra ket qua danh dau da doc\n    deactivate InboxController\n\n    ApiClient --&gt; InboxPage : Cap nhat giao dien\n    deactivate ApiClient\n\nelse Gui thong bao he thong\n    InboxPage -&gt; ApiClient : Gui yeu cau tao thong bao he thong\\n(CreateInboxAnnouncementAsync())\n    activate ApiClient\n\n    ApiClient -&gt; InboxController : Goi API gui announcement\\n(POST /Inbox/announcement)\n    activate InboxController\n\n    InboxController -&gt; WorkflowService : Gui thong bao toi tat ca tai khoan dashboard\\n(BroadcastAnnouncementAsync())\n    activate WorkflowService\n\n    WorkflowService -&gt; DBContext : Tao inbox message cho tung user va luu thay doi\n    activate DBContext\n    DBContext --&gt; WorkflowService : Gui thong bao thanh cong\n    deactivate DBContext\n\n    WorkflowService --&gt; InboxController : Ket qua gui thong bao\n    deactivate WorkflowService\n\n    InboxController --&gt; ApiClient : Tra ket qua announcement\n    deactivate InboxController\n\n    ApiClient --&gt; InboxPage : Gui thong bao thanh cong\n    deactivate ApiClient\nend\n\ndeactivate InboxPage\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="7cRFbH-BwiTE_xUOo4G6-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="995" width="1421" x="20" y="1380" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml ModerationSequenceVi\ntitle 10. Moderation / Change request\n\nhide footbox\n\nskinparam shadowing false\nskinparam sequence {\n  ArrowColor #2F4858\n  LifeLineBorderColor #2F4858\n  LifeLineBackgroundColor #EAF3F7\n  ParticipantBorderColor #2F4858\n  ParticipantBackgroundColor white\n  ParticipantFontColor #1F2D3D\n  ActorBorderColor #2F4858\n  ActorBackgroundColor white\n  ActorFontColor #1F2D3D\n}\n\nautonumber 1\n\nboundary \&quot;ModerationList.razor\&quot; as ModerationPage\ncontrol \&quot;AdminApiClient\&quot; as ApiClient\ncontrol \&quot;ChangeRequestController\&quot; as ChangeRequestController\ncontrol \&quot;ChangeRequestWorkflowService\&quot; as WorkflowService\nentity \&quot;DBContext\&quot; as DBContext\n\nactivate ModerationPage\n\nModerationPage -&gt; ApiClient : Gui yeu cau lay danh sach yeu cau\\n(GetChangeRequestsAsync())\nactivate ApiClient\n\nApiClient -&gt; ChangeRequestController : Goi API lay change request\\n(GET /ChangeRequest?... )\nactivate ChangeRequestController\n\nChangeRequestController -&gt; WorkflowService : Lay danh sach yeu cau theo bo loc\\n(GetRequestsAsync())\nactivate WorkflowService\n\nWorkflowService -&gt; DBContext : Lay change request, du lieu live\\nva phan trang ket qua\nactivate DBContext\nDBContext --&gt; WorkflowService : Danh sach yeu cau thay doi\ndeactivate DBContext\n\nWorkflowService --&gt; ChangeRequestController : ChangeRequestListDto\ndeactivate WorkflowService\n\nChangeRequestController --&gt; ApiClient : Tra ve du lieu moderation\ndeactivate ChangeRequestController\n\nApiClient --&gt; ModerationPage : Hien thi danh sach yeu cau\ndeactivate ApiClient\n\nalt Phe duyet\n    ModerationPage -&gt; ApiClient : Gui yeu cau phe duyet\\n(ApproveChangeRequestAsync())\n    activate ApiClient\n\n    ApiClient -&gt; ChangeRequestController : Goi API phe duyet\\n(POST /ChangeRequest/{id}/approve)\n    activate ChangeRequestController\n\n    ChangeRequestController -&gt; WorkflowService : Phe duyet yeu cau\\n(ApproveAsync())\n    activate WorkflowService\n\n    WorkflowService -&gt; DBContext : Ap dung thay doi vao du lieu live,\\ncap nhat trang thai request va tao thong bao\n    activate DBContext\n    DBContext --&gt; WorkflowService : Ket qua sau khi phe duyet\n    deactivate DBContext\n\n    WorkflowService --&gt; ChangeRequestController : ChangeRequestDto\n    deactivate WorkflowService\n\n    ChangeRequestController --&gt; ApiClient : Tra ket qua phe duyet\n    deactivate ChangeRequestController\n\n    ApiClient --&gt; ModerationPage : Cap nhat giao dien\n    deactivate ApiClient\n\nelse Tu choi\n    ModerationPage -&gt; ApiClient : Gui yeu cau tu choi\\n(RejectChangeRequestAsync())\n    activate ApiClient\n\n    ApiClient -&gt; ChangeRequestController : Goi API tu choi\\n(POST /ChangeRequest/{id}/reject)\n    activate ChangeRequestController\n\n    ChangeRequestController -&gt; WorkflowService : Tu choi yeu cau\\n(RejectAsync())\n    activate WorkflowService\n\n    WorkflowService -&gt; DBContext : Cap nhat trang thai request,\\nluu admin note va tao thong bao\n    activate DBContext\n    DBContext --&gt; WorkflowService : Ket qua sau khi tu choi\n    deactivate DBContext\n\n    WorkflowService --&gt; ChangeRequestController : ChangeRequestDto\n    deactivate WorkflowService\n\n    ChangeRequestController --&gt; ApiClient : Tra ket qua tu choi\n    deactivate ChangeRequestController\n\n    ApiClient --&gt; ModerationPage : Cap nhat giao dien\n    deactivate ApiClient\nend\n\ndeactivate ModerationPage\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="7cRFbH-BwiTE_xUOo4G6-2">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="995" width="1251" x="40" y="2510" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml UsageHistorySequenceVi\ntitle 11. Usage history\n\nhide footbox\n\nskinparam shadowing false\nskinparam sequence {\n  ArrowColor #2F4858\n  LifeLineBorderColor #2F4858\n  LifeLineBackgroundColor #EAF3F7\n  ParticipantBorderColor #2F4858\n  ParticipantBackgroundColor white\n  ParticipantFontColor #1F2D3D\n  ActorBorderColor #2F4858\n  ActorBackgroundColor white\n  ActorFontColor #1F2D3D\n}\n\nautonumber 1\n\nboundary \&quot;UsageHistory.razor\&quot; as UsagePage\ncontrol \&quot;AdminApiClient\&quot; as ApiClient\ncontrol \&quot;AnalyticsV1 / UsageController\&quot; as UsageSource\nentity \&quot;DBContext\&quot; as DBContext\n\nactivate UsagePage\n\nUsagePage -&gt; ApiClient : Gui yeu cau lay lich su su dung\\n(GetUsageHistoryAsync())\nactivate ApiClient\n\nApiClient -&gt; UsageSource : Goi nguon du lieu usage analytics\\n(GetUsageAnalyticsStatisticsV1() / GetUsageAnalyticsHistorySnapshotV1())\n\nalt Lay duoc du lieu analytics\n    UsageSource --&gt; ApiClient : Du lieu thong ke va lich su usage\n    ApiClient -&gt; ApiClient : Ghep va chuan hoa du lieu usage history\\n(MapUsageHistoryOverviewFromV1())\nelse Fallback endpoint legacy\n    ApiClient -&gt; UsageSource : Goi API usage lich su cu\\n(GET /Usage)\n    activate UsageSource\n\n    UsageSource -&gt; DBContext : Lay playback events theo scope user,\\nlay tour names va tinh thong ke tong hop\n    activate DBContext\n    DBContext --&gt; UsageSource : Du lieu lich su su dung\n    deactivate DBContext\n\n    UsageSource --&gt; ApiClient : UsageHistoryOverviewDto\n    deactivate UsageSource\nend\n\nApiClient --&gt; UsagePage : Tra ve du lieu usage history\ndeactivate ApiClient\n\nUsagePage -&gt; UsagePage : Hien thi thong ke tong hop,\\ndanh sach usage va auto refresh\\n(LoadAsync())\n\ndeactivate UsagePage\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="7cRFbH-BwiTE_xUOo4G6-3">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="561" width="1182" x="60" y="3530" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml StatisticsSequenceVi\ntitle Statistics Page\n\nhide footbox\n\nskinparam shadowing false\nskinparam sequence {\n  ArrowColor #2F4858\n  LifeLineBorderColor #2F4858\n  LifeLineBackgroundColor #EAF3F7\n  ParticipantBorderColor #2F4858\n  ParticipantBackgroundColor white\n  ParticipantFontColor #1F2D3D\n  ActorBorderColor #2F4858\n  ActorBackgroundColor white\n  ActorFontColor #1F2D3D\n}\n\nautonumber 1\n\nactor \&quot;Admin\&quot; as Admin\nboundary \&quot;Statistics.razor\&quot; as StatisticsPage\ncontrol \&quot;AdminApiClient\&quot; as ApiClient\ncontrol \&quot;StatisticsController\&quot; as StatisticsController\nentity \&quot;DBContext\&quot; as DBContext\nboundary \&quot;admin-ui.js\&quot; as AdminJs\n\nactivate Admin\n\nAdmin -&gt; StatisticsPage : Mo trang Statistics / thay doi bo loc\\n(LoadAsync())\nactivate StatisticsPage\n\nStatisticsPage -&gt; ApiClient : Gui yeu cau lay du lieu thong ke tong hop\\n(GetStatisticsAsync())\nactivate ApiClient\n\nApiClient -&gt; StatisticsController : Goi API thong ke theo bo loc\\n(GET /Statistics?... )\nactivate StatisticsController\n\nStatisticsController -&gt; DBContext : Lay du lieu theo bo loc\\n(BuildStatisticsOverviewAsync())\nactivate DBContext\n\nDBContext --&gt; StatisticsController : Tra ve du lieu tho\\n(tracking, playback, heatmap, location, route, tour...)\ndeactivate DBContext\n\nStatisticsController -&gt; StatisticsController : Tong hop summary, chart, heatmap,\\nroute history, top POI va average listening\\n(BuildHeatmapPoints() va cac xu ly thong ke khac)\n\nStatisticsController --&gt; ApiClient : Tra ve goi du lieu thong ke tong hop\\n(StatisticsOverviewDto)\ndeactivate StatisticsController\n\nApiClient --&gt; StatisticsPage : Tra du lieu overview cho trang\ndeactivate ApiClient\n\nStatisticsPage -&gt; StatisticsPage : Cap nhat summary, chart, report,\\nroute history va selected route\\n(LoadAsync())\n\nStatisticsPage -&gt; StatisticsPage : Tao state cho ban do thong ke\\n(CreateStatisticsMapState())\n\nStatisticsPage -&gt; AdminJs : Khoi tao / dong bo heatmap, route,\\ntour overlay va POI tren ban do\\n(initializeStatisticsMap() / syncStatisticsMap())\nactivate AdminJs\n\nAdminJs -&gt; AdminJs : Chuan hoa heatmap points va render ban do\\n(normalizeStatisticsHeatPoints() / renderStatisticsMap())\n\nAdminJs --&gt; StatisticsPage : Hien thi ban do thong ke da cap nhat\ndeactivate AdminJs\n\nStatisticsPage --&gt; Admin : Hien thi tong quan Statistics\\n(summary, chart, heatmap, route history, top POI, average listening)\n\ndeactivate StatisticsPage\ndeactivate Admin\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="7cRFbH-BwiTE_xUOo4G6-4">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="794" width="1997" x="60" y="4110" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml ActivityHistorySequenceVi\ntitle 13. Activity History\n\nhide footbox\n\nskinparam shadowing false\nskinparam sequence {\n  ArrowColor #2F4858\n  LifeLineBorderColor #2F4858\n  LifeLineBackgroundColor #EAF3F7\n  ParticipantBorderColor #2F4858\n  ParticipantBackgroundColor white\n  ParticipantFontColor #1F2D3D\n  ActorBorderColor #2F4858\n  ActorBackgroundColor white\n  ActorFontColor #1F2D3D\n}\n\nautonumber 1\n\nboundary \&quot;ActivityHistory.razor\&quot; as ActivityPage\ncontrol \&quot;AdminApiClient\&quot; as ApiClient\ncontrol \&quot;ActivityLogController\&quot; as ActivityController\nentity \&quot;DBContext/ActivityLogs\&quot; as DBContext\n\nactivate ActivityPage\n\nActivityPage -&gt; ApiClient : Gui yeu cau lay lich su hoat dong\\n(GetActivityLogsAsync(query))\nactivate ApiClient\n\nApiClient -&gt; ActivityController : Goi API activity log theo bo loc\\n(GET /ActivityLog?page=...&amp;pageSize=...&amp;search=...&amp;action=...&amp;entity=...)\nactivate ActivityController\n\nActivityController -&gt; DBContext : Xay dung truy van activity logs\\nva loc theo search, action, entity\\n(BuildQuery())\nactivate DBContext\n\nDBContext --&gt; ActivityController : Du lieu activity logs\ndeactivate DBContext\n\nActivityController -&gt; ActivityController : Sap xep, phan trang va map DTO\n\nActivityController --&gt; ApiClient : Tra ve du lieu lich su hoat dong\\n(ActivityLogListDto)\ndeactivate ActivityController\n\nApiClient --&gt; ActivityPage : Hien thi lich su hoat dong\ndeactivate ApiClient\n\ndeactivate ActivityPage\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="7cRFbH-BwiTE_xUOo4G6-5">
