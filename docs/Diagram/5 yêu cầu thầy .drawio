        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml CategorySequenceVi\ntitle 3. Danh muc\n\nhide footbox\n\nskinparam shadowing false\nskinparam sequence {\n  ArrowColor #2F4858\n  LifeLineBorderColor #2F4858\n  LifeLineBackgroundColor #EAF3F7\n  ParticipantBorderColor #2F4858\n  ParticipantBackgroundColor white\n  ParticipantFontColor #1F2D3D\n  ActorBorderColor #2F4858\n  ActorBackgroundColor white\n  ActorFontColor #1F2D3D\n}\n\nautonumber 1\n\nboundary \&quot;CategoryList.razor\&quot; as CategoryPage\ncontrol \&quot;AdminApiClient\&quot; as ApiClient\ncontrol \&quot;CategoryController\&quot; as CategoryController\nentity \&quot;DBContext/Categories\&quot; as DBContext\n\nactivate CategoryPage\n\nCategoryPage -&gt; ApiClient : Gui yeu cau lay danh sach danh muc\\n(GetCategoriesAsync())\nactivate ApiClient\n\nApiClient -&gt; CategoryController : Goi API lay danh muc\\n(GET /Category)\nactivate CategoryController\n\nCategoryController -&gt; DBContext : Lay danh sach danh muc\nactivate DBContext\nDBContext --&gt; CategoryController : Danh sach danh muc\ndeactivate DBContext\n\nCategoryController --&gt; ApiClient : Tra ve du lieu danh muc\ndeactivate CategoryController\nApiClient --&gt; CategoryPage : Hien thi danh sach danh muc\ndeactivate ApiClient\n\nalt Tao moi\n    CategoryPage -&gt; ApiClient : Gui yeu cau tao danh muc\\n(CreateCategoryAsync())\n    activate ApiClient\n\n    ApiClient -&gt; CategoryController : Goi API tao danh muc\\n(POST /Category)\n    activate CategoryController\n\n    CategoryController -&gt; DBContext : Kiem tra du lieu va luu danh muc moi\\n(SaveChangesAsync())\n    activate DBContext\n    DBContext --&gt; CategoryController : Tao moi thanh cong / Loi du lieu\n    deactivate DBContext\n\n    CategoryController --&gt; ApiClient : Tra ket qua tao moi\n    deactivate CategoryController\n    ApiClient --&gt; CategoryPage : Cap nhat giao dien sau tao moi\n    deactivate ApiClient\n\nelse Cap nhat\n    CategoryPage -&gt; ApiClient : Gui yeu cau cap nhat danh muc\\n(UpdateCategoryAsync())\n    activate ApiClient\n\n    ApiClient -&gt; CategoryController : Goi API cap nhat danh muc\\n(PUT /Category/{id})\n    activate CategoryController\n\n    CategoryController -&gt; DBContext : Tim category, kiem tra va luu cap nhat\\n(SaveChangesAsync())\n    activate DBContext\n    DBContext --&gt; CategoryController : Cap nhat thanh cong / Loi du lieu\n    deactivate DBContext\n\n    CategoryController --&gt; ApiClient : Tra ket qua cap nhat\n    deactivate CategoryController\n    ApiClient --&gt; CategoryPage : Cap nhat giao dien sau chinh sua\n    deactivate ApiClient\n\nelse Archive\n    CategoryPage -&gt; ApiClient : Gui yeu cau archive danh muc\\n(DeleteCategoryAsync())\n    activate ApiClient\n\n    ApiClient -&gt; CategoryController : Goi API archive danh muc\\n(DELETE /Category/{id})\n    activate CategoryController\n\n    CategoryController -&gt; DBContext : Dat Status = 0 va luu thay doi\\n(SaveChangesAsync())\n    activate DBContext\n    DBContext --&gt; CategoryController : Archive thanh cong\n    deactivate DBContext\n\n    CategoryController --&gt; ApiClient : Tra ket qua archive\n    deactivate CategoryController\n    ApiClient --&gt; CategoryPage : Cap nhat giao dien sau archive\n    deactivate ApiClient\nend\n\ndeactivate CategoryPage\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="k0PbXVgMCdZMVS44L1eZ-15">
