        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml ViewPlaceDetailsMobileSequenceVi\ntitle 3. View Place Details\n\nhide footbox\n\nskinparam shadowing false\nskinparam sequence {\n  ArrowColor #2F4858\n  LifeLineBorderColor #2F4858\n  LifeLineBackgroundColor #EAF3F7\n  ParticipantBorderColor #2F4858\n  ParticipantBackgroundColor white\n  ParticipantFontColor #1F2D3D\n  ActorBorderColor #2F4858\n  ActorBackgroundColor white\n  ActorFontColor #1F2D3D\n}\n\nautonumber 1\n\nactor \&quot;Nguoi dung\&quot; as User\nboundary \&quot;POI List Screen\&quot; as PoiListScreen\ncontrol \&quot;PlaceCatalogService\&quot; as PlaceCatalogService\ncontrol \&quot;Public Audio API\&quot; as PublicAudioApi\nentity \&quot;SQLite/Local Cache\&quot; as LocalCache\nentity \&quot;Server Database\&quot; as ServerDatabase\n\nactivate User\n\nUser -&gt; PoiListScreen : Chon mot dia diem\nactivate PoiListScreen\n\nPoiListScreen -&gt; PoiListScreen : Mo khung chi tiet,\\nhien thi gallery, thong tin va audio hien co neu co\n\nalt Audio chi tiet da co san\n    PoiListScreen -&gt; PoiListScreen : Hien thi danh sach audio kha dung\n\nelse Can nap them audio chi tiet\n    PoiListScreen -&gt; PlaceCatalogService : Lay audio tracks cua dia diem\\n(GetAudioTracksAsync())\n    activate PlaceCatalogService\n\n    alt Dung cache / offline data\n        PlaceCatalogService -&gt; LocalCache : Doc audio track da luu\n        activate LocalCache\n        LocalCache --&gt; PlaceCatalogService : Danh sach audio track\n        deactivate LocalCache\n\n    else Sync tu server va cap nhat cache\n        PlaceCatalogService -&gt; PublicAudioApi : Goi public location audio\n        activate PublicAudioApi\n\n        PublicAudioApi -&gt; ServerDatabase : Lay audio track cua dia diem\n        activate ServerDatabase\n        ServerDatabase --&gt; PublicAudioApi : Danh sach audio track\n        deactivate ServerDatabase\n\n        PublicAudioApi --&gt; PlaceCatalogService : Audio track snapshot\n        deactivate PublicAudioApi\n\n        PlaceCatalogService -&gt; LocalCache : Luu audio track vao cache\n        activate LocalCache\n        LocalCache --&gt; PlaceCatalogService : Cache updated\n        deactivate LocalCache\n    end\n\n    PlaceCatalogService --&gt; PoiListScreen : Audio track cap nhat\n    deactivate PlaceCatalogService\n\n    PoiListScreen -&gt; PoiListScreen : Cap nhat danh sach audio\\nva trang thai hien thi\nend\n\nPoiListScreen --&gt; User : Hien thi chi tiet dia diem\n\ndeactivate PoiListScreen\ndeactivate User\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="PuR3pW1kyNaqQgFaz-QU-3">
