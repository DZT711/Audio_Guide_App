        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml TourSequenceVi\ntitle 7. Tour\n\nhide footbox\n\nskinparam shadowing false\nskinparam sequence {\n  ArrowColor #2F4858\n  LifeLineBorderColor #2F4858\n  LifeLineBackgroundColor #EAF3F7\n  ParticipantBorderColor #2F4858\n  ParticipantBackgroundColor white\n  ParticipantFontColor #1F2D3D\n  ActorBorderColor #2F4858\n  ActorBackgroundColor white\n  ActorFontColor #1F2D3D\n}\n\nautonumber 1\n\nboundary \&quot;TourList.razor\&quot; as TourPage\ncontrol \&quot;AdminApiClient\&quot; as ApiClient\ncontrol \&quot;TourController\&quot; as TourController\ncontrol \&quot;TourRoutePlanningService\&quot; as RoutePlanningService\nentity \&quot;DBContext\&quot; as DBContext\n\nactivate TourPage\n\nTourPage -&gt; ApiClient : Gui yeu cau lay danh sach tour\\n(GetToursAsync())\nactivate ApiClient\n\nApiClient -&gt; TourController : Goi API lay tour\\n(GET /Tour)\nactivate TourController\n\nTourController -&gt; DBContext : Lay danh sach tour theo quyen\nactivate DBContext\nDBContext --&gt; TourController : Danh sach tuyen tham quan\ndeactivate DBContext\n\nTourController --&gt; ApiClient : Tra ve du lieu tour\\n(TourDto[])\ndeactivate TourController\nApiClient --&gt; TourPage : Hien thi danh sach tour\ndeactivate ApiClient\n\nalt Xem truoc tuyen duong\n    TourPage -&gt; ApiClient : Gui yeu cau xem truoc tuyen duong\\n(PreviewTourRouteAsync())\n    activate ApiClient\n\n    ApiClient -&gt; TourController : Goi API xem truoc tuyen duong\\n(POST /Tour/preview)\n    activate TourController\n\n    TourController -&gt; RoutePlanningService : Tinh quang duong va thoi gian du kien\\n(CalculatePreviewAsync())\n    activate RoutePlanningService\n    RoutePlanningService --&gt; TourController : Du lieu xem truoc tuyen duong\n    deactivate RoutePlanningService\n\n    TourController --&gt; ApiClient : Tra ve route preview\n    deactivate TourController\n    ApiClient --&gt; TourPage : Hien thi du lieu xem truoc\n    deactivate ApiClient\n\nelse Luu tour\n    TourPage -&gt; ApiClient : Gui yeu cau tao moi / cap nhat tour\\n(CreateTourAsync() / UpdateTourAsync())\n    activate ApiClient\n\n    ApiClient -&gt; TourController : Goi API luu tour\\n(POST /Tour / PUT /Tour/{id})\n    activate TourController\n\n    TourController -&gt; DBContext : Kiem tra POI va stops\n    activate DBContext\n    DBContext --&gt; TourController : Du lieu POI hop le / Loi du lieu\n    deactivate DBContext\n\n    TourController -&gt; RoutePlanningService : Tinh route neu can\\n(CalculatePreviewAsync())\n    activate RoutePlanningService\n    RoutePlanningService --&gt; TourController : Du lieu route\n    deactivate RoutePlanningService\n\n    TourController -&gt; DBContext : Luu tour va cac stops\\n(SaveChangesAsync())\n    activate DBContext\n    DBContext --&gt; TourController : Thanh cong\n    deactivate DBContext\n\n    TourController --&gt; ApiClient : Tra ket qua luu\n    deactivate TourController\n    ApiClient --&gt; TourPage : Cap nhat giao dien\n    deactivate ApiClient\n\nelse Archive\n    TourPage -&gt; ApiClient : Gui yeu cau archive tour\\n(DeleteTourAsync())\n    activate ApiClient\n\n    ApiClient -&gt; TourController : Goi API archive tour\\n(DELETE /Tour/{id})\n    activate TourController\n\n    TourController -&gt; DBContext : Archive tour\n    activate DBContext\n    DBContext --&gt; TourController : Archive thanh cong\n    deactivate DBContext\n\n    TourController --&gt; ApiClient : Tra ket qua archive\n    deactivate TourController\n    ApiClient --&gt; TourPage : Cap nhat giao dien\n    deactivate ApiClient\nend\n\ndeactivate TourPage\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="vAADwkPExonPpisjlmIm-4">
