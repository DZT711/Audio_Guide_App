                    </mxCell>
                </UserObject>
                <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml StatisticsHeatmapActivityVi\ntitle Heatmap thống kê\n\nskinparam shadowing false\nskinparam activity {\n  BackgroundColor white\n  BorderColor #2F4858\n  FontColor #1F2D3D\n  DiamondBackgroundColor #EAF3F7\n  DiamondBorderColor #2F4858\n  ArrowColor #2F4858\n  BarColor #2F4858\n  StartColor #2F4858\n  EndColor #2F4858\n}\n\nstart\n\n:Người dùng mở trang Statistics;\n:Chọn hoặc nhập bộ lọc thống kê;\n:Hệ thống gửi yêu cầu lấy dữ liệu heatmap;\n:Hệ thống lấy dữ liệu theo dõi vị trí theo bộ lọc;\n:Hệ thống tổng hợp các điểm heatmap;\n:Hệ thống tính mức độ hiển thị của từng điểm;\n:Hệ thống trả dữ liệu heatmap;\n:Hệ thống chuẩn hóa dữ liệu heatmap;\n:Hệ thống hiển thị heatmap thống kê;\n\nstop\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="621e_S05bnQUiYwob-83-10">
