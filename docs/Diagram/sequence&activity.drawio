                <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml StatisticsHeatmapSequenceVi\ntitle 12. Statistics Heatmap\n\nhide footbox\n\nskinparam shadowing false\nskinparam sequence {\n  ArrowColor #2F4858\n  LifeLineBorderColor #2F4858\n  LifeLineBackgroundColor #EAF3F7\n  ParticipantBorderColor #2F4858\n  ParticipantBackgroundColor white\n  ParticipantFontColor #1F2D3D\n  ActorBorderColor #2F4858\n  ActorBackgroundColor white\n  ActorFontColor #1F2D3D\n}\n\nautonumber 1\n\nboundary \&quot;Statistics.razor\&quot; as StatisticsPage\ncontrol \&quot;AdminApiClient\&quot; as ApiClient\ncontrol \&quot;StatisticsController\&quot; as StatisticsController\nentity \&quot;DBContext\&quot; as DBContext\n\nStatisticsPage -&gt; ApiClient : GetStatisticsAsync(query)\nactivate StatisticsPage\nactivate ApiClient\n\nApiClient -&gt; StatisticsController : GET Statistics?from=...&amp;to=...&amp;tourId=...&amp;ward=...&amp;search=...\nactivate StatisticsController\n\nStatisticsController -&gt; DBContext : Lấy dữ liệu tracking theo bộ lọc\nactivate DBContext\nDBContext --&gt; StatisticsController : Dữ liệu tracking thô\ndeactivate DBContext\n\nStatisticsController -&gt; StatisticsController : Tổng hợp heatmap points\\nvà tính intensity\nStatisticsController --&gt; ApiClient : StatisticsOverviewDto\\n(HeatPoints)\ndeactivate StatisticsController\n\nApiClient --&gt; StatisticsPage : Dữ liệu heatmap\ndeactivate ApiClient\n\nStatisticsPage -&gt; StatisticsPage : Chuẩn hóa heatmap points\\nvà render heatmap\nStatisticsPage --&gt; StatisticsPage : Hiển thị heatmap thống kê\n\ndeactivate StatisticsPage\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="RxmDpDUO9YmNSrNrCA55-1">
