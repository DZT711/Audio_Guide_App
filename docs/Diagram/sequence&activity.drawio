                <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml ModerationSequenceVi\ntitle 10. Moderation / Change request\n\nhide footbox\n\nskinparam shadowing false\nskinparam sequence {\n  ArrowColor #2F4858\n  LifeLineBorderColor #2F4858\n  LifeLineBackgroundColor #EAF3F7\n  ParticipantBorderColor #2F4858\n  ParticipantBackgroundColor white\n  ParticipantFontColor #1F2D3D\n  ActorBorderColor #2F4858\n  ActorBackgroundColor white\n  ActorFontColor #1F2D3D\n}\n\nautonumber 1\n\nboundary \&quot;ModerationList.razor\&quot; as ModerationList\ncontrol \&quot;AdminApiClient\&quot; as ApiClient\ncontrol \&quot;ChangeRequestController\&quot; as ChangeRequestController\ncontrol \&quot;ChangeRequestWorkflowService\&quot; as WorkflowService\n\nModerationList -&gt; ApiClient : GetChangeRequestsAsync(query)\nactivate ModerationList\nactivate ApiClient\n\nApiClient -&gt; ChangeRequestController : GET ChangeRequest\nactivate ChangeRequestController\n\nChangeRequestController -&gt; WorkflowService : Lấy danh sách yêu cầu\nactivate WorkflowService\nWorkflowService --&gt; ChangeRequestController : Danh sách yêu cầu thay đổi\ndeactivate WorkflowService\n\nalt Phê duyệt\n    ModerationList -&gt; ApiClient : ApproveChangeRequestAsync(id, note)\n    ApiClient -&gt; ChangeRequestController : POST ChangeRequest/{id}/approve\n\n    ChangeRequestController -&gt; WorkflowService : Áp dụng thay đổi vào dữ liệu live\n    activate WorkflowService\n    WorkflowService --&gt; ChangeRequestController : Kết quả sau khi phê duyệt\n    deactivate WorkflowService\n\nelse Từ chối\n    ModerationList -&gt; ApiClient : RejectChangeRequestAsync(id, note)\n    ApiClient -&gt; ChangeRequestController : POST ChangeRequest/{id}/reject\n\n    ChangeRequestController -&gt; WorkflowService : Từ chối và báo cho chủ yêu cầu\n    activate WorkflowService\n    WorkflowService --&gt; ChangeRequestController : Kết quả sau khi từ chối\n    deactivate WorkflowService\nend\n\ndeactivate ChangeRequestController\ndeactivate ApiClient\ndeactivate ModerationList\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="WZVrMcKF7iwWqCo2LqL2-10">
