                <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml WebTourSequenceVi\ntitle 7. Tour\n\nhide footbox\n\nskinparam shadowing false\nskinparam sequence {\n  ArrowColor #2F4858\n  LifeLineBorderColor #2F4858\n  LifeLineBackgroundColor #EAF3F7\n  ParticipantBorderColor #2F4858\n  ParticipantBackgroundColor white\n  ParticipantFontColor #1F2D3D\n  ActorBorderColor #2F4858\n  ActorBackgroundColor white\n  ActorFontColor #1F2D3D\n}\n\nautonumber 1\n\nboundary \&quot;TourList.razor\&quot; as TourList\ncontrol \&quot;AdminApiClient\&quot; as ApiClient\ncontrol \&quot;TourController\&quot; as TourController\ncontrol \&quot;TourRoutePlanningService\&quot; as RoutePlanningService\nentity \&quot;DBContext\&quot; as DBContext\n\nTourList -&gt; ApiClient : GetToursAsync()\nactivate TourList\nactivate ApiClient\n\nApiClient -&gt; TourController : GET Tour\nactivate TourController\nTourController -&gt; DBContext : Lấy danh sách tour theo quyền\nactivate DBContext\nDBContext --&gt; TourController : Danh sách tuyến tham quan\ndeactivate DBContext\nTourController --&gt; ApiClient : TourDto[]\ndeactivate TourController\nApiClient --&gt; TourList : Hiển thị danh sách tour\ndeactivate ApiClient\n\nalt Xem trước tuyến đường\n    TourList -&gt; ApiClient : PreviewTourRouteAsync(request)\n    activate ApiClient\n    ApiClient -&gt; TourController : POST Tour/preview\n    activate TourController\n    TourController -&gt; RoutePlanningService : Tính quãng đường và thời gian dự kiến\n    activate RoutePlanningService\n    RoutePlanningService --&gt; TourController : Dữ liệu xem trước tuyến đường\n    deactivate RoutePlanningService\n    TourController --&gt; ApiClient : Route preview\n    deactivate TourController\n    ApiClient --&gt; TourList : Hiển thị dữ liệu xem trước\n    deactivate ApiClient\n\nelse Lưu tour\n    TourList -&gt; ApiClient : CreateTourAsync(...) / UpdateTourAsync(...)\n    activate ApiClient\n    ApiClient -&gt; TourController : POST/PUT Tour\n    activate TourController\n    TourController -&gt; DBContext : Kiểm tra POI,\\ntính route nếu cần,\\nlưu tour và các stops\n    activate DBContext\n    DBContext --&gt; TourController : Thành công\n    deactivate DBContext\n    TourController --&gt; ApiClient : Kết quả lưu\n    deactivate TourController\n    ApiClient --&gt; TourList : Cập nhật giao diện\n    deactivate ApiClient\n\nelse Archive\n    TourList -&gt; ApiClient : DeleteTourAsync(id)\n    activate ApiClient\n    ApiClient -&gt; TourController : DELETE Tour/{id}\n    activate TourController\n    TourController -&gt; DBContext : Archive tour\n    activate DBContext\n    DBContext --&gt; TourController : Archive thành công\n    deactivate DBContext\n    TourController --&gt; ApiClient : Kết quả archive\n    deactivate TourController\n    ApiClient --&gt; TourList : Cập nhật giao diện\n    deactivate ApiClient\nend\n\ndeactivate TourList\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="CWrTp6XawFfQfag9i10m-7">
