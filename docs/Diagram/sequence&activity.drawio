                <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml MobileAudioPlaybackSequenceVi\ntitle 8.17. Audio Playback\n\nhide footbox\n\nskinparam shadowing false\nskinparam sequence {\n  ArrowColor #2F4858\n  LifeLineBorderColor #2F4858\n  LifeLineBackgroundColor #EAF3F7\n  ParticipantBorderColor #2F4858\n  ParticipantBackgroundColor white\n  ParticipantFontColor #1F2D3D\n  ActorBorderColor #2F4858\n  ActorBackgroundColor white\n  ActorFontColor #1F2D3D\n}\n\nautonumber 1\n\nactor \&quot;Người dùng\&quot; as User\nboundary \&quot;Place Detail Screen\&quot; as PlaceDetail\ncontrol \&quot;AudioDownloadService\&quot; as AudioDownloadService\ncontrol \&quot;HistoryService\&quot; as HistoryService\ncontrol \&quot;PlaybackCoordinatorService\&quot; as PlaybackCoordinator\ncontrol \&quot;AudioPlaybackService\&quot; as AudioPlaybackService\nentity \&quot;Local Download Manifest/File\&quot; as LocalAudioCache\n\nUser -&gt; PlaceDetail : Chọn audio track để phát\nactivate PlaceDetail\n\nPlaceDetail -&gt; PlaceDetail : Xác định track được chọn\\nvà chuẩn bị hàng đợi phát\n\nPlaceDetail -&gt; AudioDownloadService : ResolvePlayableTrackAsync(...)\nactivate AudioDownloadService\nAudioDownloadService -&gt; LocalAudioCache : Kiểm tra file audio cục bộ\nactivate LocalAudioCache\nLocalAudioCache --&gt; AudioDownloadService : Local file / chưa có file\ndeactivate LocalAudioCache\nAudioDownloadService --&gt; PlaceDetail : Playable track / playback queue\ndeactivate AudioDownloadService\n\nPlaceDetail -&gt; HistoryService : AddToHistory(place)\\n(async / best effort)\nactivate HistoryService\nHistoryService --&gt; PlaceDetail : History updated\ndeactivate HistoryService\n\nPlaceDetail -&gt; PlaybackCoordinator : PlayQueueAsync(queue, startIndex)\nactivate PlaybackCoordinator\nPlaybackCoordinator -&gt; AudioPlaybackService : Phát track hiện tại\nactivate AudioPlaybackService\nAudioPlaybackService --&gt; PlaybackCoordinator : Trạng thái phát audio\ndeactivate AudioPlaybackService\n\nalt Người dùng dừng thủ công\n    PlaybackCoordinator --&gt; PlaceDetail : Dừng phát hàng đợi\nelse Còn track tiếp theo\n    PlaybackCoordinator -&gt; PlaybackCoordinator : Tự chuyển sang track tiếp theo\n    PlaybackCoordinator --&gt; PlaceDetail : Tiếp tục phát\nelse Hết queue\n    PlaybackCoordinator --&gt; PlaceDetail : Kết thúc phát hàng đợi\nend\n\nPlaceDetail --&gt; User : Cập nhật trạng thái phát audio\ndeactivate PlaybackCoordinator\ndeactivate PlaceDetail\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="BfgLEszow10ICDQ_8rbH-11">
