                <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml MobileSettingsSequenceVi\ntitle 9. Settings\n\nhide footbox\n\nskinparam shadowing false\nskinparam sequence {\n  ArrowColor #2F4858\n  LifeLineBorderColor #2F4858\n  LifeLineBackgroundColor #EAF3F7\n  ParticipantBorderColor #2F4858\n  ParticipantBackgroundColor white\n  ParticipantFontColor #1F2D3D\n  ActorBorderColor #2F4858\n  ActorBackgroundColor white\n  ActorFontColor #1F2D3D\n}\n\nautonumber 1\n\nactor \&quot;Người dùng\&quot; as User\nboundary \&quot;Settings Screen\&quot; as SettingsPage\ncontrol \&quot;AppSettingsService\&quot; as AppSettingsService\ncontrol \&quot;LocalizationService\&quot; as LocalizationService\ncontrol \&quot;ThemeService\&quot; as ThemeService\ncontrol \&quot;AppDataModeService\&quot; as AppDataModeService\ncontrol \&quot;AudioPlaybackService\&quot; as AudioPlaybackService\ncontrol \&quot;LocationTrackingService\&quot; as LocationTrackingService\nentity \&quot;SQLite/App Settings\&quot; as LocalSettings\n\nUser -&gt; SettingsPage : Mở màn hình Settings\nactivate SettingsPage\n\nSettingsPage -&gt; AppSettingsService : `CreateSnapshot()`\nactivate AppSettingsService\nAppSettingsService --&gt; SettingsPage : Cài đặt hiện tại\ndeactivate AppSettingsService\n\nSettingsPage --&gt; User : Hiển thị các tùy chọn cài đặt\n\nopt Xem trước ngôn ngữ / giao diện\n    User -&gt; SettingsPage : Chọn ngôn ngữ hoặc giao diện\n    SettingsPage -&gt; LocalizationService : Cập nhật ngôn ngữ xem trước\n    activate LocalizationService\n    LocalizationService --&gt; SettingsPage : Giao diện ngôn ngữ mới\n    deactivate LocalizationService\n\n    SettingsPage -&gt; ThemeService : Cập nhật giao diện xem trước\n    activate ThemeService\n    ThemeService --&gt; SettingsPage : Theme preview updated\n    deactivate ThemeService\nend\n\nopt Test voice\n    User -&gt; SettingsPage : Chọn test voice\n    SettingsPage -&gt; AudioPlaybackService : `TestCurrentVoiceAsync()`\n    activate AudioPlaybackService\n    AudioPlaybackService --&gt; SettingsPage : Voice preview\n    deactivate AudioPlaybackService\nend\n\nUser -&gt; SettingsPage : Nhấn Save\nSettingsPage -&gt; SettingsPage : Kiểm tra ràng buộc cài đặt\\n`BackgroundTracking` và `BatterySaver`\n\nSettingsPage -&gt; AppSettingsService : `SaveAsync(snapshot)`\nactivate AppSettingsService\n\nAppSettingsService -&gt; LocalSettings : Lưu app settings\nactivate LocalSettings\nLocalSettings --&gt; AppSettingsService : Settings updated\ndeactivate LocalSettings\n\nAppSettingsService -&gt; LocalizationService : Áp dụng ngôn ngữ đã chọn\nactivate LocalizationService\nLocalizationService --&gt; AppSettingsService : Language applied\ndeactivate LocalizationService\n\nAppSettingsService -&gt; ThemeService : Áp dụng giao diện đã chọn\nactivate ThemeService\nThemeService --&gt; AppSettingsService : Theme applied\ndeactivate ThemeService\n\nAppSettingsService -&gt; AppDataModeService : Áp dụng API mode\nactivate AppDataModeService\nAppDataModeService --&gt; AppSettingsService : API mode applied\ndeactivate AppDataModeService\n\nAppSettingsService --&gt; SettingsPage : Save success\ndeactivate AppSettingsService\n\nSettingsPage -&gt; AudioPlaybackService : `ApplyRuntimeVolumeAsync()`\nactivate AudioPlaybackService\nAudioPlaybackService --&gt; SettingsPage : Volume applied\ndeactivate AudioPlaybackService\n\nSettingsPage -&gt; LocationTrackingService : `StartTrackingFromSettingsAsync()`\nactivate LocationTrackingService\nLocationTrackingService --&gt; SettingsPage : Tracking updated\ndeactivate LocationTrackingService\n\nSettingsPage --&gt; User : Thông báo lưu cài đặt thành công\ndeactivate SettingsPage\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="BfgLEszow10ICDQ_8rbH-9">
