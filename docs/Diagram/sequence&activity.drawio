                <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml UsageHistorySequenceVi\ntitle 11. Usage history\n\nhide footbox\n\nskinparam shadowing false\nskinparam sequence {\n  ArrowColor #2F4858\n  LifeLineBorderColor #2F4858\n  LifeLineBackgroundColor #EAF3F7\n  ParticipantBorderColor #2F4858\n  ParticipantBackgroundColor white\n  ParticipantFontColor #1F2D3D\n  ActorBorderColor #2F4858\n  ActorBackgroundColor white\n  ActorFontColor #1F2D3D\n}\n\nautonumber 1\n\nboundary \&quot;UsageHistory.razor\&quot; as UsageHistory\ncontrol \&quot;AdminApiClient\&quot; as ApiClient\ncontrol \&quot;UsageController\&quot; as UsageController\nentity \&quot;DBContext\&quot; as DbContext\n\nUsageHistory -&gt; ApiClient : GetUsageHistoryAsync()\nactivate UsageHistory\nactivate ApiClient\n\nApiClient -&gt; UsageController : GET Usage\nactivate UsageController\n\nUsageController -&gt; DbContext : Lấy playback events theo scope user\nactivate DbContext\ndeactivate DbContext\n\nUsageController -&gt; DbContext : Ghép tour names, tính thống kê\nactivate DbContext\nDbContext --&gt; UsageController : Dữ liệu lịch sử sử dụng\ndeactivate DbContext\n\ndeactivate UsageController\ndeactivate ApiClient\ndeactivate UsageHistory\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="WZVrMcKF7iwWqCo2LqL2-11">
