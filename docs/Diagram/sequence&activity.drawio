                <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml WebAudioSequenceVi\ntitle 6. Audio\n\nhide footbox\n\nskinparam shadowing false\nskinparam sequence {\n  ArrowColor #2F4858\n  LifeLineBorderColor #2F4858\n  LifeLineBackgroundColor #EAF3F7\n  ParticipantBorderColor #2F4858\n  ParticipantBackgroundColor white\n  ParticipantFontColor #1F2D3D\n  ActorBorderColor #2F4858\n  ActorBackgroundColor white\n  ActorFontColor #1F2D3D\n}\n\nautonumber 1\n\nboundary \&quot;AudioList.razor\&quot; as AudioList\ncontrol \&quot;AdminApiClient\&quot; as ApiClient\ncontrol \&quot;AudioController\&quot; as AudioController\ncontrol \&quot;ChangeRequestController\&quot; as ChangeRequestController\nentity \&quot;DBContext\&quot; as DBContext\n\nAudioList -&gt; ApiClient : GetAudioAsync()\nactivate AudioList\nactivate ApiClient\n\nApiClient -&gt; AudioController : GET Audio\nactivate AudioController\nAudioController -&gt; DBContext : Lấy danh sách audio theo quyền\nactivate DBContext\nDBContext --&gt; AudioController : Danh sách âm thanh\ndeactivate DBContext\nAudioController --&gt; ApiClient : AudioDto[]\ndeactivate AudioController\nApiClient --&gt; AudioList : Hiển thị danh sách audio\ndeactivate ApiClient\n\nalt Tạo preview TTS\n    AudioList -&gt; ApiClient : GenerateAudioTtsPreviewAsync(...)\n    activate ApiClient\n    ApiClient -&gt; AudioController : POST Audio/preview-tts\n    activate AudioController\n    AudioController --&gt; ApiClient : Audio preview\n    deactivate AudioController\n    ApiClient --&gt; AudioList : Hiển thị hoặc phát preview\n    deactivate ApiClient\n\nelse Lưu audio\n    AudioList -&gt; ApiClient : CreateAudioAsync(...) / UpdateAudioAsync(...)\n    activate ApiClient\n    ApiClient -&gt; AudioController : POST/PUT Audio\n    activate AudioController\n    AudioController -&gt; DBContext : Kiểm tra dữ liệu\\nvà lưu audio\n    activate DBContext\n    DBContext --&gt; AudioController : Thành công\n    deactivate DBContext\n    AudioController --&gt; ApiClient : Kết quả lưu\n    deactivate AudioController\n    ApiClient --&gt; AudioList : Cập nhật giao diện\n    deactivate ApiClient\n\nelse Archive\n    AudioList -&gt; ApiClient : DeleteAudioAsync(id)\n    activate ApiClient\n    ApiClient -&gt; AudioController : DELETE Audio/{id}\n    activate AudioController\n    AudioController -&gt; DBContext : Archive audio\n    activate DBContext\n    DBContext --&gt; AudioController : Archive thành công\n    deactivate DBContext\n    AudioController --&gt; ApiClient : Kết quả archive\n    deactivate AudioController\n    ApiClient --&gt; AudioList : Cập nhật giao diện\n    deactivate ApiClient\n\nelse Gửi yêu cầu thay đổi\n    AudioList -&gt; ApiClient : SubmitAudioChangeRequestAsync(...)\n    activate ApiClient\n    ApiClient -&gt; ChangeRequestController : POST ChangeRequest/audio\n    activate ChangeRequestController\n    ChangeRequestController -&gt; DBContext : Tạo change request\n    activate DBContext\n    DBContext --&gt; ChangeRequestController : Thành công\n    deactivate DBContext\n    ChangeRequestController --&gt; ApiClient : Kết quả yêu cầu\n    deactivate ChangeRequestController\n    ApiClient --&gt; AudioList : Gửi yêu cầu thành công\n    deactivate ApiClient\nend\n\ndeactivate AudioList\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="CWrTp6XawFfQfag9i10m-6">
