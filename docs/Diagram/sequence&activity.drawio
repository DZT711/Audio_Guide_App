                    </mxCell>
                </UserObject>
                <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml MobilePlaceDetailsSequenceVi\ntitle 3. View Place Details\n\nhide footbox\n\nskinparam shadowing false\nskinparam sequence {\n  ArrowColor #2F4858\n  LifeLineBorderColor #2F4858\n  LifeLineBackgroundColor #EAF3F7\n  ParticipantBorderColor #2F4858\n  ParticipantBackgroundColor white\n  ParticipantFontColor #1F2D3D\n  ActorBorderColor #2F4858\n  ActorBackgroundColor white\n  ActorFontColor #1F2D3D\n}\n\nautonumber 1\n\nactor \&quot;Người dùng\&quot; as User\nboundary \&quot;POI List Screen\&quot; as MainPage\ncontrol \&quot;PlaceCatalogService\&quot; as PlaceCatalogService\ncontrol \&quot;Public Audio API\&quot; as PublicAudioApi\nentity \&quot;SQLite/Local Cache\&quot; as LocalCache\nentity \&quot;Server Database\&quot; as ServerDatabase\n\nUser -&gt; MainPage : Chọn một địa điểm\nactivate MainPage\n\nMainPage -&gt; MainPage : Mở khung chi tiết\\nhiển thị gallery, thông tin và audio hiện có (nếu có)\n\nalt Audio chi tiết đã có sẵn\n    MainPage -&gt; MainPage : Hiển thị danh sách audio khả dụng\n\nelse Cần nạp thêm audio chi tiết\n    MainPage -&gt; PlaceCatalogService : `GetAudioTracksAsync(placeId)`\n    activate PlaceCatalogService\n\n    alt Dùng cache / offline data\n        PlaceCatalogService -&gt; LocalCache : Đọc audio track đã lưu\n        activate LocalCache\n        LocalCache --&gt; PlaceCatalogService : Danh sách audio track\n        deactivate LocalCache\n\n    else Sync từ server và cập nhật cache\n        PlaceCatalogService -&gt; PublicAudioApi : GET public location audio\n        activate PublicAudioApi\n\n        PublicAudioApi -&gt; ServerDatabase : Lấy audio track của địa điểm\n        activate ServerDatabase\n        ServerDatabase --&gt; PublicAudioApi : Danh sách audio track\n        deactivate ServerDatabase\n\n        PublicAudioApi --&gt; PlaceCatalogService : Audio track snapshot\n        deactivate PublicAudioApi\n\n        PlaceCatalogService -&gt; LocalCache : Lưu audio track vào cache\n        activate LocalCache\n        LocalCache --&gt; PlaceCatalogService : Cache updated\n        deactivate LocalCache\n    end\n\n    PlaceCatalogService --&gt; MainPage : Audio track cập nhật\n    deactivate PlaceCatalogService\n\n    MainPage -&gt; MainPage : Cập nhật danh sách audio và trạng thái hiển thị\nend\n\nMainPage --&gt; User : Hiển thị chi tiết địa điểm\ndeactivate MainPage\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="BfgLEszow10ICDQ_8rbH-5">
