                    </mxCell>
                </UserObject>
                <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml AdminQrSequenceVi\ntitle QR cho POI (Admin)\n\nhide footbox\n\nskinparam shadowing false\nskinparam sequence {\n  ArrowColor #2F4858\n  LifeLineBorderColor #2F4858\n  LifeLineBackgroundColor #EAF3F7\n  ParticipantBorderColor #2F4858\n  ParticipantBackgroundColor white\n  ParticipantFontColor #1F2D3D\n  ActorBorderColor #2F4858\n  ActorBackgroundColor white\n  ActorFontColor #1F2D3D\n}\n\nautonumber 1\n\nactor \&quot;Admin\&quot; as Admin\nboundary \&quot;POIList.razor /\\nLocationQrManager\&quot; as QrPage\ncontrol \&quot;AdminApiClient\&quot; as ApiClient\ncontrol \&quot;LocationQrController\&quot; as QrController\ncontrol \&quot;LocationQrService\&quot; as QrService\nentity \&quot;DBContext\&quot; as DBContext\n\nAdmin -&gt; QrPage : Mở chức năng QR của POI\nactivate QrPage\n\nQrPage -&gt; ApiClient : GetLocationQrStatusAsync(locationId)\nactivate ApiClient\n\nApiClient -&gt; QrController : GET LocationQr/location/{id}/status\nactivate QrController\n\nQrController -&gt; DBContext : Kiểm tra quyền và lấy POI được phép thao tác\nactivate DBContext\nDBContext --&gt; QrController : Thông tin POI + audio mặc định\ndeactivate DBContext\n\nQrController -&gt; QrService : BuildStatus(...)\nactivate QrService\nQrService --&gt; QrController : Dữ liệu QR\\n(link landing, link tải app,\\ncấu hình QR mặc định)\ndeactivate QrService\n\nQrController --&gt; ApiClient : LocationQrStatusDto\ndeactivate QrController\nApiClient --&gt; QrPage : Hiển thị thông tin QR\ndeactivate ApiClient\n\nopt In QR cho POI\n    Admin -&gt; QrPage : Chọn in / tải QR\n    QrPage -&gt; ApiClient : GenerateLocationQrAsync(locationId, request)\n    activate ApiClient\n\n    ApiClient -&gt; QrController : POST LocationQr/location/{id}/generate\n    activate QrController\n\n    QrController -&gt; DBContext : Kiểm tra quyền và lấy POI được phép thao tác\n    activate DBContext\n    DBContext --&gt; QrController : Thông tin POI + audio mặc định\n    deactivate DBContext\n\n    QrController -&gt; QrService : GenerateLocationQrFile(...)\n    activate QrService\n    QrService --&gt; QrController : Tệp QR\n    deactivate QrService\n\n    QrController --&gt; ApiClient : QR file\n    deactivate QrController\n    ApiClient --&gt; QrPage : Tải / in file QR\n    deactivate ApiClient\nend\n\ndeactivate QrPage\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="gjlHMqZ_v8curAu2xrZ3-8">
                    <mxCell style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" parent="1" vertex="1">
                        <mxGeometry x="20" y="6590" width="1233" height="703" as="geometry"/>
                    </mxCell>
                </UserObject>
                <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml MobileQrScanSequenceVi\ntitle Quét QR trên mobile\n\nhide footbox\n\nskinparam shadowing false\nskinparam sequence {\n  ArrowColor #2F4858\n  LifeLineBorderColor #2F4858\n  LifeLineBackgroundColor #EAF3F7\n  ParticipantBorderColor #2F4858\n  ParticipantBackgroundColor white\n  ParticipantFontColor #1F2D3D\n  ActorBorderColor #2F4858\n  ActorBackgroundColor white\n  ActorFontColor #1F2D3D\n}\n\nautonumber 1\n\nactor \&quot;Khách tham quan\&quot; as Visitor\nboundary \&quot;Camera / QR Scanner\&quot; as Scanner\nboundary \&quot;Trình duyệt / WebView\&quot; as Browser\ncontrol \&quot;LocationQrController\&quot; as QrController\ncontrol \&quot;LocationQrService\&quot; as QrService\nentity \&quot;DBContext\&quot; as DBContext\n\nVisitor -&gt; Scanner : Quét mã QR\nactivate Scanner\nScanner -&gt; Browser : Mở link công khai\nactivate Browser\ndeactivate Scanner\n\nalt QR mở POI\n    Browser -&gt; QrController : GET LocationQr/public/location/{id}\n    activate QrController\n\n    QrController -&gt; DBContext : Lấy thông tin POI,\\naudio, hình ảnh và trạng thái hoạt động\n    activate DBContext\n    DBContext --&gt; QrController : Dữ liệu POI\n    deactivate DBContext\n\n    QrController -&gt; DBContext : Lưu lượt mở trang QR\n    activate DBContext\n    DBContext --&gt; QrController : Đã ghi nhận lượt truy cập\n    deactivate DBContext\n\n    QrController -&gt; QrService : RenderLocationLandingPage(...)\n    activate QrService\n    QrService --&gt; QrController : Trang landing của POI\n    deactivate QrService\n\n    QrController --&gt; Browser : HTML landing page\n    deactivate QrController\n\n    Browser --&gt; Visitor : Hiển thị trang POI,\\nphát audio tự động nếu được bật\n\nelse QR nếu chưa tải app \n    Browser -&gt; QrController : GET LocationQr/android-apk-qr\n    activate QrController\n\n    QrController -&gt; QrService : GenerateAndroidApkQrFile(...)\n    activate QrService\n    QrService --&gt; QrController : Tệp QR / link tải app\n    deactivate QrService\n\n    QrController --&gt; Browser : Trang / tệp QR tải app\n    deactivate QrController\n\n    Browser --&gt; Visitor : Hiển thị link hoặc mã QR tải ứng dụng\nend\n\ndeactivate Browser\n\n@enduml\n&quot;,&quot;format&quot;:&quot;svg&quot;}" id="gjlHMqZ_v8curAu2xrZ3-10">
