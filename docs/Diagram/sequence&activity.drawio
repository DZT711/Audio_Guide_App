                <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml StatisticsSequenceVi\ntitle 12. Statistics\n\nhide footbox\n\nskinparam shadowing false\nskinparam sequence {\n  ArrowColor #2F4858\n  LifeLineBorderColor #2F4858\n  LifeLineBackgroundColor #EAF3F7\n  ParticipantBorderColor #2F4858\n  ParticipantBackgroundColor white\n  ParticipantFontColor #1F2D3D\n  ActorBorderColor #2F4858\n  ActorBackgroundColor white\n  ActorFontColor #1F2D3D\n}\n\nautonumber 1\n\nboundary \&quot;Statistics.razor\&quot; as Statistics\ncontrol \&quot;AdminApiClient\&quot; as ApiClient\ncontrol \&quot;StatisticsController\&quot; as StatisticsController\nentity \&quot;DBContext\&quot; as DbContext\n\nStatistics -&gt; ApiClient : GetStatisticsAsync(query)\nactivate Statistics\nactivate ApiClient\n\nApiClient -&gt; StatisticsController : GET Statistics?from=...&amp;to=...&amp;tourId=...&amp;ward=...&amp;search=...\nactivate StatisticsController\n\nStatisticsController -&gt; DbContext : Lấy locations, audio, tours, playback, tracking\nactivate DbContext\ndeactivate DbContext\n\nStatisticsController -&gt; DbContext : Tổng hợp biểu đồ, heatmap, top POI, average listening\nactivate DbContext\nDbContext --&gt; StatisticsController : Dữ liệu thống kê tổng quan\ndeactivate DbContext\n\ndeactivate StatisticsController\ndeactivate ApiClient\ndeactivate Statistics\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="WZVrMcKF7iwWqCo2LqL2-12">
