                        <mxGeometry x="190.00042541503905" y="5780.001367797851" width="1162" height="744" as="geometry"/>
                    </mxCell>
                </UserObject>
                <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml InboxSequenceVi\ntitle 9. Hộp thư\n\nhide footbox\n\nskinparam shadowing false\nskinparam sequence {\n  ArrowColor #2F4858\n  LifeLineBorderColor #2F4858\n  LifeLineBackgroundColor #EAF3F7\n  ParticipantBorderColor #2F4858\n  ParticipantBackgroundColor white\n  ParticipantFontColor #1F2D3D\n  ActorBorderColor #2F4858\n  ActorBackgroundColor white\n  ActorFontColor #1F2D3D\n}\n\nautonumber 1\n\nboundary \&quot;Inbox.razor\&quot; as Inbox\ncontrol \&quot;AdminApiClient\&quot; as ApiClient\ncontrol \&quot;InboxController\&quot; as InboxController\ncontrol \&quot;ChangeRequestWorkflowService\&quot; as WorkflowService\n\nInbox -&gt; ApiClient : GetInboxAsync(query)\nactivate Inbox\nactivate ApiClient\n\nApiClient -&gt; InboxController : GET Inbox?page=...&amp;pageSize=...&amp;unreadOnly=...\nactivate InboxController\n\nInboxController -&gt; WorkflowService : Lấy inbox theo user hiện tại\nactivate WorkflowService\nWorkflowService --&gt; InboxController : Dữ liệu tổng quan hộp thư\ndeactivate WorkflowService\n\nInbox -&gt; ApiClient : MarkInboxMessageReadAsync(id)\nApiClient -&gt; InboxController : POST Inbox/{id}/read\n\nInboxController -&gt; WorkflowService : Đánh dấu đã đọc\nactivate WorkflowService\nWorkflowService --&gt; InboxController : Đánh dấu đã đọc thành công\ndeactivate WorkflowService\n\nInbox -&gt; ApiClient : CreateInboxAnnouncementAsync(request)\nApiClient -&gt; InboxController : POST Inbox/announcement\n\nInboxController -&gt; WorkflowService : Gửi thông báo hệ thống tới mọi inbox\nactivate WorkflowService\nWorkflowService --&gt; InboxController : Gửi thông báo thành công\ndeactivate WorkflowService\n\ndeactivate InboxController\ndeactivate ApiClient\ndeactivate Inbox\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="WZVrMcKF7iwWqCo2LqL2-9">
