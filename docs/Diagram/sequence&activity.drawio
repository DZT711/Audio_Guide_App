                <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml MobileOfflineSequenceVi\ntitle 5. Offline Management\n\nhide footbox\n\nskinparam shadowing false\nskinparam sequence {\n  ArrowColor #2F4858\n  LifeLineBorderColor #2F4858\n  LifeLineBackgroundColor #EAF3F7\n  ParticipantBorderColor #2F4858\n  ParticipantBackgroundColor white\n  ParticipantFontColor #1F2D3D\n  ActorBorderColor #2F4858\n  ActorBackgroundColor white\n  ActorFontColor #1F2D3D\n}\n\nautonumber 1\n\nactor \&quot;Người dùng\&quot; as User\nboundary \&quot;Offline Screen\&quot; as OfflinePage\ncontrol \&quot;PlaceCatalogService\&quot; as PlaceCatalogService\ncontrol \&quot;AudioDownloadService\&quot; as AudioDownloadService\ncontrol \&quot;Public Catalog API\&quot; as PublicCatalogApi\nentity \&quot;Local Cache / Downloaded Files\&quot; as LocalStorage\n\nUser -&gt; OfflinePage : Mở màn hình Offline\nactivate OfflinePage\n\nOfflinePage -&gt; PlaceCatalogService : Tải danh sách offline pack\nactivate PlaceCatalogService\n\nalt Dùng dữ liệu đã lưu\n    PlaceCatalogService -&gt; LocalStorage : Đọc catalog và trạng thái đã tải\n    activate LocalStorage\n    LocalStorage --&gt; PlaceCatalogService : Danh sách offline pack\n    deactivate LocalStorage\n\nelse Làm mới dữ liệu\n    PlaceCatalogService -&gt; PublicCatalogApi : Đồng bộ catalog và trạng thái pack\n    activate PublicCatalogApi\n    PublicCatalogApi --&gt; PlaceCatalogService : Dữ liệu offline pack\n    deactivate PublicCatalogApi\n\n    PlaceCatalogService -&gt; LocalStorage : Cập nhật cache\n    activate LocalStorage\n    LocalStorage --&gt; PlaceCatalogService : Cache updated\n    deactivate LocalStorage\nend\n\nPlaceCatalogService --&gt; OfflinePage : Danh sách offline pack\ndeactivate PlaceCatalogService\n\nOfflinePage --&gt; User : Hiển thị danh sách offline pack\n\nalt Tải pack\n    User -&gt; OfflinePage : Chọn tải audio pack\n    OfflinePage -&gt; OfflinePage : Kiểm tra Internet và API mode\n    OfflinePage -&gt; PublicCatalogApi : Lấy audio track có file tải được\n    activate PublicCatalogApi\n    PublicCatalogApi --&gt; OfflinePage : Danh sách audio có thể tải\n    deactivate PublicCatalogApi\n\n    OfflinePage -&gt; AudioDownloadService : Tải audio pack\n    activate AudioDownloadService\n    AudioDownloadService -&gt; LocalStorage : Lưu file audio vào máy\n    activate LocalStorage\n    LocalStorage --&gt; AudioDownloadService : Pack updated\n    deactivate LocalStorage\n    AudioDownloadService --&gt; OfflinePage : Tải pack thành công\n    deactivate AudioDownloadService\n\n    OfflinePage --&gt; User : Cập nhật trạng thái đã tải\nelse Xóa pack\n    User -&gt; OfflinePage : Chọn xóa audio pack\n    OfflinePage -&gt; AudioDownloadService : Xóa audio pack khỏi máy\n    activate AudioDownloadService\n    AudioDownloadService -&gt; LocalStorage : Xóa file audio đã tải\n    activate LocalStorage\n    LocalStorage --&gt; AudioDownloadService : Pack removed\n    deactivate LocalStorage\n    AudioDownloadService --&gt; OfflinePage : Xóa pack thành công\n    deactivate AudioDownloadService\n\n    OfflinePage --&gt; User : Cập nhật trạng thái chưa tải\nend\n\ndeactivate OfflinePage\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="BfgLEszow10ICDQ_8rbH-7">
