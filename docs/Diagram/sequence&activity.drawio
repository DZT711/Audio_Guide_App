                    </mxCell>
                </UserObject>
                <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml ParallelPoiAccessSequenceVi\ntitle Xử lý khi nhiều du khách cùng truy cập POI\n\nhide footbox\n\nskinparam shadowing false\nskinparam sequence {\n  ArrowColor #2F4858\n  LifeLineBorderColor #2F4858\n  LifeLineBackgroundColor #EAF3F7\n  ParticipantBorderColor #2F4858\n  ParticipantBackgroundColor white\n  ParticipantFontColor #1F2D3D\n  ActorBorderColor #2F4858\n  ActorBackgroundColor white\n  ActorFontColor #1F2D3D\n}\n\nautonumber 1\n\nactor \&quot;Du khách\&quot; as Visitor\nboundary \&quot;Ứng dụng mobile\&quot; as MobileApp\ncontrol \&quot;ApiService\&quot; as ApiService\ncontrol \&quot;LocationController / AudioController\&quot; as ApiController\nentity \&quot;DB / File metadata\&quot; as DataStore\n\nVisitor -&gt; MobileApp : Chọn POI / nghe audio\nactivate MobileApp\n\nalt Một người dùng\n    MobileApp -&gt; ApiService : Gửi yêu cầu lấy dữ liệu POI/audio\n    activate ApiService\n    ApiService -&gt; ApiController : GET dữ liệu công khai\n    activate ApiController\n    ApiController -&gt; DataStore : Đọc dữ liệu POI/audio\n    activate DataStore\n    DataStore --&gt; ApiController : Dữ liệu tương ứng\n    deactivate DataStore\n    ApiController --&gt; ApiService : Kết quả\n    deactivate ApiController\n    ApiService --&gt; MobileApp : Dữ liệu POI/audio\n    deactivate ApiService\n    MobileApp --&gt; Visitor : Hiển thị / phát nội dung\n\nelse Nhiều người dùng đồng thời\n    MobileApp -&gt; ApiService : Gửi yêu cầu lấy dữ liệu POI/audio\n    activate ApiService\n    ApiService -&gt; ApiController : GET dữ liệu công khai\n    activate ApiController\n    ApiController -&gt; DataStore : Đọc dữ liệu POI/audio\n    activate DataStore\n    DataStore --&gt; ApiController : Dữ liệu tương ứng\n    deactivate DataStore\n    ApiController --&gt; ApiService : Kết quả\n    deactivate ApiController\n    ApiService --&gt; MobileApp : Dữ liệu POI/audio\n    deactivate ApiService\n    MobileApp --&gt; Visitor : Hiển thị / phát nội dung\n\n    note over ApiController,DataStore\n    Các yêu cầu tương tự từ nhiều thiết bị khác\n    được xử lý song song và độc lập.\n    Hệ thống chưa dùng hàng chờ điều phối chung phía server.\n    end note\nend\n\ndeactivate MobileApp\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="gjlHMqZ_v8curAu2xrZ3-3">
