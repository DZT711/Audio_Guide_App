                <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml MobileHistorySequenceVi\ntitle 6. View History\n\nhide footbox\n\nskinparam shadowing false\nskinparam sequence {\n  ArrowColor #2F4858\n  LifeLineBorderColor #2F4858\n  LifeLineBackgroundColor #EAF3F7\n  ParticipantBorderColor #2F4858\n  ParticipantBackgroundColor white\n  ParticipantFontColor #1F2D3D\n  ActorBorderColor #2F4858\n  ActorBackgroundColor white\n  ActorFontColor #1F2D3D\n}\n\nautonumber 1\n\nactor \&quot;Người dùng\&quot; as User\nboundary \&quot;History Screen\&quot; as HistoryPage\ncontrol \&quot;HistoryService\&quot; as HistoryService\nentity \&quot;SQLite/Playback History\&quot; as LocalHistory\n\nUser -&gt; HistoryPage : Mở màn hình History\nactivate HistoryPage\n\nHistoryPage -&gt; HistoryService : `InitializeAsync()`\nactivate HistoryService\n\nHistoryService -&gt; LocalHistory : Tải lịch sử đã lưu\nactivate LocalHistory\nLocalHistory --&gt; HistoryService : Danh sách lịch sử nghe\ndeactivate LocalHistory\n\nHistoryService --&gt; HistoryPage : History items\ndeactivate HistoryService\n\nHistoryPage -&gt; HistoryPage : Tính tổng số địa điểm\\nvà thời lượng lịch sử\nHistoryPage --&gt; User : Hiển thị danh sách lịch sử\n\nalt Xem chi tiết mục lịch sử\n    User -&gt; HistoryPage : Chọn một mục lịch sử\n    HistoryPage -&gt; HistoryPage : Mở khung chi tiết\\nhiển thị thông tin và audio track\n\n    alt Có audio track đã lưu\n        HistoryPage -&gt; HistoryPage : Hiển thị danh sách audio đã nghe\n    else Chưa có audio track chi tiết\n        HistoryPage -&gt; HistoryPage : Dựng danh sách audio mẫu để hiển thị\n    end\n\n    HistoryPage --&gt; User : Hiển thị chi tiết lịch sử\n\nelse Xóa một mục lịch sử\n    User -&gt; HistoryPage : Chọn xóa một mục\n    HistoryPage -&gt; HistoryService : `RemoveFromHistory(item)`\n    activate HistoryService\n    HistoryService -&gt;&gt; LocalHistory : Xóa mục lịch sử (async)\n    deactivate HistoryService\n    HistoryPage --&gt; User : Cập nhật danh sách lịch sử\n\nelse Xóa toàn bộ lịch sử\n    User -&gt; HistoryPage : Chọn xóa toàn bộ lịch sử\n    HistoryPage -&gt; HistoryPage : Hiển thị xác nhận xóa\n\n    alt Đồng ý xóa\n        HistoryPage -&gt; HistoryService : `ClearHistory()`\n        activate HistoryService\n        HistoryService -&gt;&gt; LocalHistory : Xóa toàn bộ lịch sử (async)\n        deactivate HistoryService\n        HistoryPage --&gt; User : Cập nhật danh sách rỗng\n    else Hủy\n        HistoryPage --&gt; User : Giữ nguyên danh sách lịch sử\n    end\nend\n\ndeactivate HistoryPage\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="BfgLEszow10ICDQ_8rbH-8">
