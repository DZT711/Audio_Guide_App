<mxfile host="app.diagrams.net">
  <diagram name="Trang-1" id="SLe2oRT_l7HSzYHhVhJu">
    <mxGraphModel dx="1653" dy="785" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml MobileGeofenceTieBreakSequenceVi\ntitle Xử lý khoảng cách bằng nhau giữa 2 POI gần nhau\n\nhide footbox\n\nskinparam shadowing false\nskinparam sequence {\n  ArrowColor #2F4858\n  LifeLineBorderColor #2F4858\n  LifeLineBackgroundColor #EAF3F7\n  ParticipantBorderColor #2F4858\n  ParticipantBackgroundColor white\n  ParticipantFontColor #1F2D3D\n  ActorBorderColor #2F4858\n  ActorBackgroundColor white\n  ActorFontColor #1F2D3D\n}\n\nautonumber 1\n\nactor \&quot;Người dùng\&quot; as User\ncontrol \&quot;LocationTrackingService\&quot; as TrackingService\ncontrol \&quot;GeofenceOrchestratorService\&quot; as Orchestrator\ncontrol \&quot;GeofenceEvaluationEngine\&quot; as EvaluationEngine\nentity \&quot;Geofence Definitions / Spatial Index\&quot; as Definitions\ncontrol \&quot;GeofenceTriggerSelector\&quot; as TriggerSelector\n\nUser -&gt; TrackingService : Di chuyển vào vùng gần nhiều POI\nactivate TrackingService\n\nTrackingService -&gt; Orchestrator : Gửi vị trí hiện tại\\n(OnTrackedLocationUpdated(...))\nactivate Orchestrator\n\nOrchestrator -&gt; Orchestrator : Đưa location vào hàng đợi\\n(EnqueueLocation(...))\nOrchestrator -&gt; Orchestrator : Lấy sample mới nhất để xử lý\\n(ProcessingLoopAsync(...))\nOrchestrator -&gt; Orchestrator : Xử lý geofence chính\\n(ProcessLocationSampleAsync(...))\n\nOrchestrator -&gt; EvaluationEngine : Đánh giá geofence triggers\\n(Evaluate(...))\nactivate EvaluationEngine\n\nEvaluationEngine -&gt; Definitions : Lấy các POI ứng viên gần vị trí hiện tại\\n(GetCandidateDefinitions(...))\nactivate Definitions\nDefinitions --&gt; EvaluationEngine : Danh sách POI gần nhau\ndeactivate Definitions\n\nEvaluationEngine -&gt; EvaluationEngine : Kiểm tra trigger từng POI\\n(EvaluateTrigger(...))\nEvaluationEngine --&gt; Orchestrator : Trả về AcceptedTriggers / SkippedTriggers\\n(Evaluate(...))\ndeactivate EvaluationEngine\n\nOrchestrator -&gt; Orchestrator : Lọc trigger được phép dùng\\n(ShouldAllowTrigger(...))\n\nOrchestrator -&gt; TriggerSelector : Chọn trigger tốt nhất\\n(SelectBest(...))\nactivate TriggerSelector\n\nTriggerSelector -&gt; TriggerSelector : So sánh theo Priority\\n(Definition.Priority)\n\nalt Priority khác nhau\n    TriggerSelector -&gt; TriggerSelector : Chọn POI có Priority cao hơn\nelse Priority bằng nhau\n    TriggerSelector -&gt; TriggerSelector : So sánh DistanceMeters\n\n    alt Khoảng cách khác nhau\n        TriggerSelector -&gt; TriggerSelector : Chọn POI có DistanceMeters nhỏ hơn\n    else Khoảng cách bằng nhau\n        TriggerSelector -&gt; TriggerSelector : So sánh loại sự kiện\\n(EventType)\n\n        alt EnteredRadius và NearStay\n            TriggerSelector -&gt; TriggerSelector : Ưu tiên EnteredRadius\n        else Cùng loại sự kiện\n            TriggerSelector -&gt; TriggerSelector : So sánh Id\\n(StringComparer.OrdinalIgnoreCase)\n            TriggerSelector -&gt; TriggerSelector : Chọn POI theo thứ tự alphabet\n        end\n    end\nend\n\nTriggerSelector --&gt; Orchestrator : selectedTrigger\\n(SelectBest(...))\ndeactivate TriggerSelector\n\nOrchestrator -&gt; Orchestrator : Ghi nhận trigger được chọn\\n(RaiseTriggerAccepted(...))\nOrchestrator -&gt; Orchestrator : Xử lý nghiệp vụ tiếp theo\\n(HandleTriggerAsync(...))\n\nOrchestrator --&gt; TrackingService : Hoàn tất chọn POI ưu tiên\ndeactivate Orchestrator\n\nTrackingService --&gt; User : Tiếp tục xử lý POI được ưu tiên\ndeactivate TrackingService\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="2ALPifY47V_Ws6IIi7WP-2">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1389" width="1670" x="20" y="20" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml MobileGeofenceTieBreakSequenceVi\ntitle Xử lý khoảng cách bằng nhau giữa 2 POI gần nhau\n\nhide footbox\n\nskinparam shadowing false\nskinparam sequence {\n  ArrowColor #2F4858\n  LifeLineBorderColor #2F4858\n  LifeLineBackgroundColor #EAF3F7\n  ParticipantBorderColor #2F4858\n  ParticipantBackgroundColor white\n  ParticipantFontColor #1F2D3D\n  ActorBorderColor #2F4858\n  ActorBackgroundColor white\n  ActorFontColor #1F2D3D\n}\n\nautonumber 1\n\nactor \&quot;Người dùng\&quot; as User\ncontrol \&quot;LocationTrackingService\&quot; as TrackingService\ncontrol \&quot;GeofenceOrchestratorService\&quot; as Orchestrator\ncontrol \&quot;GeofenceEvaluationEngine\&quot; as EvaluationEngine\nentity \&quot;Geofence Definitions\&quot; as Definitions\n\nUser -&gt; TrackingService : Di chuyển vào vùng gần nhiều POI\nactivate TrackingService\n\nTrackingService -&gt; Orchestrator : Gửi vị trí hiện tại\\n(OnTrackedLocationUpdated)\nactivate Orchestrator\n\nOrchestrator -&gt; EvaluationEngine : Đánh giá geofence triggers\\n(ProcessLocationSampleAsync -&gt; Evaluate)\nactivate EvaluationEngine\n\nEvaluationEngine -&gt; Definitions : Lấy các POI ứng viên gần vị trí hiện tại\\n(GetCandidateDefinitions)\nactivate Definitions\nDefinitions --&gt; EvaluationEngine : Danh sách POI gần nhau\\n(GetCandidateDefinitions)\ndeactivate Definitions\n\nEvaluationEngine -&gt; EvaluationEngine : So sánh theo Priority\\n(GeofenceTriggerSelector.SelectBest)\n\nalt Priority khác nhau\n    EvaluationEngine -&gt; EvaluationEngine : Chọn POI có Priority cao hơn\\n(GeofenceTriggerSelector.SelectBest)\nelse Priority bằng nhau\n    EvaluationEngine -&gt; EvaluationEngine : So sánh DistanceMeters\\n(GeofenceTriggerSelector.SelectBest)\n\n    alt Khoảng cách khác nhau\n        EvaluationEngine -&gt; EvaluationEngine : Chọn POI có DistanceMeters nhỏ hơn\\n(GeofenceTriggerSelector.SelectBest)\n    else Khoảng cách bằng nhau\n        EvaluationEngine -&gt; EvaluationEngine : So sánh loại sự kiện\\n(GeofenceTriggerSelector.SelectBest)\n\n        alt EnteredRadius và NearStay\n            EvaluationEngine -&gt; EvaluationEngine : Ưu tiên EnteredRadius\\n(GeofenceTriggerSelector.SelectBest)\n        else Cùng loại sự kiện\n            EvaluationEngine -&gt; EvaluationEngine : So sánh Id\\n(không phân biệt hoa thường)\\n(GeofenceTriggerSelector.SelectBest)\n            EvaluationEngine -&gt; EvaluationEngine : Chọn POI theo thứ tự alphabet\\n(GeofenceTriggerSelector.SelectBest)\n        end\n    end\nend\n\nEvaluationEngine --&gt; Orchestrator : POI thắng cuối cùng\\n(GeofenceTriggerSelector.SelectBest)\ndeactivate EvaluationEngine\n\nOrchestrator --&gt; TrackingService : Trả kết quả POI được chọn\\n(RaiseTriggerAccepted -&gt; HandleTriggerAsync)\ndeactivate Orchestrator\n\nTrackingService --&gt; User : Tiếp tục xử lý POI được ưu tiên\\n(HandleTriggerAsync)\ndeactivate TrackingService\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="2ALPifY47V_Ws6IIi7WP-3">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1047" width="1300" x="30" y="1430" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
