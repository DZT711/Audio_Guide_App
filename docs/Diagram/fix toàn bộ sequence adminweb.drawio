  <diagram id="BrDOnMlOuoT64vDeIycq" name="user management">
    <mxGraphModel dx="1113" dy="619" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml UserManagementSequenceVi\ntitle 8. Nguoi dung dashboard\n\nhide footbox\n\nskinparam shadowing false\nskinparam sequence {\n  ArrowColor #2F4858\n  LifeLineBorderColor #2F4858\n  LifeLineBackgroundColor #EAF3F7\n  ParticipantBorderColor #2F4858\n  ParticipantBackgroundColor white\n  ParticipantFontColor #1F2D3D\n  ActorBorderColor #2F4858\n  ActorBackgroundColor white\n  ActorFontColor #1F2D3D\n}\n\nautonumber 1\n\nactor \&quot;Admin\&quot; as Admin\nboundary \&quot;UserList.razor\&quot; as UserPage\ncontrol \&quot;AdminApiClient\&quot; as ApiClient\ncontrol \&quot;DashboardUserController\&quot; as UserController\nentity \&quot;DBContext\&quot; as DBContext\n\nAdmin -&gt; UserPage : Mo trang User Management\\n(OnInitializedAsync())\nactivate UserPage\n\nUserPage -&gt; UserPage : Tai du lieu user\\n(LoadUsersAsync())\n\nUserPage -&gt; ApiClient : Gui yeu cau lay danh sach user\\n(GetUsersAsync())\nactivate ApiClient\n\nApiClient -&gt; UserController : Goi API lay user\\n(GET /DashboardUser)\nactivate UserController\n\nUserController -&gt; DBContext : Lay danh sach user va so POI/audio so huu\\n(GetUsers())\nactivate DBContext\nDBContext --&gt; UserController : Danh sach nguoi dung\ndeactivate DBContext\n\nUserController --&gt; ApiClient : Tra ve du lieu user\ndeactivate UserController\n\nApiClient --&gt; UserPage : Tra danh sach user cho giao dien\ndeactivate ApiClient\n\nUserPage -&gt; UserPage : Cap nhat Total Users\\n(Summaries)\nUserPage -&gt; UserPage : Cap nhat Active\\n(Summaries)\nUserPage -&gt; UserPage : Cap nhat Owners\\n(Summaries)\nUserPage -&gt; UserPage : Cap nhat Locked\\n(Summaries)\n\nopt Tim kiem va loc user\n    Admin -&gt; UserPage : Nhap tim kiem / chon All Users,\\nAdmins, Owners, Inactive\\n(@bind _searchText / SetRoleFilter())\n    UserPage -&gt; UserPage : Loc danh sach user tai client\\n(VisibleUsers)\nend\n\nopt Phan trang danh sach\n    Admin -&gt; UserPage : Chuyen trang truoc / sau\n    UserPage -&gt; UserPage : Cap nhat trang hien tai\\n(PreviousUserPage() / NextUserPage())\nend\n\nopt Tao moi user\n    Admin -&gt; UserPage : Mo form tao moi\\n(StartCreate())\n    Admin -&gt; UserPage : Bam Save tao user\\n(SaveUserAsync())\n    UserPage -&gt; ApiClient : Gui yeu cau tao user\\n(CreateUserAsync())\n    activate ApiClient\n\n    ApiClient -&gt; UserController : Goi API tao user\\n(POST /DashboardUser)\n    activate UserController\n\n    UserController -&gt; DBContext : Kiem tra role, username,\\nemail, phone va luu user moi\\n(CreateUser())\n    activate DBContext\n    DBContext --&gt; UserController : Tao moi thanh cong\n    deactivate DBContext\n\n    UserController --&gt; ApiClient : Tra ket qua tao moi\n    deactivate UserController\n    ApiClient --&gt; UserPage : Hoan tat tao user\n    deactivate ApiClient\n\n    UserPage -&gt; UserPage : Cap nhat giao dien sau tao moi\\n(LoadUsersAsync() / ResetForm())\nend\n\nopt Moi user bang email\n    Admin -&gt; UserPage : Mo form moi user\\n(StartInvite())\n    Admin -&gt; UserPage : Bam tao invitation\\n(SaveUserAsync())\n    UserPage -&gt; ApiClient : Gui yeu cau moi user\\n(InviteUserAsync())\n    activate ApiClient\n\n    ApiClient -&gt; UserController : Goi API moi user\\n(POST /DashboardUser/invite)\n    activate UserController\n\n    UserController -&gt; DBContext : Sinh username neu can,\\ntao mat khau tam va luu user status = 0\\n(InviteUser())\n    activate DBContext\n    DBContext --&gt; UserController : Ket qua moi user\n    deactivate DBContext\n\n    UserController --&gt; ApiClient : Tra ket qua moi user\n    deactivate UserController\n    ApiClient --&gt; UserPage : Hoan tat moi user\n    deactivate ApiClient\n\n    UserPage -&gt; UserPage : Mo email draft va cap nhat giao dien\\n(JS composeInvite / LoadUsersAsync())\nend\n\nopt Chinh sua user\n    Admin -&gt; UserPage : Mo form chinh sua\\n(StartEdit())\n    Admin -&gt; UserPage : Bam Save chinh sua\\n(SaveUserAsync())\n    UserPage -&gt; ApiClient : Gui yeu cau cap nhat user\\n(UpdateUserAsync())\n    activate ApiClient\n\n    ApiClient -&gt; UserController : Goi API cap nhat user\\n(PUT /DashboardUser/{id})\n    activate UserController\n\n    UserController -&gt; DBContext : Tim user, kiem tra trung,\\ncap nhat va hash mat khau neu co\\n(UpdateUser())\n    activate DBContext\n    DBContext --&gt; UserController : Cap nhat thanh cong\n    deactivate DBContext\n\n    UserController --&gt; ApiClient : Tra ket qua cap nhat\n    deactivate UserController\n    ApiClient --&gt; UserPage : Hoan tat cap nhat user\n    deactivate ApiClient\n\n    UserPage -&gt; UserPage : Cap nhat giao dien sau chinh sua\\n(LoadUsersAsync())\nend\n\nopt Khoa / mo khoa hoac archive user\n    Admin -&gt; UserPage : Chon doi trang thai user\\n(PromptUserStatusChange() / ConfirmPendingStatusAsync())\n    UserPage -&gt; ApiClient : Gui yeu cau cap nhat trang thai\\n(UpdateUserAsync() / DeleteUserAsync())\n    activate ApiClient\n\n    ApiClient -&gt; UserController : Goi API cap nhat hoac archive user\\n(PUT /DashboardUser/{id} / DELETE /DashboardUser/{id})\n    activate UserController\n\n    UserController -&gt; DBContext : Dat Status phu hop va luu thay doi\\n(UpdateUser() / ArchiveUser())\n    activate DBContext\n    DBContext --&gt; UserController : Cap nhat thanh cong\n    deactivate DBContext\n\n    UserController --&gt; ApiClient : Tra ket qua thay doi trang thai\n    deactivate UserController\n    ApiClient --&gt; UserPage : Hoan tat thay doi trang thai\n    deactivate ApiClient\n\n    UserPage -&gt; UserPage : Cap nhat giao dien sau thay doi\\n(LoadUsersAsync())\nend\n\nUserPage --&gt; Admin : Hien thi summary, bo loc,\\ndanh sach user va form quan ly\ndeactivate UserPage\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="7PQBL1RsRIKw3FN54aQD-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="2473" width="1503" x="20" y="10" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="fboz5I4Cll_qqPTvmU5z" name="Moderations">
    <mxGraphModel dx="1271" dy="707" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml ModerationSequenceVi\ntitle 10. Moderation / Change request\n\nhide footbox\n\nskinparam shadowing false\nskinparam sequence {\n  ArrowColor #2F4858\n  LifeLineBorderColor #2F4858\n  LifeLineBackgroundColor #EAF3F7\n  ParticipantBorderColor #2F4858\n  ParticipantBackgroundColor white\n  ParticipantFontColor #1F2D3D\n  ActorBorderColor #2F4858\n  ActorBackgroundColor white\n  ActorFontColor #1F2D3D\n}\n\nautonumber 1\n\nactor \&quot;Admin\&quot; as Admin\nboundary \&quot;ModerationList.razor\&quot; as ModerationPage\ncontrol \&quot;AdminApiClient\&quot; as ApiClient\ncontrol \&quot;ChangeRequestController\&quot; as ChangeRequestController\ncontrol \&quot;ChangeRequestWorkflowService\&quot; as WorkflowService\nentity \&quot;DBContext\&quot; as DBContext\n\nAdmin -&gt; ModerationPage : Mo trang Moderation / nhan Refresh\\n(OnInitializedAsync() / RefreshAsync())\nactivate ModerationPage\n\nModerationPage -&gt; ModerationPage : Tai du lieu moderation queue\\n(LoadItemsAsync())\n\nModerationPage -&gt; ApiClient : Gui yeu cau lay change request\\n(GetChangeRequestsAsync())\nactivate ApiClient\n\nApiClient -&gt; ChangeRequestController : Goi API lay change request\\n(GET /ChangeRequest)\nactivate ChangeRequestController\n\nChangeRequestController -&gt; WorkflowService : Lay danh sach yeu cau theo bo loc\\n(GetRequestsAsync())\nactivate WorkflowService\n\nWorkflowService -&gt; DBContext : Lay change request, du lieu live\\nva phan trang ket qua\nactivate DBContext\nDBContext --&gt; WorkflowService : Danh sach yeu cau thay doi\ndeactivate DBContext\n\nWorkflowService --&gt; ChangeRequestController : Tra ve moderation result\\n(ChangeRequestListDto)\ndeactivate WorkflowService\n\nChangeRequestController --&gt; ApiClient : Tra ve du lieu moderation\ndeactivate ChangeRequestController\n\nApiClient --&gt; ModerationPage : Tra danh sach moderation cho giao dien\ndeactivate ApiClient\n\nModerationPage -&gt; ModerationPage : Cap nhat Matching Requests\\n(_result.TotalCount)\nModerationPage -&gt; ModerationPage : Cap nhat POI Requests\\n(_items.Count(item =&gt; item.Type == \&quot;POI\&quot;))\nModerationPage -&gt; ModerationPage : Cap nhat Audio Requests\\n(_items.Count(item =&gt; item.Type == \&quot;Audio\&quot;))\nModerationPage -&gt; ModerationPage : Cap nhat Pending Queue\\n(_statusFilter == \&quot;Pending\&quot; ? _result.TotalCount : _items.Count(item =&gt; item.Status == \&quot;Pending\&quot;))\n\nopt Tim kiem va loc moderation\n    Admin -&gt; ModerationPage : Nhap tim kiem / chon type /\\nchon action / chon status\\n(@bind _searchText / @bind _typeFilter /\\n@bind _actionFilter / @bind _statusFilter)\n    ModerationPage -&gt; ModerationPage : Dat lai trang va tai lai du lieu\\n(HandleFiltersChangedAsync() / LoadItemsAsync())\nend\n\nopt Phan trang moderation\n    Admin -&gt; ModerationPage : Chuyen trang truoc / sau\n    ModerationPage -&gt; ModerationPage : Cap nhat trang hien tai va tai lai du lieu\\n(PreviousPageAsync() / NextPageAsync() / LoadItemsAsync())\nend\n\nopt Xem chi tiet request\n    Admin -&gt; ModerationPage : Mo chi tiet request\\n(OpenDetailModal())\n    ModerationPage -&gt; ModerationPage : Hien thi pending payload,\\nlive data va reviewer note\\n(ResolveSelectedItem() / GetChangedFields() / GetChangeSummaryRows())\nend\n\nopt Phe duyet request\n    Admin -&gt; ModerationPage : Nhan Approve\\n(ApproveAsync())\n    ModerationPage -&gt; ApiClient : Gui yeu cau phe duyet\\n(ApproveChangeRequestAsync())\n    activate ApiClient\n\n    ApiClient -&gt; ChangeRequestController : Goi API phe duyet\\n(POST /ChangeRequest/{id}/approve)\n    activate ChangeRequestController\n\n    ChangeRequestController -&gt; WorkflowService : Phe duyet yeu cau\\n(ApproveAsync())\n    activate WorkflowService\n\n    WorkflowService -&gt; DBContext : Ap dung thay doi vao du lieu live,\\ncap nhat request va tao thong bao\n    activate DBContext\n    DBContext --&gt; WorkflowService : Ket qua sau khi phe duyet\n    deactivate DBContext\n\n    WorkflowService --&gt; ChangeRequestController : Tra ve request da phe duyet\n    deactivate WorkflowService\n    ChangeRequestController --&gt; ApiClient : Tra ket qua phe duyet\n    deactivate ChangeRequestController\n    ApiClient --&gt; ModerationPage : Hoan tat phe duyet\n    deactivate ApiClient\n\n    ModerationPage -&gt; ModerationPage : Cap nhat giao dien sau phe duyet\\n(LoadItemsAsync())\nend\n\nopt Tu choi request\n    Admin -&gt; ModerationPage : Nhan Reject\\n(RejectAsync())\n    ModerationPage -&gt; ApiClient : Gui yeu cau tu choi\\n(RejectChangeRequestAsync())\n    activate ApiClient\n\n    ApiClient -&gt; ChangeRequestController : Goi API tu choi\\n(POST /ChangeRequest/{id}/reject)\n    activate ChangeRequestController\n\n    ChangeRequestController -&gt; WorkflowService : Tu choi yeu cau\\n(RejectAsync())\n    activate WorkflowService\n\n    WorkflowService -&gt; DBContext : Cap nhat trang thai request,\\nluu admin note va tao thong bao\n    activate DBContext\n    DBContext --&gt; WorkflowService : Ket qua sau khi tu choi\n    deactivate DBContext\n\n    WorkflowService --&gt; ChangeRequestController : Tra ve request da tu choi\n    deactivate WorkflowService\n    ChangeRequestController --&gt; ApiClient : Tra ket qua tu choi\n    deactivate ChangeRequestController\n    ApiClient --&gt; ModerationPage : Hoan tat tu choi\n    deactivate ApiClient\n\n    ModerationPage -&gt; ModerationPage : Cap nhat giao dien sau tu choi\\n(LoadItemsAsync())\nend\n\nModerationPage --&gt; Admin : Hien thi moderation queue,\\nbo loc, chi tiet request va thao tac review\ndeactivate ModerationPage\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="GZM-amBMO5W021oybNdg-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="2012" width="1892" x="20" y="20" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
