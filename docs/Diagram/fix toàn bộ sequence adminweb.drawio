        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml StatisticsSequenceVi\ntitle Statistics\n\nhide footbox\n\nskinparam shadowing false\nskinparam sequence {\n  ArrowColor #2F4858\n  LifeLineBorderColor #2F4858\n  LifeLineBackgroundColor #EAF3F7\n  ParticipantBorderColor #2F4858\n  ParticipantBackgroundColor white\n  ParticipantFontColor #1F2D3D\n  ActorBorderColor #2F4858\n  ActorBackgroundColor white\n  ActorFontColor #1F2D3D\n}\n\nautonumber 1\n\nactor \&quot;Admin\&quot; as Admin\nboundary \&quot;Statistics.razor\&quot; as StatisticsPage\ncontrol \&quot;AdminApiClient\&quot; as ApiClient\ncontrol \&quot;StatisticsController\&quot; as StatisticsController\nentity \&quot;DBContext\&quot; as DBContext\nparticipant \&quot;admin-ui.js\&quot; as AdminUiJs\n\nAdmin -&gt; StatisticsPage : Mo trang Statistics\\n(OnInitializedAsync())\nactivate StatisticsPage\n\nStatisticsPage -&gt; StatisticsPage : Tai du lieu thong ke\\n(LoadAsync())\n\nStatisticsPage -&gt; ApiClient : Gui yeu cau lay du lieu thong ke tong hop\\n(GetStatisticsAsync())\nactivate ApiClient\n\nApiClient -&gt; StatisticsController : Goi API thong ke theo bo loc\\n(GET /Statistics)\nactivate StatisticsController\n\nStatisticsController -&gt; StatisticsController : Tong hop du lieu thong ke overview\\n(BuildStatisticsOverviewAsync())\n\nStatisticsController -&gt; DBContext : Lay playback events theo bo loc\\n(BuildPlaybackQuery())\nactivate DBContext\nDBContext --&gt; StatisticsController : Du lieu playback\ndeactivate DBContext\n\nStatisticsController -&gt; DBContext : Lay tracking events theo bo loc\\n(BuildTrackingQuery())\nactivate DBContext\nDBContext --&gt; StatisticsController : Du lieu tracking\ndeactivate DBContext\n\nStatisticsController -&gt; DBContext : Lay heatmap events theo bo loc\\n(BuildHeatmapQuery())\nactivate DBContext\nDBContext --&gt; StatisticsController : Du lieu heatmap\ndeactivate DBContext\n\nStatisticsController -&gt; StatisticsController : Tinh so Playback Events\\n(BuildStatisticsOverviewAsync())\nStatisticsController -&gt; StatisticsController : Tinh so Anonymous Guests\\n(BuildStatisticsOverviewAsync())\nStatisticsController -&gt; StatisticsController : Tinh so Visible POIs\\n(BuildStatisticsOverviewAsync())\n\nStatisticsController -&gt; StatisticsController : Dung Playback Timeline\\n(BuildPlaybackTimeline())\nStatisticsController -&gt; StatisticsController : Dung Plays By Ward\\n(BuildPlaysByWard())\nStatisticsController -&gt; StatisticsController : Dung Plays By Tour\\n(BuildPlaysByTour())\nStatisticsController -&gt; StatisticsController : Dung heatmap points\\n(BuildHeatmapPoints())\nStatisticsController -&gt; StatisticsController : Dung route history\\n(BuildRouteHistory())\nStatisticsController -&gt; StatisticsController : Dung bang Average Listening By POI\\n(BuildAverageListeningReport())\n\nStatisticsController --&gt; ApiClient : Tra ve du lieu thong ke tong hop\\n(StatisticsOverviewDto)\ndeactivate StatisticsController\n\nApiClient --&gt; StatisticsPage : Tra du lieu statistics cho giao dien\ndeactivate ApiClient\n\nStatisticsPage -&gt; StatisticsPage : Cap nhat card thong ke, chart,\\nroute history, heatmap va bang bao cao\\n(LoadAsync())\nStatisticsPage -&gt; StatisticsPage : Tao state ban do thong ke\\n(CreateStatisticsMapState())\n\nStatisticsPage -&gt; AdminUiJs : Khoi tao / dong bo ban do thong ke\\n(initializeStatisticsMap() / syncStatisticsMap())\nactivate AdminUiJs\nAdminUiJs --&gt; StatisticsPage : Render heatmap, route va POI tren ban do\ndeactivate AdminUiJs\n\nopt Doi ngay From / To\n    Admin -&gt; StatisticsPage : Thay doi ngay loc\\n(HandleDateFilterChangedAsync())\n    StatisticsPage -&gt; StatisticsPage : Kiem tra va ap dung ngay loc\\n(TryApplyDateFilterText())\nend\n\nopt Chon Tour / Ward\n    Admin -&gt; StatisticsPage : Chon Tour\\n(@bind _selectedTourValue)\n    Admin -&gt; StatisticsPage : Chon Ward\\n(@bind _selectedWard)\n    StatisticsPage -&gt; StatisticsPage : Ap dung bo loc Tour / Ward da chon\\n(LoadAsync() / GetStatisticsAsync())\nend\n\nopt Lam moi du lieu\n    Admin -&gt; StatisticsPage : Nhan Refresh\\n(RefreshAsync())\n    StatisticsPage -&gt; StatisticsPage : Tai lai du lieu thong ke\\n(LoadAsync())\nend\n\nopt Dat lai bo loc\n    Admin -&gt; StatisticsPage : Nhan Reset\\n(ResetFiltersAsync())\n    StatisticsPage -&gt; StatisticsPage : Khoi phuc bo loc mac dinh va tai lai du lieu\\n(LoadAsync())\nend\n\nopt Tuong tac route history\n    Admin -&gt; StatisticsPage : Chon route trong danh sach\\n(SelectRoute())\n    StatisticsPage -&gt; StatisticsPage : Dam bao route duoc hien trong trang hien tai\\n(EnsureSelectedRouteVisibleOnCurrentPage())\nend\n\nopt Phan trang route history\n    Admin -&gt; StatisticsPage : Chuyen trang truoc / sau\n    StatisticsPage -&gt; StatisticsPage : Cap nhat trang route\\n(PreviousRoutePage() / NextRoutePage())\nend\n\nopt Mo rong va dieu khien heatmap\n    Admin -&gt; StatisticsPage : Mo rong / thu gon heatmap\\n(ToggleHeatmapExpandedAsync())\n    Admin -&gt; StatisticsPage : Dua ban do ve trung tam\\n(CenterStatisticsMapAsync())\n    Admin -&gt; StatisticsPage : Bat / tat theo doi vi tri hien tai\\n(ToggleCurrentLocationTrackingAsync())\nend\n\nopt Tim kiem dia diem tren heatmap\n    Admin -&gt; StatisticsPage : Nhap tu khoa tim kiem tren ban do\\n(@bind _mapSearchText)\n    Admin -&gt; StatisticsPage : Nhan Find place\\n(SearchMapAsync())\n    StatisticsPage -&gt; StatisticsPage : Chon ket qua tim kiem\\n(SelectMapSearchResultAsync())\nend\n\nStatisticsPage --&gt; Admin : Hien thi Statistics voi Playback Events,\\nAnonymous Guests, Visible POIs,\\nHeatmap, Route History, cac chart va bao cao\ndeactivate StatisticsPage\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="tpvhFaQZulDXkQwg5Qx8-2">
