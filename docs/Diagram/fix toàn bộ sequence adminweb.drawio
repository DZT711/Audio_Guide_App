        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml LocationsSequenceVi\ntitle 5. Dia diem / POI\n\nhide footbox\n\nskinparam shadowing false\nskinparam sequence {\n  ArrowColor #2F4858\n  LifeLineBorderColor #2F4858\n  LifeLineBackgroundColor #EAF3F7\n  ParticipantBorderColor #2F4858\n  ParticipantBackgroundColor white\n  ParticipantFontColor #1F2D3D\n  ActorBorderColor #2F4858\n  ActorBackgroundColor white\n  ActorFontColor #1F2D3D\n}\n\nautonumber 1\n\nactor \&quot;Admin\&quot; as Admin\nboundary \&quot;POIList.razor\&quot; as PoiPage\ncontrol \&quot;AdminApiClient\&quot; as ApiClient\ncontrol \&quot;LocationController\&quot; as LocationController\ncontrol \&quot;LocationQrController\&quot; as LocationQrController\nentity \&quot;DBContext\&quot; as DBContext\n\nAdmin -&gt; PoiPage : Mo trang Locations / nhan Refresh\\n(OnInitializedAsync() / RefreshAsync())\nactivate PoiPage\n\nPoiPage -&gt; PoiPage : Tai du lieu POI va category\\n(LoadDataAsync())\n\npar Lay danh sach POI\n    PoiPage -&gt; ApiClient : Gui yeu cau lay danh sach POI\\n(GetLocationsAsync())\n    activate ApiClient\n    ApiClient -&gt; LocationController : Goi API lay danh sach POI\\n(GET /Location)\n    activate LocationController\n    LocationController -&gt; DBContext : Lay danh sach POI theo quyen\\n(GetAllLocations() / BuildLocationQuery())\n    activate DBContext\n    DBContext --&gt; LocationController : Danh sach dia diem\n    deactivate DBContext\n    LocationController --&gt; ApiClient : Tra ve du lieu POI\n    deactivate LocationController\n    ApiClient --&gt; PoiPage : Tra danh sach POI cho giao dien\n    deactivate ApiClient\n\nelse Lay danh sach category\n    PoiPage -&gt; ApiClient : Gui yeu cau lay category\\n(GetCategoriesAsync())\n    activate ApiClient\n    ApiClient --&gt; PoiPage : Tra danh sach category cho giao dien\n    deactivate ApiClient\nend\n\nPoiPage -&gt; PoiPage : Cap nhat Total Locations\\n(_locations.Count)\nPoiPage -&gt; PoiPage : Cap nhat Active\\n(_locations.Count(item =&gt; item.Status == 1))\nPoiPage -&gt; PoiPage : Cap nhat Linked Categories\\n(CategoryOptions.Count())\nPoiPage -&gt; PoiPage : Cap nhat Matching Search\\n(FilteredLocations.Count())\n\nopt Tim kiem va loc danh sach\n    Admin -&gt; PoiPage : Nhap tim kiem / chon category / chon status\\n(@bind _searchText / @bind _selectedCategoryName / @bind _selectedStatus)\n    PoiPage -&gt; PoiPage : Loc du lieu tai client\\n(FilteredLocations)\nend\n\nopt Phan trang danh sach\n    Admin -&gt; PoiPage : Chuyen trang truoc / sau\\n(PreviousLocationPage() / NextLocationPage())\nend\n\nopt Tao moi / chinh sua POI\n    Admin -&gt; PoiPage : Mo form tao moi / chinh sua\\n(StartCreateAsync() / StartEditAsync())\n    Admin -&gt; PoiPage : Luu POI\\n(SaveLocationAsync())\n    PoiPage -&gt; ApiClient : Gui yeu cau tao / cap nhat POI\\n(CreateLocationAsync() / UpdateLocationAsync())\n    activate ApiClient\n    ApiClient -&gt; LocationController : Goi API tao / cap nhat POI\\n(POST /Location / PUT /Location/{id})\n    activate LocationController\n    LocationController -&gt; DBContext : Kiem tra va luu POI\\n(CreateLocation() / UpdateLocation())\n    activate DBContext\n    DBContext --&gt; LocationController : Luu thanh cong\n    deactivate DBContext\n    LocationController --&gt; ApiClient : Tra ket qua luu\n    deactivate LocationController\n    ApiClient --&gt; PoiPage : Hoan tat luu POI\n    deactivate ApiClient\n    PoiPage -&gt; PoiPage : Tai lai du lieu POI\\n(LoadDataAsync())\nend\n\nopt Archive POI\n    Admin -&gt; PoiPage : Chon archive va xac nhan\\n(PromptArchiveLocation() / ConfirmArchiveLocationAsync())\n    PoiPage -&gt; ApiClient : Gui yeu cau archive POI\\n(DeleteLocationAsync())\n    activate ApiClient\n    ApiClient -&gt; LocationController : Goi API archive POI\\n(DELETE /Location/{id})\n    activate LocationController\n    LocationController -&gt; DBContext : Cap nhat trang thai inactive\\n(DeleteLocation())\n    activate DBContext\n    DBContext --&gt; LocationController : Archive thanh cong\n    deactivate DBContext\n    LocationController --&gt; ApiClient : Tra ket qua archive\n    deactivate LocationController\n    ApiClient --&gt; PoiPage : Hoan tat archive\n    deactivate ApiClient\n    PoiPage -&gt; PoiPage : Tai lai du lieu POI\\n(LoadDataAsync())\nend\n\nopt Xem / tao QR\n    Admin -&gt; PoiPage : Mo QR cua POI\\n(OpenQrAsync())\n    PoiPage -&gt; ApiClient : Lay trang thai QR / tao file QR\\n(GetLocationQrStatusAsync() / GenerateLocationQrAsync())\n    activate ApiClient\n    ApiClient -&gt; LocationQrController : Goi API QR cua POI\\n(GET status / POST generate)\n    activate LocationQrController\n    LocationQrController -&gt; DBContext : Lay du lieu QR cua POI\n    activate DBContext\n    DBContext --&gt; LocationQrController : Du lieu QR\n    deactivate DBContext\n    LocationQrController --&gt; ApiClient : Tra trang thai QR / file QR\n    deactivate LocationQrController\n    ApiClient --&gt; PoiPage : Cap nhat giao dien QR\n    deactivate ApiClient\nend\n\nPoiPage --&gt; Admin : Hien thi thong ke, bo loc,\\ndanh sach POI va cac thao tac quan ly\ndeactivate PoiPage\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="6C2sIVUiAqwiujJq6s2Q-8">
