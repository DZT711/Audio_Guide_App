        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml OwnerAdminWebSequenceVi\ntitle Owner trong Admin Web\n\nhide footbox\n\nskinparam shadowing false\nskinparam sequence {\n  ArrowColor #2F4858\n  LifeLineBorderColor #2F4858\n  LifeLineBackgroundColor #EAF3F7\n  ParticipantBorderColor #2F4858\n  ParticipantBackgroundColor white\n  ParticipantFontColor #1F2D3D\n  ActorBorderColor #2F4858\n  ActorBackgroundColor white\n  ActorFontColor #1F2D3D\n}\n\nautonumber 1\n\nactor \&quot;Owner\&quot; as Owner\nboundary \&quot;Dashboard / Statistics /\\nUsage / POI / Tour /\\nCategories / Languages /\\nAudio / Inbox\&quot; as OwnerPage\ncontrol \&quot;AdminApiClient\&quot; as ApiClient\ncontrol \&quot;DashboardController /\\nStatisticsController /\\nUsageController\&quot; as AnalyticsControllers\ncontrol \&quot;LocationController /\\nTourController /\\nCategoryController /\\nLanguageController /\\nAudioController\&quot; as ContentControllers\ncontrol \&quot;ChangeRequestController\&quot; as ChangeRequestController\ncontrol \&quot;InboxController\&quot; as InboxController\ncontrol \&quot;ChangeRequestWorkflowService\&quot; as WorkflowService\nentity \&quot;DBContext\&quot; as DBContext\n\nopt Xem Dashboard / Statistics / Usage\n    Owner -&gt; OwnerPage : Mo Dashboard / Statistics / Usage\n    OwnerPage -&gt; ApiClient : Gui yeu cau tai du lieu tong hop\\n(GetDashboardOverviewAsync() / GetStatisticsAsync() / GetUsageHistoryAsync())\n    ApiClient -&gt; AnalyticsControllers : Goi API tong hop theo quyen owner\n    AnalyticsControllers -&gt; DBContext : Lay du lieu da scope theo owner\n    DBContext --&gt; AnalyticsControllers : Du lieu dashboard / statistics / usage\n    AnalyticsControllers --&gt; ApiClient : Tra ve du lieu tong hop\n    ApiClient --&gt; OwnerPage : Hien thi dashboard / statistics / usage\nend\n\nopt Xem POI cua minh\n    Owner -&gt; OwnerPage : Mo trang POI\n    OwnerPage -&gt; ApiClient : Gui yeu cau lay POI\\n(GetLocationsAsync())\n    ApiClient -&gt; ContentControllers : Goi API POI theo quyen owner\n    ContentControllers -&gt; DBContext : Lay danh sach POI owner hien tai\n    DBContext --&gt; ContentControllers : Danh sach POI\n    ContentControllers --&gt; ApiClient : Tra du lieu POI\n    ApiClient --&gt; OwnerPage : Hien thi danh sach POI\nend\n\nopt Xem Tour cua minh\n    Owner -&gt; OwnerPage : Mo trang Tour\n    OwnerPage -&gt; ApiClient : Gui yeu cau lay tour\\n(GetToursAsync())\n    ApiClient -&gt; ContentControllers : Goi API Tour theo quyen owner\n    ContentControllers -&gt; DBContext : Lay danh sach tour owner hien tai\n    DBContext --&gt; ContentControllers : Danh sach tour\n    ContentControllers --&gt; ApiClient : Tra du lieu tour\n    ApiClient --&gt; OwnerPage : Hien thi danh sach tour\nend\n\nopt Xem Categories / Languages\n    Owner -&gt; OwnerPage : Mo trang Categories / Languages\n    OwnerPage -&gt; ApiClient : Gui yeu cau lay categories / languages\\n(GetCategoriesAsync() / GetLanguagesAsync())\n    ApiClient -&gt; ContentControllers : Goi API Categories / Languages\n    ContentControllers -&gt; DBContext : Lay danh muc va ngon ngu hien thi\n    DBContext --&gt; ContentControllers : Du lieu categories / languages\n    ContentControllers --&gt; ApiClient : Tra du lieu categories / languages\n    ApiClient --&gt; OwnerPage : Hien thi categories / languages\nend\n\nopt Xem Audio cua minh\n    Owner -&gt; OwnerPage : Mo trang Audio\n    OwnerPage -&gt; ApiClient : Gui yeu cau lay audio\\n(GetAudioAsync())\n    ApiClient -&gt; ContentControllers : Goi API Audio theo quyen owner\n    ContentControllers -&gt; DBContext : Lay danh sach audio owner hien tai\n    DBContext --&gt; ContentControllers : Danh sach audio\n    ContentControllers --&gt; ApiClient : Tra du lieu audio\n    ApiClient --&gt; OwnerPage : Hien thi danh sach audio\nend\n\nopt Gui yeu cau tao / cap nhat / archive POI\n    Owner -&gt; OwnerPage : Tao moi / chinh sua / archive POI\n    OwnerPage -&gt; ApiClient : Gui request thay doi POI\\n(SubmitLocationChangeRequestAsync())\n    ApiClient -&gt; ChangeRequestController : Goi API tao request POI\n    ChangeRequestController -&gt; WorkflowService : Tao yeu cau thay doi POI\\n(SubmitLocationAsync())\n    WorkflowService -&gt; DBContext : Kiem tra owner, du lieu live va luu request\n    DBContext --&gt; WorkflowService : Request da tao\n    WorkflowService --&gt; ChangeRequestController : Tra ket qua request\n    ChangeRequestController --&gt; ApiClient : Tra change request\n    ApiClient --&gt; OwnerPage : Thong bao gui request thanh cong\nend\n\nopt Gui yeu cau tao / cap nhat / archive Audio\n    Owner -&gt; OwnerPage : Tao moi / chinh sua / archive Audio\n    OwnerPage -&gt; ApiClient : Gui request thay doi Audio\\n(SubmitAudioChangeRequestAsync())\n    ApiClient -&gt; ChangeRequestController : Goi API tao request Audio\n    ChangeRequestController -&gt; WorkflowService : Tao yeu cau thay doi Audio\\n(SubmitAudioAsync())\n    WorkflowService -&gt; DBContext : Kiem tra owner, du lieu live va luu request\n    DBContext --&gt; WorkflowService : Request da tao\n    WorkflowService --&gt; ChangeRequestController : Tra ket qua request\n    ChangeRequestController --&gt; ApiClient : Tra change request\n    ApiClient --&gt; OwnerPage : Thong bao gui request thanh cong\nend\n\nopt Xem Inbox / ket qua phe duyet\n    Owner -&gt; OwnerPage : Mo Inbox\n    OwnerPage -&gt; ApiClient : Gui yeu cau lay hop thu\\n(GetInboxAsync())\n    ApiClient -&gt; InboxController : Goi API Inbox\n    InboxController -&gt; WorkflowService : Lay inbox theo owner hien tai\\n(GetInboxAsync())\n    WorkflowService -&gt; DBContext : Lay message va unread count\n    DBContext --&gt; WorkflowService : Du lieu hop thu\n    WorkflowService --&gt; InboxController : InboxOverviewDto\n    InboxController --&gt; ApiClient : Tra du lieu hop thu\n    ApiClient --&gt; OwnerPage : Hien thi thong bao phe duyet / tu choi\nend\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="_62sLLVoR1KcHNmORsgJ-3">
