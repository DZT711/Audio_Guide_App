        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml CategoryManagementSequenceVi\ntitle 3. Danh muc\n\nhide footbox\n\nskinparam shadowing false\nskinparam sequence {\n  ArrowColor #2F4858\n  LifeLineBorderColor #2F4858\n  LifeLineBackgroundColor #EAF3F7\n  ParticipantBorderColor #2F4858\n  ParticipantBackgroundColor white\n  ParticipantFontColor #1F2D3D\n  ActorBorderColor #2F4858\n  ActorBackgroundColor white\n  ActorFontColor #1F2D3D\n}\n\nautonumber 1\n\nactor \&quot;Admin\&quot; as Admin\nboundary \&quot;CategoryList.razor\&quot; as CategoryPage\ncontrol \&quot;AdminApiClient\&quot; as ApiClient\ncontrol \&quot;CategoryController\&quot; as CategoryController\nentity \&quot;DBContext\&quot; as DBContext\n\nAdmin -&gt; CategoryPage : Mo trang Category Management / nhan Refresh\\n(OnInitializedAsync() / RefreshAsync())\nactivate CategoryPage\n\nCategoryPage -&gt; CategoryPage : Tai du lieu danh muc\\n(LoadCategoriesAsync())\n\nCategoryPage -&gt; ApiClient : Gui yeu cau lay danh sach danh muc\\n(GetCategoriesAsync())\nactivate ApiClient\n\nApiClient -&gt; CategoryController : Goi API lay danh muc\\n(GET /Category)\nactivate CategoryController\n\nCategoryController -&gt; DBContext : Lay danh sach danh muc\\n(GetAllCategories())\nactivate DBContext\nDBContext --&gt; CategoryController : Danh sach danh muc\ndeactivate DBContext\n\nCategoryController --&gt; ApiClient : Tra ve du lieu danh muc\ndeactivate CategoryController\n\nApiClient --&gt; CategoryPage : Tra danh sach danh muc cho giao dien\ndeactivate ApiClient\n\nCategoryPage -&gt; CategoryPage : Cap nhat Total Categories\\n(@_categories.Count)\nCategoryPage -&gt; CategoryPage : Cap nhat Active\\n(@_categories.Count(item =&gt; item.Status == 1))\nCategoryPage -&gt; CategoryPage : Cap nhat Inactive\\n(@_categories.Count(item =&gt; item.Status == 0))\nCategoryPage -&gt; CategoryPage : Cap nhat Matching Search\\n(FilteredCategories)\n\nopt Tim kiem danh muc\n    Admin -&gt; CategoryPage : Nhap tu khoa tim kiem\\n(@bind _searchText)\n    CategoryPage -&gt; CategoryPage : Loc danh sach danh muc tai client\\n(FilteredCategories)\nend\n\nopt Tao moi danh muc\n    Admin -&gt; CategoryPage : Nhap form tao moi va bam Save\\n(SaveCategoryAsync())\n    CategoryPage -&gt; ApiClient : Gui yeu cau tao danh muc\\n(CreateCategoryAsync())\n    activate ApiClient\n\n    ApiClient -&gt; CategoryController : Goi API tao danh muc\\n(POST /Category)\n    activate CategoryController\n\n    CategoryController -&gt; DBContext : Kiem tra du lieu va luu danh muc moi\\n(CreateCategory() / SaveChangesAsync())\n    activate DBContext\n    DBContext --&gt; CategoryController : Tao moi thanh cong\n    deactivate DBContext\n\n    CategoryController --&gt; ApiClient : Tra ket qua tao moi\n    deactivate CategoryController\n    ApiClient --&gt; CategoryPage : Hoan tat tao moi danh muc\n    deactivate ApiClient\n\n    CategoryPage -&gt; CategoryPage : Cap nhat giao dien sau tao moi\\n(LoadCategoriesAsync() / StartCreate())\nend\n\nopt Chinh sua danh muc\n    Admin -&gt; CategoryPage : Mo form chinh sua\\n(StartEdit())\n    Admin -&gt; CategoryPage : Bam Save chinh sua\\n(SaveCategoryAsync())\n    CategoryPage -&gt; ApiClient : Gui yeu cau cap nhat danh muc\\n(UpdateCategoryAsync())\n    activate ApiClient\n\n    ApiClient -&gt; CategoryController : Goi API cap nhat danh muc\\n(PUT /Category/{id})\n    activate CategoryController\n\n    CategoryController -&gt; DBContext : Tim danh muc, kiem tra va luu cap nhat\\n(UpdateCategory() / SaveChangesAsync())\n    activate DBContext\n    DBContext --&gt; CategoryController : Cap nhat thanh cong\n    deactivate DBContext\n\n    CategoryController --&gt; ApiClient : Tra ket qua cap nhat\n    deactivate CategoryController\n    ApiClient --&gt; CategoryPage : Hoan tat cap nhat danh muc\n    deactivate ApiClient\n\n    CategoryPage -&gt; CategoryPage : Cap nhat giao dien sau chinh sua\\n(LoadCategoriesAsync())\nend\n\nopt Archive danh muc\n    Admin -&gt; CategoryPage : Chon archive va xac nhan\\n(PromptArchiveCategory() / ConfirmArchiveCategoryAsync())\n    CategoryPage -&gt; ApiClient : Gui yeu cau archive danh muc\\n(DeleteCategoryAsync())\n    activate ApiClient\n\n    ApiClient -&gt; CategoryController : Goi API archive danh muc\\n(DELETE /Category/{id})\n    activate CategoryController\n\n    CategoryController -&gt; DBContext : Dat Status = 0 va luu thay doi\\n(DeleteCategory() / SaveChangesAsync())\n    activate DBContext\n    DBContext --&gt; CategoryController : Archive thanh cong\n    deactivate DBContext\n\n    CategoryController --&gt; ApiClient : Tra ket qua archive\n    deactivate CategoryController\n    ApiClient --&gt; CategoryPage : Hoan tat archive\n    deactivate ApiClient\n\n    CategoryPage -&gt; CategoryPage : Cap nhat giao dien sau archive\\n(LoadCategoriesAsync())\nend\n\nCategoryPage --&gt; Admin : Hien thi Total Categories, Active,\\nInactive, Matching Search va danh sach danh muc\ndeactivate CategoryPage\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="W-dpBALr9AOtfJScxxpD-1">
