      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml TourManagementSequenceVi\ntitle 7. Tour\n\nhide footbox\n\nskinparam shadowing false\nskinparam sequence {\n  ArrowColor #2F4858\n  LifeLineBorderColor #2F4858\n  LifeLineBackgroundColor #EAF3F7\n  ParticipantBorderColor #2F4858\n  ParticipantBackgroundColor white\n  ParticipantFontColor #1F2D3D\n  ActorBorderColor #2F4858\n  ActorBackgroundColor white\n  ActorFontColor #1F2D3D\n}\n\nautonumber 1\n\nactor \&quot;Admin\&quot; as Admin\nboundary \&quot;TourList.razor\&quot; as TourPage\ncontrol \&quot;AdminApiClient\&quot; as ApiClient\ncontrol \&quot;TourController\&quot; as TourController\ncontrol \&quot;TourRoutePlanningService\&quot; as RoutePlanningService\nentity \&quot;DBContext\&quot; as DBContext\n\nAdmin -&gt; TourPage : Mo trang Tour Management / nhan Refresh\\n(OnInitializedAsync() / RefreshAsync())\nactivate TourPage\n\nTourPage -&gt; TourPage : Tai du lieu tour va planner POI\\n(LoadDataAsync())\n\npar Lay danh sach tour\n    TourPage -&gt; ApiClient : Gui yeu cau lay danh sach tour\\n(GetToursAsync())\n    activate ApiClient\n    ApiClient -&gt; TourController : Goi API lay tour\\n(GET /Tour)\n    activate TourController\n    TourController -&gt; DBContext : Lay danh sach tour theo quyen\\n(GetTours() / BuildTourQuery())\n    activate DBContext\n    DBContext --&gt; TourController : Danh sach tuyen tham quan\n    deactivate DBContext\n    TourController --&gt; ApiClient : Tra ve du lieu tour\n    deactivate TourController\n    ApiClient --&gt; TourPage : Tra danh sach tour cho giao dien\n    deactivate ApiClient\n\nelse Lay planner POI\n    TourPage -&gt; ApiClient : Gui yeu cau lay POI planner\\n(GetLocationsAsync())\n    activate ApiClient\n    ApiClient --&gt; TourPage : Tra danh sach POI planner\n    deactivate ApiClient\nend\n\nTourPage -&gt; TourPage : Cap nhat Visible Tours\\n(@_tours.Count)\nTourPage -&gt; TourPage : Cap nhat Active Tours\\n(@_tours.Count(item =&gt; item.Status == 1))\nTourPage -&gt; TourPage : Cap nhat Planner POIs\\n(PlannerLocations)\nTourPage -&gt; TourPage : Cap nhat Matching Results\\n(FilteredTours)\n\nopt Tim kiem / loc tour\n    Admin -&gt; TourPage : Nhap tu khoa tim kiem / chon trang thai\\n(@bind _searchText / @bind _selectedStatus)\n    TourPage -&gt; TourPage : Loc danh sach tour tai client\\n(FilteredTours)\nend\n\nopt Tao moi hoac chinh sua tour\n    Admin -&gt; TourPage : Mo form tao moi / chinh sua\\n(StartCreateAsync() / StartEditAsync())\n    TourPage -&gt; TourPage : Lam moi du lieu xem truoc tuyen duong\\n(RefreshRoutePreviewAsync())\n\n    TourPage -&gt; ApiClient : Gui yeu cau xem truoc tuyen duong\\n(PreviewTourRouteAsync())\n    activate ApiClient\n    ApiClient -&gt; TourController : Goi API xem truoc tuyen duong\\n(POST /Tour/preview)\n    activate TourController\n    TourController -&gt; RoutePlanningService : Tinh quang duong va thoi gian du kien\\n(CalculatePreviewAsync())\n    activate RoutePlanningService\n    RoutePlanningService --&gt; TourController : Du lieu route preview\n    deactivate RoutePlanningService\n    TourController --&gt; ApiClient : Tra ve route preview\n    deactivate TourController\n    ApiClient --&gt; TourPage : Cap nhat du lieu xem truoc\n    deactivate ApiClient\n\n    Admin -&gt; TourPage : Bam Save tour\\n(SaveTourAsync())\n    TourPage -&gt; ApiClient : Gui yeu cau tao / cap nhat tour\\n(CreateTourAsync() / UpdateTourAsync())\n    activate ApiClient\n    ApiClient -&gt; TourController : Goi API tao / cap nhat tour\\n(POST /Tour / PUT /Tour/{id})\n    activate TourController\n    TourController -&gt; DBContext : Kiem tra POI va stops hop le\n    activate DBContext\n    DBContext --&gt; TourController : Du lieu POI hop le\n    deactivate DBContext\n    TourController -&gt; RoutePlanningService : Tinh route neu can\\n(CalculatePreviewAsync())\n    activate RoutePlanningService\n    RoutePlanningService --&gt; TourController : Du lieu route\n    deactivate RoutePlanningService\n    TourController -&gt; DBContext : Luu tour va cac stops\\n(CreateTour() / UpdateTour() / SaveChangesAsync())\n    activate DBContext\n    DBContext --&gt; TourController : Luu thanh cong\n    deactivate DBContext\n    TourController --&gt; ApiClient : Tra ket qua luu\n    deactivate TourController\n    ApiClient --&gt; TourPage : Hoan tat luu tour\n    deactivate ApiClient\n\n    TourPage -&gt; TourPage : Tai lai du lieu tour\\n(LoadDataAsync())\nend\n\nopt Archive tour\n    Admin -&gt; TourPage : Chon archive va xac nhan\\n(PromptArchiveTour() / ConfirmArchiveTourAsync())\n    TourPage -&gt; ApiClient : Gui yeu cau archive tour\\n(DeleteTourAsync())\n    activate ApiClient\n    ApiClient -&gt; TourController : Goi API archive tour\\n(DELETE /Tour/{id})\n    activate TourController\n    TourController -&gt; DBContext : Cap nhat trang thai inactive\\n(DeleteTour())\n    activate DBContext\n    DBContext --&gt; TourController : Archive thanh cong\n    deactivate DBContext\n    TourController --&gt; ApiClient : Tra ket qua archive\n    deactivate TourController\n    ApiClient --&gt; TourPage : Hoan tat archive\n    deactivate ApiClient\n    TourPage -&gt; TourPage : Tai lai du lieu tour\\n(LoadDataAsync())\nend\n\nTourPage --&gt; Admin : Hien thi Visible Tours, Active Tours,\\nPlanner POIs, Matching Results va danh sach tour\ndeactivate TourPage\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="9veTh8_g4wSZjR0OhdEK-3">
