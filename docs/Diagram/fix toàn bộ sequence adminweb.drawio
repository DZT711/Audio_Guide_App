<mxfile host="app.diagrams.net" pages="13">
  <diagram name="usgae history" id="g2RmduwW13QzXrK_l2i6">
    <mxGraphModel dx="2967" dy="2819" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml UsageHistorySequenceVi\ntitle 11. Usage History\n\nhide footbox\n\nskinparam shadowing false\nskinparam sequence {\n  ArrowColor #2F4858\n  LifeLineBorderColor #2F4858\n  LifeLineBackgroundColor #EAF3F7\n  ParticipantBorderColor #2F4858\n  ParticipantBackgroundColor white\n  ParticipantFontColor #1F2D3D\n  ActorBorderColor #2F4858\n  ActorBackgroundColor white\n  ActorFontColor #1F2D3D\n}\n\nautonumber 1\n\nactor \&quot;Admin\&quot; as Admin\nboundary \&quot;UsageHistory.razor\&quot; as UsagePage\ncontrol \&quot;AdminApiClient\&quot; as ApiClient\ncontrol \&quot;AnalyticsV1Controller\&quot; as AnalyticsController\ncontrol \&quot;UsageAnalyticsService\&quot; as AnalyticsService\nentity \&quot;DBContext\&quot; as DBContext\n\nAdmin -&gt; UsagePage : Mo trang Usage History / nhan Refresh\\n(OnInitializedAsync() / RefreshAsync())\nactivate UsagePage\n\nUsagePage -&gt; UsagePage : Tai du lieu usage history\\n(LoadAsync())\n\nUsagePage -&gt; ApiClient : Gui yeu cau lay du lieu usage history tong hop\\n(GetUsageHistoryAsync())\nactivate ApiClient\n\npar Lay thong ke tong hop usage\n    ApiClient -&gt; AnalyticsController : Lay thong ke usage tong hop\\n(GetUsageAnalyticsStatisticsV1Async() / GetStatistics())\n    activate AnalyticsController\n\n    AnalyticsController -&gt; AnalyticsService : Tong hop thong ke usage\\n(GetStatisticsAsync())\n    activate AnalyticsService\n\n    AnalyticsService -&gt; DBContext : Tinh so Unique Guests\\n(CountAsync())\n    activate DBContext\n    DBContext --&gt; AnalyticsService : So Unique Guests\n    deactivate DBContext\n\n    AnalyticsService -&gt; DBContext : Tinh so Online Guests\\n(CountOnlineUsageUsersAsync())\n    activate DBContext\n    DBContext --&gt; AnalyticsService : So Online Guests\n    deactivate DBContext\n\n    AnalyticsService --&gt; AnalyticsController : Tra ve thong ke usage tong hop\n    deactivate AnalyticsService\n    AnalyticsController --&gt; ApiClient : Tra ve UsageStatisticsDto\n    deactivate AnalyticsController\n\nelse Lay lich su phat de hien thi bang\n    ApiClient -&gt; AnalyticsController : Lay snapshot lich su su dung\\n(GetUsageAnalyticsHistorySnapshotV1Async() / GetHistory())\n    activate AnalyticsController\n\n    AnalyticsController -&gt; AnalyticsService : Lay lich su usage theo trang\\n(GetHistoryAsync())\n    activate AnalyticsService\n\n    AnalyticsService -&gt; DBContext : Lay cac usage events moi nhat\n    activate DBContext\n    DBContext --&gt; AnalyticsService : Du lieu lich su su dung\n    deactivate DBContext\n\n    AnalyticsService --&gt; AnalyticsController : Tra ve lich su usage\n    deactivate AnalyticsService\n    AnalyticsController --&gt; ApiClient : Tra ve UsageEventHistoryPageDto\n    deactivate AnalyticsController\nend\n\nApiClient -&gt; ApiClient : Ghep va chuan hoa du lieu usage history\\n(MapUsageHistoryOverviewFromV1())\nApiClient -&gt; ApiClient : Tinh so Locations Used\\n(MapUsageHistoryOverviewFromV1())\nApiClient -&gt; ApiClient : Gan Unique Guests va Online Guests cho overview\\n(MapUsageHistoryOverviewFromV1())\n\nApiClient --&gt; UsagePage : Tra ve du lieu usage history tong hop\\n(UsageHistoryOverviewDto)\ndeactivate ApiClient\n\nUsagePage -&gt; UsagePage : Cap nhat cac the Unique Guests,\\nOnline Guests, Locations Used va bang Playback Log\\n(LoadAsync())\n\nopt Tim kiem usage history\n    Admin -&gt; UsagePage : Nhap tu khoa tim kiem\\n(@bind _searchText)\n    UsagePage -&gt; UsagePage : Dat lai trang hien tai\\n(ResetUsagePage())\n    UsagePage -&gt; UsagePage : Tim kiem du lieu tai client\\n(FilteredItems)\nend\n\nopt Loc usage history\n    Admin -&gt; UsagePage : Chon location / event type\\n(@bind _selectedLocation / @bind _selectedEventType)\n    UsagePage -&gt; UsagePage : Dat lai trang hien tai\\n(ResetUsagePage())\n    UsagePage -&gt; UsagePage : Loc du lieu tai client\\n(FilteredItems)\nend\n\nopt Phan trang danh sach\n    Admin -&gt; UsagePage : Chuyen trang truoc / sau\n    UsagePage -&gt; UsagePage : Cap nhat trang hien tai\\n(PreviousPage() / NextPage())\n    UsagePage -&gt; UsagePage : Lay danh sach theo trang\\n(PagedItems)\nend\n\nUsagePage --&gt; Admin : Hien thi Unique Guests, Online Guests,\\nLocations Used va Playback Log\ndeactivate UsagePage\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="a3u8_o4fXSrLUFXueulb-5">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1646" width="1755" x="40" y="-40" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="6vrn4fE7M914tqA2L17o" name="Dashboard">
    <mxGraphModel dx="1212" dy="661" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml DashboardSequenceVi\ntitle Dashboard\n\nhide footbox\n\nskinparam shadowing false\nskinparam sequence {\n  ArrowColor #2F4858\n  LifeLineBorderColor #2F4858\n  LifeLineBackgroundColor #EAF3F7\n  ParticipantBorderColor #2F4858\n  ParticipantBackgroundColor white\n  ParticipantFontColor #1F2D3D\n  ActorBorderColor #2F4858\n  ActorBackgroundColor white\n  ActorFontColor #1F2D3D\n}\n\nautonumber 1\n\nactor \&quot;Admin\&quot; as Admin\nboundary \&quot;Dashboard.razor\&quot; as DashboardPage\ncontrol \&quot;AdminApiClient\&quot; as ApiClient\ncontrol \&quot;DashboardController\&quot; as DashboardController\ncontrol \&quot;AdminRequestAuthorizationService\&quot; as AuthService\nentity \&quot;DBContext\&quot; as DBContext\n\nAdmin -&gt; DashboardPage : Mo trang Dashboard\\n(OnInitializedAsync())\nactivate DashboardPage\n\nDashboardPage -&gt; DashboardPage : Tai du lieu tong quan dashboard\\n(LoadOverviewAsync())\n\nDashboardPage -&gt; ApiClient : Gui yeu cau lay tong quan dashboard\\n(GetDashboardOverviewAsync())\nactivate ApiClient\n\nApiClient -&gt; DashboardController : Goi API tong quan dashboard\\n(GET /Dashboard/overview)\nactivate DashboardController\n\nDashboardController -&gt; AuthService : Xac thuc quyen xem dashboard\\n(AuthorizeAsync())\nactivate AuthService\n\nAuthService -&gt; DBContext : Kiem tra session, user va quyen\nactivate DBContext\nDBContext --&gt; AuthService : Ket qua xac thuc\ndeactivate DBContext\n\nAuthService --&gt; DashboardController : Duoc phep / Tu choi truy cap\ndeactivate AuthService\n\nalt Khong du quyen\n    DashboardController --&gt; ApiClient : Tra ve loi truy cap\\n(401 / 403)\n    deactivate DashboardController\n    ApiClient --&gt; DashboardPage : Bao loi tai dashboard\n    deactivate ApiClient\n    DashboardPage --&gt; Admin : Hien thi thong bao loi\nelse Duoc phep truy cap\n    DashboardController -&gt; DashboardController : Tong hop du lieu tong quan dashboard\\n(BuildOverviewAsync())\n\n    DashboardController -&gt; DBContext : Tinh so Total POIs\\n(BuildOverviewAsync())\n    activate DBContext\n    DBContext --&gt; DashboardController : Du lieu Total POIs\n    deactivate DBContext\n\n    DashboardController -&gt; DBContext : Tinh so Total Audios\\n(BuildOverviewAsync())\n    activate DBContext\n    DBContext --&gt; DashboardController : Du lieu Total Audios\n    deactivate DBContext\n\n    DashboardController -&gt; DBContext : Tinh so Curated Tours\\n(BuildOverviewAsync())\n    activate DBContext\n    DBContext --&gt; DashboardController : Du lieu Curated Tours\n    deactivate DBContext\n\n    DashboardController -&gt; DBContext : Tinh so Dashboard Users\\n(BuildOverviewAsync())\n    activate DBContext\n    DBContext --&gt; DashboardController : Du lieu Dashboard Users\n    deactivate DBContext\n\n    DashboardController -&gt; DBContext : Lay hoat dong gan day\\n(BuildActivitiesAsync())\n    activate DBContext\n    DBContext --&gt; DashboardController : Du lieu Activities\n    deactivate DBContext\n\n    DashboardController -&gt; DBContext : Lay muc uu tien can theo doi\\n(BuildFocusItemsAsync())\n    activate DBContext\n    DBContext --&gt; DashboardController : Du lieu FocusItems\n    deactivate DBContext\n\n    DashboardController --&gt; ApiClient : Tra ve du lieu tong quan dashboard\\n(DashboardOverviewDto)\n    deactivate DashboardController\n\n    ApiClient --&gt; DashboardPage : Tra du lieu dashboard cho giao dien\n    deactivate ApiClient\n\n    DashboardPage -&gt; DashboardPage : Cap nhat Metrics, Recent Activity\\nva Team Priorities\\n(LoadOverviewAsync())\n\n    opt Dieu huong nhanh tu dashboard\n        Admin -&gt; DashboardPage : Chon Usage History / Statistics /\\nTour Management / Manage Users\n        DashboardPage --&gt; Admin : Mo trang quan ly tuong ung\\n(href / ShowUserAccessNotice())\n    end\n\n    opt Xem danh sach hoat dong\n        Admin -&gt; DashboardPage : Chon View All / View Audio\n        DashboardPage --&gt; Admin : Mo trang Moderation hoac Audio\\n(href)\n    end\n\n    DashboardPage --&gt; Admin : Hien thi dashboard voi Metrics,\\nRecent Activity va Team Priorities\nend\n\ndeactivate DashboardPage\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="o_dTuXLRcXjFonIOawRv-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1457" width="1410" x="30" y="970" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
