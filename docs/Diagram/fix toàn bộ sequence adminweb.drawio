  <diagram id="yGvFx0PBVP43HUmrX_Tv" name="Inbbox">
    <mxGraphModel dx="3540" dy="1974" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml InboxSequenceVi\ntitle Inbox\n\nhide footbox\n\nskinparam shadowing false\nskinparam sequence {\n  ArrowColor #2F4858\n  LifeLineBorderColor #2F4858\n  LifeLineBackgroundColor #EAF3F7\n  ParticipantBorderColor #2F4858\n  ParticipantBackgroundColor white\n  ParticipantFontColor #1F2D3D\n  ActorBorderColor #2F4858\n  ActorBackgroundColor white\n  ActorFontColor #1F2D3D\n}\n\nautonumber 1\n\nactor \&quot;Admin\&quot; as Admin\nboundary \&quot;Inbox.razor\&quot; as InboxPage\ncontrol \&quot;AdminApiClient\&quot; as ApiClient\ncontrol \&quot;InboxController\&quot; as InboxController\ncontrol \&quot;ChangeRequestWorkflowService\&quot; as WorkflowService\nentity \&quot;DBContext\&quot; as DBContext\n\nAdmin -&gt; InboxPage : Mo trang Inbox\\n(OnInitializedAsync())\nactivate InboxPage\n\nInboxPage -&gt; InboxPage : Tai du lieu hop thu\\n(LoadAsync())\n\nInboxPage -&gt; ApiClient : Gui yeu cau lay hop thu\\n(GetInboxAsync())\nactivate ApiClient\n\nApiClient -&gt; InboxController : Goi API hop thu theo bo loc\\n(GET /Inbox)\nactivate InboxController\n\nInboxController -&gt; WorkflowService : Lay tong hop hop thu nguoi dung hien tai\\n(GetInboxAsync())\nactivate WorkflowService\n\nWorkflowService -&gt; DBContext : Lay danh sach tin nhan va thong ke hop thu\nactivate DBContext\nDBContext --&gt; WorkflowService : Du lieu hop thu\ndeactivate DBContext\n\nWorkflowService --&gt; InboxController : Tra ve tong hop hop thu\\n(InboxOverviewDto)\ndeactivate WorkflowService\n\nInboxController --&gt; ApiClient : Tra ve du lieu hop thu\\n(InboxOverviewDto)\ndeactivate InboxController\n\nApiClient --&gt; InboxPage : Tra du lieu inbox cho giao dien\ndeactivate ApiClient\n\nInboxPage -&gt; InboxPage : Cap nhat thong ke va danh sach tin nhan\\n(LoadAsync())\n\nopt Lam moi hop thu\n    Admin -&gt; InboxPage : Nhan Refresh\\n(RefreshAsync())\n    InboxPage -&gt; InboxPage : Tai lai du lieu hop thu\\n(LoadAsync())\nend\n\nopt Loc All / Unread Only\n    Admin -&gt; InboxPage : Chon bo loc tin nhan\\n(SetUnreadFilterAsync())\n    InboxPage -&gt; InboxPage : Dat lai trang va tai lai du lieu\\n(LoadAsync())\nend\n\nopt Phan trang hop thu\n    Admin -&gt; InboxPage : Chuyen trang hop thu\n    InboxPage -&gt; InboxPage : Cap nhat trang hien tai\\n(PreviousPageAsync() / NextPageAsync() / GoToPageAsync())\n    InboxPage -&gt; InboxPage : Tai lai du lieu hop thu\\n(LoadAsync())\nend\n\nopt Danh dau da doc\n    Admin -&gt; InboxPage : Nhan Mark Read\\n(MarkReadAsync())\n    InboxPage -&gt; ApiClient : Gui yeu cau danh dau da doc\\n(MarkInboxMessageReadAsync())\n    activate ApiClient\n\n    ApiClient -&gt; InboxController : Goi API cap nhat trang thai tin nhan\\n(POST /Inbox/{id}/read)\n    activate InboxController\n\n    InboxController -&gt; WorkflowService : Danh dau tin nhan da doc\\n(MarkInboxReadAsync())\n    activate WorkflowService\n\n    WorkflowService -&gt; DBContext : Cap nhat trang thai da doc\n    activate DBContext\n    DBContext --&gt; WorkflowService : Luu thanh cong\n    deactivate DBContext\n\n    WorkflowService --&gt; InboxController : Hoan tat cap nhat\n    deactivate WorkflowService\n    InboxController --&gt; ApiClient : Tra ket qua cap nhat\n    deactivate InboxController\n    ApiClient --&gt; InboxPage : Hoan tat danh dau da doc\n    deactivate ApiClient\n\n    InboxPage -&gt; InboxPage : Tai lai hop thu\\n(LoadAsync())\nend\n\nopt Gui thong bao he thong\n    Admin -&gt; InboxPage : Mo composer / Gui announcement\\n(ToggleBroadcastComposer() / SendAnnouncementAsync())\n    InboxPage -&gt; ApiClient : Gui yeu cau tao thong bao\\n(CreateInboxAnnouncementAsync())\n    activate ApiClient\n\n    ApiClient -&gt; InboxController : Goi API broadcast announcement\\n(POST /Inbox/announcement)\n    activate InboxController\n\n    InboxController -&gt; WorkflowService : Gui thong bao den moi hop thu\\n(BroadcastAnnouncementAsync())\n    activate WorkflowService\n\n    WorkflowService -&gt; DBContext : Tao thong bao cho cac tai khoan\n    activate DBContext\n    DBContext --&gt; WorkflowService : Luu thanh cong\n    deactivate DBContext\n\n    WorkflowService --&gt; InboxController : Hoan tat broadcast\n    deactivate WorkflowService\n    InboxController --&gt; ApiClient : Tra ket qua gui thong bao\n    deactivate InboxController\n    ApiClient --&gt; InboxPage : Gui thong bao thanh cong\n    deactivate ApiClient\n\n    InboxPage -&gt; InboxPage : Tai lai hop thu\\n(LoadAsync())\nend\n\nInboxPage --&gt; Admin : Hien thi thong ke, bo loc va danh sach tin nhan\ndeactivate InboxPage\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="1mQcTkXCpBAhCk0gXc5N-2">
