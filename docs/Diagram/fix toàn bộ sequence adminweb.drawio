  <diagram id="hQp4sI888ttz2kf0TZkl" name="audio &amp; voices">
    <mxGraphModel dx="890" dy="495" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml AudioManagementSequenceVi\ntitle 6. Audio\n\nhide footbox\n\nskinparam shadowing false\nskinparam sequence {\n  ArrowColor #2F4858\n  LifeLineBorderColor #2F4858\n  LifeLineBackgroundColor #EAF3F7\n  ParticipantBorderColor #2F4858\n  ParticipantBackgroundColor white\n  ParticipantFontColor #1F2D3D\n  ActorBorderColor #2F4858\n  ActorBackgroundColor white\n  ActorFontColor #1F2D3D\n}\n\nautonumber 1\n\nactor \&quot;Admin\&quot; as Admin\nboundary \&quot;AudioList.razor\&quot; as AudioPage\ncontrol \&quot;AdminApiClient\&quot; as ApiClient\ncontrol \&quot;AudioController\&quot; as AudioController\nentity \&quot;DBContext\&quot; as DBContext\n\nAdmin -&gt; AudioPage : Mo trang Audio &amp; Voice / nhan Refresh\\n(OnInitializedAsync() / RefreshAsync())\nactivate AudioPage\n\nAudioPage -&gt; AudioPage : Tai du lieu audio, location va language\\n(LoadDataAsync())\n\npar Lay danh sach audio\n    AudioPage -&gt; ApiClient : Gui yeu cau lay danh sach audio\\n(GetAudioAsync())\n    activate ApiClient\n    ApiClient -&gt; AudioController : Goi API lay audio\\n(GET /Audio)\n    activate AudioController\n    AudioController -&gt; DBContext : Lay danh sach audio theo quyen\\n(GetAllAudio() / BuildAudioQuery())\n    activate DBContext\n    DBContext --&gt; AudioController : Danh sach am thanh\n    deactivate DBContext\n    AudioController --&gt; ApiClient : Tra ve du lieu audio\n    deactivate AudioController\n    ApiClient --&gt; AudioPage : Tra danh sach audio cho giao dien\n    deactivate ApiClient\n\nelse Lay location va language phu tro form / bo loc\n    AudioPage -&gt; ApiClient : Gui yeu cau lay location va language\\n(GetLocationsAsync() / GetLanguagesAsync())\n    activate ApiClient\n    ApiClient --&gt; AudioPage : Tra danh sach location va language\n    deactivate ApiClient\nend\n\nAudioPage -&gt; AudioPage : Cap nhat Total Audio Items\\n(@_audioItems.Count)\nAudioPage -&gt; AudioPage : Cap nhat Male Voice Labels\\n(@_audioItems.Count(item =&gt; IsVoice(item, \&quot;Male\&quot;)))\nAudioPage -&gt; AudioPage : Cap nhat Female Voice Labels\\n(@_audioItems.Count(item =&gt; IsVoice(item, \&quot;Female\&quot;)))\nAudioPage -&gt; AudioPage : Cap nhat Script-backed TTS Items\\n(@_audioItems.Count(item =&gt; !string.IsNullOrWhiteSpace(item.Script)))\n\nopt Tim kiem va loc audio\n    Admin -&gt; AudioPage : Nhap tim kiem / chon location /\\nchon voice / chon status\\n(@bind _searchText / @bind _locationFilter /\\n@bind _voiceFilter / @bind _statusFilter)\n    AudioPage -&gt; AudioPage : Dat lai trang hien tai\\n(ResetAudioPage())\n    AudioPage -&gt; AudioPage : Loc danh sach audio tai client\\n(FilteredAudio)\nend\n\nopt Phan trang danh sach\n    Admin -&gt; AudioPage : Chuyen trang truoc / sau\n    AudioPage -&gt; AudioPage : Cap nhat trang hien tai\\n(PreviousAudioPage() / NextAudioPage())\nend\n\nopt Tao moi hoac chinh sua audio\n    Admin -&gt; AudioPage : Mo form tao moi / chinh sua\\n(StartCreateAsync() / StartEditAsync())\n    Admin -&gt; AudioPage : Bam Save audio\\n(SaveAudioAsync())\n    AudioPage -&gt; ApiClient : Gui yeu cau tao / cap nhat audio\\n(CreateAudioAsync() / UpdateAudioAsync())\n    activate ApiClient\n\n    ApiClient -&gt; AudioController : Goi API luu audio\\n(POST /Audio / PUT /Audio/{id})\n    activate AudioController\n\n    AudioController -&gt; DBContext : Kiem tra location, language va du lieu audio\\n(CreateAudio() / UpdateAudio())\n    activate DBContext\n    DBContext --&gt; AudioController : Du lieu hop le / Loi du lieu\n    deactivate DBContext\n\n    AudioController --&gt; ApiClient : Tra ket qua luu\n    deactivate AudioController\n    ApiClient --&gt; AudioPage : Hoan tat luu audio\n    deactivate ApiClient\n\n    AudioPage -&gt; AudioPage : Cap nhat giao dien sau khi luu\\n(LoadDataAsync() / StartCreateAsync())\nend\n\nopt Archive audio\n    Admin -&gt; AudioPage : Chon archive va xac nhan\\n(PromptArchiveAudio() / ConfirmArchiveAudioAsync())\n    AudioPage -&gt; ApiClient : Gui yeu cau archive audio\\n(DeleteAudioAsync())\n    activate ApiClient\n\n    ApiClient -&gt; AudioController : Goi API archive audio\\n(DELETE /Audio/{id})\n    activate AudioController\n\n    AudioController -&gt; DBContext : Archive audio va luu thay doi\\n(DeleteAudio())\n    activate DBContext\n    DBContext --&gt; AudioController : Archive thanh cong\n    deactivate DBContext\n\n    AudioController --&gt; ApiClient : Tra ket qua archive\n    deactivate AudioController\n    ApiClient --&gt; AudioPage : Hoan tat archive\n    deactivate ApiClient\n\n    AudioPage -&gt; AudioPage : Cap nhat giao dien sau archive\\n(LoadDataAsync())\nend\n\nAudioPage --&gt; Admin : Hien thi Total Audio Items, Male Voice Labels,\\nFemale Voice Labels, Script-backed TTS Items,\\nbo loc va danh sach audio\ndeactivate AudioPage\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="3w2hncjG4otcWe8nM-4y-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1872" width="1548" x="20" y="20" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
