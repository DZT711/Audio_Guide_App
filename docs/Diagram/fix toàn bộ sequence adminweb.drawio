        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml LanguageManagementSequenceVi\ntitle 4. Ngon ngu\n\nhide footbox\n\nskinparam shadowing false\nskinparam sequence {\n  ArrowColor #2F4858\n  LifeLineBorderColor #2F4858\n  LifeLineBackgroundColor #EAF3F7\n  ParticipantBorderColor #2F4858\n  ParticipantBackgroundColor white\n  ParticipantFontColor #1F2D3D\n  ActorBorderColor #2F4858\n  ActorBackgroundColor white\n  ActorFontColor #1F2D3D\n}\n\nautonumber 1\n\nactor \&quot;Admin\&quot; as Admin\nboundary \&quot;LanguageList.razor\&quot; as LanguagePage\ncontrol \&quot;AdminApiClient\&quot; as ApiClient\ncontrol \&quot;LanguageController\&quot; as LanguageController\nentity \&quot;DBContext\&quot; as DBContext\n\nAdmin -&gt; LanguagePage : Mo trang Language Management / nhan Refresh\\n(OnInitializedAsync() / RefreshAsync())\nactivate LanguagePage\n\nLanguagePage -&gt; LanguagePage : Tai du lieu ngon ngu\\n(LoadLanguagesAsync())\n\nLanguagePage -&gt; ApiClient : Gui yeu cau lay danh sach ngon ngu\\n(GetLanguagesAsync())\nactivate ApiClient\n\nApiClient -&gt; LanguageController : Goi API lay ngon ngu\\n(GET /Language)\nactivate LanguageController\n\nLanguageController -&gt; DBContext : Lay danh sach ngon ngu\\n(GetAllLanguages())\nactivate DBContext\nDBContext --&gt; LanguageController : Danh sach ngon ngu\ndeactivate DBContext\n\nLanguageController --&gt; ApiClient : Tra ve du lieu ngon ngu\ndeactivate LanguageController\n\nApiClient --&gt; LanguagePage : Tra danh sach ngon ngu cho giao dien\ndeactivate ApiClient\n\nLanguagePage -&gt; LanguagePage : Cap nhat Total Languages\\n(@_languages.Count)\nLanguagePage -&gt; LanguagePage : Cap nhat Active\\n(@_languages.Count(item =&gt; item.Status == 1))\nLanguagePage -&gt; LanguagePage : Cap nhat Native Voice On\\n(@_languages.Count(item =&gt; item.PreferNativeVoice &amp;&amp; item.Status == 1))\nLanguagePage -&gt; LanguagePage : Cap nhat Default Language\\n(@_languages.Count(item =&gt; item.IsDefault &amp;&amp; item.Status == 1))\n\nopt Tim kiem ngon ngu\n    Admin -&gt; LanguagePage : Nhap tu khoa tim kiem\\n(@bind _searchText)\n    LanguagePage -&gt; LanguagePage : Loc danh sach ngon ngu tai client\\n(FilteredLanguages)\nend\n\nLanguagePage -&gt; LanguagePage : Cap nhat Matching Search\\n(FilteredLanguages)\n\nopt Tao moi hoac chinh sua ngon ngu\n    Admin -&gt; LanguagePage : Mo form tao moi / chinh sua\\n(StartCreate() / StartEdit())\n    Admin -&gt; LanguagePage : Bam Save ngon ngu\\n(SaveLanguageAsync())\n    LanguagePage -&gt; ApiClient : Gui yeu cau tao / cap nhat ngon ngu\\n(CreateLanguageAsync() / UpdateLanguageAsync())\n    activate ApiClient\n\n    ApiClient -&gt; LanguageController : Goi API luu ngon ngu\\n(POST /Language / PUT /Language/{id})\n    activate LanguageController\n\n    LanguageController -&gt; DBContext : Kiem tra du lieu, ma ngon ngu,\\ncap nhat default neu can va luu thay doi\\n(CreateLanguage() / UpdateLanguage() / SaveChangesAsync())\n    activate DBContext\n    DBContext --&gt; LanguageController : Luu thanh cong / Loi du lieu\n    deactivate DBContext\n\n    LanguageController --&gt; ApiClient : Tra ket qua luu\n    deactivate LanguageController\n    ApiClient --&gt; LanguagePage : Hoan tat luu ngon ngu\n    deactivate ApiClient\n\n    LanguagePage -&gt; LanguagePage : Cap nhat giao dien sau khi luu\\n(LoadLanguagesAsync() / StartCreate())\nend\n\nopt Archive ngon ngu\n    Admin -&gt; LanguagePage : Chon archive va xac nhan\\n(PromptArchiveLanguage() / ConfirmArchiveLanguageAsync())\n    LanguagePage -&gt; ApiClient : Gui yeu cau archive ngon ngu\\n(DeleteLanguageAsync())\n    activate ApiClient\n\n    ApiClient -&gt; LanguageController : Goi API archive ngon ngu\\n(DELETE /Language/{id})\n    activate LanguageController\n\n    LanguageController -&gt; DBContext : Archive ngon ngu, bo default neu can\\nva dam bao luon co ngon ngu mac dinh\\n(DeleteLanguage() / SaveChangesAsync())\n    activate DBContext\n    DBContext --&gt; LanguageController : Archive thanh cong\n    deactivate DBContext\n\n    LanguageController --&gt; ApiClient : Tra ket qua archive\n    deactivate LanguageController\n    ApiClient --&gt; LanguagePage : Hoan tat archive\n    deactivate ApiClient\n\n    LanguagePage -&gt; LanguagePage : Cap nhat giao dien sau archive\\n(LoadLanguagesAsync())\nend\n\nLanguagePage --&gt; Admin : Hien thi Total Languages, Active,\\nNative Voice On, Default Language,\\nMatching Search va danh sach ngon ngu\ndeactivate LanguagePage\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="tGDnWhfFq59i1sAkW1tY-1">
