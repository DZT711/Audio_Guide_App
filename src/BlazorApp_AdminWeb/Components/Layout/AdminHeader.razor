@implements IDisposable
@inject NavigationManager Navigation
@inject AdminAuthService AuthService
@inject NotificationService Notifications
@inject AdminSessionState SessionState
@inject AdminUiLanguageService Language

<header class="admin-header">
    <div class="admin-header__leading">
        <button class="btn admin-header__menu d-lg-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#admin-sidebar-drawer" aria-controls="admin-sidebar-drawer">
            <i class="bi bi-list"></i>
        </button>

        <button type="button" class="btn admin-header__toggle d-none d-lg-inline-flex" @onclick="ToggleSidebarAsync" title="@(Language.T("sidebar.navigation", "Navigation"))">
            <i class="bi @(SidebarCollapsed ? "bi-chevron-bar-right" : "bi-chevron-bar-left")"></i>
        </button>

        <div>
            <span class="admin-header__eyebrow">@Language.T("header.brand", "Smart Tourism Admin")</span>
            <h1>@GetPageTitle()</h1>
        </div>
    </div>

    <div class="admin-header__actions">
        <span class="admin-header__context d-none d-md-inline-flex">
            <i class="bi bi-lightning-charge-fill"></i>
            @GetHeaderContext()
        </span>

        <div class="admin-header__language-switch" aria-label="Admin language switch">
            <button type="button"
                    class="@(GetLanguageButtonClass("en"))"
                    @onclick='() => SetLanguage("en")'>
                @Language.T("language.en", "EN")
            </button>
            <button type="button"
                    class="@(GetLanguageButtonClass("vi"))"
                    @onclick='() => SetLanguage("vi")'>
                @Language.T("language.vi", "VI")
            </button>
        </div>

        <button type="button" class="btn btn-outline-secondary admin-header__logout" @onclick="LogoutAsync">
            <i class="bi bi-box-arrow-right me-2"></i>
            @Language.T("header.logout", "Logout")
        </button>

        <div class="admin-header__avatar">@GetAvatarInitial()</div>
    </div>
</header>

@code {
    [Parameter]
    public bool SidebarCollapsed { get; set; }

    [Parameter]
    public EventCallback OnToggleSidebar { get; set; }

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += HandleLocationChanged;
        Language.Changed += HandleLanguageChanged;
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
        => InvokeAsync(StateHasChanged);

    private void HandleLanguageChanged() => InvokeAsync(StateHasChanged);

    private Task ToggleSidebarAsync() => OnToggleSidebar.InvokeAsync();

    private void SetLanguage(string language) => Language.SetLanguage(language);

    private async Task LogoutAsync()
    {
        await AuthService.LogoutAsync();
        Notifications.Info(
            Language.T("header.logout.message", "You have been signed out."),
            Language.T("header.logout", "Logout"));
        Navigation.NavigateTo("/");
    }

    private string GetPageTitle()
    {
        var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri).Split('?', '#')[0].Trim('/').ToLowerInvariant();

        return relativePath switch
        {
            "" => Language.T("page.login", "Login"),
            "dashboard" => Language.T("page.dashboard", "Dashboard"),
            "statistics" => Language.T("page.statistics", "Statistics"),
            "usage" => Language.T("page.usage", "Usage History"),
            "poi" => Language.T("page.poi", "Location Management"),
            "categories" => Language.T("page.categories", "Category Management"),
            "languages" => Language.T("page.languages", "Language Management"),
            "audio" => Language.T("page.audio", "Audio & Voice Management"),
            "tours" => Language.T("page.tours", "Tour Management"),
            "users" => Language.T("page.users", "User Management"),
            "moderation" => Language.T("page.moderation", "Moderation Queue"),
            "history" => Language.T("page.history", "Activity History"),
            _ => Language.T("page.admin", "Admin")
        };
    }

    private string GetHeaderContext()
    {
        if (string.IsNullOrWhiteSpace(SessionState.Role))
        {
            return Language.T("header.default-context", "Admin session");
        }

        return $"{Language.GetRoleLabel(SessionState.Role)} · {Language.GetStatusLabel(SessionState.CurrentUser?.Status ?? 0)}";
    }

    private string GetAvatarInitial()
    {
        var value = SessionState.DisplayName;
        return string.IsNullOrWhiteSpace(value) ? "A" : value[..1].ToUpperInvariant();
    }

    private string GetLanguageButtonClass(string language) =>
        string.Equals(Language.CurrentLanguage, language, StringComparison.OrdinalIgnoreCase)
            ? "admin-header__language-btn admin-header__language-btn--active"
            : "admin-header__language-btn";

    public void Dispose()
    {
        Navigation.LocationChanged -= HandleLocationChanged;
        Language.Changed -= HandleLanguageChanged;
    }
}
