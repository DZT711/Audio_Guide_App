@implements IAsyncDisposable
@inject AdminApiClient ApiClient
@inject AdminUiLanguageService LanguageService

<footer class="admin-footer" data-reveal>
    <div class="admin-footer__primary">
        <div class="admin-footer__brand">
            <span class="admin-footer__eyebrow">@L("footer.server-status", "Server Status")</span>
            <div class="admin-footer__headline">
                <span class="@GetStatusDotClass()" aria-hidden="true"></span>
                <strong>@GetStatusLabel()</strong>
            </div>
            <p>@GetStatusCopy()</p>
        </div>

        <div class="admin-footer__facts">
            <article class="admin-footer__fact">
                <span>@L("footer.api-version", "API Version")</span>
                <strong>@(_serverInfo?.ApiVersion ?? L("footer.unknown", "Unknown"))</strong>
                <small>@GetEnvironmentLabel()</small>
            </article>
            <article class="admin-footer__fact">
                <span>@L("footer.active-users", "Active Users")</span>
                <strong>@(_serverInfo?.ActiveAdminUserCount ?? 0)</strong>
                <small>@L("footer.active-users.hint", "Live admin sessions connected now")</small>
            </article>
            <article class="admin-footer__fact">
                <span>@L("footer.server-time", "Server Time")</span>
                <strong>@GetServerTimeLabel()</strong>
                <small>@(_serverInfo?.TimeZoneDisplayName ?? L("footer.timezone.unavailable", "Time zone unavailable"))</small>
            </article>
            <article class="admin-footer__fact">
                <span>@L("footer.uptime", "Uptime")</span>
                <strong>@GetUptimeLabel()</strong>
                <small>@GetStartedAtLabel()</small>
            </article>
            <article class="admin-footer__fact">
                <span>@L("footer.runtime", "Runtime")</span>
                <strong>@(_serverInfo?.FrameworkDescription ?? L("footer.unavailable", "Unavailable"))</strong>
                <small>@GetLastCheckedLabel()</small>
            </article>
        </div>
    </div>
</footer>

@code {
    private string L(string key, string fallback) => LanguageService.T(key, fallback);
    private ServerInfoDto? _serverInfo;
    private bool _isServerReachable;
    private DateTimeOffset? _lastCheckedAt;
    private CancellationTokenSource? _refreshCancellationSource;
    private Task? _refreshTask;

    protected override async Task OnInitializedAsync()
    {
        LanguageService.Changed += HandleLanguageChanged;
        await LoadServerInfoAsync();

        _refreshCancellationSource = new CancellationTokenSource();
        _refreshTask = RefreshLoopAsync(_refreshCancellationSource.Token);
    }

    private void HandleLanguageChanged() => InvokeAsync(StateHasChanged);

    private async Task RefreshLoopAsync(CancellationToken cancellationToken)
    {
        try
        {
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(30));
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                await LoadServerInfoAsync(cancellationToken);
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task LoadServerInfoAsync(CancellationToken cancellationToken = default)
    {
        try
        {
            _serverInfo = await ApiClient.GetServerInfoAsync(cancellationToken);
            _isServerReachable = true;
            _lastCheckedAt = DateTimeOffset.Now;
        }
        catch
        {
            _serverInfo = null;
            _isServerReachable = false;
            _lastCheckedAt = DateTimeOffset.Now;
        }
    }

    private string GetStatusDotClass() => _isServerReachable
        ? "admin-footer__status-dot admin-footer__status-dot--online"
        : "admin-footer__status-dot admin-footer__status-dot--offline";

    private string GetStatusLabel() => _isServerReachable
        ? TranslateServerStatus(_serverInfo?.Status)
        : L("footer.unavailable", "Unavailable");

    private string GetStatusCopy() => _isServerReachable
        ? L("footer.status.online-copy", "The admin console is connected to the API and receiving live server metadata.")
        : L("footer.status.offline-copy", "The admin console could not reach the API status endpoint on the last refresh.");

    private string GetServerTimeLabel() =>
        _serverInfo is null
            ? L("footer.unavailable", "Unavailable")
            : _serverInfo.ServerTimeLocal.ToString("dd MMM yyyy HH:mm:ss");

    private string GetUptimeLabel() =>
        _serverInfo is null
            ? L("footer.unavailable", "Unavailable")
            : FormatDuration(_serverInfo.UptimeSeconds);

    private string GetEnvironmentLabel() =>
        TranslateEnvironmentName(_serverInfo?.EnvironmentName);

    private string GetStartedAtLabel() =>
        _serverInfo is null
            ? L("footer.started.unavailable", "Start time unavailable")
            : $"{L("footer.started.prefix", "Started")} {_serverInfo.StartedAtUtc.ToLocalTime():dd MMM yyyy HH:mm}";

    private string GetLastCheckedLabel() =>
        _lastCheckedAt is null
            ? L("footer.checked.none", "Not checked yet")
            : $"{L("footer.checked.prefix", "Checked")} {_lastCheckedAt.Value:HH:mm:ss}";

    private string TranslateServerStatus(string? status)
    {
        if (string.IsNullOrWhiteSpace(status))
        {
            return L("footer.status.online", "Online");
        }

        return string.Equals(status, "online", StringComparison.OrdinalIgnoreCase)
            ? L("footer.status.online", "Online")
            : status;
    }

    private string TranslateEnvironmentName(string? environmentName)
    {
        if (string.IsNullOrWhiteSpace(environmentName))
        {
            return L("footer.environment.unavailable", "Environment unavailable");
        }

        return string.Equals(environmentName, "development", StringComparison.OrdinalIgnoreCase)
            ? L("footer.environment.development", "Development")
            : environmentName;
    }

    private static string FormatDuration(long totalSeconds)
    {
        var duration = TimeSpan.FromSeconds(Math.Max(0, totalSeconds));

        if (duration.TotalDays >= 1)
        {
            return $"{(int)duration.TotalDays}d {duration.Hours}h {duration.Minutes}m";
        }

        if (duration.TotalHours >= 1)
        {
            return $"{(int)duration.TotalHours}h {duration.Minutes}m";
        }

        if (duration.TotalMinutes >= 1)
        {
            return $"{(int)duration.TotalMinutes}m {duration.Seconds}s";
        }

        return $"{duration.Seconds}s";
    }

    public async ValueTask DisposeAsync()
    {
        LanguageService.Changed -= HandleLanguageChanged;

        if (_refreshCancellationSource is null)
        {
            return;
        }

        await _refreshCancellationSource.CancelAsync();

        if (_refreshTask is not null)
        {
            try
            {
                await _refreshTask;
            }
            catch (OperationCanceledException)
            {
            }
        }

        _refreshCancellationSource.Dispose();
    }
}
